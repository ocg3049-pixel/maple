@Component
script GameInputHandler extends Component

	@ExecSpace("ClientOnly")
	@EventSender("Service", "InputService")
	handler HandleKeyDownEvent(KeyDownEvent event)
		if event.key == KeyboardKey.E then
			_UIEquipInventoryManager:ToggleWin("/ui/DefaultGroup/EquipWindow")
		elseif event.key == KeyboardKey.I then
			_UIEquipInventoryManager:ToggleWin("/ui/DefaultGroup/InvenWindow")
		end
	end

end
