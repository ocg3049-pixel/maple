	-- 등급 색상 반환 (Rich Text용 hex)
	@ExecSpace("ClientOnly")
	method string GetGradeColor(string grade)
		if grade == "레어" then return "#5B9BD5" end
		if grade == "에픽" then return "#AA59C9" end
		if grade == "유니크" then return "#DAA520" end
		if grade == "레전드리" then return "#27AE60" end
		return "#FFFFFF"
	end

	-- 등급 약자 반환
	@ExecSpace("ClientOnly")
	method string GetGradeLabel(string grade)
		if grade == "레어" then return "R" end
		if grade == "에픽" then return "E" end
		if grade == "유니크" then return "U" end
		if grade == "레전드리" then return "L" end
		return "?"
	end

	-- 아이템 문자열에서 잠재능력/에디셔널 잠재능력 섹션 텍스트 생성
	@ExecSpace("ClientOnly")
	method string BuildPotentialText(string s)
		local result = ""
		local validGrades = {["레어"]=true,["에픽"]=true,["유니크"]=true,["레전드리"]=true}
		local potGrade = self:GetField(s, 9)
		if validGrades[potGrade] then
			local color = self:GetGradeColor(potGrade)
			local label = self:GetGradeLabel(potGrade)
			result = result .. "\n<color=" .. color .. ">[" .. label .. "] 잠재옵션</color>"
			local p1 = self:GetField(s, 10)
			local p2 = self:GetField(s, 11)
			local p3 = self:GetField(s, 12)
			if p1 ~= "" and p1 ~= "0" then result = result .. "\n" .. p1 end
			if p2 ~= "" and p2 ~= "0" then result = result .. "\n" .. p2 end
			if p3 ~= "" and p3 ~= "0" then result = result .. "\n" .. p3 end
		end
		local addPotGrade = self:GetField(s, 13)
		if validGrades[addPotGrade] then
			local color = self:GetGradeColor(addPotGrade)
			local label = self:GetGradeLabel(addPotGrade)
			result = result .. "\n<color=" .. color .. ">[" .. label .. "] 에디셔널 잠재옵션</color>"
			local a1 = self:GetField(s, 14)
			local a2 = self:GetField(s, 15)
			local a3 = self:GetField(s, 16)
			if a1 ~= "" and a1 ~= "0" then result = result .. "\n" .. a1 end
			if a2 ~= "" and a2 ~= "0" then result = result .. "\n" .. a2 end
			if a3 ~= "" and a3 ~= "0" then result = result .. "\n" .. a3 end
		end
		return result
	end

	-- 주문서 드래그 탭에서 주문서 소모 (탭 전환 후 사용 시 올바른 탭 참조)
	@ExecSpace("ClientOnly")
	method void ConsumeScrollInDragTab(number scrollSlot)
		local savedTab = self._T.activeTab
		if self._T.dragScrollTab ~= "" then
			self._T.activeTab = self._T.dragScrollTab
		end
		self:ConsumeScrollFromSlot(scrollSlot)
		self._T.activeTab = savedTab
	end

	-- 스택형 주문서 1개 소모 (count>1이면 감소, count==1이면 슬롯 삭제)
	@ExecSpace("ClientOnly")
	method void ConsumeScrollFromSlot(number scrollSlot)
		local scrollStr = self:GetInven(scrollSlot)
		if scrollStr == "" then return end
		local cnt = self:ParseCount(scrollStr)
		if cnt <= 1 then
			self:SetInvenStr(scrollSlot, "")
		else
			local fields = {}
			for part in string.gmatch(scrollStr, "[^|]+") do fields[#fields+1] = part end
			while #fields < 7 do fields[#fields+1] = "0" end
			fields[7] = tostring(cnt - 1)
			self:SetInvenStr(scrollSlot, table.concat(fields, "|"))
		end
	end

	@ExecSpace("ClientOnly")
	method number GetItemMaxStack(string ruid)
		if ruid == "47841bc4d3554cf0a68bd05f19de1f18" then return 10 end
		if ruid == "14267ae8e168458480697c148ddfdcab" then return 99 end
		if ruid == "314215aface349c48b81eee58065e1b7" then return 99 end
		if ruid == "0f134eebddee4b368062790b46afc26a" then return 99 end
		-- 큐브류 슬롯당 최대 999개
		if ruid == "b2300eda46f3445e9b1c6e774a2ee95a" then return 999 end
		if ruid == "b8f0af90c30b462f859f45bdc1878d8b" then return 999 end
		if ruid == "af5404f4c8fc4ec78ccc1a57446f69db" then return 999 end
		if ruid == "9c2a12b9a92f44d4b6dd95c7fb182ac9" then return 999 end
		return 1
	end

	@ExecSpace("ClientOnly")
	method string BuildItemStr(string baseName, string ruid, number slotIdx, number stars, number scrolls, number upgrade)
		return baseName .. "|" .. ruid .. "|" .. tostring(slotIdx) .. "|" .. tostring(stars) .. "|" .. tostring(scrolls) .. "|" .. tostring(upgrade)
	end

	@ExecSpace("ClientOnly")
	method string GetDisplayName(string s)
		local baseName = self:ParseName(s)
		local scrolls = self:ParseScrolls(s)
		if scrolls > 0 then
			return baseName .. "+" .. tostring(scrolls)
		end
		return baseName
	end

	-- 캐릭터 입장 시 장비 초기화
	@ExecSpace("ClientOnly")
	method void InitEquip(string faceN, string faceR, string hairN, string hairR, string topN, string topR, string botN, string botR, string shoN, string shoR, string wpnN, string wpnR)
		self.equip1 = faceN .. "|" .. faceR .. "|1|0|0|0"
		self.equip2 = hairN .. "|" .. hairR .. "|2|0|0|0"
		self.equip3 = topN  .. "|" .. topR  .. "|3|0|0|0"
		self.equip4 = botN  .. "|" .. botR  .. "|4|0|0|0"
		self.equip5 = shoN  .. "|" .. shoR  .. "|5|0|0|0"
		self.equip6 = wpnN  .. "|" .. wpnR  .. "|6|0|0|0"
		self.equip7 = ""
		-- 모든 탭 초기화
		for _, tab in ipairs({"equip","consume","etc","install","cash","decorate"}) do
			self._T.tabData[tab] = {}
		end
		self._T.activeTab = "equip"
		self._T.scrollRow = 0
		-- 테스트: 초기 메소 1000원 + 아이템 지급
		self.meso = 1000
		-- 연두색 머리띠 → 장비 탭
		self._T.tabData["equip"][1] = "연두색 머리띠|274b50c184c047d8abf1b520c958ce98|7|0|0|7|1|1|2|공격력 +6%|크리티컬 확률 +8%|데미지 +6%|2|최대 HP +5%|STR +6%|올스탯 +3%"
		-- 연두색주문서 10개 → 소비 탭 슬롯 1 (스택, 최대 99)
		local scrollRUID = "314215aface349c48b81eee58065e1b7"
		self._T.tabData["consume"][1] = "연두색주문서|" .. scrollRUID .. "|0|0|0|0|10"
		-- 드롭 아이템 20개 → 소비 탭 슬롯 11~12 (슬롯당 10개)
		local dropRUID = "47841bc4d3554cf0a68bd05f19de1f18"
		self._T.tabData["consume"][11] = "드롭 아이템|" .. dropRUID .. "|0|0|0|0|10"
		self._T.tabData["consume"][12] = "드롭 아이템|" .. dropRUID .. "|0|0|0|0|10"
		-- 잠재능력 부여주문서 20개 → 소비 탭 슬롯 13 (슬롯당 최대 99개)
		local potionScrollRUID = "14267ae8e168458480697c148ddfdcab"
		self._T.tabData["consume"][13] = "잠재능력 부여주문서|" .. potionScrollRUID .. "|0|0|0|0|20"
		-- 에디셔널 잠재능력 부여주문서 20개 → 소비 탭 슬롯 14
		local addPotScrollRUID = "0f134eebddee4b368062790b46afc26a"
		self._T.tabData["consume"][14] = "에디셔널 잠재능력 부여주문서|" .. addPotScrollRUID .. "|0|0|0|0|20"
		-- 큐브류 999개 → 소비 탭 슬롯 15~18
		self._T.tabData["consume"][15] = "레드큐브|b2300eda46f3445e9b1c6e774a2ee95a|0|0|0|0|999"
		self._T.tabData["consume"][16] = "블랙큐브|b8f0af90c30b462f859f45bdc1878d8b|0|0|0|0|999"
		self._T.tabData["consume"][17] = "에디셔널큐브|af5404f4c8fc4ec78ccc1a57446f69db|0|0|0|0|999"
		self._T.tabData["consume"][18] = "화이트 에디셔널큐브|9c2a12b9a92f44d4b6dd95c7fb182ac9|0|0|0|0|999"
		self:RefreshUI()
	end

	@ExecSpace("ClientOnly")
	method void MoveEquipToInven(number slotIdx)
		log("[EquipInven] MoveEquipToInven slot=" .. tostring(slotIdx))
		local s = self:GetEquip(slotIdx)
		if s == "" then return end
		local ruid = self:ParseRUID(s)
		if ruid == "" then return end

		-- 장비 아이템은 장비 탭으로
		local savedTab = self._T.activeTab
		self._T.activeTab = "equip"
		local emptySlot = nil
		for i = 1, 128 do
			if self:GetInven(i) == "" then emptySlot = i; break end
		end
		if emptySlot == nil then
			self._T.activeTab = savedTab
			log("[EquipInven] 인벤토리 가득 참"); return
		end
		self:SetInvenStr(emptySlot, s)
		self:SetEquipStr(slotIdx, "")
		self._T.activeTab = savedTab

		local player = _UserService.LocalPlayer
		if isvalid(player) then
			local cm = player.CostumeManagerComponent
			if isvalid(cm) then
				local cats = {
					MapleAvatarItemCategory.Face, MapleAvatarItemCategory.Hair,
					MapleAvatarItemCategory.Coat, MapleAvatarItemCategory.Pants,
					MapleAvatarItemCategory.Shoes, MapleAvatarItemCategory.TwoHandedWeapon,
					MapleAvatarItemCategory.Cap,
				}
				cm:SetEquip(cats[slotIdx], "")
			end
		end
		self:RefreshUI()
	end

	@ExecSpace("ClientOnly")
	method void MoveInvenToEquip(number invenIdx)
		local s = self:GetInven(invenIdx)
		if s == "" then return end
		local name    = self:ParseName(s)
		local ruid    = self:ParseInvenRUID(s)
		local slotIdx = self:ParseSlotIdx(s)
		if slotIdx < 1 or slotIdx > 7 then return end

		-- 6필드 포맷 그대로 swap
		local cur = self:GetEquip(slotIdx)
		if cur ~= "" and self:ParseRUID(cur) ~= "" then
			self:SetInvenStr(invenIdx, cur)
		else
			self:SetInvenStr(invenIdx, "")
		end

		self:SetEquipStr(slotIdx, s)

		local player = _UserService.LocalPlayer
		if isvalid(player) then
			local cm = player.CostumeManagerComponent
			if isvalid(cm) then
				local cats = {
					MapleAvatarItemCategory.Face, MapleAvatarItemCategory.Hair,
					MapleAvatarItemCategory.Coat, MapleAvatarItemCategory.Pants,
					MapleAvatarItemCategory.Shoes, MapleAvatarItemCategory.TwoHandedWeapon,
					MapleAvatarItemCategory.Cap,
				}
				cm:SetEquip(cats[slotIdx], ruid)
			end
		end
		self:RefreshUI()
	end

	-- 드랍 아이템 습득 시 호출 (서버→클라이언트 RPC 경유)
	@ExecSpace("ClientOnly")
	method void AddItemToInventory(string name, string ruid, string itemType)
		-- avataritem → 장비 탭, 나머지 → 소비 탭
		local targetTab = (itemType == "avataritem") and "equip" or "consume"
		local slotMark = (itemType == "avataritem") and "7" or "0"
		local td = self._T.tabData[targetTab]

		if itemType ~= "avataritem" then
			local maxStack = self:GetItemMaxStack(ruid)
			if maxStack > 1 then
				-- 같은 RUID이며 아직 여유 있는 슬롯에 먼저 쌓기
				for i = 1, 128 do
					local s = td[i] or ""
					if s ~= "" and self:ParseInvenRUID(s) == ruid then
						local cnt = self:ParseCount(s)
						if cnt < maxStack then
							local fields = {}
							for part in string.gmatch(s, "[^|]+") do fields[#fields + 1] = part end
							while #fields < 7 do fields[#fields + 1] = "0" end
							fields[7] = tostring(cnt + 1)
							td[i] = table.concat(fields, "|")
							self:RefreshUI()
							log("[Inven] 스택 추가: " .. name .. " 슬롯=" .. tostring(i) .. " 수량=" .. tostring(cnt + 1))
							return
						end
					end
				end
				-- 여유 슬롯 없으면 새 슬롯 생성 (7필드 포맷, count=1)
				for i = 1, 128 do
					if (td[i] or "") == "" then
						td[i] = name .. "|" .. ruid .. "|0|0|0|0|1"
						self:RefreshUI()
						log("[Inven] 추가(새 슬롯): " .. name .. " 탭=" .. targetTab .. " 슬롯=" .. tostring(i))
						return
					end
				end
			else
				-- 비스택 소비 아이템 (기존 방식)
				for i = 1, 128 do
					if (td[i] or "") == "" then
						td[i] = name .. "|" .. ruid .. "|" .. slotMark
						self:RefreshUI()
						log("[Inven] 추가: " .. name .. " 탭=" .. targetTab .. " 슬롯=" .. tostring(i))
						return
					end
				end
			end
		else
			-- 장비 아이템 (기존 방식)
			for i = 1, 128 do
				if (td[i] or "") == "" then
					td[i] = name .. "|" .. ruid .. "|" .. slotMark
					self:RefreshUI()
					log("[Inven] 추가: " .. name .. " 탭=" .. targetTab .. " 슬롯=" .. tostring(i))
					return
				end
			end
		end
		log("[Inven] 인벤토리 가득 참, 추가 불가: " .. name)
	end

	@ExecSpace("ClientOnly")
	method void RefreshUI()
		self:UpdateEquipUI()
		self:UpdateInvenUI()
		local cw = _EntityService:GetEntityByPath("/ui/DefaultGroup/CharInfoWindow")
		if isvalid(cw) and cw.Enable then
			_CharInfoManager:RefreshCharInfo()
		end
	end

	@ExecSpace("ClientOnly")
	method void AddMeso(integer amount)
		self.meso = self.meso + amount
		self:UpdateMesoUI()
		log("[Meso] +" .. tostring(amount) .. "원  합계: " .. tostring(self.meso) .. "원")
	end

	@ExecSpace("ClientOnly")
	method void UpdateMesoUI()
		local textEnt = _EntityService:GetEntityByPath("/ui/DefaultGroup/InvenWindow/MesoBar/MesoText")
		if isvalid(textEnt) then
			textEnt.TextComponent.Text = "메소: " .. tostring(self.meso)
		end
	end

	@ExecSpace("ClientOnly")
	method void UpdateEquipUI()
		local slotNames = { "SlotFace","SlotHair","SlotTop","SlotBottom","SlotShoes","SlotWeapon","SlotCap" }
		for i, sn in ipairs(slotNames) do
			local d    = self:GetEquip(i)
			local ruid = self:ParseRUID(d)
			local name = self:ParseName(d)
			local has  = ruid ~= ""
			local base = "/ui/DefaultGroup/EquipWindow/" .. sn
			local icon = _EntityService:GetEntityByPath(base .. "/Icon")
			local nEnt = _EntityService:GetEntityByPath(base .. "/ItemName")
			if isvalid(icon) then
				local spr = icon.SpriteGUIRendererComponent
				if has then
					spr.ImageRUID = "thumbnail://" .. ruid
					spr.Color = Color(1, 1, 1, 1)
				else
					spr.ImageRUID = ""
					spr.Color = Color(1, 1, 1, 0)
				end
			end
			if isvalid(nEnt) then
				nEnt.TextComponent.Text = ""
			end
		end
	end

	@ExecSpace("ClientOnly")
	method void UpdateInvenUI()
		self:UpdateInvenViewport()
	end

	-- 툴팁: 장비창 슬롯 호버 (1프레임 지연으로 스쳐지나감 필터링)
	@ExecSpace("ClientOnly")
	method void ShowEquipTooltip(number slotIdx)
		self._T.hoverEquipSlot = slotIdx
		self._T.hoverInvenSlot = 0
		self._T.pendingHideTooltip = false
		self._T.pendingShowSlotType = "equip"
		self._T.pendingShowSlotIdx = slotIdx
	end

	-- 툴팁: 인벤 슬롯 호버 (1프레임 지연으로 스쳐지나감 필터링)
	@ExecSpace("ClientOnly")
	method void ShowInvenTooltip(number invenIdx)
		self._T.hoverInvenSlot = invenIdx
		self._T.hoverEquipSlot = 0
		self._T.pendingHideTooltip = false
		self._T.pendingShowSlotType = "inven"
		self._T.pendingShowSlotIdx = invenIdx
	end

	-- 툴팁 표시 (7필드 아이템 스트링 기반, 메이플스타일 재설계)
	@ExecSpace("ClientOnly")
	method void ShowTooltipFromStr(string s, boolean isEquip, string slotPath, string winPath)
		local tp = _EntityService:GetEntityByPath("/ui/DefaultGroup/TooltipPanel")
		if not isvalid(tp) then return end

		local baseName = self:ParseName(s)
		local ruid     = self:ParseInvenRUID(s)
		local stars    = self:ParseStars(s)
		local scrolls  = self:ParseScrolls(s)
		local upgrade  = self:ParseUpgrade(s)

		-- 1. 이름 (+주문서강화수)
		local displayName = scrolls > 0 and (baseName .. " (+" .. tostring(scrolls) .. ")") or baseName
		local titleEnt = _EntityService:GetEntityByPath("/ui/DefaultGroup/TooltipPanel/TooltipTitle")
		if isvalid(titleEnt) then
			titleEnt.TextComponent.Text = displayName
		end

		-- 2. 별 표시: TpStarFull (★/☆, 5+공백+5+공백+5 × 7행 = 최대 100개, 상단 중앙)
		local STAR_MAX       = 100
		local STARS_PER_GROUP = 5
		local PER_ROW        = 15  -- 5+space+5+space+5
		local fullStarEnt  = _EntityService:GetEntityByPath("/ui/DefaultGroup/TooltipPanel/TpStarFull")
		local emptyStarEnt = _EntityService:GetEntityByPath("/ui/DefaultGroup/TooltipPanel/StarText")
		if isvalid(fullStarEnt) then
			local rows = {}
			local rowStr  = ""
			local colInRow = 0
			for i = 1, STAR_MAX do
				if colInRow > 0 and colInRow % STARS_PER_GROUP == 0 then
					rowStr = rowStr .. " "
				end
				rowStr = rowStr .. (i <= stars and "<color=#FFD700>★</color>" or "<color=#888888>☆</color>")
				colInRow = colInRow + 1
				if colInRow == PER_ROW then
					rows[#rows + 1] = rowStr
					rowStr   = ""
					colInRow = 0
				end
			end
			if colInRow > 0 then rows[#rows + 1] = rowStr end
			fullStarEnt.TextComponent.Text = table.concat(rows, "\n")
		end
		if isvalid(emptyStarEnt) then
			emptyStarEnt.TextComponent.Text = ""
		end

		-- 3. 아이콘
		local iconEnt = _EntityService:GetEntityByPath("/ui/DefaultGroup/TooltipPanel/TooltipIcon")
		if isvalid(iconEnt) then
			local spr = iconEnt.SpriteGUIRendererComponent
			if ruid ~= "" then
				spr.ImageRUID = isEquip and ("thumbnail://" .. ruid) or ruid
				spr.Color = Color(1, 1, 1, 1)
			else
				spr.ImageRUID = ""
				spr.Color = Color(1, 1, 1, 0)
			end
		end

		-- 4. REQ 조건 텍스트
		local reqEnt = _EntityService:GetEntityByPath("/ui/DefaultGroup/TooltipPanel/ReqText")
		if isvalid(reqEnt) then
			reqEnt.TextComponent.Text = self:GetItemReqText(baseName)
		end

		-- 5. 직업 텍스트 색상 (연두색 머리띠: 모두 착용 가능 → 흰색)
		local WHITE = Color(1, 1, 1, 1)
		local GRAY  = Color(0.5, 0.5, 0.5, 1)
		local jobCanUse = {true, true, true, true}
		for i = 1, 4 do
			local je = _EntityService:GetEntityByPath("/ui/DefaultGroup/TooltipPanel/Job" .. tostring(i))
			if isvalid(je) then
				je.TextComponent.FontColor = jobCanUse[i] and WHITE or GRAY
			end
		end

		-- 6. 능력치 텍스트 + 잠재능력 섹션 + TooltipInfo·패널·BG 높이 동적 조정
		local infoEnt = _EntityService:GetEntityByPath("/ui/DefaultGroup/TooltipPanel/TooltipInfo")
		if isvalid(infoEnt) then
			local statsText = self:BuildTooltipStatsText(baseName, stars, upgrade)
			local potText = self:BuildPotentialText(s)
			infoEnt.TextComponent.Text = statsText .. potText
			-- 줄 수 계산
			local txt = infoEnt.TextComponent.Text
			local lineCount = 1
			for _ in string.gmatch(txt, "\n") do lineCount = lineCount + 1 end
			local infoH = math.max(lineCount * 22, 44)
			-- TooltipInfo 높이를 내용에 맞게 축소 (MiddleCenter 정렬이 패널 밖으로 밀리는 현상 방지)
			infoEnt.UITransformComponent.RectSize = Vector2(379, infoH)
			-- 패널·BG도 동일하게 조정 (너비 403)
			local newH = 348 + infoH + 15
			tp.UITransformComponent.RectSize = Vector2(403, newH)
			local bgEnt = _EntityService:GetEntityByPath("/ui/DefaultGroup/TooltipPanel/TooltipBG")
			if isvalid(bgEnt) then
				bgEnt.UITransformComponent.RectSize = Vector2(403, newH)
				bgEnt.UITransformComponent.anchoredPosition = Vector2(0, 0)
			end
		end

		-- 7. 툴팁 위치 (슬롯 우측에 배치, 190px 오프셋)
		local slotEnt = _EntityService:GetEntityByPath(slotPath)
		local winEnt  = _EntityService:GetEntityByPath(winPath)
		if isvalid(slotEnt) and isvalid(winEnt) then
			local sp = slotEnt.UITransformComponent.anchoredPosition
			local wp = winEnt.UITransformComponent.anchoredPosition
			local cx = wp.x + sp.x
			local cy = wp.y + sp.y
			local offset = 230
			local tx = cx + offset
			if tx + 202 > 960 then tx = cx - offset end
			tp.UITransformComponent.anchoredPosition = Vector2(tx, cy)
		end

		self:BringWindowToFront("/ui/DefaultGroup/TooltipPanel")
		tp.Enable = true
	end

	-- 스타포스 누적 수치 포함 능력치 텍스트 생성
	@ExecSpace("ClientOnly")
	method string BuildTooltipStatsText(string name, integer stars, integer upgrade)
		local str_b, dex_b, int_b, luk_b, hp_b, atk_b, matk_b, def_b = 0, 0, 0, 0, 0, 0, 0, 0
		local equipType = "기타"

		if name == "연두색 머리띠" then
			def_b = 5
			equipType = "모자"
		end

		-- 스타포스 누적 수치 계산 (각 레벨별 증가량 합산)
		local str_sf, dex_sf, int_sf, luk_sf, hp_sf, atk_sf, matk_sf = 0, 0, 0, 0, 0, 0, 0
		for i = 0, stars - 1 do
			if i < 5 then
				str_sf = str_sf + 3; dex_sf = dex_sf + 3
				int_sf = int_sf + 3; luk_sf = luk_sf + 3
				hp_sf  = hp_sf  + 25
			elseif i < 10 then
				str_sf = str_sf + 4; dex_sf = dex_sf + 4
				int_sf = int_sf + 4; luk_sf = luk_sf + 4
				hp_sf  = hp_sf  + 50
			elseif i < 15 then
				str_sf = str_sf + 5; dex_sf = dex_sf + 5
				int_sf = int_sf + 5; luk_sf = luk_sf + 5
			elseif i < 20 then
				str_sf = str_sf + 7; dex_sf = dex_sf + 7
				int_sf = int_sf + 7; luk_sf = luk_sf + 7
				atk_sf = atk_sf + 7; matk_sf = matk_sf + 7
			elseif i < 22 then
				str_sf  = str_sf  + 22; dex_sf  = dex_sf  + 22
				int_sf  = int_sf  + 22; luk_sf  = luk_sf  + 22
				atk_sf  = atk_sf  + 21; matk_sf = matk_sf + 21
			else
				atk_sf  = atk_sf  + (i + 1)
				matk_sf = matk_sf + (i + 1)
			end
		end

		local text = "장비분류 : " .. equipType .. "\n"

		-- 스타포스로 오른 수치 표시: 전체합 (기존 +강화)
		if str_sf > 0 then
			text = text .. "STR : +" .. tostring(str_b + str_sf) .. " (" .. tostring(str_b) .. " +" .. tostring(str_sf) .. ")\n"
		end
		if dex_sf > 0 then
			text = text .. "DEX : +" .. tostring(dex_b + dex_sf) .. " (" .. tostring(dex_b) .. " +" .. tostring(dex_sf) .. ")\n"
		end
		if int_sf > 0 then
			text = text .. "INT : +" .. tostring(int_b + int_sf) .. " (" .. tostring(int_b) .. " +" .. tostring(int_sf) .. ")\n"
		end
		if luk_sf > 0 then
			text = text .. "LUK : +" .. tostring(luk_b + luk_sf) .. " (" .. tostring(luk_b) .. " +" .. tostring(luk_sf) .. ")\n"
		end
		if hp_sf > 0 then
			text = text .. "최대 HP : +" .. tostring(hp_b + hp_sf) .. " (" .. tostring(hp_b) .. " +" .. tostring(hp_sf) .. ")\n"
		end
		if atk_sf > 0 then
			text = text .. "공격력 : +" .. tostring(atk_b + atk_sf) .. " (" .. tostring(atk_b) .. " +" .. tostring(atk_sf) .. ")\n"
		end
		if matk_sf > 0 then
			text = text .. "마력 : +" .. tostring(matk_b + matk_sf) .. " (" .. tostring(matk_b) .. " +" .. tostring(matk_sf) .. ")\n"
		end

		if def_b > 0 then
			text = text .. "물리방어력 : +" .. tostring(def_b) .. "\n"
		end

		text = text .. "업그레이드 가능 횟수 : " .. tostring(upgrade)
		return text
	end

	-- 아이템별 REQ 조건 텍스트
	@ExecSpace("ClientOnly")
	method string GetItemReqText(string name)
		if name == "연두색 머리띠" then
			return "REQ LEV : 5\nREQ STR : 0   REQ LUK : 0\nREQ DEX : 0   REQ INT : 0"
		end
		return ""
	end

	-- 툴팁 숨김
	@ExecSpace("ClientOnly")
	method void HideTooltip()
		local tp = _EntityService:GetEntityByPath("/ui/DefaultGroup/TooltipPanel")
		if isvalid(tp) then tp.Enable = false end
		self.tooltipSource = ""
	end

	-- 아이템 기본 설명 (업그레이드 횟수 제외 - 동적으로 표시됨)
	@ExecSpace("ClientOnly")
	method string GetItemBaseDescription(string name)
		if name == "껍질" then
			return "[LV.1] 달팽이의 껍질을\n벗긴 것이다."
		elseif name == "연두색 머리띠" then
			return "REQ LEV: 5\nSTR: 0  DEX: 0\nINT: 0  LUK: 0\nPOP: 0\n초보자/전사\n마법사/궁수/도적\n[모자] 방어력+5"
		elseif name == "연두색주문서" then
			return "[연두색 머리띠용]\n성공률: 60%\n강화 1회 소모"
		elseif name == "잠재능력 부여주문서" then
			return "장비에 잠재능력을 부여합니다.\n성공률: 70%\n실패 시 아이템 파괴\n이미 부여된 아이템에 사용 불가"
		elseif name == "에디셔널 잠재능력 부여주문서" then
			return "장비에 에디셔널 잠재능력을 부여합니다.\n성공률: 70%\n실패 시 아이템 파괴\n1번 성공하면 재사용 불가"
		end
		return ""
	end

	-- 하위 호환용 alias
	@ExecSpace("ClientOnly")
	method string GetItemTooltipText(string name)
		return self:GetItemBaseDescription(name)
	end

	-- ── 주문서 드래그 드랍 ──────────────────────────────────────────

	@ExecSpace("ClientOnly")
	method void StartDrag(number scrollSlot)
		local s = self:GetInven(scrollSlot)
		if s == "" then return end
		local ruid = self:ParseInvenRUID(s)
		local ghost = _EntityService:GetEntityByPath("/ui/DefaultGroup/DragGhost")
		if isvalid(ghost) then
			ghost.SpriteGUIRendererComponent.ImageRUID = ruid
			ghost.SpriteGUIRendererComponent.Color = Color(1, 1, 1, 1)
			local cur = _InputService:GetCursorPosition()
			ghost.UITransformComponent.anchoredPosition = Vector2(cur.x - 960, cur.y - 540)
			_UILogic:SetSiblingIndex(ghost.UITransformComponent, 9999)
			ghost.Enable = true
		end
		self.isDragging = true
		self.dragScrollSlot = scrollSlot
		self._T.dragScrollTab = self._T.activeTab
		self._T.dragScrollStr = s
		self._T.justStartedDrag = true
		log("[Drag] 드래그 시작: 인벤 슬롯 " .. tostring(scrollSlot) .. " s=" .. tostring(s) .. " ruid=" .. tostring(ruid))
	end

	@ExecSpace("ClientOnly")
	method void CancelDrag()
		local ghost = _EntityService:GetEntityByPath("/ui/DefaultGroup/DragGhost")
		if isvalid(ghost) then
			ghost.Enable = false
		end
		self.isDragging = false
		self.dragScrollSlot = 0
		self._T.dragScrollTab = ""
		self._T.dragScrollStr = ""
		if self._T.isDraggingInvenItem then self:CancelInvenDrag() end
	end

	@ExecSpace("ClientOnly")
	method void StartPotionDrag(number invenSlot)
		local s = self:GetInven(invenSlot)
		if s == "" then return end
		local ruid = self:ParseInvenRUID(s)
		local ghost = _EntityService:GetEntityByPath("/ui/DefaultGroup/DragGhost")
		if isvalid(ghost) then
			ghost.SpriteGUIRendererComponent.ImageRUID = ruid
			ghost.SpriteGUIRendererComponent.Color = Color(1, 1, 1, 1)
			local cur = _InputService:GetCursorPosition()
			ghost.UITransformComponent.anchoredPosition = Vector2(cur.x - 960, cur.y - 540)
			_UILogic:SetSiblingIndex(ghost.UITransformComponent, 9999)
			ghost.Enable = true
		end
		self._T.isDraggingPotion = true
		self._T.potionInvenSlot = invenSlot
		self._T.justStartedDrag = true
		log("[Drag] 포션 드래그 시작: 인벤 슬롯 " .. tostring(invenSlot))
	end

	@ExecSpace("ClientOnly")
	method void CancelPotionDrag()
		local ghost = _EntityService:GetEntityByPath("/ui/DefaultGroup/DragGhost")
		if isvalid(ghost) then ghost.Enable = false end
		self._T.isDraggingPotion = false
		self._T.potionInvenSlot = 0
		self._T.pendingCancelPotionDrag = false
	end

	@ExecSpace("ClientOnly")
	method void StartEquipDrag(number invenSlot)
		self._T.isDraggingEquipToEnhance = true
		self._T.dragEquipToEnhanceSlot = invenSlot
		self._T.pendingCancelEquipDrag = false
		local s = self:GetInven(invenSlot)
		local ruid = s ~= "" and self:ParseInvenRUID(s) or ""
		local ghost = _EntityService:GetEntityByPath("/ui/DefaultGroup/DragGhost")
		if isvalid(ghost) then
			if ruid ~= "" then
				ghost.SpriteGUIRendererComponent.ImageRUID = "thumbnail://" .. ruid
			end
			local cur = _InputService:GetCursorPosition()
			ghost.UITransformComponent.anchoredPosition = Vector2(cur.x - 960, cur.y - 540)
			_UILogic:SetSiblingIndex(ghost.UITransformComponent, 9999)
			ghost.Enable = true
		end
		self._T.justStartedDrag = true
		log("[EquipDrag] 시작 slot=" .. tostring(invenSlot))
	end

	@ExecSpace("ClientOnly")
	method void CancelEquipDrag()
		self._T.isDraggingEquipToEnhance = false
		self._T.dragEquipToEnhanceSlot = 0
		self._T.hoverEnhanceSlot = false
		self._T.pendingCancelEquipDrag = false
		local ghost = _EntityService:GetEntityByPath("/ui/DefaultGroup/DragGhost")
		if isvalid(ghost) then
			ghost.Enable = false
			ghost.SpriteGUIRendererComponent.ImageRUID = ""
		end
		if self._T.isDraggingInvenItem then self:CancelInvenDrag() end
		log("[EquipDrag] 취소")
	end

	@ExecSpace("ClientOnly")
	method void OnEnhanceDropEnter(UITouchEnterEvent e)
		self._T.hoverEnhanceSlot = true
	end

	@ExecSpace("ClientOnly")
	method void OnEnhanceDropExit(UITouchExitEvent e)
		self._T.hoverEnhanceSlot = false
	end

	@ExecSpace("ClientOnly")
	method void OnEnhanceDropTouch(UITouchDownEvent e)
		if not self._T.isDraggingEquipToEnhance then return end
		local slot = self._T.dragEquipToEnhanceSlot
		local s = self:GetInven(slot)
		if s ~= "" then
			local name = self:ParseName(s)
			local ruid = self:ParseInvenRUID(s)
			_EnhancementManager:SetEnhanceTarget(name, ruid, slot)
			log("[EquipDrag] 클릭 드롭 완료: " .. name)
		end
		self:CancelEquipDrag()
	end

	-- ── 인벤 슬롯 간 이동 드래그 ─────────────────────────────────────

	@ExecSpace("ClientOnly")
	method void StartInvenDrag(number invenSlot)
		if self._T.isDraggingInvenItem then return end
		local s = self:GetInven(invenSlot)
		if s == "" then return end
		self._T.isDraggingInvenItem = true
		self._T.dragInvenSourceSlot = invenSlot
		self._T.pendingCancelInvenDrag = false
		self._T.justStartedDrag = true
		local ghost = _EntityService:GetEntityByPath("/ui/DefaultGroup/DragGhost")
		if isvalid(ghost) then
			local ruid = self:ParseInvenRUID(s)
			local si = self:ParseSlotIdx(s)
			ghost.SpriteGUIRendererComponent.ImageRUID = (si >= 1) and ("thumbnail://" .. ruid) or ruid
			ghost.SpriteGUIRendererComponent.Color = Color(1, 1, 1, 1)
			local cur = _InputService:GetCursorPosition()
			ghost.UITransformComponent.anchoredPosition = Vector2(cur.x - 960, cur.y - 540)
			_UILogic:SetSiblingIndex(ghost.UITransformComponent, 9999)
			ghost.Enable = true
		end
		log("[InvenDrag] 시작 slot=" .. tostring(invenSlot))
	end

	@ExecSpace("ClientOnly")
	method void CancelInvenDrag()
		self._T.isDraggingInvenItem = false
		self._T.dragInvenSourceSlot = 0
		self._T.pendingCancelInvenDrag = false
		self._T.invenDragHoverSlot = 0
		if not self.isDragging and not self._T.isDraggingPotion and not self._T.isDraggingEquipToEnhance then
			local ghost = _EntityService:GetEntityByPath("/ui/DefaultGroup/DragGhost")
			if isvalid(ghost) then ghost.Enable = false end
		end
	end

	@ExecSpace("ClientOnly")
	method void ApplyInvenDrop(number targetSlot)
		if not self._T.isDraggingInvenItem then return end
		local srcSlot = self._T.dragInvenSourceSlot
		if srcSlot == targetSlot then
			self:CancelInvenDrag()
			if self.isDragging then self:CancelDrag() end
			return
		end
		-- 스크롤 드래그 중이고 대상이 장비 아이템이면 → 주문서 적용 우선
		if self.isDragging then
			local targetStr = self:GetInven(targetSlot)
			local targetSI = self:ParseSlotIdx(targetStr)
			if targetSI >= 1 and targetSI <= 7 then
				self:CancelInvenDrag()
				self:ApplyScrollToInven(targetSlot)
				return
			end
		end
		-- 인벤 슬롯 간 swap
		local srcStr = self:GetInven(srcSlot)
		local dstStr = self:GetInven(targetSlot)
		self:SetInvenStr(srcSlot, dstStr)
		self:SetInvenStr(targetSlot, srcStr)
		self:RefreshUI()
		log("[InvenDrag] 이동: 슬롯" .. tostring(srcSlot) .. " ↔ 슬롯" .. tostring(targetSlot))
		self:CancelInvenDrag()
		if self.isDragging then self:CancelDrag() end
	end

	@ExecSpace("ClientOnly")
	method void ApplyScrollToEquip(number equipSlot)
		if not self.isDragging then return end
		local scrollSlot = self.dragScrollSlot
		local scrollStr = self._T.dragScrollStr
		if scrollStr == "" then self:CancelDrag() return end
		local itemStr = self:GetEquip(equipSlot)
		if itemStr == "" then self:CancelDrag() return end

		local scrollRUID = self:ParseInvenRUID(scrollStr)

		-- 잠재능력 부여주문서: 미부여 아이템에만 사용, 70% 성공, 실패 시 아이템 파괴
		if scrollRUID == "14267ae8e168458480697c148ddfdcab" then
			if self:ParseHasPotential(itemStr) >= 1 then
				log("[PotScroll] 이미 잠재능력이 부여된 아이템입니다.")
				self:CancelDrag()
				return
			end
			self:ConsumeScrollInDragTab(scrollSlot)
			local success = _UtilLogic:RandomDouble() < 0.7
			if success then
				local fields = {}
				for part in string.gmatch(itemStr, "[^|]+") do fields[#fields+1] = part end
				while #fields < 12 do fields[#fields+1] = "0" end
				fields[7] = "1"
				local et = self:GetEquipTypeBySlot(self:ParseSlotIdx(itemStr))
				fields[9] = "레어"
				fields[10] = self:RollPotOption(et, "레어", 1)
				fields[11] = self:RollPotOption(et, "레어", 2)
				fields[12] = self:RollPotOption(et, "레어", 3)
				self:SetEquipStr(equipSlot, table.concat(fields, "|"))
				log("[PotScroll] 성공! " .. fields[10] .. " / " .. fields[11] .. " / " .. fields[12])
			else
				self:SetEquipStr(equipSlot, "")
				log("[PotScroll] 실패! 아이템 파괴됨")
			end
			self:RefreshUI()
			self:CancelDrag()
			if success then self:ShowEquipTooltip(equipSlot) else self:HideTooltip() end
			return
		end

		-- 에디셔널 잠재능력 부여주문서: 잠재능력 부여 선행 필수, 에디셔널 미부여 아이템에만 사용, 70% 성공, 실패 시 파괴
		if scrollRUID == "0f134eebddee4b368062790b46afc26a" then
			if self:ParseHasPotential(itemStr) < 1 then
				log("[AddPotScroll] 잠재능력이 부여되지 않은 아이템입니다. 먼저 잠재능력을 부여하세요.")
				self:CancelDrag()
				return
			end
			if self:ParseHasAdditionalPotential(itemStr) >= 1 then
				log("[AddPotScroll] 이미 에디셔널 잠재능력이 부여된 아이템입니다.")
				self:CancelDrag()
				return
			end
			self:ConsumeScrollInDragTab(scrollSlot)
			local success = _UtilLogic:RandomDouble() < 0.7
			if success then
				local fields = {}
				for part in string.gmatch(itemStr, "[^|]+") do fields[#fields+1] = part end
				while #fields < 16 do fields[#fields+1] = "0" end
				fields[8] = "1"
				local et = self:GetEquipTypeBySlot(self:ParseSlotIdx(itemStr))
				fields[13] = "레어"
				fields[14] = self:RollAddPotOption(et, "레어", 1)
				fields[15] = self:RollAddPotOption(et, "레어", 2)
				fields[16] = self:RollAddPotOption(et, "레어", 3)
				self:SetEquipStr(equipSlot, table.concat(fields, "|"))
				log("[AddPotScroll] 성공! " .. fields[14] .. " / " .. fields[15] .. " / " .. fields[16])
			else
				self:SetEquipStr(equipSlot, "")
				log("[AddPotScroll] 실패! 아이템 파괴됨")
			end
			self:RefreshUI()
			self:CancelDrag()
			if success then self:ShowEquipTooltip(equipSlot) else self:HideTooltip() end
			return
		end

		-- 기존 주문서 (연두색주문서 등) 처리
		local upgrade = self:ParseUpgrade(itemStr)
		if upgrade <= 0 then
			log("[Scroll] 업그레이드 횟수 부족. 강화 불가")
			self:CancelDrag()
			return
		end
		self:ConsumeScrollInDragTab(scrollSlot)
		local success = _UtilLogic:RandomDouble() < 0.6
		local baseName  = self:ParseName(itemStr)
		local ruid      = self:ParseInvenRUID(itemStr)
		local slotIdx   = self:ParseSlotIdx(itemStr)
		local stars     = self:ParseStars(itemStr)
		local scrolls   = self:ParseScrolls(itemStr)
		local newUpgrade = upgrade - 1
		if success then
			scrolls = scrolls + 1
			log("[Scroll] 성공! +" .. tostring(scrolls) .. "  남은 업그레이드: " .. tostring(newUpgrade))
		else
			log("[Scroll] 실패.  남은 업그레이드: " .. tostring(newUpgrade))
		end
		local newStr = self:BuildItemStr(baseName, ruid, slotIdx, stars, scrolls, newUpgrade)
		self:SetEquipStr(equipSlot, newStr)
		self:RefreshUI()
		self:CancelDrag()
		self:ShowEquipTooltip(equipSlot)
	end

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		local cursor = _InputService:GetCursorPosition()
		local cursorUI = Vector2(cursor.x, cursor.y)
		local ghostUI = Vector2(cursor.x - 960, cursor.y - 540)
		-- 툴팁 1프레임 지연 표시: Enter 후 같은 프레임에 Exit가 오면 취소됨
		if self._T.pendingShowSlotType ~= "" then
			local t = self._T.pendingShowSlotType
			local idx = self._T.pendingShowSlotIdx
			self._T.pendingShowSlotType = ""
			self._T.pendingShowSlotIdx = 0
			if t == "equip" and self._T.hoverEquipSlot == idx then
				local s = self:GetEquip(idx)
				if s == "" then
					self:HideTooltip()
				else
					self.tooltipSource = "equip"
					local slotNames = { "SlotFace","SlotHair","SlotTop","SlotBottom","SlotShoes","SlotWeapon","SlotCap" }
					self:ShowTooltipFromStr(s, true, "/ui/DefaultGroup/EquipWindow/" .. slotNames[idx], "/ui/DefaultGroup/EquipWindow")
				end
			elseif t == "inven" and self._T.hoverInvenSlot == idx then
				local dataIdx = self._T.minimized and (self._T.scrollRow * 4 + idx) or idx
				local s = (dataIdx <= 128) and self:GetInven(dataIdx) or ""
				if s == "" then
					self:HideTooltip()
				else
					local si = self:ParseSlotIdx(s)
					self.tooltipSource = "inven"
					self:ShowTooltipFromStr(s, si >= 1, "/ui/DefaultGroup/InvenWindow/InvenSlot" .. idx, "/ui/DefaultGroup/InvenWindow")
				end
			end
		end
		-- 툴팁 지연 숨김: Exit 후 Enter가 없으면 1프레임 뒤에 HideTooltip
		if self._T.pendingHideTooltip then
			self._T.pendingHideTooltip = false
			if self._T.hoverEquipSlot == 0 and self._T.hoverInvenSlot == 0 then
				self:HideTooltip()
			end
		end
		-- 주문서 드래그: 고스트 위치 갱신
		if self.isDragging then
			local ghost = _EntityService:GetEntityByPath("/ui/DefaultGroup/DragGhost")
			if isvalid(ghost) then
				ghost.UITransformComponent.anchoredPosition = ghostUI
			end
		end
		-- 포션 드래그: 고스트 위치 갱신
		if self._T.isDraggingPotion then
			local ghost = _EntityService:GetEntityByPath("/ui/DefaultGroup/DragGhost")
			if isvalid(ghost) then
				ghost.UITransformComponent.anchoredPosition = ghostUI
			end
		end
		-- 강화 드래그: 고스트 위치 갱신
		if self._T.isDraggingEquipToEnhance then
			local ghost = _EntityService:GetEntityByPath("/ui/DefaultGroup/DragGhost")
			if isvalid(ghost) then
				ghost.UITransformComponent.anchoredPosition = ghostUI
			end
		end
		-- 인벤 슬롯 간 드래그: 고스트 위치 갱신 + 대상 슬롯 추적
		if self._T.isDraggingInvenItem then
			local ghost = _EntityService:GetEntityByPath("/ui/DefaultGroup/DragGhost")
			if isvalid(ghost) then
				ghost.UITransformComponent.anchoredPosition = ghostUI
			end
			-- 커서 위치로 드롭 대상 슬롯 직접 계산
			local invenWin = _EntityService:GetEntityByPath("/ui/DefaultGroup/InvenWindow")
			if isvalid(invenWin) then
				local wp = invenWin.UITransformComponent.anchoredPosition
				local rx = ghostUI.x - wp.x
				local ry = ghostUI.y - wp.y
				local hovSlot = 0
				if not self._T.minimized then
					local colXs = {-525,-455,-385,-315,-245,-175,-105,-35,35,105,175,245,315,385,455,525}
					local rowYs = {176,106,36,-34,-104,-174,-244,-314}
					-- 그리드 경계 근처(±55px)에서 가장 가까운 행/열로 스냅
					local snapRy = ry
					if ry > rowYs[1] and ry <= rowYs[1] + 55 then snapRy = rowYs[1]
					elseif ry < rowYs[8] and ry >= rowYs[8] - 55 then snapRy = rowYs[8] end
					local snapRx = rx
					if rx < colXs[1] and rx >= colXs[1] - 55 then snapRx = colXs[1]
					elseif rx > colXs[16] and rx <= colXs[16] + 55 then snapRx = colXs[16] end
					for row = 1, 8 do
						if math.abs(snapRy - rowYs[row]) <= 35 then
							for col = 1, 16 do
								if math.abs(snapRx - colXs[col]) <= 35 then
									hovSlot = (row - 1) * 16 + col
									break
								end
							end
							break
						end
					end
				else
					local colXs = {-111,-37,37,111}
					local rowYs = {176,106,36,-34,-104,-174,-244,-314}
					local snapRy = ry
					if ry > rowYs[1] and ry <= rowYs[1] + 55 then snapRy = rowYs[1]
					elseif ry < rowYs[8] and ry >= rowYs[8] - 55 then snapRy = rowYs[8] end
					local snapRx = rx
					if rx < colXs[1] and rx >= colXs[1] - 55 then snapRx = colXs[1]
					elseif rx > colXs[4] and rx <= colXs[4] + 55 then snapRx = colXs[4] end
					for row = 1, 8 do
						if math.abs(snapRy - rowYs[row]) <= 35 then
							for col = 1, 4 do
								if math.abs(snapRx - colXs[col]) <= 37 then
									hovSlot = (row - 1) * 4 + col
									break
								end
							end
							break
						end
					end
				end
				self._T.invenDragHoverSlot = hovSlot
			end
			if not self.isDragging and not self._T.isDraggingEquipToEnhance then
				local ghost = _EntityService:GetEntityByPath("/ui/DefaultGroup/DragGhost")
				if isvalid(ghost) then
					ghost.UITransformComponent.anchoredPosition = ghostUI
				end
			end
		end
		-- 창 드래그: 마우스 버튼 떼면 강제 종료 (윈도우 밖 릴리즈 대응)
		if self._T.isDraggingWindow then
			if not _InputService:IsKeyPressed(KeyboardKey.Mouse0) then
				self:StopWindowDrag()
			elseif self._T.dragWindowPath ~= "" then
				local w = _EntityService:GetEntityByPath(self._T.dragWindowPath)
				if isvalid(w) then
					local newX = cursorUI.x - self._T.dragWinOffsetX
					local newY = cursorUI.y - self._T.dragWinOffsetY
					-- 화면 경계 제한 (±900 x, ±500 y)
					if newX < -900 then newX = -900 elseif newX > 900 then newX = 900 end
					if newY < -500 then newY = -500 elseif newY > 500 then newY = 500 end
					w.UITransformComponent.anchoredPosition = Vector2(newX, newY)
				end
			end
		end
		-- 스크롤 썸 드래그 처리
		if self._T.isDraggingThumb then
			if not _InputService:IsKeyPressed(KeyboardKey.Mouse0) then
				self._T.isDraggingThumb = false
			elseif self._T.minimized then
				local win = _EntityService:GetEntityByPath("/ui/DefaultGroup/InvenWindow")
				if isvalid(win) then
					local winPos = win.UITransformComponent.anchoredPosition
					local newThumbY = ghostUI.y - winPos.y - self._T.thumbDragOffsetY
					-- 썸 이동 범위: ThumbBG halfH=24 기준 (topLimit=158, botLimit=-306)
					local _tTop = 158  -- ThumbBG 상단이 UP버튼 하단(182)에 맞춤
					local _tBot = -306 -- ThumbBG 하단이 DN버튼 상단(-330)에 맞춤
					newThumbY = math.max(_tBot, math.min(_tTop, newThumbY))
					local progress = (_tTop - newThumbY) / (_tTop - _tBot)
					local newRow = math.floor(progress * 24 + 0.5)
					newRow = math.max(0, math.min(24, newRow))
					local rowChanged = newRow ~= self._T.scrollRow
					self._T.scrollRow = newRow
					local th = _EntityService:GetEntityByPath("/ui/DefaultGroup/InvenWindow/InvenScrollThumb")
					if isvalid(th) then
						th.UITransformComponent.anchoredPosition = Vector2(209, newThumbY)
					end
					if rowChanged then self:UpdateInvenViewport() end
				end
			end
		end
		-- 스크롤 트랙 홀드 처리
		if self._T.isHoldingScrollTrack and not self._T.isDraggingThumb then
			if not _InputService:IsKeyPressed(KeyboardKey.Mouse0) then
				self._T.isHoldingScrollTrack = false
			else
				self._T.scrollTrackTimer = self._T.scrollTrackTimer + delta
				if self._T.scrollTrackTimer >= 0.12 then
					self._T.scrollTrackTimer = 0.0
					self:ScrollTrackStep()
				end
			end
		end
		-- EnhanceWindow 열림 상태 변화 감지 → 스택 동기화
		local eWin = _EntityService:GetEntityByPath("/ui/DefaultGroup/EnhanceWindow")
		if isvalid(eWin) then
			local nowOpen = eWin.Enable
			if nowOpen ~= self._T.prevEnhanceOpen then
				self._T.prevEnhanceOpen = nowOpen
				if nowOpen then
					self:PushWin("/ui/DefaultGroup/EnhanceWindow")
					self:BringWindowToFront("/ui/DefaultGroup/EnhanceWindow")
				else
					self:RemoveWin("/ui/DefaultGroup/EnhanceWindow")
				end
			end
		end
		-- SkillWindow 열림 상태 변화 감지 → 스택 동기화
		local sWin = _EntityService:GetEntityByPath("/ui/DefaultGroup/SkillWindow")
		if isvalid(sWin) then
			local nowOpen = sWin.Enable
			if nowOpen ~= self._T.prevSkillOpen then
				self._T.prevSkillOpen = nowOpen
				if nowOpen then
					self:PushWin("/ui/DefaultGroup/SkillWindow")
					self:BringWindowToFront("/ui/DefaultGroup/SkillWindow")
				else
					self:RemoveWin("/ui/DefaultGroup/SkillWindow")
				end
			end
		end
	end

	@ExecSpace("ClientOnly")
	method void OnScreenRelease(ScreenTouchReleaseEvent e)
		self._T.dragHandledThisClick = false
		if self._T.justStartedDrag then
			self._T.justStartedDrag = false
			return
		end
		if self.isDragging then
			-- hover 중인 슬롯에 드랍 처리
			local eq = self._T.hoverEquipSlot
			local iv = self._T.hoverInvenSlot
			self._T.hoverEquipSlot = 0
			self._T.hoverInvenSlot = 0
			if eq > 0 then
				-- 장비창 슬롯 드랍: 주문서 적용 (인벤 이동과 무관)
				self:ApplyScrollToEquip(eq)
			elseif not self._T.isDraggingInvenItem then
				-- 인벤 이동 드래그 중이 아닐 때만 스크롤→인벤 처리
				if iv > 0 then
					self:ApplyScrollToInven(iv)
				else
					self:CancelDrag()
				end
			end
			-- isDraggingInvenItem=true이고 장비슬롯이 아닌 경우: 아래 블록에서 처리
		end
		if self._T.isDraggingPotion then
			local cursor = _InputService:GetCursorPosition()
			local cursorUI = Vector2(cursor.x, cursor.y)
			local key = _SkillManager:FindSkillBarSlot(cursorUI.x, cursorUI.y)
			if key ~= "" then
				local s = self:GetInven(self._T.potionInvenSlot)
				local ruid = self:ParseInvenRUID(s)
				_SkillManager:AssignSkillToSlot(key, ruid, "HP포션")
				self:SetInvenStr(self._T.potionInvenSlot, "")
				self:RefreshUI()
				log("[Drag] 포션을 단축키 [" .. key .. "]에 배정")
			end
			self:CancelPotionDrag()
		end
		if self._T.isDraggingEquipToEnhance then
			if self._T.hoverEnhanceSlot then
				local slot = self._T.dragEquipToEnhanceSlot
				local s = self:GetInven(slot)
				if s ~= "" then
					local name = self:ParseName(s)
					local ruid = self:ParseInvenRUID(s)
					_EnhancementManager:SetEnhanceTarget(name, ruid, slot)
					log("[Drag] 강화 드롭 성공: " .. name)
				end
			end
			self:CancelEquipDrag()
		end
		if self._T.isDraggingWindow then self:StopWindowDrag() end
	end

	-- ── 창 드래그 ───────────────────────────────────────────────────

	@ExecSpace("ClientOnly")
	method Vector2 GetWindowDefaultPos(string path)
		if path == "/ui/DefaultGroup/InvenWindow" then
			return Vector2(200, 0)
		elseif path == "/ui/DefaultGroup/EquipWindow" then
			return Vector2(-230, 0)
		elseif path == "/ui/DefaultGroup/EnhanceWindow" then
			return Vector2(550, 0)
		elseif path == "/ui/DefaultGroup/CharInfoWindow" then
			return Vector2(350, 0)
		end
		return Vector2(0, 0)
	end

	@ExecSpace("ClientOnly")
	method void StartWindowDrag(string winPath)
		local w = _EntityService:GetEntityByPath(winPath)
		if not isvalid(w) then return end
		if self.isDragging then self:CancelDrag() end
		self._T.isDraggingWindow = true
		self._T.dragWindowPath = winPath
		local cursor = _InputService:GetCursorPosition()
		local cursorUI = Vector2(cursor.x, cursor.y)
		local winPos = w.UITransformComponent.anchoredPosition
		self._T.dragWinOffsetX = cursorUI.x - winPos.x
		self._T.dragWinOffsetY = cursorUI.y - winPos.y
		self:BringWindowToFront(winPath)
		log("[WinDrag] 드래그 시작: " .. winPath)
	end

	@ExecSpace("ClientOnly")
	method void BringWindowToFront(string winPath)
		local paths = {
			"/ui/DefaultGroup/InvenWindow",
			"/ui/DefaultGroup/EquipWindow",
			"/ui/DefaultGroup/EnhanceWindow",
			"/ui/DefaultGroup/SkillWindow",
			"/ui/DefaultGroup/CharInfoWindow",
			"/ui/DefaultGroup/TooltipPanel",
			"/ui/DefaultGroup/ItemTypeSelectPopup",
			"/ui/DefaultGroup/BoxQuantityPopup"
		}
		local maxIdx = 0
		for _, p in ipairs(paths) do
			local e = _EntityService:GetEntityByPath(p)
			if isvalid(e) then
				local idx = _UILogic:GetSiblingIndex(e.UITransformComponent)
				if idx > maxIdx then maxIdx = idx end
			end
		end
		local target = _EntityService:GetEntityByPath(winPath)
		if isvalid(target) then
			_UILogic:SetSiblingIndex(target.UITransformComponent, maxIdx)
		end
	end

	@ExecSpace("ClientOnly")
	method void StopWindowDrag()
		self._T.isDraggingWindow = false
		self._T.dragWindowPath = ""
		log("[WinDrag] 드래그 종료")
	end

	@ExecSpace("ClientOnly")
	method void OnInvenTitleDown(UITouchDownEvent e)
		if e.TouchId ~= -1 then return end
		self:StartWindowDrag("/ui/DefaultGroup/InvenWindow")
	end

	@ExecSpace("ClientOnly")
	method void OnEquipTitleDown(UITouchDownEvent e)
		if e.TouchId ~= -1 then return end
		self:StartWindowDrag("/ui/DefaultGroup/EquipWindow")
	end

	@ExecSpace("ClientOnly")
	method void OnEnhanceTitleDown(UITouchDownEvent e)
		if e.TouchId ~= -1 then return end
		self:StartWindowDrag("/ui/DefaultGroup/EnhanceWindow")
	end

	@ExecSpace("ClientOnly")
	method void OnCharInfoTitleDown(UITouchDownEvent e)
		log("[WinDrag] OnCharInfoTitleDown 호출됨, TouchId=" .. tostring(e.TouchId))
		if e.TouchId ~= -1 then return end
		self:StartWindowDrag("/ui/DefaultGroup/CharInfoWindow")
	end

	-- ScreenTouchEvent 기반 CharInfoWindow 타이틀바 드래그
	-- UITouchDownEvent가 CharInfoWindow에서 발생하지 않아 대체 구현
	@ExecSpace("ClientOnly")
	method void OnCharInfoTitleTouch(ScreenTouchEvent e)
		if e.TouchId ~= 1 then return end
		local ciw = _EntityService:GetEntityByPath("/ui/DefaultGroup/CharInfoWindow")
		if not isvalid(ciw) or not ciw.Enable then return end
		if self._T.isDraggingWindow then return end
		-- e.TouchPoint는 1920×1080 bottom-left 좌표
		-- anchoredPosition은 center origin, y-up
		-- 변환: UI_x = tp.x - 960, UI_y = tp.y - 540
		local tp = e.TouchPoint
		local touchUI_x = tp.x - 960
		local touchUI_y = tp.y - 540
		local winPos = ciw.UITransformComponent.anchoredPosition
		-- TitleText: anchoredPosition=(0, 432), RectSize=(650, 62)
		local titleCX = winPos.x
		local titleCY = winPos.y + 432
		if math.abs(touchUI_x - titleCX) <= 325 and math.abs(touchUI_y - titleCY) <= 40 then
			self:StartWindowDrag("/ui/DefaultGroup/CharInfoWindow")
			log("[WinDrag] CharInfo ScreenTouch 드래그 시작")
		end
	end

