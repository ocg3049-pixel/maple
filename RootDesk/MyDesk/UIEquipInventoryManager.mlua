	@ExecSpace("ClientOnly")
	method void ApplyScrollToInven(number invenSlot)
		if not self.isDragging then return end
		local scrollSlot = self.dragScrollSlot
		local scrollStr = self._T.dragScrollStr
		if scrollStr == "" then self:CancelDrag() return end
		local itemStr = self:GetInven(invenSlot)
		if itemStr == "" then self:CancelDrag() return end
		local slotIdx = self:ParseSlotIdx(itemStr)
		if slotIdx < 1 or slotIdx > 7 then
			log("[Scroll] 장비 아이템이 아님 (slotIdx=" .. tostring(slotIdx) .. ") — 주문서 사용 불가")
			self:CancelDrag()
			return
		end

		local scrollRUID = self:ParseInvenRUID(scrollStr)

		-- 잠재능력 부여주문서: 미부여 아이템에만 사용, 70% 성공, 실패 시 아이템 파괴
		if scrollRUID == "14267ae8e168458480697c148ddfdcab" then
			if self:ParseHasPotential(itemStr) >= 1 then
				log("[PotScroll] 이미 잠재능력이 부여된 아이템입니다.")
				self:CancelDrag()
				return
			end
			self:ConsumeScrollInDragTab(scrollSlot)
			local success = _UtilLogic:RandomDouble() < 0.7
			if success then
				local fields = {}
				for part in string.gmatch(itemStr, "[^|]+") do fields[#fields+1] = part end
				while #fields < 12 do fields[#fields+1] = "0" end
				fields[7] = "1"
				local et = self:GetEquipTypeBySlot(self:ParseSlotIdx(itemStr))
				fields[9] = "레어"
				fields[10] = self:RollPotOption(et, "레어", 1)
				fields[11] = self:RollPotOption(et, "레어", 2)
				fields[12] = self:RollPotOption(et, "레어", 3)
				self:SetInvenStr(invenSlot, table.concat(fields, "|"))
				log("[PotScroll] 성공! " .. fields[10] .. " / " .. fields[11] .. " / " .. fields[12])
			else
				self:SetInvenStr(invenSlot, "")
				log("[PotScroll] 실패! 아이템 파괴됨")
			end
			self:RefreshUI()
			self:CancelDrag()
			if success then self:ShowInvenTooltip(invenSlot) else self:HideTooltip() end
			return
		end

		-- 에디셔널 잠재능력 부여주문서: 잠재능력 부여 선행 필수, 에디셔널 미부여 아이템에만 사용, 70% 성공, 실패 시 파괴
		if scrollRUID == "0f134eebddee4b368062790b46afc26a" then
			if self:ParseHasPotential(itemStr) < 1 then
				log("[AddPotScroll] 잠재능력이 부여되지 않은 아이템입니다. 먼저 잠재능력을 부여하세요.")
				self:CancelDrag()
				return
			end
			if self:ParseHasAdditionalPotential(itemStr) >= 1 then
				log("[AddPotScroll] 이미 에디셔널 잠재능력이 부여된 아이템입니다.")
				self:CancelDrag()
				return
			end
			self:ConsumeScrollInDragTab(scrollSlot)
			local success = _UtilLogic:RandomDouble() < 0.7
			if success then
				local fields = {}
				for part in string.gmatch(itemStr, "[^|]+") do fields[#fields+1] = part end
				while #fields < 16 do fields[#fields+1] = "0" end
				fields[8] = "1"
				local et = self:GetEquipTypeBySlot(self:ParseSlotIdx(itemStr))
				fields[13] = "레어"
				fields[14] = self:RollAddPotOption(et, "레어", 1)
				fields[15] = self:RollAddPotOption(et, "레어", 2)
				fields[16] = self:RollAddPotOption(et, "레어", 3)
				self:SetInvenStr(invenSlot, table.concat(fields, "|"))
				log("[AddPotScroll] 성공! " .. fields[14] .. " / " .. fields[15] .. " / " .. fields[16])
			else
				self:SetInvenStr(invenSlot, "")
				log("[AddPotScroll] 실패! 아이템 파괴됨")
			end
			self:RefreshUI()
			self:CancelDrag()
			if success then self:ShowInvenTooltip(invenSlot) else self:HideTooltip() end
			return
		end

		-- 기존 주문서 (연두색주문서 등) 처리
		local upgrade = self:ParseUpgrade(itemStr)
		if upgrade <= 0 then
			log("[Scroll] 업그레이드 횟수 부족. 강화 불가")
			self:CancelDrag()
			return
		end
		self:ConsumeScrollInDragTab(scrollSlot)
		local success = _UtilLogic:RandomDouble() < 0.6
		local baseName  = self:ParseName(itemStr)
		local ruid      = self:ParseInvenRUID(itemStr)
		local stars     = self:ParseStars(itemStr)
		local scrolls   = self:ParseScrolls(itemStr)
		local newUpgrade = upgrade - 1
		if success then
			scrolls = scrolls + 1
			log("[Scroll] 성공! +" .. tostring(scrolls) .. "  남은 업그레이드: " .. tostring(newUpgrade))
		else
			log("[Scroll] 실패.  남은 업그레이드: " .. tostring(newUpgrade))
		end
		local newStr = self:BuildItemStr(baseName, ruid, slotIdx, stars, scrolls, newUpgrade)
		self:SetInvenStr(invenSlot, newStr)
		self:RefreshUI()
		self:CancelDrag()
		self:ShowInvenTooltip(invenSlot)
	end

	-- ── 탭 / 스크롤 / 최소화 ────────────────────────────────────────

	@ExecSpace("ClientOnly")
	method void UpdateTabColors()
		local tabKeys = {"equip","consume","etc","install","cash","decorate"}
		local base = "/ui/DefaultGroup/InvenWindow/InvenTab_"
		for _, tk in ipairs(tabKeys) do
			local isActive = (tk == self._T.activeTab)
			local activeColor = Color(0.27, 0.75, 1.0, 1.0)
			local inactiveColor = Color(0.22, 0.22, 0.28, 1.0)
			local tabBG = _EntityService:GetEntityByPath(base .. tk .. "/TabBG")
			if isvalid(tabBG) then
				local spr = tabBG.SpriteGUIRendererComponent
				if isvalid(spr) then
					spr.Color = isActive and activeColor or inactiveColor
				end
			end
			local tabLbl = _EntityService:GetEntityByPath(base .. tk .. "/TabLbl")
			if isvalid(tabLbl) then
				local spr = tabLbl.SpriteGUIRendererComponent
				if isvalid(spr) then
					spr.Color = isActive and activeColor or inactiveColor
				end
			end
		end
	end

	@ExecSpace("ClientOnly")
	method void OnTabSwitch(string tabKey)
		self._T.activeTab = tabKey
		self._T.scrollRow = 0
		self:UpdateInvenViewport()
		self:UpdateTabColors()
		log("[Inven] 탭 전환: " .. tabKey)
	end

	@ExecSpace("ClientOnly")
	method void OnScrollUp()
		if self._T.scrollRow > 0 then
			self._T.scrollRow = self._T.scrollRow - 1
			self:UpdateInvenViewport()
		end
	end

	@ExecSpace("ClientOnly")
	method void OnScrollDown()
		if not self._T.minimized then return end
		local maxRow = 24  -- ceil(128/4) - 8 = 32 - 8
		if self._T.scrollRow < maxRow then
			self._T.scrollRow = self._T.scrollRow + 1
			self:UpdateInvenViewport()
		end
	end

	@ExecSpace("ClientOnly")
	method void OnMinimizeToggle()
		self._T.minimized = not self._T.minimized
		self._T.scrollRow = 0
		local b = "/ui/DefaultGroup/InvenWindow/"
		local function sp(p, x, y)
			local e = _EntityService:GetEntityByPath(p)
			if isvalid(e) then e.UITransformComponent.anchoredPosition = Vector2(x, y) end
		end
		local function sr(p, w, h)
			local e = _EntityService:GetEntityByPath(p)
			if isvalid(e) then e.UITransformComponent.RectSize = Vector2(w, h) end
		end
		local winEnt = _EntityService:GetEntityByPath("/ui/DefaultGroup/InvenWindow")
		local tabKeys2 = {"equip","consume","etc","install","cash","decorate"}
		local tabX = {-350, -210, -70, 70, 210, 350}
		if self._T.minimized then
			-- 최소화: 455×760, 4×8=32슬롯 가시, 스크롤 있음 (탭 70% 축소)
			local minW = 455
			local minTabW = 62
			local minTabX = {-155, -93, -31, 31, 93, 155}
			if isvalid(winEnt) then winEnt.UITransformComponent.RectSize = Vector2(minW, 760) end
			sr(b .. "BG", minW, 760)
			sr(b .. "TitleText", minW, 50)
			sr(b .. "TitleText/TitleBG", minW, 50)
			sr(b .. "MesoBar", minW - 20, 50)
			sp(b .. "CloseInven",          207,  355)
			sp(b .. "InvenMinBtn",         165,  355)
			sp(b .. "InvenScrollTrack",    209,  -75)
			sr(b .. "InvenScrollTrack",     16,  500)
			sp(b .. "InvenScrollUp",       209,  194)
			sp(b .. "InvenScrollDown",     209, -342)
			sp(b .. "InvenScrollThumb",    209,  158)
			for i, tk in ipairs(tabKeys2) do
				sp(b .. "InvenTab_" .. tk, minTabX[i], 228)
				sr(b .. "InvenTab_" .. tk, minTabW, 36)
				sr(b .. "InvenTab_" .. tk .. "/TabBG", minTabW, 36)
				sr(b .. "InvenTab_" .. tk .. "/TabLbl", minTabW, 36)
			end
			local colX = {-111, -37, 37, 111}
			local rowY = {176, 106, 36, -34, -104, -174, -244, -314}
			for i = 1, 32 do
				local col = ((i - 1) % 4) + 1
				local row = math.floor((i - 1) / 4) + 1
				sp(b .. "InvenSlot" .. i, colX[col], rowY[row])
			end
			sp(b .. "InvenSlotCount", 190, 333)
			for i = 33, 128 do sp(b .. "InvenSlot" .. i, 3000, 3000) end
			log("[Inven] 최소화 (4×8, 스크롤)")
		else
			-- 확장: 1200×760, 16×8=128슬롯 전체 가시, 스크롤 없음
			if isvalid(winEnt) then winEnt.UITransformComponent.RectSize = Vector2(1200, 760) end
			sr(b .. "BG", 1200, 760)
			sr(b .. "TitleText", 1200, 50)
			sr(b .. "TitleText/TitleBG", 1200, 50)
			sr(b .. "MesoBar", 1180, 50)
			sp(b .. "CloseInven",          580,  355)
			sp(b .. "InvenMinBtn",         538,  355)
			sp(b .. "InvenScrollTrack", 3000, 3000)
			sp(b .. "InvenScrollUp",    3000, 3000)
			sp(b .. "InvenScrollDown",  3000, 3000)
			sp(b .. "InvenScrollThumb", 3000, 3000)
			for i, tk in ipairs(tabKeys2) do
				sp(b .. "InvenTab_" .. tk, tabX[i], 250)
				sr(b .. "InvenTab_" .. tk, 132, 36)
				sr(b .. "InvenTab_" .. tk .. "/TabBG", 132, 36)
				sr(b .. "InvenTab_" .. tk .. "/TabLbl", 132, 36)
			end
			local colX = {-525,-455,-385,-315,-245,-175,-105,-35,35,105,175,245,315,385,455,525}
			local rowY = {176, 106, 36, -34, -104, -174, -244, -314}
			for i = 1, 128 do
				local col = ((i - 1) % 16) + 1
				local row = math.floor((i - 1) / 16) + 1
				sp(b .. "InvenSlot" .. i, colX[col], rowY[row])
			end
			sp(b .. "InvenSlotCount", 555, 303)
			log("[Inven] 확장 (16×8, 스크롤 없음)")
		end
		self:UpdateInvenViewport()
	end

	@ExecSpace("ClientOnly")
	method void UpdateInvenViewport()
		local tab = self._T.activeTab
		local scrollRow = self._T.scrollRow
		local td = self._T.tabData[tab]
		local base = "/ui/DefaultGroup/InvenWindow/InvenSlot"
		-- 확장: 128슬롯 전체 표시(1:1 매핑), 최소화: 32슬롯(스크롤 4열 기준)
		local visSlots = self._T.minimized and 32 or 128
		for v = 1, visSlots do
			local dataIdx = self._T.minimized and (scrollRow * 4 + v) or v
			local s = (dataIdx <= 128) and (td[dataIdx] or "") or ""
			local icon = _EntityService:GetEntityByPath(base .. v .. "/Icon")
			local nEnt = _EntityService:GetEntityByPath(base .. v .. "/ItemName")
			if isvalid(icon) then
				local spr = icon:GetComponent("MOD.Core.SpriteGUIRendererComponent")
				if isvalid(spr) then
					if s ~= "" then
						local ruid = self:ParseInvenRUID(s)
						local si = self:ParseSlotIdx(s)
						spr.ImageRUID = (si >= 1) and ("thumbnail://" .. ruid) or ruid
						spr.Color = Color(1, 1, 1, 1)
					else
						spr.ImageRUID = ""
						spr.Color = Color(1, 1, 1, 0)
					end
				end
			end
			if isvalid(nEnt) then
				local tc = nEnt:GetComponent("MOD.Core.TextComponent")
				if isvalid(tc) then
					if s ~= "" then
						local si = self:ParseSlotIdx(s)
						if si == 0 then
							tc.Text = tostring(self:ParseCount(s))
						else
							tc.Text = ""
						end
					else
						tc.Text = ""
					end
				end
			end
			local sEnt = _EntityService:GetEntityByPath(base .. v .. "/StarLabel")
			if isvalid(sEnt) then
				local stc = sEnt:GetComponent("MOD.Core.TextComponent")
				if isvalid(stc) then
					stc.Text = (s ~= "") and self:GetStarText(self:ParseStars(s)) or ""
				end
			end
		end
		log("[Inven] viewport 갱신: tab=" .. tab .. " scrollRow=" .. tostring(scrollRow) .. " visSlots=" .. tostring(visSlots))
		-- 슬롯 카운트 갱신
		local countEnt = _EntityService:GetEntityByPath("/ui/DefaultGroup/InvenWindow/InvenSlotCount")
		if isvalid(countEnt) then
			local used = 0
			for i = 1, 128 do if (td[i] or "") ~= "" then used = used + 1 end end
			countEnt.TextComponent.Text = tostring(used) .. "/128"
		end
		-- 스크롤 썸 위치 갱신 (최소화 모드에서만)
		if self._T.minimized then
			-- ThumbBG(자식) 높이=48, halfH=24. 부모(InvenScrollThumb)를 UP하단-halfH ~ DN상단+halfH 범위에서 이동
			local thumbBGHalfH = 24  -- ThumbBG 48/2
			local maxRow = 24
			local topLimit = 182 - thumbBGHalfH  -- 158: ThumbBG 상단이 UP버튼 하단(182)에 맞춤
			local botLimit = -330 + thumbBGHalfH -- -306: ThumbBG 하단이 DN버튼 상단(-330)에 맞춤
			local thumbY = topLimit
			if maxRow > 0 then
				local progress = scrollRow / maxRow
				thumbY = topLimit - progress * (topLimit - botLimit)
			end
			local thumb = _EntityService:GetEntityByPath("/ui/DefaultGroup/InvenWindow/InvenScrollThumb")
			if isvalid(thumb) then
				thumb.UITransformComponent.anchoredPosition = Vector2(209, thumbY)
			end
		end
	end

	-- ── ESC 창 스택 관리 ────────────────────────────────────────────

	@ExecSpace("ClientOnly")
	method void PushWin(string path)
		self:RemoveWin(path)
		local stack = self._T.winStack
		stack[#stack + 1] = path
	end

	@ExecSpace("ClientOnly")
	method void RemoveWin(string path)
		local stack = self._T.winStack
		local newStack = {}
		for _, p in ipairs(stack) do
			if p ~= path then
				newStack[#newStack + 1] = p
			end
		end
		self._T.winStack = newStack
	end

	-- ── 스크롤 방식 3종: 썸 드래그 / 마우스 휠 / 트랙 홀드 ────────────

	@ExecSpace("ClientOnly")
	method void OnScrollThumbDown(UITouchDownEvent e)
		-- 스크롤 썸 드래그 시작
		if e.TouchId ~= -1 then return end
		if not self._T.minimized then return end
		self._T.isDraggingThumb = true
		self._T.isHoldingScrollTrack = false
		local win = _EntityService:GetEntityByPath("/ui/DefaultGroup/InvenWindow")
		if not isvalid(win) then return end
		local winPos = win.UITransformComponent.anchoredPosition
		local cursor = _InputService:GetCursorPosition()
		local cursorUI = Vector2(cursor.x - 960, cursor.y - 540)
		local localY = cursorUI.y - winPos.y
		local thumb = _EntityService:GetEntityByPath("/ui/DefaultGroup/InvenWindow/InvenScrollThumb")
		if isvalid(thumb) then
			self._T.thumbDragOffsetY = localY - thumb.UITransformComponent.anchoredPosition.y
		else
			self._T.thumbDragOffsetY = 0.0
		end
		log("[Scroll] 썸 드래그 시작")
	end

	@ExecSpace("ClientOnly")
	method void OnScrollTrackDown(UITouchDownEvent e)
		-- 트랙 클릭 홀드: 썸이 커서 위치로 한 단계씩 이동
		if e.TouchId ~= -1 then return end
		if not self._T.minimized then return end
		if self._T.isDraggingThumb then return end
		self._T.isHoldingScrollTrack = true
		self._T.scrollTrackTimer = 0.0
		self:ScrollTrackStep()
		log("[Scroll] 트랙 홀드 시작")
	end

	@ExecSpace("ClientOnly")
	method void OnMouseScroll(MouseScrollEvent e)
		-- 마우스 휠: 인벤 창 영역 위에 있을 때만 동작
		if not self._T.minimized then return end
		local win = _EntityService:GetEntityByPath("/ui/DefaultGroup/InvenWindow")
		if not isvalid(win) or not win.Enable then return end
		local winPos = win.UITransformComponent.anchoredPosition
		local cursor = _InputService:GetCursorPosition()
		local cursorUI = Vector2(cursor.x - 960, cursor.y - 540)
		local localX = cursorUI.x - winPos.x
		local localY = cursorUI.y - winPos.y
		if localX < -227.5 or localX > 227.5 or localY < -380.0 or localY > 380.0 then return end
		-- 휠 속도 1/5: 5회 누를 때마다 1행 이동
		if e.ScrollDelta > 0 then
			self._T.wheelAccum = self._T.wheelAccum + 0.2
			if self._T.wheelAccum >= 1.0 then
				self._T.wheelAccum = self._T.wheelAccum - 1.0
				self:OnScrollUp()
			end
		elseif e.ScrollDelta < 0 then
			self._T.wheelAccum = self._T.wheelAccum - 0.2
			if self._T.wheelAccum <= -1.0 then
				self._T.wheelAccum = self._T.wheelAccum + 1.0
				self:OnScrollDown()
			end
		end
	end

	@ExecSpace("ClientOnly")
	method void ScrollTrackStep()
		-- 트랙 클릭 위치 기준으로 scrollRow 한 단계 이동
		if not self._T.minimized then return end
		local win = _EntityService:GetEntityByPath("/ui/DefaultGroup/InvenWindow")
		if not isvalid(win) then return end
		local winPos = win.UITransformComponent.anchoredPosition
		local cursor = _InputService:GetCursorPosition()
		local cursorUI = Vector2(cursor.x - 960, cursor.y - 540)
		local localY = cursorUI.y - winPos.y
		-- 썸 이동 범위: topLimit=158, botLimit=-306, range=464
		local progress = (158 - localY) / 464
		progress = math.max(0.0, math.min(1.0, progress))
		local targetRow = math.floor(progress * 24 + 0.5)
		if self._T.scrollRow < targetRow then
			self._T.scrollRow = self._T.scrollRow + 1
			self:UpdateInvenViewport()
		elseif self._T.scrollRow > targetRow then
			self._T.scrollRow = self._T.scrollRow - 1
			self:UpdateInvenViewport()
		end
	end

	-- ── 박스 아이템 사용 ─────────────────────────────────────────────

	@ExecSpace("ClientOnly")
	method void ShowBoxTypeSelectPopup(number sourceSlot)
		self._T.boxSourceSlot = sourceSlot
		local s = self:GetInven(sourceSlot)
		local ruid = self:ParseInvenRUID(s)
		local iconEnt = _EntityService:GetEntityByPath("/ui/DefaultGroup/ItemTypeSelectPopup/Dialog/ItemIcon")
		if isvalid(iconEnt) then
			local spr = iconEnt.SpriteGUIRendererComponent
			if isvalid(spr) then
				spr.ImageRUID = ruid
				spr.Color = Color(1, 1, 1, 1)
			end
		end
		local popup = _EntityService:GetEntityByPath("/ui/DefaultGroup/ItemTypeSelectPopup")
		if isvalid(popup) then
			self:BringWindowToFront("/ui/DefaultGroup/ItemTypeSelectPopup")
			self:PushWin("/ui/DefaultGroup/ItemTypeSelectPopup")
			popup.Enable = true
		end
		log("[Box] 타입 선택 팝업 표시 sourceSlot=" .. tostring(sourceSlot))
	end

	@ExecSpace("ClientOnly")
	method void HideBoxTypeSelectPopup()
		local popup = _EntityService:GetEntityByPath("/ui/DefaultGroup/ItemTypeSelectPopup")
		if isvalid(popup) then popup.Enable = false end
		self:RemoveWin("/ui/DefaultGroup/ItemTypeSelectPopup")
	end

	@ExecSpace("ClientOnly")
	method void OnBoxTypeSelect(number typeSlotIdx)
		if typeSlotIdx == 0 then
			log("[Box] 해당 종류는 아직 준비 중입니다.")
			return
		end
		self._T.boxSelectedType = typeSlotIdx
		self:HideBoxTypeSelectPopup()
		self:ShowBoxQuantityPopup(typeSlotIdx)
	end

	@ExecSpace("ClientOnly")
	method void ShowBoxQuantityPopup(number typeSlotIdx)
		local sourceSlot = self._T.boxSourceSlot
		local s = self:GetInven(sourceSlot)
		local boxCount = self:ParseCount(s)
		local ruid = self:ParseInvenRUID(s)
		local name = self:ParseName(s)
		-- 장비 탭 여유 슬롯 계산
		local savedTab = self._T.activeTab
		self._T.activeTab = "equip"
		local freeSlots = 0
		for i = 1, 128 do
			if self:GetInven(i) == "" then freeSlots = freeSlots + 1 end
		end
		self._T.activeTab = savedTab
		local maxQty = math.min(boxCount, freeSlots)
		self._T.boxMaxQty = maxQty
		-- 아이템 이미지
		local iconEnt = _EntityService:GetEntityByPath("/ui/DefaultGroup/BoxQuantityPopup/Dialog/ItemIcon")
		if isvalid(iconEnt) then
			local spr = iconEnt.SpriteGUIRendererComponent
			if isvalid(spr) then
				spr.ImageRUID = ruid
				spr.Color = Color(1, 1, 1, 1)
			end
		end
		-- 아이템 이름
		local nameEnt = _EntityService:GetEntityByPath("/ui/DefaultGroup/BoxQuantityPopup/Dialog/ItemNameText")
		if isvalid(nameEnt) then nameEnt.TextComponent.Text = name end
		-- 최대 수량 안내
		local maxQtyEnt = _EntityService:GetEntityByPath("/ui/DefaultGroup/BoxQuantityPopup/Dialog/MaxQtyText")
		if isvalid(maxQtyEnt) then
			maxQtyEnt.TextComponent.Text = "최대 " .. tostring(maxQty) .. "개 사용 가능"
		end
		-- 입력창 초기값
		local inputEnt = _EntityService:GetEntityByPath("/ui/DefaultGroup/BoxQuantityPopup/Dialog/QuantityInput")
		if isvalid(inputEnt) then inputEnt.TextInputComponent.Text = "1" end
		-- 팝업 표시
		local popup = _EntityService:GetEntityByPath("/ui/DefaultGroup/BoxQuantityPopup")
		if isvalid(popup) then
			self:BringWindowToFront("/ui/DefaultGroup/BoxQuantityPopup")
			self:PushWin("/ui/DefaultGroup/BoxQuantityPopup")
			popup.Enable = true
		end
		log("[Box] 수량 팝업 표시 maxQty=" .. tostring(maxQty))
	end

	@ExecSpace("ClientOnly")
	method void HideBoxQuantityPopup()
		local popup = _EntityService:GetEntityByPath("/ui/DefaultGroup/BoxQuantityPopup")
		if isvalid(popup) then popup.Enable = false end
		self:RemoveWin("/ui/DefaultGroup/BoxQuantityPopup")
	end

	@ExecSpace("ClientOnly")
	method void OnBoxQuantityConfirm()
		local inputEnt = _EntityService:GetEntityByPath("/ui/DefaultGroup/BoxQuantityPopup/Dialog/QuantityInput")
		if not isvalid(inputEnt) then return end
		local inputText = inputEnt.TextInputComponent.Text
		local qty = tonumber(inputText) or 0
		local maxQty = self._T.boxMaxQty or 0
		if qty <= 0 then
			log("[Box] 수량 0 이하, 취소")
			self:HideBoxQuantityPopup()
			return
		end
		if qty > maxQty then qty = maxQty end
		if qty <= 0 then
			log("[Box] 여유 슬롯 없음")
			self:HideBoxQuantityPopup()
			return
		end
		local sourceSlot = self._T.boxSourceSlot
		-- 장비 탭에 qty개 추가 (모자: 연두색 머리띠)
		local hatItem = "연두색 머리띠|274b50c184c047d8abf1b520c958ce98|7|0|0|7"
		local savedTab = self._T.activeTab
		self._T.activeTab = "equip"
		local added = 0
		for i = 1, 128 do
			if added >= qty then break end
			if self:GetInven(i) == "" then
				self:SetInvenStr(i, hatItem)
				added = added + 1
			end
		end
		-- 소비 탭에서 상자 수량 감소
		self._T.activeTab = "consume"
		local s = self:GetInven(sourceSlot)
		local boxCount = self:ParseCount(s)
		local newCount = boxCount - added
		if newCount <= 0 then
			self:SetInvenStr(sourceSlot, "")
		else
			-- 7번째 필드(count)만 교체
			local fields = {}
			for part in string.gmatch(s, "[^|]+") do
				fields[#fields + 1] = part
			end
			fields[7] = tostring(newCount)
			self:SetInvenStr(sourceSlot, table.concat(fields, "|"))
		end
		self._T.activeTab = savedTab
		self:HideBoxQuantityPopup()
		self:RefreshUI()
		log("[Box] 상자 " .. tostring(added) .. "개 사용 → 연두색 머리띠 획득. 남은 상자: " .. tostring(math.max(0, boxCount - added)))
	end

	@ExecSpace("ClientOnly")
	method void OnBoxQuantityCancel()
		self:HideBoxQuantityPopup()
	end

	@ExecSpace("ClientOnly")
	method void OnEndPlay()
		-- 마우스 휠 이벤트 핸들러 해제
		if self._T.scrollHandler then
			_InputService:DisconnectEvent(MouseScrollEvent, self._T.scrollHandler)
			self._T.scrollHandler = nil
		end
	end

	@ExecSpace("ClientOnly")
	method void CloseTopWindow()
		local stack = self._T.winStack
		if #stack == 0 then return end
		local path = stack[#stack]
		self:RemoveWin(path)
		if path == "/ui/DefaultGroup/EnhanceWindow" then
			_EnhancementManager:CloseWindow()
		elseif path == "/ui/DefaultGroup/SkillWindow" then
			local w = _EntityService:GetEntityByPath(path)
			if isvalid(w) then w.Enable = false end
			local stp = _EntityService:GetEntityByPath("/ui/DefaultGroup/SkillTooltipPanel")
			if isvalid(stp) then stp.Enable = false end
		else
			local w = _EntityService:GetEntityByPath(path)
			if isvalid(w) then w.Enable = false end
			if path == "/ui/DefaultGroup/InvenWindow" then
				if self.tooltipSource == "inven" then self:HideTooltip() end
			elseif path == "/ui/DefaultGroup/EquipWindow" then
				if self.tooltipSource == "equip" then self:HideTooltip() end
			end
		end
		log("[ESC] 창 닫힘: " .. path)
	end

end
