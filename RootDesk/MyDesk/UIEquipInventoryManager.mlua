@Logic
script UIEquipInventoryManager extends Logic

	-- 장비 슬롯 7개 (7=모자): "이름|RUID" 형식
	property string equip1 = ""
	property string equip2 = ""
	property string equip3 = ""
	property string equip4 = ""
	property string equip5 = ""
	property string equip6 = ""
	property string equip7 = ""

	-- 메소
	property integer meso = 0

	-- 더블클릭 추적
	property number lastEquipSlot = 0
	property number lastEquipTime = 0.0
	property number lastInvenSlot = 0
	property number lastInvenTime = 0.0

	-- 주문서 드래그 드랍
	property boolean isDragging = false
	property number dragScrollSlot = 0

	-- 창 드래그
	property boolean isDraggingWindow = false
	property string dragWindowPath = ""
	property number dragWinOffsetX = 0.0
	property number dragWinOffsetY = 0.0

	-- 툴팁 출처 추적: "equip" / "inven" / ""
	property string tooltipSource = ""

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		self._T.winStack = {}
		self._T.tabData = { equip={}, consume={}, etc={}, install={}, cash={}, decorate={} }
		self._T.activeTab = "equip"
		self._T.scrollRow = 0
		self._T.minimized = false
		self._T.prevEnhanceOpen = false
		self._T.prevSkillOpen   = false
		self._T.isDraggingWindow = false
		self._T.dragWindowPath = ""
		self._T.dragWinOffsetX = 0.0
		self._T.dragWinOffsetY = 0.0
		self._T.pendingCancelDrag = false
		self._T.isDraggingPotion = false
		self._T.potionInvenSlot = 0
		self._T.pendingCancelPotionDrag = false
		self._T.isDraggingEquipToEnhance = false
		self._T.dragEquipToEnhanceSlot = 0
		self._T.hoverEnhanceSlot = false
		self._T.pendingCancelEquipDrag = false
		self._T.isDraggingInvenItem = false
		self._T.dragInvenSourceSlot = 0
		self._T.pendingCancelInvenDrag = false
		self._T.invenDragHoverSlot = 0
		self._T.justStartedDrag = false
		self._T.dragHandledThisClick = false
		self._T.dragScrollTab = ""
		self._T.dragScrollStr = ""
		self._T.pendingHideTooltip = false
		self._T.isDraggingThumb = false
		self._T.thumbDragOffsetY = 0.0
		self._T.isHoldingScrollTrack = false
		self._T.scrollTrackTimer = 0.0
		self._T.scrollHandler = nil
		self._T.wheelAccum = 0.0
		self._T.hoverEquipSlot = 0
		self._T.hoverInvenSlot = 0
		self._T.pendingShowSlotType = ""
		self._T.pendingShowSlotIdx = 0
		self._T.boxSourceSlot = 0
		self._T.boxSelectedType = 0
		self._T.boxMaxQty = 0
		local cE = _EntityService:GetEntityByPath("/ui/DefaultGroup/EquipWindow/CloseEquip")
		local cI = _EntityService:GetEntityByPath("/ui/DefaultGroup/InvenWindow/CloseInven")
		local cEnh = _EntityService:GetEntityByPath("/ui/DefaultGroup/EnhanceWindow/CloseEnhance")
		if isvalid(cE) then cE:ConnectEvent(ButtonClickEvent, self.OnCloseEquip) end
		if isvalid(cI) then cI:ConnectEvent(ButtonClickEvent, self.OnCloseInven) end
		if isvalid(cEnh) then cEnh:ConnectEvent(ButtonClickEvent, self.OnCloseEnhance) end
		local cCI = _EntityService:GetEntityByPath("/ui/DefaultGroup/CharInfoWindow/CloseCharInfo")
		if isvalid(cCI) then cCI:ConnectEvent(ButtonClickEvent, self.OnCloseCharInfo) end
		_InputService:ConnectEvent(KeyDownEvent, self.OnKeyDown)

		-- 장비 슬롯: UITouchReceiveComponent 추가 후 click + hover 연결
		local eBase = "/ui/DefaultGroup/EquipWindow/"
		local eNames = { "SlotFace","SlotHair","SlotTop","SlotBottom","SlotShoes","SlotWeapon" }
		local eHandlers = {
			self.OnEquipBtn1, self.OnEquipBtn2, self.OnEquipBtn3,
			self.OnEquipBtn4, self.OnEquipBtn5, self.OnEquipBtn6
		}
		local eEnterHandlers = {
			self.OnEquipHoverEnter1, self.OnEquipHoverEnter2, self.OnEquipHoverEnter3,
			self.OnEquipHoverEnter4, self.OnEquipHoverEnter5, self.OnEquipHoverEnter6
		}
		for i, sn in ipairs(eNames) do
			local slot = _EntityService:GetEntityByPath(eBase .. sn)
			if isvalid(slot) then
				if not isvalid(slot:GetComponent("MOD.Core.UITouchReceiveComponent")) then
					slot:AddComponent("MOD.Core.UITouchReceiveComponent")
				end
				slot:ConnectEvent(UITouchDownEvent, eHandlers[i])
				-- 호버: Touch 자식 엔티티가 touch 이벤트를 가로채므로 그쪽에 연결
				local eHoverTarget = slot
				local eTouchChild = _EntityService:GetEntityByPath(eBase .. sn .. "/Touch")
				if isvalid(eTouchChild) then eHoverTarget = eTouchChild end
				eHoverTarget:ConnectEvent(UITouchEnterEvent, eEnterHandlers[i])
				local equipSlotI = i
				eHoverTarget:ConnectEvent(UITouchExitEvent, function(e)
					if self._T.hoverEquipSlot == equipSlotI then
						self._T.hoverEquipSlot = 0
						self._T.hoverInvenSlot = 0
						self._T.pendingHideTooltip = true
					end
				end)
				log("[EquipInven] equip wired: " .. sn)
			end
		end

		-- 모자 슬롯 (SlotCap)
		local capSlot = _EntityService:GetEntityByPath(eBase .. "SlotCap")
		if isvalid(capSlot) then
			if not isvalid(capSlot:GetComponent("MOD.Core.UITouchReceiveComponent")) then
				capSlot:AddComponent("MOD.Core.UITouchReceiveComponent")
			end
			capSlot:ConnectEvent(UITouchDownEvent, self.OnEquipBtn7)
			local capHoverTarget = capSlot
			local capTouchChild = _EntityService:GetEntityByPath(eBase .. "SlotCap/Touch")
			if isvalid(capTouchChild) then capHoverTarget = capTouchChild end
			capHoverTarget:ConnectEvent(UITouchEnterEvent, self.OnEquipHoverEnter7)
			capHoverTarget:ConnectEvent(UITouchExitEvent, function(e)
				if self._T.hoverEquipSlot == 7 then
					self._T.hoverEquipSlot = 0
					self._T.hoverInvenSlot = 0
					self._T.pendingHideTooltip = true
				end
			end)
			log("[EquipInven] equip wired: SlotCap")
		end

		-- 인벤 슬롯: click + hover 연결 (128슬롯)
		-- SlotBG와 Icon에 UITouchReceiveComponent가 있으므로 slot, SlotBG, Icon 모두에 연결
		local iBase = "/ui/DefaultGroup/InvenWindow/InvenSlot"
		for i = 1, 128 do
			local capturedI = i
			local slot = _EntityService:GetEntityByPath(iBase .. i)
			if isvalid(slot) then
				if not isvalid(slot:GetComponent("MOD.Core.UITouchReceiveComponent")) then
					slot:AddComponent("MOD.Core.UITouchReceiveComponent")
				end
				local function slotClickHandler(e)
					if e.TouchId ~= -1 then return end
					if self._T.dragHandledThisClick then return end
					local limit = self._T.minimized and 32 or 128
					if capturedI > limit then return end
					local dataIdx = self._T.minimized and (self._T.scrollRow * 4 + capturedI) or capturedI
					if dataIdx > 128 then return end
					self._T.dragHandledThisClick = true
					-- 인벤 드래그 중이면
					if self._T.isDraggingInvenItem then
						if self._T.dragInvenSourceSlot == dataIdx then
							-- 같은 슬롯 재클릭: 드래그 취소 후 더블클릭 감지로 이어감
							self:CancelInvenDrag()
						else
							-- 다른 슬롯: 드롭
							self:ApplyInvenDrop(dataIdx)
							return
						end
					end
					-- 주문서 드래그 중이면 두 번째 클릭으로 주문서 적용
					if self.isDragging then
						self:ApplyScrollToInven(dataIdx)
						return
					end
					self:OnSlotClick("inven", dataIdx)
				end
				local function slotEnterHandler(e)
					local limit = self._T.minimized and 32 or 128
					if capturedI <= limit then self:ShowInvenTooltip(capturedI) end
				end
				local function slotExitHandler(e)
					if self._T.hoverInvenSlot == capturedI then
						self._T.hoverEquipSlot = 0
						self._T.hoverInvenSlot = 0
						self._T.pendingHideTooltip = true
					end
				end
				-- slot 자체
				slot:ConnectEvent(UITouchDownEvent, slotClickHandler)
				slot:ConnectEvent(UITouchEnterEvent, slotEnterHandler)
				slot:ConnectEvent(UITouchExitEvent, slotExitHandler)
				-- SlotBG (흰색 배경 자식)
				local slotBG = _EntityService:GetEntityByPath(iBase .. capturedI .. "/SlotBG")
				if isvalid(slotBG) then
					slotBG:ConnectEvent(UITouchDownEvent, slotClickHandler)
					slotBG:ConnectEvent(UITouchEnterEvent, slotEnterHandler)
					slotBG:ConnectEvent(UITouchExitEvent, slotExitHandler)
				end
				-- Icon
				local iconEnt = _EntityService:GetEntityByPath(iBase .. capturedI .. "/Icon")
				if isvalid(iconEnt) then
					iconEnt:ConnectEvent(UITouchDownEvent, slotClickHandler)
					iconEnt:ConnectEvent(UITouchEnterEvent, slotEnterHandler)
					iconEnt:ConnectEvent(UITouchExitEvent, slotExitHandler)
				end
				-- ItemName, StarLabel은 TextComponent만 있고 UITouchReceive 없음 → 클릭 통과
			end
		end
		log("[EquipInven] inven wired (128 slots)")

		-- 탭 버튼 와이어링: tabEnt, TabBG, TabLbl 모두에 연결 (displayOrder=10=front)
		local tabKeys = {"equip","consume","etc","install","cash","decorate"}
		for _, tk in ipairs(tabKeys) do
			local capturedTk = tk
			local tabBase = "/ui/DefaultGroup/InvenWindow/InvenTab_" .. tk
			local tabEnt = _EntityService:GetEntityByPath(tabBase)
			local tabBG = _EntityService:GetEntityByPath(tabBase .. "/TabBG")
			local tabLbl = _EntityService:GetEntityByPath(tabBase .. "/TabLbl")
			log("[TAB_WIRE] " .. tk .. " tabEnt=" .. tostring(isvalid(tabEnt)) .. " TabBG=" .. tostring(isvalid(tabBG)) .. " TabLbl=" .. tostring(isvalid(tabLbl)))
			local function tabHandler(e)
				if e.TouchId ~= -1 then return end
				log("[TAB_CLICK] " .. capturedTk)
				self:OnTabSwitch(capturedTk)
			end
			if isvalid(tabEnt) then
				tabEnt:ConnectEvent(UITouchDownEvent, tabHandler)
			end
			if isvalid(tabBG) then
				tabBG:ConnectEvent(UITouchDownEvent, tabHandler)
			end
			-- TabLbl은 TextComponent만 있음 → RaycastTarget=false → 클릭이 TabBG로 전달
		end
		-- 스크롤 버튼 와이어링 (Touch 자식에 직접 연결)
		local scrollUpEnt = _EntityService:GetEntityByPath("/ui/DefaultGroup/InvenWindow/InvenScrollUp")
		local scrollUpTouch = _EntityService:GetEntityByPath("/ui/DefaultGroup/InvenWindow/InvenScrollUp/Touch")
		local suTarget = isvalid(scrollUpTouch) and scrollUpTouch or scrollUpEnt
		if isvalid(suTarget) then
			suTarget:ConnectEvent(UITouchDownEvent, function(e)
				if e.TouchId ~= -1 then return end
				self:OnScrollUp()
			end)
		end
		local scrollDownEnt = _EntityService:GetEntityByPath("/ui/DefaultGroup/InvenWindow/InvenScrollDown")
		local scrollDownTouch = _EntityService:GetEntityByPath("/ui/DefaultGroup/InvenWindow/InvenScrollDown/Touch")
		local sdTarget = isvalid(scrollDownTouch) and scrollDownTouch or scrollDownEnt
		if isvalid(sdTarget) then
			sdTarget:ConnectEvent(UITouchDownEvent, function(e)
				if e.TouchId ~= -1 then return end
				self:OnScrollDown()
			end)
		end
		-- 최소화 버튼 와이어링 (Touch 자식에 직접 연결)
		local minBtnEnt = _EntityService:GetEntityByPath("/ui/DefaultGroup/InvenWindow/InvenMinBtn")
		local minBtnTouch = _EntityService:GetEntityByPath("/ui/DefaultGroup/InvenWindow/InvenMinBtn/Touch")
		local mbTarget = isvalid(minBtnTouch) and minBtnTouch or minBtnEnt
		if isvalid(mbTarget) then
			mbTarget:ConnectEvent(UITouchDownEvent, function(e)
				if e.TouchId ~= -1 then return end
				self:OnMinimizeToggle()
			end)
		end
		log("[EquipInven] tab/scroll/minimize wired")
		-- 스크롤 썸 드래그 와이어링
		local thumbEnt2 = _EntityService:GetEntityByPath("/ui/DefaultGroup/InvenWindow/InvenScrollThumb")
		if isvalid(thumbEnt2) then
			if not isvalid(thumbEnt2:GetComponent("MOD.Core.UITouchReceiveComponent")) then
				thumbEnt2:AddComponent("MOD.Core.UITouchReceiveComponent")
			end
			thumbEnt2:ConnectEvent(UITouchDownEvent, self.OnScrollThumbDown)
		end
		-- 스크롤 트랙 클릭/홀드 와이어링
		local trackEnt2 = _EntityService:GetEntityByPath("/ui/DefaultGroup/InvenWindow/InvenScrollTrack")
		if isvalid(trackEnt2) then
			if not isvalid(trackEnt2:GetComponent("MOD.Core.UITouchReceiveComponent")) then
				trackEnt2:AddComponent("MOD.Core.UITouchReceiveComponent")
			end
			trackEnt2:ConnectEvent(UITouchDownEvent, self.OnScrollTrackDown)
		end
		-- 마우스 휠 스크롤 와이어링
		self._T.scrollHandler = _InputService:ConnectEvent(MouseScrollEvent, self.OnMouseScroll)
		log("[EquipInven] 스크롤 드래그/홀드/휠 와이어링 완료")

		-- 장비 슬롯 UITouchUpEvent (주문서 드랍 감지)
		local eUpHandlers = {
			self.OnEquipSlotUp1, self.OnEquipSlotUp2, self.OnEquipSlotUp3,
			self.OnEquipSlotUp4, self.OnEquipSlotUp5, self.OnEquipSlotUp6
		}
		for i, sn in ipairs(eNames) do
			local slot = _EntityService:GetEntityByPath(eBase .. sn)
			if isvalid(slot) then
				slot:ConnectEvent(UITouchUpEvent, eUpHandlers[i])
			end
		end
		local capSlotUp = _EntityService:GetEntityByPath(eBase .. "SlotCap")
		if isvalid(capSlotUp) then
			capSlotUp:ConnectEvent(UITouchUpEvent, self.OnEquipSlotUp7)
		end
		-- 인벤 슬롯 UITouchUpEvent (드랍 감지, 128 슬롯, slot+SlotBG+Icon+Touch 모두에 연결)
		for i = 1, 128 do
			local capturedUp = i
			local iSlotUp = _EntityService:GetEntityByPath(iBase .. i)
			if isvalid(iSlotUp) then
				local function upHandler(e)
				end
				iSlotUp:ConnectEvent(UITouchUpEvent, upHandler)
				local slotBGUp = _EntityService:GetEntityByPath(iBase .. capturedUp .. "/SlotBG")
				if isvalid(slotBGUp) then slotBGUp:ConnectEvent(UITouchUpEvent, upHandler) end
				local iconUp = _EntityService:GetEntityByPath(iBase .. capturedUp .. "/Icon")
				if isvalid(iconUp) then iconUp:ConnectEvent(UITouchUpEvent, upHandler) end
				local iUpTouch = _EntityService:GetEntityByPath(iBase .. capturedUp .. "/Touch")
				if isvalid(iUpTouch) then iUpTouch:ConnectEvent(UITouchUpEvent, upHandler) end
			end
		end
		_InputService:ConnectEvent(ScreenTouchReleaseEvent, self.OnScreenRelease)
		_InputService:ConnectEvent(ScreenTouchEvent, self.OnCharInfoTitleTouch)
		local initGhost = _EntityService:GetEntityByPath("/ui/DefaultGroup/DragGhost")
		if isvalid(initGhost) then initGhost.Enable = false end
		log("[EquipInven] drag-drop wired")

		-- 박스 타입 선택 팝업 버튼 와이어링
		local typePopupBase = "/ui/DefaultGroup/ItemTypeSelectPopup/Dialog/"
		local typeSlotMap = {7, 0, 3, 0, 4, 5, 6, 0, 0, 0, 0, 1, 2, 0}
		for bi = 0, 13 do
			local capturedTypeSlot = typeSlotMap[bi + 1]
			local typeBtnEnt = _EntityService:GetEntityByPath(typePopupBase .. "TypeBtn_" .. tostring(bi))
			if isvalid(typeBtnEnt) then
				local capturedSelf = self
				typeBtnEnt:ConnectEvent(ButtonClickEvent, function(e)
					capturedSelf:OnBoxTypeSelect(capturedTypeSlot)
				end)
			end
		end
		local typeCloseBtnEnt = _EntityService:GetEntityByPath(typePopupBase .. "CloseBtn")
		if isvalid(typeCloseBtnEnt) then
			typeCloseBtnEnt:ConnectEvent(ButtonClickEvent, function(e)
				self:HideBoxTypeSelectPopup()
			end)
		end
		-- 박스 수량 팝업 버튼 와이어링
		local qtyPopupBase = "/ui/DefaultGroup/BoxQuantityPopup/Dialog/"
		local confirmBtnEnt = _EntityService:GetEntityByPath(qtyPopupBase .. "ConfirmBtn")
		if isvalid(confirmBtnEnt) then
			confirmBtnEnt:ConnectEvent(ButtonClickEvent, function(e)
				self:OnBoxQuantityConfirm()
			end)
		end
		local cancelBtnEnt = _EntityService:GetEntityByPath(qtyPopupBase .. "CancelBtn")
		if isvalid(cancelBtnEnt) then
			cancelBtnEnt:ConnectEvent(ButtonClickEvent, function(e)
				self:OnBoxQuantityCancel()
			end)
		end
		local qtyCloseBtnEnt = _EntityService:GetEntityByPath(qtyPopupBase .. "CloseBtn")
		if isvalid(qtyCloseBtnEnt) then
			qtyCloseBtnEnt:ConnectEvent(ButtonClickEvent, function(e)
				self:OnBoxQuantityCancel()
			end)
		end
		log("[EquipInven] 박스 팝업 버튼 와이어링 완료")

		-- 강화 드롭존 hover 감지 + 클릭 드롭
		local dropZone = _EntityService:GetEntityByPath("/ui/DefaultGroup/EnhanceWindow/RightPanel/SlotArea/TargetSlotBG/DropZone")
		if isvalid(dropZone) then
			dropZone:ConnectEvent(UITouchEnterEvent, self.OnEnhanceDropEnter)
			dropZone:ConnectEvent(UITouchExitEvent, self.OnEnhanceDropExit)
			dropZone:ConnectEvent(UITouchDownEvent, self.OnEnhanceDropTouch)
			log("[EquipInven] 강화 드롭존 wired")
		end

		-- 창 타이틀바 드래그 와이어링
		local titlePaths = {
			"/ui/DefaultGroup/InvenWindow/TitleText",
			"/ui/DefaultGroup/EquipWindow/TitleText",
			"/ui/DefaultGroup/EnhanceWindow/TitleText",
			"/ui/DefaultGroup/CharInfoWindow/TitleText/DragHandle"
		}
		local titleHandlers = {
			self.OnInvenTitleDown,
			self.OnEquipTitleDown,
			self.OnEnhanceTitleDown,
			self.OnCharInfoTitleDown
		}
		for i, tp in ipairs(titlePaths) do
			local te = _EntityService:GetEntityByPath(tp)
			if isvalid(te) then
				if not isvalid(te:GetComponent("MOD.Core.UITouchReceiveComponent")) then
					te:AddComponent("MOD.Core.UITouchReceiveComponent")
				end
				te:ConnectEvent(UITouchDownEvent, titleHandlers[i])
				-- 자식 엔티티도 와이어링 (자식이 터치를 흡수하는 경우 대비)
				local children = te.Children:ToTable()
				for _, child in ipairs(children) do
					if not isvalid(child:GetComponent("MOD.Core.UITouchReceiveComponent")) then
						child:AddComponent("MOD.Core.UITouchReceiveComponent")
					end
					child:ConnectEvent(UITouchDownEvent, titleHandlers[i])
				end
				log("[WinDrag] 타이틀 와이어링: " .. tp)
			end
		end
		-- 매 Play 시작 시 UI를 올바른 초기 상태로 리셋
		-- Maker Play 모드에서 DefaultGroup이 항상 false로 시작하므로 먼저 활성화
		local function setEnable(path, val)
			local e = _EntityService:GetEntityByPath(path)
			if isvalid(e) then e.Enable = val end
		end
		setEnable("/ui/DefaultGroup",                      true)   -- 부모 먼저!
		setEnable("/ui/DefaultGroup/LoginGroup",          true)
		setEnable("/ui/DefaultGroup/CharacterSelectGroup", false)
		setEnable("/ui/DefaultGroup/CreateCharacter",      false)
		setEnable("/ui/DefaultGroup/InvenWindow",          false)
		setEnable("/ui/DefaultGroup/EquipWindow",          false)
		setEnable("/ui/DefaultGroup/EnhanceWindow",        false)
		setEnable("/ui/DefaultGroup/CharInfoWindow",       false)
		setEnable("/ui/DefaultGroup/ItemTypeSelectPopup", false)
		setEnable("/ui/DefaultGroup/BoxQuantityPopup",    false)
		-- Enable 애니메이션이 자식 위치를 오염시키므로 완료 후 복원
		wait(0.5)
		local function setPos(path, x, y)
			local e = _EntityService:GetEntityByPath(path)
			if isvalid(e) then
				e.UITransformComponent.anchoredPosition = Vector2(x, y)
			end
		end
		local lgBase = "/ui/DefaultGroup/LoginGroup/LoginBackground/"
		setPos(lgBase .. "TitleText",    0,   250)
		setPos(lgBase .. "AccountText",  0,  -200)
		setPos(lgBase .. "PasswordText", 0,  -300)
		setPos(lgBase .. "StartButton",  300, -250)
		log("[EquipInven] UI 초기 상태 리셋 완료 - 로그인 화면 표시")
		log("[EquipInven] ready")
	end

	@ExecSpace("ClientOnly")
	method void OnKeyDown(KeyDownEvent event)
		if event.key == KeyboardKey.E then
			self:ToggleWin("/ui/DefaultGroup/EquipWindow")
		elseif event.key == KeyboardKey.I then
			self:ToggleWin("/ui/DefaultGroup/InvenWindow")
		elseif event.key == KeyboardKey.C then
			self:ToggleWin("/ui/DefaultGroup/CharInfoWindow")
		elseif event.key == KeyboardKey.Tab then
			local invenWin = _EntityService:GetEntityByPath("/ui/DefaultGroup/InvenWindow")
			if isvalid(invenWin) and invenWin.Enable and invenWin.Visible then
				local tabOrder = {"equip","consume","etc","install","cash","decorate"}
				local current = self._T.activeTab
				local nextIdx = 1
				for i, tk in ipairs(tabOrder) do
					if tk == current then
						nextIdx = (i % #tabOrder) + 1
						break
					end
				end
				self:OnTabSwitch(tabOrder[nextIdx])
			end
		elseif event.key == KeyboardKey.Escape then
			self:CloseTopWindow()
		end
	end

	@ExecSpace("ClientOnly")
	method void ToggleWin(string path)
		local dg = _EntityService:GetEntityByPath("/ui/DefaultGroup")
		if isvalid(dg) and not dg.Enable then dg.Enable = true end

		local w = _EntityService:GetEntityByPath(path)
		if not isvalid(w) then return end

		local enable = not w.Enable
		if enable then
			self:PushWin(path)
			self:BringWindowToFront(path)
			local cur = w.UITransformComponent.anchoredPosition
			if math.abs(cur.x) > 1000 or math.abs(cur.y) > 1000 then
				w.UITransformComponent.anchoredPosition = self:GetWindowDefaultPos(path)
			end
			-- 위치를 먼저 설정한 뒤 창을 표시 (구 위치에서 점프하는 현상 방지)
			self:ResetWindowChildren(path)
			w.Enable = true
			if path == "/ui/DefaultGroup/CharInfoWindow" then
				_CharInfoManager:RefreshCharInfo()
			end
		else
			w.Enable = false
			self:RemoveWin(path)
			-- 창이 닫힐 때 해당 창 소속 툴팁이 열려있으면 같이 닫기
			if path == "/ui/DefaultGroup/EquipWindow" and self.tooltipSource == "equip" then
				self:HideTooltip()
			elseif path == "/ui/DefaultGroup/InvenWindow" and self.tooltipSource == "inven" then
				self:HideTooltip()
			end
		end
	end

	@ExecSpace("ClientOnly")
	method void ResetWindowChildren(string path)
		local function sp(p, x, y)
			local e = _EntityService:GetEntityByPath(p)
			if isvalid(e) then e.UITransformComponent.anchoredPosition = Vector2(x, y) end
		end
		if path == "/ui/DefaultGroup/EquipWindow" then
			local b = path .. "/"
			sp(b .. "BG",            0,    0)
			sp(b .. "TitleText",     0,  -30)
			sp(b .. "TitleText/TitleBG", 0, 0)
			sp(b .. "TitleText/Label",   0, 0)
			sp(b .. "CloseEquip",  -10,  -10)
			sp(b .. "Divider",       0,  -58)
			sp(b .. "HintText",      0,  -85)
			sp(b .. "SlotCap",       0,  120)
			sp(b .. "SlotFace",    -95,   10)
			sp(b .. "SlotHair",     95,   10)
			sp(b .. "SlotTop",     -95, -100)
			sp(b .. "SlotBottom",   95, -100)
			sp(b .. "SlotShoes",   -95, -210)
			sp(b .. "SlotWeapon",   95, -210)
			local slots = {"SlotFace","SlotHair","SlotTop","SlotBottom","SlotShoes","SlotWeapon","SlotCap"}
			for _, sn in ipairs(slots) do
				sp(b .. sn .. "/SlotBG",    0,   0)
				sp(b .. sn .. "/Icon",      0,  -8)
				sp(b .. sn .. "/ItemName",  0, -32)
				sp(b .. sn .. "/Label",     0,  -8)
				sp(b .. sn .. "/StarLabel", 0,  46)
				sp(b .. sn .. "/Touch",     0,   0)
			end
		elseif path == "/ui/DefaultGroup/InvenWindow" then
			local b = path .. "/"
			local function sr(p, w, h)
				local e = _EntityService:GetEntityByPath(p)
				if isvalid(e) then e.UITransformComponent.RectSize = Vector2(w, h) end
			end
			local winEnt = _EntityService:GetEntityByPath(path)
			local tabKeys2 = {"equip","consume","etc","install","cash","decorate"}
			local tabX = {-350, -210, -70, 70, 210, 350}
			if self._T.minimized then
				-- 최소화 모드: 455×760, 4×8=32슬롯 가시, 스크롤 있음 (탭 70% 축소)
				local minW = 455
				local minTabW = 62
				local minTabX = {-155, -93, -31, 31, 93, 155}
				if isvalid(winEnt) then winEnt.UITransformComponent.RectSize = Vector2(minW, 760) end
				sr(b .. "BG", minW, 760)
				sr(b .. "TitleText", minW, 50)
				sr(b .. "TitleText/TitleBG", minW, 50)
				sr(b .. "MesoBar", minW - 20, 50)
				sp(b .. "BG",                    0,    0)
				sp(b .. "TitleText",             0,  355)
				sp(b .. "TitleText/TitleBG",     0,    0)
				sp(b .. "TitleText/Label",     -60,    0)
				sp(b .. "CloseInven",          207,  355)
				sp(b .. "InvenMinBtn",         165,  355)
				sp(b .. "Divider",            3000, 3000)
				sp(b .. "HintText",           3000, 3000)
				sp(b .. "MesoBar",             -20, -350)
				for i, tk in ipairs(tabKeys2) do
					sp(b .. "InvenTab_" .. tk, minTabX[i], 228)
					sr(b .. "InvenTab_" .. tk, minTabW, 36)
					sr(b .. "InvenTab_" .. tk .. "/TabBG", minTabW, 36)
				end
				sp(b .. "InvenSlotCount", 190, 333)
				sp(b .. "InvenScrollTrack", 209,  -75)
				sr(b .. "InvenScrollTrack",  16,  500)
				sp(b .. "InvenScrollUp",    209,  194)
				sp(b .. "InvenScrollDown",  209, -342)
				sp(b .. "InvenScrollThumb", 209,  158)
				local colX = {-111, -37, 37, 111}
				local rowY = {176, 106, 36, -34, -104, -174, -244, -314}
				for i = 1, 32 do
					local col = ((i - 1) % 4) + 1
					local row = math.floor((i - 1) / 4) + 1
					sp(b .. "InvenSlot" .. i, colX[col], rowY[row])
				end
				for i = 33, 128 do
					sp(b .. "InvenSlot" .. i, 3000, 3000)
				end
			else
				-- 확장 모드: 1200×760, 16×8=128슬롯 전체 가시, 스크롤 없음
				if isvalid(winEnt) then winEnt.UITransformComponent.RectSize = Vector2(1200, 760) end
				sr(b .. "BG", 1200, 760)
				sr(b .. "TitleText", 1200, 50)
				sr(b .. "TitleText/TitleBG", 1200, 50)
				sr(b .. "MesoBar", 1180, 50)
				sp(b .. "BG",                    0,    0)
				sp(b .. "TitleText",             0,  355)
				sp(b .. "TitleText/TitleBG",     0,    0)
				sp(b .. "TitleText/Label",     -60,    0)
				sp(b .. "CloseInven",          580,  355)
				sp(b .. "InvenMinBtn",         538,  355)
				sp(b .. "Divider",            3000, 3000)
				sp(b .. "HintText",           3000, 3000)
				sp(b .. "MesoBar",             -20, -350)
				for i, tk in ipairs(tabKeys2) do
					sp(b .. "InvenTab_" .. tk, tabX[i], 250)
					sr(b .. "InvenTab_" .. tk, 132, 36)
					sr(b .. "InvenTab_" .. tk .. "/TabBG", 132, 36)
					sr(b .. "InvenTab_" .. tk .. "/TabActiveBG", 132, 36)
				end
				sp(b .. "InvenSlotCount", 555, 303)
				sp(b .. "InvenScrollTrack", 3000, 3000)
				sp(b .. "InvenScrollUp",    3000, 3000)
				sp(b .. "InvenScrollDown",  3000, 3000)
				sp(b .. "InvenScrollThumb", 3000, 3000)
				local colX = {-525,-455,-385,-315,-245,-175,-105,-35,35,105,175,245,315,385,455,525}
				local rowY = {176, 106, 36, -34, -104, -174, -244, -314}
				for i = 1, 128 do
					local col = ((i - 1) % 16) + 1
					local row = math.floor((i - 1) / 16) + 1
					sp(b .. "InvenSlot" .. i, colX[col], rowY[row])
				end
			end
			-- 뷰포트 콘텐츠 갱신
			self:UpdateInvenViewport()
			self:UpdateTabColors()
		end
	end

