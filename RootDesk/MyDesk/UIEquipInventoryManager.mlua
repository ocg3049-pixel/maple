	end

	@ExecSpace("ClientOnly")
	method void OnSlotClick(string winType, number slotIdx)
		local t = _UtilLogic.ElapsedSeconds
		if winType == "equip" then
			if self.lastEquipSlot == slotIdx and t - self.lastEquipTime < 0.5 then
				if _EnhancementManager:IsWindowOpen() then
					_EnhancementManager:ClearTarget()
				else
					self:MoveEquipToInven(slotIdx)
				end
				self.lastEquipSlot = 0
			else
				self.lastEquipSlot = slotIdx
				self.lastEquipTime = t
			end
		else
			-- 치장 탭: 더블클릭 → 치장 슬롯에 장착 (다른 아이템 분기보다 먼저 가로챈다)
			if self._T.activeTab == "decorate" then
				if self.lastInvenSlot == slotIdx and t - self.lastInvenTime < 0.5 then
					_DecoWindowManager:EquipDecoFromInven(slotIdx)
					self.lastInvenSlot = 0
				else
					self.lastInvenSlot = slotIdx
					self.lastInvenTime = t
				end
				return
			end
			local dragS = self:GetInven(slotIdx)
			local dragSI = dragS ~= "" and self:ParseSlotIdx(dragS) or -1
			local dragName = dragS ~= "" and self:ParseName(dragS) or ""
			if dragSI == 0 and string.find(dragName, "포션") then
				-- 포션: 더블클릭이면 사용, 단일 클릭이면 드래그 시작
				if self.lastInvenSlot == slotIdx and t - self.lastInvenTime < 0.5 then
					-- 더블클릭 → 포션 즉시 사용
					self:CancelPotionDrag()
					_PotionShopManager:RequestUsePotion()
					self:SetInvenStr(slotIdx, "")
					self:RefreshUI()
					self.lastInvenSlot = 0
				else
					-- 단일 클릭 → SkillBar로 드래그 가능
					self.lastInvenSlot = slotIdx
					self.lastInvenTime = t
					self:StartPotionDrag(slotIdx)
				end
				return
			end
			-- 드롭 아이템(slotIdx==0, name="드롭 아이템"): 더블클릭 → 박스 사용 팝업
			if dragSI == 0 and dragName == "드롭 아이템" then
				if self.lastInvenSlot == slotIdx and t - self.lastInvenTime < 0.5 then
					self:ShowBoxTypeSelectPopup(slotIdx)
					self.lastInvenSlot = 0
				else
					self.lastInvenSlot = slotIdx
					self.lastInvenTime = t
					self:StartInvenDrag(slotIdx)
				end
				return
			end
			-- 큐브: 더블클릭 → 강화창 열기 (잠재능력 탭 또는 에디셔널 탭)
			if dragSI == 0 then
				local dragRUID2 = dragS ~= "" and self:ParseInvenRUID(dragS) or ""
				local isPotCube = (dragRUID2 == "b2300eda46f3445e9b1c6e774a2ee95a" or dragRUID2 == "b8f0af90c30b462f859f45bdc1878d8b")
				local isAddCube = (dragRUID2 == "af5404f4c8fc4ec78ccc1a57446f69db" or dragRUID2 == "9c2a12b9a92f44d4b6dd95c7fb182ac9")
				if isPotCube or isAddCube then
					if self.lastInvenSlot == slotIdx and t - self.lastInvenTime < 0.5 then
						self:CancelInvenDrag()
						local tabIdx = isPotCube and 4 or 5
						_EnhancementManager:OpenWindowWithTab(tabIdx)
						self.lastInvenSlot = 0
					else
						self.lastInvenSlot = slotIdx
						self.lastInvenTime = t
						self:StartInvenDrag(slotIdx)
					end
					return
				end
			end
			-- 공격 속도의 비약: 더블클릭 → 사용(공격속도 1단계 증가 + 스택 1개 소모), 단일클릭 → 인벤 내 이동 드래그
			if dragSI == 0 and dragName == "공격 속도의 비약" then
				if self.lastInvenSlot == slotIdx and t - self.lastInvenTime < 0.5 then
					_CharInfoManager:IncreaseAttackSpeedStage()
					self:ConsumeScrollFromSlot(slotIdx)
					self:RefreshUI()
					self.lastInvenSlot = 0
				else
					self.lastInvenSlot = slotIdx
					self.lastInvenTime = t
					self:StartInvenDrag(slotIdx)
				end
				return
			end
			-- 공격력 물약: 더블클릭 → 사용(공격력 +500, 스택 1개 소모), 단일클릭 → 인벤 내 이동 드래그
			if dragSI == 0 and dragName == "공격력 물약" then
				if self.lastInvenSlot == slotIdx and t - self.lastInvenTime < 0.5 then
					_CharInfoManager:UseAttackPotion()
					self:ConsumeScrollFromSlot(slotIdx)
					self:RefreshUI()
					self.lastInvenSlot = 0
				else
					self.lastInvenSlot = slotIdx
					self.lastInvenTime = t
					self:StartInvenDrag(slotIdx)
				end
				return
			end
			-- 레벨 70 물약: 더블클릭 → 사용(스택 1개 소모), 단일클릭 → 인벤 내 이동 드래그
			-- (별도 분기가 없어 아래 주문서 fallback으로 빠져 장비 탭으로 강제 이동되던 문제 수정)
			if dragSI == 0 and dragName == "레벨 70 물약" then
				if self.lastInvenSlot == slotIdx and t - self.lastInvenTime < 0.5 then
					_CharInfoManager:UseLevel70Potion()
					self:ConsumeScrollFromSlot(slotIdx)
					self:RefreshUI()
					self.lastInvenSlot = 0
				else
					self.lastInvenSlot = slotIdx
					self.lastInvenTime = t
					self:StartInvenDrag(slotIdx)
				end
				return
			end
			-- 주문서(slotIdx==0) → 단일 클릭으로 고스트 시작, 장비 탭으로 이동
			if dragSI == 0 then
				self:StartDrag(slotIdx)
				self:StartInvenDrag(slotIdx)
				self:OnTabSwitch("equip")
				return
			end
			if self.lastInvenSlot == slotIdx and t - self.lastInvenTime < 0.5 then
				-- 더블클릭: 드래그 취소 후 즉시 대상 설정
				if self._T.isDraggingEquipToEnhance then self:CancelEquipDrag() end
				local s = self:GetInven(slotIdx)
				if _EnhancementManager:IsWindowOpen() then
					if s ~= "" then
						local name = self:ParseName(s)
						local ruid = self:ParseInvenRUID(s)
						_EnhancementManager:SetEnhanceTarget(name, ruid, slotIdx)
					end
				else
					self:MoveInvenToEquip(slotIdx)
				end
				self.lastInvenSlot = 0
			else
				self.lastInvenSlot = slotIdx
				self.lastInvenTime = t
				-- 단일 클릭: 강화창 열려있으면 드래그 시작
				if _EnhancementManager:IsWindowOpen() and not self._T.isDraggingInvenItem then
					local s = self:GetInven(slotIdx)
					if s ~= "" then self:StartEquipDrag(slotIdx) end
				end
				-- 인벤 슬롯 이동 드래그 (장비 아이템)
				local sInven = self:GetInven(slotIdx)
				if sInven ~= "" then self:StartInvenDrag(slotIdx) end
			end
		end
	end

	-- 장비 슬롯 string get/set helpers
	@ExecSpace("ClientOnly")
	method string GetEquip(number i)
		if i == 1 then return self.equip1
		elseif i == 2 then return self.equip2
		elseif i == 3 then return self.equip3
		elseif i == 4 then return self.equip4
		elseif i == 5 then return self.equip5
		elseif i == 6 then return self.equip6
		elseif i == 7 then return self.equip7
		end
		return ""
	end

	@ExecSpace("ClientOnly")
	method void SetEquipStr(number i, string v)
		if i == 1 then self.equip1 = v
		elseif i == 2 then self.equip2 = v
		elseif i == 3 then self.equip3 = v
		elseif i == 4 then self.equip4 = v
		elseif i == 5 then self.equip5 = v
		elseif i == 6 then self.equip6 = v
		elseif i == 7 then self.equip7 = v
		end
	end

	-- 특정 탭의 슬롯 get/set (activeTab과 무관 — DecoWindowManager 등 외부 관리자 전용)
	@ExecSpace("ClientOnly")
	method string GetTabItem(string tab, number i)
		local td = self._T.tabData[tab]
		if td == nil then return "" end
		return td[i] or ""
	end

	@ExecSpace("ClientOnly")
	method void SetTabItem(string tab, number i, string v)
		local td = self._T.tabData[tab]
		if td == nil then return end
		td[i] = v
	end

	-- 인벤 슬롯 string get/set helpers (탭별 128슬롯 테이블 기반)
	@ExecSpace("ClientOnly")
	method string GetInven(number i)
		return self._T.tabData[self._T.activeTab][i] or ""
	end

	@ExecSpace("ClientOnly")
	method void SetInvenStr(number i, string v)
		self._T.tabData[self._T.activeTab][i] = v
	end

	-- 화면상 슬롯 번호(v, 좌상단부터 1..128 또는 1..32) → 실제 데이터 인덱스 변환.
	-- 축소모드(4열)는 기존 그대로(스크롤 오프셋만 더함). 확장모드(16열)는 4열씩 묶은
	-- "쿼드런트" 단위로 그룹핑하여, 각 쿼드런트가 축소모드에서 한 화면(4×8=32칸)에
	-- 보이는 것과 동일한 아이템 묶음이 되도록 배치한다.
	@ExecSpace("ClientOnly")
	method number VisualToDataIdx(number v)
		if self._T.minimized then
			return self._T.scrollRow * 4 + v
		end
		local col = (v - 1) % 16
		local row = math.floor((v - 1) / 16)
		local quadrant = math.floor(col / 4)
		local colInQuadrant = col % 4
		return quadrant * 32 + row * 4 + colInQuadrant + 1
	end

	-- 강화 단계 파싱: "+N" 접미사 → 정수
	@ExecSpace("ClientOnly")
	method number ParseEnhanceLevel(string name)
		local s = string.match(name, "%+(%d+)$")
		return tonumber(s) or 0
	end

	-- 강화 단계만큼 ★ 문자열 반환
	@ExecSpace("ClientOnly")
	method string GetStarText(number level)
		if level <= 0 then return "" end
		local stars = ""
		for i = 1, level do
			stars = stars .. "★"
		end
		return stars
	end

	-- 장비 슬롯 파싱: "이름|RUID"
	@ExecSpace("ClientOnly")
	method string ParseName(string s)
		return string.match(s, "([^|]+)") or s
	end

	@ExecSpace("ClientOnly")
	method string ParseRUID(string s)
		return string.match(s, "[^|]+|([^|]+)") or ""
	end

	-- 인벤 슬롯 파싱: "이름|RUID|slotIdx"
	@ExecSpace("ClientOnly")
	method string ParseInvenRUID(string s)
		return string.match(s, "[^|]+|([^|]+)") or ""
	end

	@ExecSpace("ClientOnly")
	method number ParseSlotIdx(string s)
		local v = string.match(s, "[^|]+|[^|]+|([^|]+)")
		return tonumber(v) or 0
	end

	-- 6필드 파서: "baseName|RUID|slotIdx|stars|scrolls|upgrade"
	@ExecSpace("ClientOnly")
	method number ParseStars(string s)
		local v = string.match(s, "[^|]+|[^|]+|[^|]+|([^|]+)")
		return tonumber(v) or 0
	end

	@ExecSpace("ClientOnly")
	method number ParseScrolls(string s)
		local v = string.match(s, "[^|]+|[^|]+|[^|]+|[^|]+|([^|]+)")
		return tonumber(v) or 0
	end

	@ExecSpace("ClientOnly")
	method number ParseUpgrade(string s)
		local v = string.match(s, "[^|]+|[^|]+|[^|]+|[^|]+|[^|]+|([^|]+)")
		return tonumber(v) or 0
	end

	@ExecSpace("ClientOnly")
	method number ParseCount(string s)
		-- 7번째 필드: 아이템 수량 (없으면 기본값 1)
		local v = string.match(s, "[^|]+|[^|]+|[^|]+|[^|]+|[^|]+|[^|]+|([^|]+)")
		return tonumber(v) or 1
	end

	-- 슬롯당 최대 보유 수량 (RUID 기준)
	-- 7번째 필드: 장비 아이템의 잠재능력 부여 여부 (0=미부여, 1=부여됨)
	@ExecSpace("ClientOnly")
	method number ParseHasPotential(string s)
		local v = string.match(s, "[^|]+|[^|]+|[^|]+|[^|]+|[^|]+|[^|]+|([^|]+)")
		return tonumber(v) or 0
	end

	-- 8번째 필드: 장비 아이템의 에디셔널 잠재능력 부여 여부 (0=미부여, 1=부여됨)
	@ExecSpace("ClientOnly")
	method number ParseHasAdditionalPotential(string s)
		local v = string.match(s, "[^|]+|[^|]+|[^|]+|[^|]+|[^|]+|[^|]+|[^|]+|([^|]+)")
		return tonumber(v) or 0
	end

	-- n번째 파이프 구분 필드 반환 (1-indexed, 빈 필드는 ""로 반환)
	@ExecSpace("ClientOnly")
	method string GetField(string s, integer n)
		local count = 0
		local last = 1
		local slen = string.len(s)
		local i = 1
		while i <= slen do
			if string.sub(s, i, i) == "|" then
				count = count + 1
				if count == n then return string.sub(s, last, i - 1) end
				last = i + 1
			end
			i = i + 1
		end
		count = count + 1
		if count == n then return string.sub(s, last) end
		return ""
	end

	-- pool={{opt,weight},...} 에서 가중치 기반 랜덤 선택
	@ExecSpace("ClientOnly")
	method string RollOneOption(table pool)
		local total = 0
		for i = 1, #pool do total = total + pool[i][2] end
		local r = _UtilLogic:RandomDouble() * total
		local cum = 0
		for i = 1, #pool do
			cum = cum + pool[i][2]
			if r <= cum then return pool[i][1] end
		end
		return pool[#pool][1]
	end

	-- 슬롯 인덱스로 장비 분류 이름 반환
	@ExecSpace("ClientOnly")
	method string GetEquipTypeBySlot(number slotIdx)
		if slotIdx == 7 then return "모자" end
		if slotIdx == 3 then return "상의" end
		if slotIdx == 4 then return "하의" end
		if slotIdx == 5 then return "신발" end
		if slotIdx == 6 then return "무기" end
		return "모자"
	end

	-- 직업별 드롭박스(무기 타입) 지급 무기 테이블. jobIdx는 CharacterSettingComponent:GetJobItems() /
	-- UIMyInfoManager:GetJobStageNames()와 동일한 순서(1=히어로 ... 10=섀도어)를 그대로 사용한다.
	@ExecSpace("ClientOnly")
	method table GetJobWeaponTable()
		return {
			[1]  = {name = "목검",        ruid = "43ad7bfeb9184252b24e6d60f76c17e5"},  -- 히어로
			[2]  = {name = "카알대검",      ruid = "444f1da6365d4599a27bbfd207585856"},  -- 팔라딘 (요청으로 나무망치 → 카알대검 교체)
			[3]  = {name = "창",          ruid = "dcaddf14378045cdbc6f512fa1a29d39"},  -- 다크나이트
			[4]  = {name = "우드완드",      ruid = "061712eadf7d4357a6c306dfd5368860"},  -- 비숍
			[5]  = {name = "나무 스태프",   ruid = "7380b5e5754a4e338e65fa232a8a095b"},  -- 아크메이지(썬,콜)
			[6]  = {name = "나무 스태프",   ruid = "7380b5e5754a4e338e65fa232a8a095b"},  -- 아크메이지(불,독)
			[7]  = {name = "석궁",        ruid = "8601845b98014cec9b336041be103015"},  -- 신궁
			[8]  = {name = "합금활",       ruid = "33f389c9f73e45dc9c55a251b3cc2646"},  -- 보우마스터
			[9]  = {name = "가니어",       ruid = "985e44451afc4730a46eb206716e7ecf"},  -- 나이트로드
			[10] = {name = "후르츠 대거",   ruid = "1489702f013a4ba4a1ec080da4df17c3"},  -- 섀도어
		}
	end

	-- 스태프/완드 계열(마력 기반) 무기 이름인지 판정 - 기본옵션 텍스트(공격력 vs 마력) 분기에 사용
	@ExecSpace("ClientOnly")
	method boolean IsStaffOrWandWeapon(string name)
		if name == "나무 스태프" then return true end
		if name == "우드완드" then return true end
		return false
	end

	-- 실제 아바타 리소스 카테고리가 OneHandedWeapon인 직업별 무기 이름인지 판정
	-- (후르츠 대거/나무 스태프/우드완드는 리소스 상 onehandedweapon 이라 TwoHandedWeapon 슬롯에 SetEquip 시 [LEA-3005] 에러 발생 - msw-search getResource로 확인됨)
	@ExecSpace("ClientOnly")
	method boolean IsOneHandedJobWeapon(string name)
		if name == "후르츠 대거" then return true end
		if name == "나무 스태프" then return true end
		if name == "우드완드" then return true end
		-- 카알대검: 이름은 대검이지만 아바타 리소스 카테고리는 onehandedweapon(런타임 SetEquip 실측 -
		-- TwoHandedWeapon 슬롯에 넣으면 LEA-3005). 한손검이므로 모션 분류(onehand: swingO1~O3)와도 일치한다.
		if name == "카알대검" then return true end
		return false
	end

	-- 드롭박스에서 지급되는 직업별 무기 이름인지 판정 (기본옵션 부여 대상 판별용)
	@ExecSpace("ClientOnly")
	method boolean IsJobDropWeapon(string name)
		local t = self:GetJobWeaponTable()
		for i = 1, 10 do
			if t[i].name == name then return true end
		end
		return false
	end

	-- jobIdx로 드롭박스 지급 무기 (이름, RUID) 조회. 알 수 없는 jobIdx면 히어로(목검) 기본값
	@ExecSpace("ClientOnly")
	method string GetJobWeaponName(number jobIdx)
		local w = self:GetJobWeaponTable()[jobIdx]
		if w == nil then return "목검" end
		return w.name
	end

	@ExecSpace("ClientOnly")
	method string GetJobWeaponRUID(number jobIdx)
		local w = self:GetJobWeaponTable()[jobIdx]
		if w == nil then return "43ad7bfeb9184252b24e6d60f76c17e5" end
		return w.ruid
	end

