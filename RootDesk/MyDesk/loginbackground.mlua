@Component
script loginbackground extends Component

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		local accountText = _EntityService:GetEntityByPath("/ui/DefaultGroup/LoginGroup/LoginBackground/AccountText")
		if not isvalid(accountText) then return end
		local player = _UserService.LocalPlayer
		if player == nil then return end
		accountText.TextComponent.Text = player.Name
	end

end
