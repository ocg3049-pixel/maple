@Logic
script SkillManager extends Logic

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 창 드래그 상태
		self._T.isDragging    = false
		self._T.dragOffsetX   = 0
		self._T.dragOffsetY   = 0
		-- 툴팁 상태
		self._T.hovering      = false
		self._T.pendingShow   = false
		self._T.hoverTabId    = "0"
		self._T.hoverDataIdx  = 0
		self._T.hoverRowIdx   = 0
		-- 스킬 쿨다운
		self._T.skillOnCooldown = false
		-- 블리자드 전용 쿨다운(20초) - 공용 쿨다운과 별개로 관리하고 퀵슬롯에 남은 시간을 표시한다.
		self._T.blizzardOnCooldown = false
		-- 텔레포트 전용 쿨다운 - 다른 스킬들의 공용 쿨다운(skillOnCooldown)과 분리해서, 다른 스킬의
		-- 모션/딜레이 중에도 텔레포트를 쓸 수 있게 한다.
		self._T.teleportOnCooldown = false
		-- 어썰터 스택형 충전(3초당 1스택, 최대 3스택) - "쿨타임 동안 아예 못 쓰는" 방식에서 "스택이
		-- 1개 이상이면 언제든 쓸 수 있는" 충전형으로 변경 (요청사항). 시작은 풀스택(3개)이다.
		self._T.assaulterStacks = 3
		self._T.assaulterMaxStacks = 3
		self._T.assaulterRechargeTimerId = nil
		-- 시전 진행 중(사라짐~착지 사이) 재시전 잠금 - 착지 즉시(OnAssaulterChainReady) 풀려서
		-- 딜레이 없이 어썰터만은 연속 시전할 수 있다 (요청사항).
		self._T.assaulterCastActive = false
		self._T.assaulterCastGuardSerial = 0
		-- 스킬 키 홀드 상태 (키를 누르고 있는 동안 쿨다운이 끝나면 자동으로 이어서 발동)
		self._T.heldSkillKeys = {}

		-- 스킬 드래그 상태
		self._T.isDraggingSkill = false
		self._T.dragSkillRUID   = ""
		self._T.dragSkillName   = ""
		self._T.dragSource      = ""  -- "window" | "bar"
		self._T.dragFromKey     = ""

		-- 클릭 배정 모드 (클릭 후 슬롯 클릭으로 배정)
		self._T.skillClickMode = false
		self._T.clickModeRUID  = ""
		self._T.clickModeName  = ""
		self._T.clickModeOrigin = ""   -- "window"(스킬창) | "keysetting"(키세팅 키) | "spare"(여분 슬롯)

		-- 퀵슬롯 위치(엔티티 접미사, 고정) 목록. 각 위치는 barKeys를 통해 임의의 키에 연결된다.
		self._T.barPositions = {"Q","W","E","R","1","2","3","4","T","U","V","X","A","S","D","F","5","6","7","8","G","H","J","L"}
		-- 위치 → 연결된 키 이름 (기본값: 위치 접미사와 동일). 퀵슬롯 리매핑(키세팅 창)으로 변경 가능.
		self._T.barKeys = {}
		for _, p in ipairs(self._T.barPositions) do
			self._T.barKeys[p] = p
		end

		-- 슬롯 데이터: 키 이름 → {ruid, name}. 임의 키를 허용하므로 비어있는 키는 nil일 수 있다.
		self._T.slotData = {}
		local allKeys = self._T.barPositions

		-- 탭/스크롤 상태
		self._T.activeSkillTab        = "0"
		self._T.skillScrollRow        = 0
		self._T.isDraggingSkillThumb  = false
		self._T.skillThumbDragOffsetY = 0.0
		self._T.isHoldingSkillTrack   = false
		self._T.skillTrackTimer       = 0.0
		self._T.skillWheelAccum       = 0.0

		-- 스킬 데이터 (탭별) — 원작처럼 "기본(0)/I/II/III/IV/H/V/VI" 8개 탭 구성.
		-- 기본(0) 탭 = 달팽이 세마리, I~IV 탭 = 1~4차 스킬(기존 목록 복원), H/V/VI 탭은 아직 비어있음.
		self._T.skillData = {
			["0"] = {
				{ ruid = "0e3a7c540e494b41b34c853eadab0d7e", name = "달팽이 세마리", level = 1, desc = "달팽이 3마리를 소환한다.\n일정 시간 후 사라진다." },
			},
			["1"] = {
				{ ruid = "5c61ff8df1544c05a200e598ea9164ce", name = "파워스트라이크", level = 1, desc = "무기로 적을 강하게 내려친다." },
				{ ruid = "362ae7fa63104016a89c5172d6c76efd", name = "러시",           level = 1, desc = "방향키를 누른 채 사용하거나 방향키를 두 번 눌러 질주한다.\n질주 자세로 이동속도가 2배가 되며,\n방향키를 떼거나 공격하면 풀린다.\n(아이콘은 임시 - 교체 가능)" },
			{ ruid = "2ba15e204ac64214a8144b0b2deeaf79", name = "가드",           level = 1, desc = "1초간 공격을 받아넘길 자세를 취한다.\n그 사이 공격을 받으면 피해를 무시하고\n2초간 무적이 된다.\n재사용 대기시간 20초(가드 성공 시 5초).\n(아이콘은 임시 - 교체 가능)" },
				{ ruid = "42e8d60e495a41bc94d4b3ac7ec022dc", name = "슬래시블러스트", level = 1, desc = "검을 휘둘러 전방의 적들을 베어낸다." },
				{ ruid = "56144f55ece34e13b1aeeb6c102eb8b1", name = "더블샷",         level = 1, desc = "화살 두 발을 동시에 발사한다." },
				{ ruid = "4e76419dd50a4ca99103118dd05e4628", name = "매직클로",       level = 1, desc = "마법의 힘을 담은 손톱으로 적을 할퀸다." },
				{ ruid = "92a5020c978c46bdabab910598118b86", name = "더블스탭",       level = 1, desc = "단검으로 적을 두 번 빠르게 찌른다." },
				{ ruid = "46b22e703399431d9ab0987233cac868", name = "럭키세븐",       level = 1, desc = "동전을 던져 여러 적을 공격한다." },
			},
			["2"] = {
				{ ruid = "e453c21d3cdf4477a54045c8a25e22f4", name = "파이널어택",     level = 1, desc = "일반 공격 시 확률적으로 추가 공격이 발동한다." },
				{ ruid = "fa1ce25dd5fb4f1ea0999086d26b38ce", name = "텔레포트",       level = 1, desc = "짧은 거리를 순간이동한다." },
				{ ruid = "5360e76224b14134b8bd00ede1d34e63", name = "썬더볼트",       level = 1, desc = "번개를 떨어뜨려 적을 공격한다." },
				{ ruid = "48f6c72aa48647e1b97b99afbc46ea17", name = "파이어에로우",   level = 1, desc = "화염이 담긴 화살을 발사한다." },
				{ ruid = "44b70137422f425eb486eb7cc5a92aec", name = "힐",             level = 1, desc = "대상의 HP를 회복시킨다." },
				{ ruid = "5dc96ca0e6674dc1b301965cfed9f168", name = "에로우 봄",      level = 1, desc = "폭발하는 화살로 주변 적을 공격한다." },
				{ ruid = "0cfe777a9cd04df9bbb22a18a598e9b7", name = "아이언 에로우",  level = 1, desc = "강한 관통력을 가진 화살을 발사한다." },
				{ ruid = "e223bdc2a6cd46f98639e00b34083332", name = "헤이스트",       level = 1, desc = "5분간 이동 속도 40%, 점프력 20%를 증가시킨다." },
				{ ruid = "03b1da381bf046c68488fae4690e4f6f", name = "부스터",         level = 1, desc = "5분간 공격 속도가 1단계 상승한다." },
				-- 새비지블로우: MSW 기본 리소스에 없어 직접 구해와 업로드한 아이콘이다
				-- (원본/RUID 대응표: msw-dev-tools/resources/새비지블로우/RUID.md).
				{ ruid = "e4e5bf026b7c4976a1842de4418326ab", name = "새비지블로우",   level = 1, desc = "전방의 적 하나를 빠르게 6번 난도질한다.\n한 타당 전투력의 220%~300% 피해를 입힌다." },
			},
			["3"] = {
				{ ruid = "efb2d49b00ea433d80379fa679614920", name = "포이즌 미스트",     level = 1, desc = "독 안개를 뿌려 범위 내 적에게 지속 피해를 입힌다." },
				{ ruid = "ddbe74e1d9bb496dae8dc7ab111aa57b", name = "익스플로젼",         level = 1, desc = "강력한 폭발을 일으켜 넓은 범위의 적에게 피해를 입힌다." },
				{ ruid = "3f93e7fe6b244027ad09611ce4f60415", name = "드래곤 로어",         level = 1, desc = "포효로 전방의 적을 밀쳐내며 피해를 입힌다." },
				{ ruid = "948d8f877f1349a38ab7111df06fd9b5", name = "스피어 버스터",       level = 1, desc = "창으로 넓은 범위의 적을 강타한다." },
				{ ruid = "73d6c63787a64b2c8d34373792b7e716", name = "디바인 스윙 강화",   level = 1, desc = "디바인 스윙의 위력을 강화한다." },
				{ ruid = "28e3b85f945347fa8209ec18b4bb296c", name = "디바인 스티그마 강화", level = 1, desc = "디바인 스티그마의 효과를 강화한다." },
				{ ruid = "8dbb1b41e92c4f8290402b9a7d51649d", name = "디바인 저지먼트 강화", level = 1, desc = "디바인 저지먼트의 효과를 강화한다." },
				{ ruid = "d714c4d5a90a43a7b5a7bfb3b49c4628", name = "콤보 어택",           level = 1, desc = "콤보 카운트를 쌓아 공격력을 증가시킨다." },
				{ ruid = "540d17412269428899086a8e62ca5aee", name = "패닉",               level = 1, desc = "콤보 구슬을 모두 소모해 대상 하나에게 강력한 피해를 입힌다.\n구슬이 없으면 사용할 수 없다." },
				{ ruid = "6a4b4c93ebf14ea1ad480a836c741205", name = "코마",               level = 1, desc = "강한 일격으로 적을 기절시킨다." },
				{ ruid = "c6ce60523c954791af5632da796cca7c", name = "쉐도우 파트너",       level = 1, desc = "분신을 소환해 함께 공격한다." },
				{ ruid = "5dea29ad262d4940b5ef47eacc280e90", name = "플래쉬 점프",         level = 1, desc = "공중에서 한 번 더 도약한다." },
				{ ruid = "bf14a6c4355b4aa0b193cd77cf066215", name = "어벤져",             level = 1, desc = "여러 적을 동시에 베어 공격한다." },
				{ ruid = "07de3cf12cc44009940e7a6673d9ac5a", name = "어썰터",             level = 1, desc = "대상에게 빠르게 돌진하여 공격한다." },
				{ ruid = "856ea69c978c4717a00fa9918f56cb10", name = "스트레이프",         level = 1, desc = "화살을 연속으로 발사해 전방의 적을 공격한다." },
				{ ruid = "7d3db33ced4149f8853b1abc0734b384", name = "에로우 레인",         level = 1, desc = "하늘에서 화살비를 퍼붓는다." },
				{ ruid = "4884171024d84b759206cf1dd01b85fc", name = "파이어 샷",           level = 1, desc = "화염이 담긴 탄환을 발사한다." },
				{ ruid = "fbfbe956c35a4bb8a5bfd707010b63b2", name = "퍼펫",               level = 1, desc = "인형을 소환해 적의 시선을 끈다." },
				{ ruid = "06536fe0f8814a6ea4c4dd5bb6b7750a", name = "모탈 블로우",         level = 1, desc = "강한 일격으로 적에게 치명타를 입힌다." },
				{ ruid = "0638d6950da040f09dc0fb5bce4e6bed", name = "아이스 스트라이크",   level = 1, desc = "얼음의 힘으로 적을 강타한다." },
				{ ruid = "49bd6b2c5d22446c9f8079a50bcc67c0", name = "샤이닝 레이",         level = 1, desc = "빛의 광선으로 적을 관통 공격한다." },
			},
			["4"] = {
				{ ruid = "8fce886b020349699cab77be0dafe5d7", name = "부메랑 스탭",         level = 1, desc = "회전하며 전방의 적을 베어낸다." },
				{ ruid = "97850763fe7241cda059cc1833df70d8", name = "어드밴스드 콤보",     level = 1, desc = "콤보 카운트를 더 빠르게 쌓는다." },
				{ ruid = "f47040b994e44e4fb6152fa010f512a6", name = "브랜디쉬",           level = 1, desc = "검을 크게 휘둘러 넓은 범위의 적을 공격한다." },
				-- 돌진: 구버전 원본 아이콘/이펙트를 직접 구해와 업로드했다(MSW 라이브러리엔 현대 리메이크
				-- 아트만 있음). 원본/RUID 대응표: msw-dev-tools/resources/돌진/RUID.md
				{ ruid = "75c8dd4cdf774f4eaf64af0406fae864", name = "돌진",               level = 1, desc = "앞으로 돌진하며 전방의 적을 최대 10명까지\n밀어낸다. 전투력의 300%~400% 피해를 입힌다.\n앞에 적이 없으면 제자리에서 시전된다.\n재사용 대기시간 1초." },
				{ ruid = "7ff10839eb5046eebb9cffc8f8828cfc", name = "생츄어리",           level = 1, desc = "성역을 소환해 범위 내 적에게 지속 피해를 입힌다." },
				{ ruid = "2ba15e204ac64214a8144b0b2deeaf79", name = "디바인 차지",         level = 1, desc = "무기에 신성한 힘을 부여한다." },
				{ ruid = "8235043d40454f99ae5db36de0451780", name = "트리플 스로우",       level = 1, desc = "표창 세 개를 동시에 던진다." },
				{ ruid = "187b564cb8dc429f9c35bffeeca875c5", name = "제네시스",           level = 1, desc = "강력한 빛의 힘으로 넓은 범위의 적을 공격한다." },
				{ ruid = "bafb08f724464e0eaddbd9e81f3f54b4", name = "바하뮤트",           level = 1, desc = "용의 힘을 빌려 적을 공격한다." },
				{ ruid = "a1382da8fa7c417296cdff334f57acb1", name = "엔젤레이",           level = 1, desc = "천사의 빛으로 적을 관통 공격한다." },
				{ ruid = "b5178c975a694ec3a51106a448fd70dd", name = "빅뱅",               level = 1, desc = "강력한 폭발로 넓은 범위에 피해를 입힌다." },
				{ ruid = "f84bad609f3a47c29ed662abea683f2e", name = "체인라이트닝",       level = 1, desc = "번개가 여러 적에게 연쇄적으로 튄다." },
				{ ruid = "7aa2a3683ff84a3ca809542b835ef68d", name = "블리자드",           level = 1, desc = "주변 발판 위에 얼음 폭풍을 흩뿌린 뒤\n시전자 주위의 적에게 전투력의\n3500%~5000% 피해를 입힌다.\n재사용 대기시간 20초." },
				{ ruid = "80add5d3f2364d01b7c5c973c884324e", name = "이프리트",           level = 1, desc = "화염의 정령을 소환해 적을 공격한다." },
				{ ruid = "e6144550c6084709bba1de715d677879", name = "아이스 데몬",         level = 1, desc = "얼음 악마를 소환해 적을 얼린다." },
				{ ruid = "9f317ee0b97d44dba5f85fb352aee093", name = "메테오",             level = 1, desc = "유성을 떨어뜨려 범위 내 적에게 피해를 입힌다." },
				{ ruid = "bf34dcd7cd284e3bba1d5094fc758923", name = "엘퀴네스",           level = 1, desc = "소환수를 불러 함께 적을 공격한다." },
				{ ruid = "8d9d46dcaa164c46a0b1da47db016c43", name = "피어싱",             level = 1, desc = "화살이 적을 관통하며 피해를 입힌다." },
				{ ruid = "804c52c890234d69a6a937d7523bb9f8", name = "스나이핑",           level = 1, desc = "원거리에서 강력한 저격을 가한다." },
				{ ruid = "5a78b6fc281449d08794e132030e258d", name = "샤프 아이즈",         level = 1, desc = "파티원의 명중률과 크리티컬 확률을 높인다." },
				{ ruid = "2f7d59f5d91c41a18713732ab2003b04", name = "프리져",             level = 1, desc = "냉기로 적을 얼려 이동을 봉쇄한다." },
				{ ruid = "847b8e1305c1485c9ed3caffb3252e56", name = "폭풍의 시",           level = 1, desc = "시를 읊어 폭풍을 일으켜 적을 공격한다." },
				{ ruid = "fd051469cf104e0bb1597e6930619354", name = "피닉스",             level = 1, desc = "불사조를 소환해 적을 공격한다." },
			},
			["5"] = {},
			["6"] = {},
			["7"] = {},
		}

		-- 부스터 아이콘 최초 갱신(월드 시작 시점 - 아직 로그인 전이라 jobIdx는 기본값 1일 수 있음).
		-- 실제 캐릭터가 확정되는 시점(CharacterSlotButton:EnterLobby)에서 다시 한번 갱신된다.
		self:RefreshBoosterIcon()

		-- SkillBar 아이콘 전부 투명화
		self:InitBarIcons()

		-- 툴팁 기본 초기화
		local tipIcon = _EntityService:GetEntityByPath("/ui/DefaultGroup/SkillTooltipPanel/Icon")
		if isvalid(tipIcon) then
			tipIcon.SpriteGUIRendererComponent.Color = Color(1, 1, 1, 0)
		end
		local tipTitle = _EntityService:GetEntityByPath("/ui/DefaultGroup/SkillTooltipPanel/Title")
		if isvalid(tipTitle) then tipTitle.TextComponent.Text = "" end
		local tipInfo = _EntityService:GetEntityByPath("/ui/DefaultGroup/SkillTooltipPanel/Info")
		if isvalid(tipInfo) then tipInfo.TextComponent.Text = "" end

		-- 키 이벤트
		_InputService:ConnectEvent(KeyDownEvent, self.OnKeyDown)
		_InputService:ConnectEvent(KeyUpEvent, self.OnKeyUp)

		-- 마우스 휠 (스킬창 위에서만 동작)
		_InputService:ConnectEvent(MouseScrollEvent, self.OnSkillMouseScroll)

		-- 닫기 버튼
		local closeBtn = _EntityService:GetEntityByPath("/ui/DefaultGroup/SkillWindow/CloseSkill")
		if isvalid(closeBtn) then
			closeBtn:ConnectEvent(UITouchDownEvent, self.OnCloseClick)
		end

		-- 타이틀바 드래그
		local titleBar = _EntityService:GetEntityByPath("/ui/DefaultGroup/SkillWindow/TitleBar")
		if isvalid(titleBar) then
			titleBar:ConnectEvent(UITouchDownEvent, self.OnTitleBarDown)
		end

		-- 탭/스킬행 클릭: UITouchDownEvent가 미작동하여 ScreenTouchEvent로 대체
		_InputService:ConnectEvent(ScreenTouchEvent, self.OnSkillWindowTouch)

		-- 스킬 카드 호버 (2열×5행 = 10칸, UITouchEnterEvent/ExitEvent는 별도)
		for i = 1, 10 do
			local rowTouch = _EntityService:GetEntityByPath("/ui/DefaultGroup/SkillWindow/SkillCard" .. i .. "/Touch")
			local capturedRow = i
			if isvalid(rowTouch) then
				rowTouch:ConnectEvent(UITouchEnterEvent, function(e)
					self:OnSkillRowHoverEnter(capturedRow)
				end)
				rowTouch:ConnectEvent(UITouchExitEvent, function(e)
					self:OnSkillRowHoverExit(capturedRow)
				end)
			end
		end

		-- 스크롤 썸 드래그
		local thumbTouch = _EntityService:GetEntityByPath("/ui/DefaultGroup/SkillWindow/SkillScrollThumbTouch")
		if isvalid(thumbTouch) then
			thumbTouch:ConnectEvent(UITouchDownEvent, self.OnSkillThumbDown)
		end

		-- 스크롤 트랙 홀드
		local trackTouch = _EntityService:GetEntityByPath("/ui/DefaultGroup/SkillWindow/SkillScrollTrackTouch")
		if isvalid(trackTouch) then
			trackTouch:ConnectEvent(UITouchDownEvent, self.OnSkillTrackDown)
		end

		-- SkillBar 슬롯 클릭/드래그 (slotPos = 고정 위치 접미사, 실제 키는 barKeys로 조회)
		for _, k in ipairs(allKeys) do
			local slotTouch = _EntityService:GetEntityByPath("/ui/DefaultGroup/SkillBar/Slot_" .. k .. "/Touch")
			local slotPos = k
			if isvalid(slotTouch) then
				slotTouch:ConnectEvent(UITouchDownEvent, function(e)
					if e.TouchId == -1 then
						if _KeySettingManager:IsCarryingFunc() then
							-- 기능을 집은 상태로 퀵슬롯 클릭 → 그 슬롯에 연결된 키로 기능을 옮긴다
							_KeySettingManager:DropFuncOnKey(self:GetKeyForBarPos(slotPos))
						elseif _KeySettingManager:IsRemapMode() then
							-- 퀵슬롯 리매핑 모드: 이 슬롯에 연결할 키 입력을 대기시킨다
							_KeySettingManager:OnBarSlotPicked(slotPos)
						elseif self._T.skillClickMode then
							-- 클릭 배정 모드: 스킬창/키세팅에서 클릭 후 슬롯 클릭
							-- (기능 키에 연결된 슬롯이면 배정하지 않고 계속 들고 있는다)
							local barKey = self:GetKeyForBarPos(slotPos)
							if _KeySettingManager:GetFuncOnKey(barKey) == "" then
								self:AssignSkillToSlot(barKey, self._T.clickModeRUID, self._T.clickModeName)
								self:ClearSkillSelection()
							else
								log("[SkillManager] 기능 키 [" .. barKey .. "] 슬롯 — 스킬 배정 불가")
							end
						else
							self:OnBarSlotDragStart(slotPos)
						end
					end
				end)
			end
		end

		-- 초기 UI 상태 반영
		self:UpdateSkillTabVisuals()
		self:UpdateSkillViewport()

		log("[SkillManager] ready")
	end

	-- 부스터 아이콘: 직업(jobIdx, UIMyInfoManager:GetJobStageNames 순서와 동일)마다 다른 아이콘을 쓴다.
	-- 검사 계열(1,2)/다크나이트(3)/마법사 계열(4,5,6)/신궁(7)/보우마스터(8)/나이트로드(9)/섀도어(10).
	@ExecSpace("ClientOnly")
	method string GetBoosterIconForJob(number jobIdx)
		if jobIdx == 1 or jobIdx == 2 then
			return "03b1da381bf046c68488fae4690e4f6f" -- 히어로, 팔라딘
		elseif jobIdx == 3 then
			return "0f444ef9b22944668a3bab6657e65e3b" -- 다크나이트
		elseif jobIdx == 4 or jobIdx == 5 or jobIdx == 6 then
			return "834961020d134b2bbaecd972693733fa" -- 비숍, 아크메이지(썬,콜)/(불,독)
		elseif jobIdx == 7 then
			return "8930c94be5f34ba09ed5f0ef80229415" -- 신궁
		elseif jobIdx == 8 then
			return "360acfc5aab24a019e1b32a514bb305f" -- 보우마스터
		elseif jobIdx == 9 then
			return "649da9106aaf40dfae9994d80ccba844" -- 나이트로드
		elseif jobIdx == 10 then
			return "d62e015f212a495c8009ff93fcd6b334" -- 섀도어
		end
		return "03b1da381bf046c68488fae4690e4f6f" -- 알 수 없는 jobIdx 기본값(히어로)
	end

	-- skillData(all/2 탭)의 "부스터" 항목 ruid를 현재 캐릭터의 jobIdx에 맞는 아이콘으로 덮어쓴다.
	-- 최초 호출(OnBeginPlay)은 로그인 전이라 jobIdx가 기본값(1)일 수 있으므로, 실제 캐릭터가 확정되는
	-- CharacterSlotButton:EnterLobby에서도 다시 호출해 정확한 아이콘으로 갱신한다.
	@ExecSpace("ClientOnly")
	method void RefreshBoosterIcon()
		local boosterIcon = self:GetBoosterIconForJob(_UIMyInfoManager:GetSelectedCharacterJobIdx())
		for _, tab in pairs(self._T.skillData) do
			for _, s in ipairs(tab) do
				if s.name == "부스터" then s.ruid = boosterIcon end
			end
		end
		-- 이미 렌더링되어 있던 스킬창 행이 있다면(예: 로그인 화면 뒤에서 미리 그려진 경우) 곧바로
		-- 다시 그려서, 아이콘이 잠깐 다른 스킬의 아이콘으로 보였다가 바뀌는 현상을 없앤다.
		self:UpdateSkillViewport()
		-- 캐릭터 확정 시점(EnterLobby)에 직업이 정해지므로 책 제목(전직명)도 함께 갱신한다.
		self:UpdateSkillBookTitle()
	end

	-- ── 스킬 뷰포트 (5행) 갱신 ────────────────────────────────────────

	@ExecSpace("ClientOnly")
	method void UpdateSkillViewport()
		-- 원작 스타일 2열×5행 카드 그리드. 스크롤 1행 = 카드 2칸(한 줄).
		local tabSkills = self._T.skillData[self._T.activeSkillTab] or {}
		local totalCount = #tabSkills
		local totalRows = math.ceil(totalCount / 2)
		local maxScrollRow = math.max(0, totalRows - 5)

		if self._T.skillScrollRow > maxScrollRow then
			self._T.skillScrollRow = maxScrollRow
		end

		for i = 1, 10 do
			local dataIdx = self._T.skillScrollRow * 2 + i
			local skill = tabSkills[dataIdx]
			local base = "/ui/DefaultGroup/SkillWindow/SkillCard" .. i
			local iconEnt  = _EntityService:GetEntityByPath(base .. "/Icon")
			local iconBox  = _EntityService:GetEntityByPath(base .. "/IconBox")
			local pillEnt  = _EntityService:GetEntityByPath(base .. "/NamePill")
			local nameEnt  = _EntityService:GetEntityByPath(base .. "/Name")
			local levelEnt = _EntityService:GetEntityByPath(base .. "/Level")
			local leafEnt  = _EntityService:GetEntityByPath(base .. "/Leaf")
			if skill then
				if isvalid(iconEnt) then
					local spr = iconEnt.SpriteGUIRendererComponent
					spr.ImageRUID = skill.ruid
					spr.Color = Color(1, 1, 1, 1)
				end
				if isvalid(iconBox) then iconBox.SpriteGUIRendererComponent.Color = Color(0.957, 0.961, 0.969, 1) end
				if isvalid(pillEnt) then pillEnt.SpriteGUIRendererComponent.Color = Color(0.525, 0.553, 0.6, 0.95) end
				if isvalid(nameEnt)  then nameEnt.TextComponent.Text  = skill.name end
				if isvalid(levelEnt) then levelEnt.TextComponent.Text = "Lv." .. tostring(skill.level) end
				if isvalid(leafEnt)  then leafEnt.TextComponent.Text  = "" end
			else
				-- 빈 카드: 아이콘/캡슐 숨기고 단풍 문양 플레이스홀더만 표시 (원작 빈 슬롯 스타일)
				if isvalid(iconEnt)  then iconEnt.SpriteGUIRendererComponent.Color = Color(1, 1, 1, 0) end
				if isvalid(iconBox)  then iconBox.SpriteGUIRendererComponent.Color = Color(1, 1, 1, 0) end
				if isvalid(pillEnt)  then pillEnt.SpriteGUIRendererComponent.Color = Color(1, 1, 1, 0) end
				if isvalid(nameEnt)  then nameEnt.TextComponent.Text  = "" end
				if isvalid(levelEnt) then levelEnt.TextComponent.Text = "" end
				if isvalid(leafEnt)  then leafEnt.TextComponent.Text  = "✦" end
			end
		end

		-- 스크롤바 (트랙 + 썸) 가시성: 스크롤 불필요 시 전부 숨김
		local topLimit = 111
		local botLimit = -147
		local thumbEnt      = _EntityService:GetEntityByPath("/ui/DefaultGroup/SkillWindow/SkillScrollThumb")
		local trackEnt      = _EntityService:GetEntityByPath("/ui/DefaultGroup/SkillWindow/SkillScrollTrack")
		local thumbTouchEnt = _EntityService:GetEntityByPath("/ui/DefaultGroup/SkillWindow/SkillScrollThumbTouch")
		local trackTouchEnt = _EntityService:GetEntityByPath("/ui/DefaultGroup/SkillWindow/SkillScrollTrackTouch")
		if maxScrollRow <= 0 then
			if isvalid(thumbEnt)      then thumbEnt.Enable      = false end
			if isvalid(trackEnt)      then trackEnt.Enable      = false end
			if isvalid(thumbTouchEnt) then thumbTouchEnt.Enable = false end
			if isvalid(trackTouchEnt) then trackTouchEnt.Enable = false end
		else
			if isvalid(trackEnt)      then trackEnt.Enable      = true end
			if isvalid(thumbTouchEnt) then thumbTouchEnt.Enable = true end
			if isvalid(trackTouchEnt) then trackTouchEnt.Enable = true end
			if isvalid(thumbEnt) then
				thumbEnt.Enable = true
				local progress = self._T.skillScrollRow / maxScrollRow
				local thumbY = topLimit - progress * (topLimit - botLimit)
				thumbEnt.UITransformComponent.anchoredPosition = Vector2(268, thumbY)
			end
		end
	end

	-- ── 탭 전환 ───────────────────────────────────────────────────────

	@ExecSpace("ClientOnly")
	method void SwitchSkillTab(string tabId)
		self._T.activeSkillTab  = tabId
		self._T.skillScrollRow  = 0
		self._T.skillWheelAccum = 0.0
		self:ClearSkillSelection()
		self:UpdateSkillTabVisuals()
		self:UpdateSkillBookTitle()
		self:UpdateSkillViewport()
		log("[SkillManager] 탭: " .. tabId)
	end

	@ExecSpace("ClientOnly")
	method void UpdateSkillTabVisuals()
		local tabIds = {"0", "1", "2", "3", "4", "5", "6", "7"}
		for _, tid in ipairs(tabIds) do
			local bg  = _EntityService:GetEntityByPath("/ui/DefaultGroup/SkillWindow/Tab_" .. tid .. "_BG")
			local lbl = _EntityService:GetEntityByPath("/ui/DefaultGroup/SkillWindow/Tab_" .. tid .. "_Label")
			if isvalid(bg) then
				-- 원작 스타일: 활성 탭 = 하늘색, 비활성 = 짙은 슬레이트
				if tid == self._T.activeSkillTab then
					bg.SpriteGUIRendererComponent.Color = Color(0.20, 0.62, 0.83, 1.0)
				else
					bg.SpriteGUIRendererComponent.Color = Color(0.141, 0.165, 0.22, 0.9)
				end
			end
			if isvalid(lbl) then
				if tid == self._T.activeSkillTab then
					lbl.TextComponent.FontColor = Color(1, 1, 1, 1)
				else
					lbl.TextComponent.FontColor = Color(0.58, 0.62, 0.68, 1)
				end
			end
		end
	end

	-- 스킬창 책 제목(원작의 "저격수의 길" 자리)을 임의 문자열로 직접 지정한다.
	@ExecSpace("ClientOnly")
	method void SetSkillBookTitle(string title)
		local e = _EntityService:GetEntityByPath("/ui/DefaultGroup/SkillWindow/SkillBookTitle")
		if isvalid(e) then e.TextComponent.Text = title end
	end

	-- 스킬창 책 제목을 활성 탭(차수)에 맞는 전직명으로 갱신한다.
	-- 기본(●) 탭 = "초보자", I~IV 탭 = 해당 직업의 1~4차 전직명(예: 히어로 직업이면 검사/파이터/
	-- 크루세이더/히어로), H/V/VI 탭 = 4차 전직명 그대로(원작처럼 5·6차도 직업명이 유지됨).
	@ExecSpace("ClientOnly")
	method void UpdateSkillBookTitle()
		local e = _EntityService:GetEntityByPath("/ui/DefaultGroup/SkillWindow/SkillBookTitle")
		if not isvalid(e) then return end
		local tab = self._T.activeSkillTab
		if tab == nil or tab == "0" then
			e.TextComponent.Text = "초보자"
			return
		end
		local jobIdx = _UIMyInfoManager:GetSelectedCharacterJobIdx()
		local names = _UIMyInfoManager:GetJobStageNames(jobIdx)
		if names == nil then
			e.TextComponent.Text = "초보자"
			return
		end
		local stage = tonumber(tab) or 1
		if stage > 4 then stage = 4 end
		e.TextComponent.Text = names[stage]
	end

	-- ── 스크롤: 썸 드래그 ─────────────────────────────────────────────

	@ExecSpace("ClientOnly")
	method void OnSkillThumbDown(UITouchDownEvent e)
		if e.TouchId ~= -1 then return end
		local win = _EntityService:GetEntityByPath("/ui/DefaultGroup/SkillWindow")
		if not isvalid(win) then return end
		local winPos  = win.UITransformComponent.anchoredPosition
		local cursor  = _InputService:GetCursorPosition()
		local ghostUI = Vector2(cursor.x - 960, cursor.y - 540)
		local localY  = ghostUI.y - winPos.y
		local th = _EntityService:GetEntityByPath("/ui/DefaultGroup/SkillWindow/SkillScrollThumb")
		local thumbY = 111.0
		if isvalid(th) then thumbY = th.UITransformComponent.anchoredPosition.y end
		self._T.isDraggingSkillThumb  = true
		self._T.isHoldingSkillTrack   = false
		self._T.skillThumbDragOffsetY = localY - thumbY
		log("[SkillManager] 썸 드래그 시작")
	end

	-- ── 스크롤: 트랙 홀드 ─────────────────────────────────────────────

	@ExecSpace("ClientOnly")
	method void OnSkillTrackDown(UITouchDownEvent e)
		if e.TouchId ~= -1 then return end
		if self._T.isDraggingSkillThumb then return end
		self._T.isHoldingSkillTrack = true
		self._T.skillTrackTimer     = 0.0
		self:SkillScrollTrackStep()
		log("[SkillManager] 트랙 홀드 시작")
	end

	@ExecSpace("ClientOnly")
	method void SkillScrollTrackStep()
		local win = _EntityService:GetEntityByPath("/ui/DefaultGroup/SkillWindow")
		if not isvalid(win) then return end
		local winPos  = win.UITransformComponent.anchoredPosition
		local cursor  = _InputService:GetCursorPosition()
		local ghostUI = Vector2(cursor.x - 960, cursor.y - 540)
		local localY  = ghostUI.y - winPos.y
		-- topLimit=111, range=258 (topLimit-botLimit = 111-(-147))
		local progress = (111 - localY) / 258
		progress = math.max(0.0, math.min(1.0, progress))
		local tabSkills = self._T.skillData[self._T.activeSkillTab] or {}
		local maxRow    = math.max(0, math.ceil(#tabSkills / 2) - 5)
		local targetRow = math.floor(progress * maxRow + 0.5)
		targetRow = math.max(0, math.min(maxRow, targetRow))
		if self._T.skillScrollRow < targetRow then
			self._T.skillScrollRow = self._T.skillScrollRow + 1
			self:UpdateSkillViewport()
		elseif self._T.skillScrollRow > targetRow then
			self._T.skillScrollRow = self._T.skillScrollRow - 1
			self:UpdateSkillViewport()
		end
	end

	-- ── 스크롤: 마우스 휠 ─────────────────────────────────────────────

	@ExecSpace("ClientOnly")
	method void OnSkillMouseScroll(MouseScrollEvent e)
		local win = _EntityService:GetEntityByPath("/ui/DefaultGroup/SkillWindow")
		if not isvalid(win) or not win.Enable then return end
		local winPos  = win.UITransformComponent.anchoredPosition
		local cursor  = _InputService:GetCursorPosition()
		local ghostUI = Vector2(cursor.x - 960, cursor.y - 540)
		local localX  = ghostUI.x - winPos.x
		local localY  = ghostUI.y - winPos.y
		-- 창 범위 바깥은 무시 (창 560×540)
		if localX < -280 or localX > 280 or localY < -270 or localY > 270 then return end
		if e.ScrollDelta > 0 then
			self._T.skillWheelAccum = self._T.skillWheelAccum + 0.2
			if self._T.skillWheelAccum >= 1.0 then
				self._T.skillWheelAccum = self._T.skillWheelAccum - 1.0
				if self._T.skillScrollRow > 0 then
					self._T.skillScrollRow = self._T.skillScrollRow - 1
					self:UpdateSkillViewport()
				end
			end
		elseif e.ScrollDelta < 0 then
			self._T.skillWheelAccum = self._T.skillWheelAccum - 0.2
			if self._T.skillWheelAccum <= -1.0 then
				self._T.skillWheelAccum = self._T.skillWheelAccum + 1.0
				local tabSkills = self._T.skillData[self._T.activeSkillTab] or {}
				local maxRow = math.max(0, math.ceil(#tabSkills / 2) - 5)
				if self._T.skillScrollRow < maxRow then
					self._T.skillScrollRow = self._T.skillScrollRow + 1
					self:UpdateSkillViewport()
				end
			end
		end
	end

	-- ── 스킬 행 호버 / 드래그 ─────────────────────────────────────────

	@ExecSpace("ClientOnly")
	method void OnSkillRowHoverEnter(integer rowIdx)
		-- rowIdx = 카드 번호(1~10). 스크롤 1행 = 카드 2칸이므로 *2 보정.
		local dataIdx   = self._T.skillScrollRow * 2 + rowIdx
		local tabSkills = self._T.skillData[self._T.activeSkillTab] or {}
		local skill     = tabSkills[dataIdx]
		if skill == nil then return end
		self._T.hovering     = true
		self._T.pendingShow  = true
		self._T.hoverTabId   = self._T.activeSkillTab
		self._T.hoverDataIdx = dataIdx
		self._T.hoverRowIdx  = rowIdx
	end

	@ExecSpace("ClientOnly")
	method void OnSkillRowHoverExit(integer rowIdx)
		if self._T.hovering then
			self._T.hovering    = false
			self._T.pendingShow = false
			self:HideSkillTooltip()
		end
	end

	@ExecSpace("ClientOnly")
	method void OnSkillRowDragStart(integer rowIdx)
		-- rowIdx = 카드 번호(1~10). 스크롤 1행 = 카드 2칸이므로 *2 보정.
		local dataIdx   = self._T.skillScrollRow * 2 + rowIdx
		local tabSkills = self._T.skillData[self._T.activeSkillTab] or {}
		local skill     = tabSkills[dataIdx]
		if skill == nil then return end
		self._T.isDraggingSkill = true
		self._T.dragSkillRUID   = skill.ruid
		self._T.dragSkillName   = skill.name
		self._T.dragSource      = "window"
		self._T.dragFromKey     = ""
		self._T.hovering        = false
		self._T.pendingShow     = false
		self:HideSkillTooltip()
		self:ShowDragGhost(skill.ruid)
		log("[SkillManager] 스킬 드래그 시작: " .. skill.name)
	end

	-- ── 공통 유틸리티 ──────────────────────────────────────────────────

	@ExecSpace("ClientOnly")
	method void InitBarIcons()
		-- 퀵슬롯 24칸 전체를 barKeys/slotData 기준으로 다시 그린다 (키 라벨/아이콘/기능 라벨)
		for _, p in ipairs(self._T.barPositions) do
			self:UpdateBarSlotVisual(p)
		end
	end

	-- ── 퀵슬롯 위치 ↔ 키 매핑 ──────────────────────────────────────────

	@ExecSpace("ClientOnly")
	method string GetKeyForBarPos(string pos)
		-- 퀵슬롯 위치(엔티티 접미사)에 연결된 키 이름
		return self._T.barKeys[pos] or pos
	end

	@ExecSpace("ClientOnly")
	method string GetBarPosForKey(string key)
		-- 해당 키가 연결된 퀵슬롯 위치 (없으면 "")
		for _, p in ipairs(self._T.barPositions) do
			if self._T.barKeys[p] == key then return p end
		end
		return ""
	end

	@ExecSpace("ClientOnly")
	method void SetBarKey(string pos, string keyName)
		-- 퀵슬롯 리매핑: 위치 pos를 keyName 키에 연결한다. 다른 위치가 이미 그 키면 서로 교환한다.
		local prevKey = self._T.barKeys[pos]
		if prevKey == keyName then return end
		local other = self:GetBarPosForKey(keyName)
		if other ~= "" and other ~= pos then
			self._T.barKeys[other] = prevKey
			self:UpdateBarSlotVisual(other)
		end
		self._T.barKeys[pos] = keyName
		self:UpdateBarSlotVisual(pos)
		self:UpdateAssaulterStackUI()
		_CharacterPersistence:MarkDirty("hotkey")
		log("[SkillManager] 퀵슬롯 키 변경: 위치 " .. pos .. " → [" .. keyName .. "]")
	end

	@ExecSpace("ClientOnly")
	method table ExportBarKeys()
		-- 위치 → 키 매핑 내보내기 (영속 저장/프리셋용)
		local out = {}
		for _, p in ipairs(self._T.barPositions) do
			out[p] = self._T.barKeys[p] or p
		end
		return out
	end

	@ExecSpace("ClientOnly")
	method void ImportBarKeys(table t)
		-- 위치 → 키 매핑 복원. 항목이 없는 위치는 기본값(위치 접미사)으로 돌아간다.
		for _, p in ipairs(self._T.barPositions) do
			local v = (t ~= nil) and t[p] or nil
			self._T.barKeys[p] = (v ~= nil and v ~= "") and tostring(v) or p
			self:UpdateBarSlotVisual(p)
		end
		self:UpdateAssaulterStackUI()
	end

	@ExecSpace("ClientOnly")
	method void UpdateBarSlotVisual(string pos)
		-- 퀵슬롯 한 칸을 다시 그린다: 키 라벨 + (스킬 아이콘 | 기능 라벨 | 빈 칸)
		local base = "/ui/DefaultGroup/SkillBar/Slot_" .. pos
		local key = self:GetKeyForBarPos(pos)
		local labelEnt = _EntityService:GetEntityByPath(base .. "/KeyLabel")
		if isvalid(labelEnt) then labelEnt.TextComponent.Text = key end
		local iconEnt = _EntityService:GetEntityByPath(base .. "/Icon")
		local funcEnt = _EntityService:GetEntityByPath(base .. "/FuncLabel")
		local slot = self._T.slotData[key]
		if slot ~= nil and slot.ruid ~= "" then
			if isvalid(iconEnt) then
				local spr = iconEnt.SpriteGUIRendererComponent
				spr.ImageRUID = slot.ruid
				spr.Color = Color(1, 1, 1, 1)
			end
			if isvalid(funcEnt) then funcEnt.TextComponent.Text = "" end
		else
			if isvalid(iconEnt) then iconEnt.SpriteGUIRendererComponent.Color = Color(1, 1, 1, 0) end
			if isvalid(funcEnt) then funcEnt.TextComponent.Text = _KeySettingManager:GetFuncLabel(key) end
		end
	end

	-- ── 클릭 배정 모드 접근자 (KeySettingManager 연동) ────────────────

	@ExecSpace("ClientOnly")
	method boolean IsClickMode()
		-- 클릭 배정 모드(스킬을 집은 상태) 여부
		return self._T.skillClickMode == true
	end

	@ExecSpace("ClientOnly")
	method table GetClickPayload()
		-- 클릭 배정 모드에서 집고 있는 스킬 정보
		return { ruid = self._T.clickModeRUID or "", name = self._T.clickModeName or "" }
	end

	@ExecSpace("ClientOnly")
	method void EnterClickMode(string ruid, string name, string origin)
		-- 스킬을 집은 상태(클릭 배정 모드)로 전환한다. origin: "window" | "keysetting" | "spare"
		self._T.skillClickMode = true
		self._T.clickModeRUID  = ruid
		self._T.clickModeName  = name
		self._T.clickModeOrigin = origin
		self:ShowDragGhost(ruid)
	end

	@ExecSpace("ClientOnly")
	method table GetSkillOnKey(string key)
		-- 해당 키에 배정된 스킬 정보 (없으면 빈 문자열)
		local slot = self._T.slotData[key]
		if slot == nil then return { ruid = "", name = "" } end
		return { ruid = slot.ruid or "", name = slot.name or "" }
	end

	@ExecSpace("ClientOnly")
	method void RemoveSkillFromKey(string key)
		-- 키에서 스킬을 제거한다 (키세팅 창에서 집기/삭제용)
		self._T.slotData[key] = { ruid = "", name = "" }
		local pos = self:GetBarPosForKey(key)
		if pos ~= "" then self:UpdateBarSlotVisual(pos) end
		_CharacterPersistence:MarkDirty("hotkey")
		self:UpdateAssaulterStackUI()
	end

	@ExecSpace("ClientOnly")
	method string GetSkillKeyName(any keyEnum)
		-- KeyboardKey → 스킬 배정 가능 키 이름 (지원하지 않는 키면 ""). 키 목록은 KeySettingManager가 단일 관리.
		if self._T.keyDefs == nil then
			self._T.keyDefs = _KeySettingManager:GetBindKeyDefs()
		end
		for _, kd in ipairs(self._T.keyDefs) do
			if keyEnum == kd.keyEnum then return kd.name end
		end
		return ""
	end

	@ExecSpace("ClientOnly")
	method void OnKeyDown(KeyDownEvent e)
		-- 퀵슬롯 리매핑 키 캡처 중에는 스킬/창 단축키를 모두 무시한다 (KeySettingManager가 처리)
		if _KeySettingManager:IsCapturingKey() then return end
		local k = e.key
		-- (질주) 좌/우 방향키 "더블탭"(0.5초 내 두 번) → 그 방향으로 질주 진입. 공격키(Ctrl) → 질주 해제.
		if k == KeyboardKey.LeftArrow or k == KeyboardKey.RightArrow then
			local dir = (k == KeyboardKey.LeftArrow) and "left" or "right"
			local now = _UtilLogic.ElapsedSeconds
			-- 이미 그 방향으로 질주 중이면 더블탭을 다시 잡지 않는다(홀드 중 반복 KeyDown으로 재발동 방지).
			if not (self._T.sprintActive == true and self._T.sprintDir == dir) then
				local lastT = (dir == "left") and (self._T.sprintLastLeft or -99.0) or (self._T.sprintLastRight or -99.0)
				if lastT + 0.5 >= now then
					self:EnterSprint(dir)
					-- 트리거 후 타이머를 비워 홀드 중 반복 입력이 좌/우를 번갈아 재발동시키지 않게 한다.
					self._T.sprintLastLeft = -99.0
					self._T.sprintLastRight = -99.0
				else
					if dir == "left" then self._T.sprintLastLeft = now else self._T.sprintLastRight = now end
				end
			end
		elseif k == KeyboardKey.LeftControl or k == KeyboardKey.RightControl then
			if self._T.sprintActive == true then self:EndSprint() end
		end
		-- 스킬창 열기 키 (기본 K - 키설정에서 다른 키로 옮겼으면 그 키)
		if _KeySettingManager:GetFuncForKeyEnum(k) == "skill" then
			self:ToggleWindow()
			return
		end
		if k == KeyboardKey.Tab then
			local w = _EntityService:GetEntityByPath("/ui/DefaultGroup/SkillWindow")
			if isvalid(w) and w.Enable then
				local tabOrder = {"0", "1", "2", "3", "4", "5", "6", "7"}
				local nextIdx = 1
				for i, tid in ipairs(tabOrder) do
					if tid == self._T.activeSkillTab then
						nextIdx = (i % #tabOrder) + 1
						break
					end
				end
				self:SwitchSkillTab(tabOrder[nextIdx])
			end
			return
		end
		-- 단축키 세팅 창이 열려있는 동안에는 스킬 오발동을 막는다 (편집 중 보호)
		if _KeySettingManager:IsWindowOpen() then return end
		local keyName = self:GetSkillKeyName(k)
		if keyName ~= "" then
			self._T.heldSkillKeys[keyName] = true
			self:UseSkillInSlot(keyName)
		end
	end

	@ExecSpace("ClientOnly")
	method void OnKeyUp(KeyUpEvent e)
		-- (질주) 진행 방향 방향키를 떼면 질주 해제.
		if e.key == KeyboardKey.LeftArrow or e.key == KeyboardKey.RightArrow then
			if self._T.sprintActive == true then
				local upDir = (e.key == KeyboardKey.LeftArrow) and "left" or "right"
				if self._T.sprintDir == upDir then self:EndSprint() end
			end
		end
		-- 스킬키를 뗀 순간 홀드 상태를 해제한다 (OnUpdate의 홀드 지속 발동 루프가 멈추도록)
		local keyName = self:GetSkillKeyName(e.key)
		if keyName ~= "" then
			self._T.heldSkillKeys[keyName] = false
		end
	end

	@ExecSpace("ClientOnly")
	method void BlinkSlotReady(string slotPos)
		-- 쿨타임이 다 돌아 다시 사용할 수 있게 되면 그 슬롯 아이콘을 2번 깜빡여 알린다(모든 쿨타임 스킬 공통).
		-- 어둡게(알파 0.25) → 밝게 → 어둡게 → 밝게 순서로 0.15초 간격 토글 = 깜빡임 2회.
		if slotPos == nil or slotPos == "" then return end
		local icon = _EntityService:GetEntityByPath("/ui/DefaultGroup/SkillBar/Slot_" .. tostring(slotPos) .. "/Icon")
		if not isvalid(icon) then return end
		local spr = icon.SpriteGUIRendererComponent
		if not isvalid(spr) then return end
		local c = spr.Color
		local bright = Color(c.r, c.g, c.b, 1)
		local dim = Color(c.r, c.g, c.b, 0.25)
		spr.Color = dim
		_TimerService:SetTimerOnce(function() if isvalid(spr) then spr.Color = bright end end, 0.15)
		_TimerService:SetTimerOnce(function() if isvalid(spr) then spr.Color = dim end end, 0.3)
		_TimerService:SetTimerOnce(function() if isvalid(spr) then spr.Color = bright end end, 0.45)
	end

	@ExecSpace("ClientOnly")
	method string GetWeaponMotionClass()
		-- 파워스트라이크/슬래쉬블래스트 모션 분기용 무기 분류를 돌려준다.
		--   "spear"   = 창/폴암 (장비 이름에 "창" 또는 "폴암" 포함)
		--   "twohand" = 두손검 등 TwoHandedWeapon 슬롯 장착 무기
		--   "onehand" = 한손검 등 그 외
		-- 인벤토리/장비는 클라이언트 전용 상태라 여기(클라이언트)서만 판정할 수 있다.
		local weaponStr = _UIEquipInventoryManager:GetEquip(6)
		local wname = (weaponStr ~= "") and _UIEquipInventoryManager:ParseName(weaponStr) or ""
		if string.find(wname, "창") ~= nil or string.find(wname, "폴암") ~= nil then
			return "spear"
		end
		-- (버그 수정) "카알대검(한손검)을 끼었는데 두손검 모션이 나온다" - 아바타 TwoHandedWeapon 슬롯
		-- 점유 여부로 판정했더니, 무기를 한손검으로 바꿔도 두손 슬롯에 이전 무기 값이 남아 있어 twohand로
		-- 오판했다. 장착 슬롯 결정(DecoWindowManager)과 동일한 "장비창 무기 이름" 기반 판정으로 통일한다.
		if wname ~= "" and _UIEquipInventoryManager:IsOneHandedJobWeapon(wname) then
			return "onehand"
		end
		return "twohand"
	end

	@ExecSpace("ClientOnly")
	method string FindBarPosForSkillName(string skillName)
		-- 지정한 스킬이 배정된 퀵슬롯 위치 접미사(Slot_<위치>)를 돌려준다(없으면 "").
		-- slotData는 "실제 키 → 슬롯" 매핑이라, 키를 찾은 뒤 GetBarPosForKey로 위치를 역조회한다.
		for key, slot in pairs(self._T.slotData or {}) do
			if slot ~= nil and slot.name == skillName then
				return self:GetBarPosForKey(key)
			end
		end
		return ""
	end

	@ExecSpace("ClientOnly")
	method void TryEnterSprintFromSkill()
		-- 러시 스킬 발동 시: 좌/우 방향키를 누르고 있으면 그 방향으로 질주 진입(안 누르고 있으면 무반응).
		if _InputService:IsKeyPressed(KeyboardKey.LeftArrow) then
			self:EnterSprint("left")
		elseif _InputService:IsKeyPressed(KeyboardKey.RightArrow) then
			self:EnterSprint("right")
		end
	end

	@ExecSpace("ClientOnly")
	method void EnterSprint(string dir)
		-- swingT3 대시 자세로 이동속도 2배 질주. 방향키를 떼거나 공격/스킬 시 해제(SprintTick/OnKeyUp/UseSkillInSlot).
		-- (요청) 쿨타임 3초 - 발동한 순간부터 3초 동안 재발동 불가, 퀵슬롯에 블리자드 방식으로 표시된다.
		local player = _UserService.LocalPlayer
		if not isvalid(player) then return end
		if self._T.sprintActive == true and self._T.sprintDir == dir then return end
		if (self._T.dashCooldownUntil or 0) >= _UtilLogic.ElapsedSeconds then return end
		if self._T.sprintActive == true then self:EndSprint() end
		self._T.dashCooldownUntil = _UtilLogic.ElapsedSeconds + 3.0
		-- 러시가 배정된 퀵슬롯 위치를 찾아 쿨타임 오버레이/카운트다운을 띄운다(블리자드와 동일한 표시).
		local dashBarPos = self:FindBarPosForSkillName("러시")
		if dashBarPos ~= "" then
			_DashCooldownUI:ShowCooldown(3.0, dashBarPos)
		end
		self._T.sprintActive = true
		self._T.sprintDir = dir
		self._T.sprintKeyEnum = (dir == "left") and KeyboardKey.LeftArrow or KeyboardKey.RightArrow
		-- 이동속도 2배는 서버에서 설정한다(클라이언트에서 InputSpeed를 직접 바꾸면 서버가 덮어써 무효).
		self:RequestSetSprintSpeed(true)
		if self._T.sprintTimerId ~= nil then _TimerService:ClearTimer(self._T.sprintTimerId) end
		self._T.sprintTimerId = _TimerService:SetTimerRepeat(function()
			self:SprintTick()
		end, 0.08)
		-- (요청) 질주 지속시간 0.4초 - 방향키를 계속 눌러도 0.4초 뒤 자동 해제된다.
		if self._T.sprintDurTimerId ~= nil then _TimerService:ClearTimer(self._T.sprintDurTimerId) end
		self._T.sprintDurTimerId = _TimerService:SetTimerOnce(function()
			self:EndSprint()
		end, 0.4)
		self:PlaySprintPose()
		log("[SkillManager] 질주 시작 dir=" .. dir)
	end

	@ExecSpace("ClientOnly")
	method void SprintTick()
		-- 질주 자세만 유지한다. 해제는 OnKeyUp(방향키 릴리즈)/공격/스킬이 담당한다
		-- (IsKeyPressed 폴링은 홀드 중에도 false로 읽혀 질주가 깜빡거리는 문제가 있어 사용하지 않는다).
		if self._T.sprintActive ~= true then return end
		self:PlaySprintPose()
	end

	@ExecSpace("ClientOnly")
	method void PlaySprintPose()
		-- 걷기 애니메이션에 덮이지 않게 swingT3 대시 자세(프레임 0~1)를 계속 재전송한다.
		local player = _UserService.LocalPlayer
		if not isvalid(player) then return end
		local ar = player.AvatarRendererComponent
		if not isvalid(ar) then return end
		local body = ar:GetBodyEntity()
		if not isvalid(body) then return end
		local ev = ActionStateChangedEvent("swingT3", "swingT3", 1.0, SpriteAnimClipPlayType.Loop, 0, 1)
		body:SendEvent(ev)
	end

	@ExecSpace("ClientOnly")
	method void EndSprint()
		if self._T.sprintActive ~= true then return end
		self._T.sprintActive = false
		if self._T.sprintTimerId ~= nil then
			_TimerService:ClearTimer(self._T.sprintTimerId)
			self._T.sprintTimerId = nil
		end
		if self._T.sprintDurTimerId ~= nil then
			_TimerService:ClearTimer(self._T.sprintDurTimerId)
			self._T.sprintDurTimerId = nil
		end
		self:RequestSetSprintSpeed(false)   -- 서버에서 원래 이동속도로 복구
		local player = _UserService.LocalPlayer
		if isvalid(player) then
			-- 남은 질주 자세 클립을 걷기/서기로 되돌린다(StateChangeEvent 유발).
			local sc = player.StateComponent
			if isvalid(sc) and sc.CurrentStateName ~= "DEAD" then
				sc:ChangeState("IDLE")
				sc:ChangeState("MOVE")
				sc:ChangeState("IDLE")
			end
		end
		log("[SkillManager] 질주 해제")
	end

	@ExecSpace("Server")
	method void RequestSetSprintSpeed(boolean active)
		-- 질주 이동속도(2배) 적용/해제를 서버에서 처리한다. 유저별 원래 InputSpeed를 저장해 정확히 복구한다.
		local player = _UserService:GetUserEntityByUserId(senderUserId)
		if not isvalid(player) then return end
		local mv = player.MovementComponent
		if not isvalid(mv) then return end
		if self._T.sprintOrigByUser == nil then self._T.sprintOrigByUser = {} end
		if active then
			if self._T.sprintOrigByUser[senderUserId] == nil then
				self._T.sprintOrigByUser[senderUserId] = mv.InputSpeed
			end
			mv.InputSpeed = self._T.sprintOrigByUser[senderUserId] * 2.0
		else
			local orig = self._T.sprintOrigByUser[senderUserId]
			if orig ~= nil then
				mv.InputSpeed = orig
				self._T.sprintOrigByUser[senderUserId] = nil
			end
		end
		log("[SkillManager] RequestSetSprintSpeed active=" .. tostring(active) .. " InputSpeed=" .. tostring(mv.InputSpeed))
	end

	@ExecSpace("ClientOnly")
	method void UseSkillInSlot(string key)
		local slot = self._T.slotData[key]
		if slot == nil or slot.ruid == "" then return end
		-- (기능 추가) "사망했을 때 부활 전까지 다른 행동을 못하게 해달라"는 요청 - 사망(DEAD) 상태에서는
		-- 어떤 슬롯도 사용할 수 없다(HP포션 포함). 이동/점프/기본공격은 서버 쪽에서 조작 자체를 꺼서 막는다
		-- (PlayerAttack.HandleDeadLockStateEvent). 부활하면 자동으로 다시 풀린다.
		local localPlayerForDeath = _UserService.LocalPlayer
		local deathState = isvalid(localPlayerForDeath) and localPlayerForDeath.StateComponent or nil
		if isvalid(deathState) and deathState.CurrentStateName == "DEAD" then
			log("[SkillManager] 사망 상태 - 스킬 사용 불가 (부활 후 사용 가능)")
			return
		end
		-- (새 대쉬=질주) 러시 스킬: 방향키(좌/우)를 누르고 있으면 질주 진입, 아니면 아무 일도 안 함. 쿨다운/RPC 없음.
		if slot.name == "러시" then
			self:TryEnterSprintFromSkill()
			return
		end
		-- (요청) 질주 중 다른 스킬을 누르면 제자리로 돌아가지 않고 즉시 그 스킬을 발동한다 - 먼저 질주만 해제한다.
		if self._T.sprintActive == true then
			self:EndSprint()
		end
		-- 캐릭터 정보창의 실제 크리티컬 확률(장비 잠재능력 반영)을 스킬 사용 시마다 서버로 동기화한다 -
		-- CalcCritical은 서버에서만 실행되고 장비/인벤토리는 클라이언트 전용 상태라, combatPower와
		-- 동일한 이유로 매 시전 직전에 최신값을 넘겨줘야 한다.
		local localPlayerForCrit = _UserService.LocalPlayer
		local paForCrit = isvalid(localPlayerForCrit) and localPlayerForCrit:GetComponent(PlayerAttack) or nil
		if paForCrit ~= nil then
			paForCrit:SyncCritRate(_CharInfoManager:CalcCritRate())
			paForCrit:SyncCritDamage(_CharInfoManager:CalcCritDamage())
		end
		if slot.name == "HP포션" then
			_PotionShopManager:RequestUsePotion()
			self._T.slotData[key] = { ruid = "", name = "" }
			local potPos = self:GetBarPosForKey(key)
			if potPos ~= "" then self:UpdateBarSlotVisual(potPos) end
			_KeySettingManager:NotifyHotkeysChanged()
			log("[SkillManager] HP포션 사용 키=" .. key)
			-- 포션 사용으로 슬롯이 비워지는 것도 단축키 변경이므로 저장 예약
			_CharacterPersistence:MarkDirty("hotkey")
			return
		end
		if slot.name == "텔레포트" then
			-- 텔레포트는 다른 스킬들의 공용 쿨다운(skillOnCooldown)과 무관하게 독립된 쿨다운으로 동작한다 -
			-- 다른 스킬의 모션 재생/딜레이 중이라도 텔레포트는 사용할 수 있어야 한다는 요청 반영. 공용
			-- skillOnCooldown 게이트보다 먼저 확인/처리하고, 공용 플래그를 건드리지 않은 채 여기서 끝낸다.
			if self._T.teleportOnCooldown then return end
			log("[SkillManager] 스킬 사용: " .. slot.name .. " (단축키: " .. key .. ")")
			-- 방향키 입력 상태는 클라이언트에서만 알 수 있다(_InputService:IsKeyPressed는 ClientOnly) - 여기서 확인해 서버로 전달한다.
			-- 위/아래를 좌우보다 우선한다: 위나 아래 화살표를 누르고 있으면 수직 텔레포트를, 아니면 좌/우(눌린 게 없으면 현재 바라보는 방향)로 이동한다.
			local dirKey = "right"
			if _InputService:IsKeyPressed(KeyboardKey.UpArrow) then
				dirKey = "up"
			elseif _InputService:IsKeyPressed(KeyboardKey.DownArrow) then
				dirKey = "down"
			elseif _InputService:IsKeyPressed(KeyboardKey.LeftArrow) then
				dirKey = "left"
			elseif _InputService:IsKeyPressed(KeyboardKey.RightArrow) then
				dirKey = "right"
			else
				local localPlayer = _UserService.LocalPlayer
				local ctrl = isvalid(localPlayer) and localPlayer.PlayerControllerComponent or nil
				if isvalid(ctrl) then
					dirKey = (ctrl.LookDirectionX >= 0) and "right" or "left"
				end
			end
			self._T.teleportOnCooldown = true
			_TimerService:SetTimerOnce(function()
				self._T.teleportOnCooldown = false
			end, 0.45)
			self:RequestFireTeleport(dirKey)
			return
		end
		if slot.name == "어썰터" then
			-- (기능 변경) 어썰터는 스택형 충전 스킬 - 3초마다 스택이 1개씩 차고(최대 3개), 스택이 1개
			-- 이상이면 언제든 사용할 수 있다. 사용 시 스택 1개 소모 (요청사항).
			-- assaulterCastActive: 시전 진행 중(사라짐~착지 사이)에는 재시전 불가 - 착지 즉시
			-- (OnAssaulterChainReady) 풀려서 딜레이 없이 연속 시전된다.
			-- "사거리 내 타겟이 없으면 사용이 되지 않아야 한다"는 기존 동작 유지 - 서버가 대상 존재를
			-- 확인한 뒤(PlayerAttack.NotifyAssaulterResult) 성공시에만 스택을 소모한다.
			if self._T.assaulterStacks <= 0 or self._T.assaulterRequestPending or self._T.assaulterCastActive then return end
			log("[SkillManager] 스킬 사용 요청: " .. slot.name .. " (단축키: " .. key .. ")")
			self._T.assaulterRequestPending = true
			self._T.assaulterPendingKey = key
			-- 서버 응답이 비정상적으로 늦어지는 경우를 대비한 안전장치 - 최대 1초 뒤 자동으로 다시 시도 가능하게 한다.
			_TimerService:SetTimerOnce(function()
				self._T.assaulterRequestPending = false
			end, 1.0)
			local combatPower = _CharInfoManager:CalcCombatPower()
			self:RequestFireAssaulter(combatPower)
			return
		end
		if slot.name == "가드" then
			-- 가드(패링): 공용 쿨다운과 무관한 독립 쿨타임 20초(패링 성공 시 5초로 단축 - NotifyGuardParrySuccess).
			-- 이펙트/모션 없이 서버에 1초 패링 창만 연다.
			if (self._T.guardCooldownUntil or 0) >= _UtilLogic.ElapsedSeconds then return end
			self._T.guardUseAt = _UtilLogic.ElapsedSeconds
			self._T.guardCooldownUntil = self._T.guardUseAt + 20.0
			self._T.guardBarPos = self:GetBarPosForKey(key)
			if self._T.guardBarPos ~= "" then
				_GuardCooldownUI:ShowCooldown(20.0, self._T.guardBarPos)
			end
			self:RequestFireGuard()
			log("[SkillManager] 가드 사용(패링 1초, 쿨타임 20초)")
			return
		end
		if self._T.skillOnCooldown then return end
		log("[SkillManager] 스킬 사용: " .. slot.name .. " (단축키: " .. key .. ")")
		if slot.name == "달팽이 세마리" then
			self._T.skillOnCooldown = true
			_TimerService:SetTimerOnce(function()
				self._T.skillOnCooldown = false
			end, 0.75)
			_SoundService:PlaySound("06f080c8c42e431785a46e20ec9be5bb", 1.0)
			self:RequestFireSnailSkill()
		elseif slot.name == "파워스트라이크" then
			-- 공격속도 배율도 쿨다운(재사용 대기시간)에 함께 적용한다 - 공격속도가 빠를수록 다음 스킬을 더 빨리 다시 쓸 수 있어야 한다.
			local atkMult = _CharInfoManager:GetAttackSpeedMultiplier()
			self._T.skillOnCooldown = true
			_TimerService:SetTimerOnce(function()
				self._T.skillOnCooldown = false
			end, 0.75 * atkMult)
			local combatPower = _CharInfoManager:CalcCombatPower()
			-- 무기 분류(창·폴암/두손검/한손검) 모션 분기용 - 인벤토리/장비는 클라이언트 전용 상태라 여기서 확인해 전달한다.
			self:RequestFirePowerStrike(combatPower, atkMult, self:GetWeaponMotionClass())
		elseif slot.name == "슬래시블러스트" or slot.name == "슬래쉬블래스트" then
			-- (이름 변경) 새 이름 "슬래시블러스트" + 이미 퀵슬롯에 저장된 옛 이름("슬래쉬블래스트")도 호환.
			-- 파워스트라이크와 동일하게 공격속도 배율을 쿨다운(재사용 대기시간)에 함께 적용한다.
			local atkMult = _CharInfoManager:GetAttackSpeedMultiplier()
			self._T.skillOnCooldown = true
			_TimerService:SetTimerOnce(function()
				self._T.skillOnCooldown = false
			end, 0.75 * atkMult)
			local combatPower = _CharInfoManager:CalcCombatPower()
			self:RequestFireSlashBlast(combatPower, atkMult, self:GetWeaponMotionClass())
		elseif slot.name == "럭키세븐" then
			-- 럭키세븐은 가니어를 장착한 상태에서만 사용 가능하다. 인벤토리/장비 상태는 클라이언트에만 존재하므로
			-- (서버는 CostumeManagerComponent의 실제 장착값을 알 수 없음) 여기 클라이언트 측에서 확인한다.
			local localPlayer = _UserService.LocalPlayer
			local costume = isvalid(localPlayer) and localPlayer.CostumeManagerComponent or nil
			if costume == nil or costume:GetEquip(MapleAvatarItemCategory.TwoHandedWeapon) ~= "985e44451afc4730a46eb206716e7ecf" then
				log("[SkillManager] 럭키세븐: 가니어를 장착하지 않아 사용할 수 없습니다.")
				return
			end
			-- 파워스트라이크와 동일하게 공격속도 배율을 쿨다운(재사용 대기시간)에 함께 적용한다.
			local atkMult = _CharInfoManager:GetAttackSpeedMultiplier()
			self._T.skillOnCooldown = true
			_TimerService:SetTimerOnce(function()
				self._T.skillOnCooldown = false
			end, 0.75 * atkMult)
			local combatPower = _CharInfoManager:CalcCombatPower()
			self:RequestFireLuckySeven(combatPower, atkMult)
		elseif slot.name == "더블스탭" then
			-- 더블스탭은 공격속도가 현재 단계보다 1단계 더 빠르게 고정 적용된다(0.9배 추가) -
			-- GetAttackSpeedMultiplier는 0.9^(stage-5)이므로, 한 단계 더 빠른 속도는 그 값에 0.9를 한 번 더 곱한 것과 같다.
			local atkMult = _CharInfoManager:GetAttackSpeedMultiplier() * 0.9
			self._T.skillOnCooldown = true
			_TimerService:SetTimerOnce(function()
				self._T.skillOnCooldown = false
			end, 0.75 * atkMult)
			local combatPower = _CharInfoManager:CalcCombatPower()
			self:RequestFireDoubleStab(combatPower, atkMult)
		elseif slot.name == "새비지블로우" then
			-- 새비지블로우: 전방 1명을 6번 때리는 단일 대상 스킬. 다른 스킬들과 동일하게 공격속도 배율을
			-- 재사용 대기시간에 함께 적용한다.
			-- 재사용 대기시간은 마지막 타격(0.12 + 7*0.09 = 0.75*배율)과 컨트롤 복구(0.77*배율) 직후로 잡는다 -
			-- "끝 딜레이를 더 줄여달라"는 피드백으로 0.90 → 0.82*배율까지 줄였다(키 홀드 연속 시전 포함).
			-- 8번 이미지는 전용 이펙트 엔티티가 자기 타이머로 끝까지 재생하므로 잘리지 않는다.
			local atkMult = _CharInfoManager:GetAttackSpeedMultiplier()
			self._T.skillOnCooldown = true
			_TimerService:SetTimerOnce(function()
				self._T.skillOnCooldown = false
			end, 0.82 * atkMult)
			local combatPower = _CharInfoManager:CalcCombatPower()
			self:RequestFireSavageBlow(combatPower, atkMult)
		elseif slot.name == "매직클로" then
			-- 파워스트라이크와 동일하게 공격속도 배율을 쿨다운(재사용 대기시간)에 함께 적용한다.
			local atkMult = _CharInfoManager:GetAttackSpeedMultiplier()
			self._T.skillOnCooldown = true
			_TimerService:SetTimerOnce(function()
				self._T.skillOnCooldown = false
			end, 0.75 * atkMult)
			local combatPower = _CharInfoManager:CalcCombatPower()
			self:RequestFireMagicClaw(combatPower, atkMult)
		elseif slot.name == "썬더볼트" then
			-- 다른 스킬들과 동일하게 공격속도 배율을 쿨다운(재사용 대기시간)에 함께 적용한다.
			local atkMult = _CharInfoManager:GetAttackSpeedMultiplier()
			self._T.skillOnCooldown = true
			_TimerService:SetTimerOnce(function()
				self._T.skillOnCooldown = false
			end, 0.75 * atkMult)
			local combatPower = _CharInfoManager:CalcCombatPower()
			self:RequestFireThunderbolt(combatPower, atkMult)
		elseif slot.name == "힐" then
			-- 힐은 다른 스킬과 달리 공격속도를 1단계 올린 속도로 사용한다(요청사항) - 기본 배율에
			-- 0.9를 추가로 곱해 "현재 공격속도 단계+1"에 해당하는 배율을 쿨다운/모션 재생시간 모두에 적용한다.
			local baseAtkMult = _CharInfoManager:GetAttackSpeedMultiplier()
			local atkMult = baseAtkMult * 0.9
			self._T.skillOnCooldown = true
			_TimerService:SetTimerOnce(function()
				self._T.skillOnCooldown = false
			end, 0.75 * atkMult)
			local combatPower = _CharInfoManager:CalcCombatPower()
			self:RequestFireHeal(combatPower, atkMult)
		elseif slot.name == "파이어에로우" then
			-- 방향키 입력 상태는 클라이언트에서만 알 수 있다(_InputService:IsKeyPressed는 ClientOnly) - 여기서 확인해 서버로 전달한다.
			-- 위/아래/좌/우를 동시에 조합해 대각선까지 지원하고, 아무 키도 없으면 서버에서 캐릭터가 바라보는 방향(전방)으로 처리한다.
			local dirX, dirY = 0, 0
			if _InputService:IsKeyPressed(KeyboardKey.LeftArrow) then
				dirX = -1
			elseif _InputService:IsKeyPressed(KeyboardKey.RightArrow) then
				dirX = 1
			end
			if _InputService:IsKeyPressed(KeyboardKey.UpArrow) then
				dirY = 1
			elseif _InputService:IsKeyPressed(KeyboardKey.DownArrow) then
				dirY = -1
			end
			local atkMult = _CharInfoManager:GetAttackSpeedMultiplier()
			self._T.skillOnCooldown = true
			_TimerService:SetTimerOnce(function()
				self._T.skillOnCooldown = false
			end, 0.75 * atkMult)
			local combatPower = _CharInfoManager:CalcCombatPower()
			-- 레벨 50 이상 이펙트 분기용 - _UIMyInfoManager.CharLevel은 서버에서 갱신되지 않는 고정값(항상 1)이라
			-- 사용할 수 없음(UIMyInfoManager.UpdateBars가 실제 표시레벨은 DisplayLevel에만 client-only로 계산함).
			-- combatPower와 동일한 클라이언트 계산식(전투력 10당 1레벨)으로 직접 구해 서버로 전달한다.
			local level = math.floor(combatPower / 10)
			self:RequestFireFireArrow(combatPower, atkMult, dirX, dirY, level)
		elseif slot.name == "아이언 에로우" then
			-- 파이어에로우와 동일한 8방향 입력 처리. 레벨에 따른 이펙트 분기는 없다(고정 1종).
			local dirX, dirY = 0, 0
			if _InputService:IsKeyPressed(KeyboardKey.LeftArrow) then
				dirX = -1
			elseif _InputService:IsKeyPressed(KeyboardKey.RightArrow) then
				dirX = 1
			end
			if _InputService:IsKeyPressed(KeyboardKey.UpArrow) then
				dirY = 1
			elseif _InputService:IsKeyPressed(KeyboardKey.DownArrow) then
				dirY = -1
			end
			local atkMult = _CharInfoManager:GetAttackSpeedMultiplier()
			self._T.skillOnCooldown = true
			_TimerService:SetTimerOnce(function()
				self._T.skillOnCooldown = false
			end, 0.75 * atkMult)
			local combatPower = _CharInfoManager:CalcCombatPower()
			self:RequestFireIronArrow(combatPower, atkMult, dirX, dirY)
		elseif slot.name == "어벤져" then
			-- 파이어에로우/아이언에로우와 동일한 8방향 입력 처리.
			local dirX, dirY = 0, 0
			if _InputService:IsKeyPressed(KeyboardKey.LeftArrow) then
				dirX = -1
			elseif _InputService:IsKeyPressed(KeyboardKey.RightArrow) then
				dirX = 1
			end
			if _InputService:IsKeyPressed(KeyboardKey.UpArrow) then
				dirY = 1
			elseif _InputService:IsKeyPressed(KeyboardKey.DownArrow) then
				dirY = -1
			end
			local atkMult = _CharInfoManager:GetAttackSpeedMultiplier()
			self._T.skillOnCooldown = true
			-- (기능 수정) 몸쪽 이펙트(0.6) + 0.2초 뒤 투사체 발사로 PlayerAttack.AttackAvenger의 실제
			-- 발동 주기가 0.85*mult로 늘어난 것에 맞춰 쿨다운도 동일하게 맞춘다(다른 화살류 스킬과 같은 이유).
			_TimerService:SetTimerOnce(function()
				self._T.skillOnCooldown = false
			end, 0.85 * atkMult)
			local combatPower = _CharInfoManager:CalcCombatPower()
			self:RequestFireAvenger(combatPower, atkMult, dirX, dirY)
		elseif slot.name == "헤이스트" then
			-- 헤이스트는 공격이 아니라 버프이므로 combatPower는 필요 없다. 다른 스킬과 동일하게
			-- 공격속도 배율만큼 짧은 재사용 대기시간만 두고(연타 스팸 방지), 5분 지속시간 자체는
			-- 재사용 가능 - 지속 중 다시 쓰면 서버 쪽에서 중첩 없이 지속시간만 갱신된다.
			local atkMult = _CharInfoManager:GetAttackSpeedMultiplier()
			self._T.skillOnCooldown = true
			_TimerService:SetTimerOnce(function()
				self._T.skillOnCooldown = false
			end, 0.75 * atkMult)
			self:RequestFireHaste(atkMult)
		elseif slot.name == "쉐도우 파트너" then
			-- 쉐도우 파트너도 헤이스트와 동일하게 공격이 아니라 버프(30분)이므로 combatPower는 필요 없다.
			-- 연타 스팸 방지용 짧은 재사용 대기시간만 두고, 지속 중 다시 쓰면 서버에서 중첩 없이
			-- 지속시간만 갱신된다.
			local atkMult = _CharInfoManager:GetAttackSpeedMultiplier()
			self._T.skillOnCooldown = true
			_TimerService:SetTimerOnce(function()
				self._T.skillOnCooldown = false
			end, 0.75 * atkMult)
			self:RequestFireShadowPartner(atkMult)
		elseif slot.name == "부스터" then
			-- 부스터: 5분간 공격속도 1단계 상승. 이 스탯(atkSpeedStage)은 CharInfoManager가 클라이언트
			-- 전용으로 들고 있어(서버에 대응 데이터 없음) 실제 효과는 이 클라이언트에서 즉시 적용하고,
			-- 서버로는 다른 플레이어에게 보이는 시전 이펙트/사운드 재생만 요청한다.
			local atkMult = _CharInfoManager:GetAttackSpeedMultiplier()
			self._T.skillOnCooldown = true
			_TimerService:SetTimerOnce(function()
				self._T.skillOnCooldown = false
			end, 0.75 * atkMult)
			local jobIdx = _UIMyInfoManager:GetSelectedCharacterJobIdx()
			local isMage = (jobIdx == 4 or jobIdx == 5 or jobIdx == 6)
			_CharInfoManager:UseBooster()
			self:RequestFireBooster(isMage, atkMult)
			log("[SkillManager] 부스터 사용!")
		elseif slot.name == "포이즌 미스트" then
			-- 포이즌 미스트: 독 데미지 자체는 공격속도 영향을 받지 않지만, 스킬 자체의 재사용 대기시간은
			-- 다른 스킬과 동일하게 공격속도 배율을 적용한다(연타 스팸 방지 목적일 뿐 독 틱과는 무관).
			local atkMult = _CharInfoManager:GetAttackSpeedMultiplier()
			self._T.skillOnCooldown = true
			_TimerService:SetTimerOnce(function()
				self._T.skillOnCooldown = false
			end, 0.75 * atkMult)
			local combatPower = _CharInfoManager:CalcCombatPower()
			self:RequestFirePoisonMist(combatPower, atkMult)
		elseif slot.name == "익스플로젼" then
			local atkMult = _CharInfoManager:GetAttackSpeedMultiplier()
			self._T.skillOnCooldown = true
			_TimerService:SetTimerOnce(function()
				self._T.skillOnCooldown = false
			end, 0.75 * atkMult)
			local combatPower = _CharInfoManager:CalcCombatPower()
			self:RequestFireExplosion(combatPower, atkMult)
		elseif slot.name == "드래곤 로어" then
			local atkMult = _CharInfoManager:GetAttackSpeedMultiplier()
			self._T.skillOnCooldown = true
			_TimerService:SetTimerOnce(function()
				self._T.skillOnCooldown = false
			end, 0.75 * atkMult)
			local combatPower = _CharInfoManager:CalcCombatPower()
			self:RequestFireDragonRoar(combatPower, atkMult)
		elseif slot.name == "스피어 버스터" then
			-- (실측 확인) 클라이언트 쿨다운을 다른 스킬과 동일하게 0.75*atkMult로 두면, 서버 쪽
			-- isSpearBursting 잠금이 풀리는 시점(RestoreSpearBurstControl)보다 클라이언트가
			-- 먼저 재시전을 시도하게 돼, 홀드 지속 시전 시 요청의 절반 가까이가 "이미 진행 중"으로
			-- 차단되는 문제가 있었다(로그로 확인: 116번 시도 중 58번 차단). 서버 잠금 해제 시점과
			-- 동일하게 맞춰 홀드 시 매번 성공하도록 한다.
			-- (버그 수정) RestoreSpearBurstControl 자체가 PlayerAttack.mlua에서 반대 방향 모션 재생
			-- 버그를 막기 위해 0.95*atkMult에서 1.55*atkMult로 늦춰졌으므로, 여기 쿨다운도 동일하게
			-- 맞춘다 - 둘이 어긋나면 이 "이미 진행 중" 차단 문제가 다시 재현된다.
			-- (기능 추가) PlayerAttack.AttackSpearBurst에서 이펙트/데미지 공용이었던 hitStartDelay가
			-- "히트 속도는 0.7초 뒤, 찌르기 3종 이펙트 시점은 그보다 0.5초 앞당겨서" 요청으로
			-- damageStartDelay(0.7)/effectStartDelay(0.2)로 다시 분리됐다.
			-- (기능 추가) "스킬이 끝났는데도 못 움직이는 시간이 길게 느껴진다"는 피드백으로
			-- RestoreSpearBurstControl 호출 시점이 damageStartDelay + 1.0*atkMult(여유 과다)에서
			-- damageStartDelay + 0.2*atkMult + 0.05(3번째 실제 데미지 판정 직후 최소 여유)로 줄었다 -
			-- 이 쿨다운도 그와 반드시 동일해야 하므로 맞춘다.
			-- (기능 추가) "3종 찌르기 이펙트 간 시간 간격을 1.5배 늘려달라"는 피드백으로 PlayerAttack.mlua의
			-- 간격 상수가 0.2*mult→0.3*mult로 늘어난 것에 맞춰 이 쿨다운도 동일하게 0.3*atkMult로 맞춘다.
			-- (기능 추가) "데미지 시점을 0.2초 앞당겨달라"는 피드백으로 damageStartDelay가 0.7→0.5로
			-- 줄어든 것에 맞춰 이 쿨다운의 기준값도 0.7→0.5로 함께 맞춘다.
			-- (되돌림) "공격속도 단계를 올려도 스피어 버스터에 적용되지 않는다"는 피드백으로, 이전에
			-- 고정했던 하드코딩(0.9^3, 공격속도 3단계 고정)을 되돌리고 다른 스킬과 동일하게 플레이어의
			-- 실제 현재 공격속도 단계를 그대로 사용한다.
			local atkMult = _CharInfoManager:GetAttackSpeedMultiplier()
			-- (버그 수정) PlayerAttack.AttackSpearBurst의 컨트롤 복구 시점과 반드시 동일한 공식으로
			-- 맞춘다(둘이 어긋나면 "이미 진행 중" 차단 문제가 재현된다).
			-- (버그 수정) "꾹 누르고 있으면 중간중간 1-2초씩 불규칙하게 멈춘다"는 피드백 - 로그로 실측한
			-- 결과, 서버 쪽 isSpearBursting 잠금 해제와 클라이언트 쿨다운 해제가 평균적으로는 같은
			-- 공식이라도 매 호출마다 클라이언트→서버 RPC 왕복 지연(네트워크 지터)이 조금씩 달라, 가끔
			-- 클라이언트가 서버보다 미세하게 먼저 재시전을 시도해 "이미 진행 중"으로 막힌다 - 이때
			-- 클라이언트는 이미 자기 쿨다운을 다 쓴 것으로 착각해 다음 재시전까지 꼬박 한 주기를 더
			-- 기다리게 되고, 그 결과 직전 성공 시점부터는 정상 간격의 약 2배로 보인다. 클라이언트
			-- 쿨다운에 지터 흡수용 여유(0.15초)를 추가로 얹어, 클라이언트가 항상 서버보다 확실히 늦게
			-- 재시전을 시도하도록 한다.
			-- (버그 수정) "공속을 올려도 공격 횟수가 거의 안 는다 - 파워스트라이크는 확실히 는다"는
			-- 피드백 - damageStartDelay(0.5)가 atkMult와 무관한 고정값이라 전체 주기가 공속에 비례해
			-- 줄지 않던 것이 원인이었다. PlayerAttack.AttackSpearBurst와 동일하게 damageStartDelay 자체를
			-- 0.5*atkMult로 스케일링했으므로, 여기 쿨다운 공식도 반드시 동일하게 맞춘다.
			-- (버그 수정) 이어서 "+0.05" 안전 여유도 atkMult와 무관한 고정값이라 공속이 빨라질수록 전체
			-- 주기에서 차지하는 비중이 커져 DPS 스케일링을 계속 깎아먹고 있었다 - 0.05*atkMult로 바꿔
			-- 파워스트라이크(0.75*atkMult)와 동일하게 순수 비례식(0.85*atkMult)이 되도록 한다. 지터
			-- 흡수용 여유(jitterMargin)만은 실제 네트워크 왕복 지연(공속과 무관한 고정 시간)을 막기
			-- 위한 것이므로 의도적으로 고정값(0.15초)을 유지한다.
			local damageStartDelay = 0.5 * atkMult
			local motionComboEnd = (0.12 + 0.25 + 0.2) * atkMult
			local jitterMargin = 0.15
			local spearBurstCooldownDuration = math.max(damageStartDelay + 0.3 * atkMult + 0.05 * atkMult, motionComboEnd + 0.05 * atkMult) + jitterMargin
			self._T.skillOnCooldown = true
			_TimerService:SetTimerOnce(function()
				self._T.skillOnCooldown = false
			end, spearBurstCooldownDuration)
			local combatPower = _CharInfoManager:CalcCombatPower()
			self:RequestFireSpearBurst(combatPower, atkMult)
		elseif slot.name == "콤보 어택" then
			-- 콤보 어택(3차, 버프 30분): 헤이스트와 동일하게 공격이 아니라 버프이므로 combatPower는
			-- 필요 없고, 짧은 재사용 대기시간만 둔다(연타 스팸 방지). 지속 중 다시 쓰면 서버 쪽에서
			-- 중첩 없이 지속시간만 갱신된다.
			local atkMult = _CharInfoManager:GetAttackSpeedMultiplier()
			self._T.skillOnCooldown = true
			_TimerService:SetTimerOnce(function()
				self._T.skillOnCooldown = false
			end, 0.75 * atkMult)
			self:RequestFireComboAttack(atkMult)
			log("[SkillManager] 콤보 어택 사용!")
		elseif slot.name == "패닉" then
			-- 패닉: 콤보 어택으로 쌓은 콤보 구슬을 모두 소모해 단일 대상에게 강력한 피해를 입힌다.
			-- 구슬이 하나도 없으면 사용할 수 없다(요청사항) - 서버(PlayerAttack.AttackPanic)에서도
			-- 다시 확인하지만, 클라이언트에서 미리 걸러 헛되이 쿨다운이 걸리지 않게 한다(럭키세븐의
			-- 가니어 장착 확인과 동일한 패턴).
			local localPlayer = _UserService.LocalPlayer
			local paComp = isvalid(localPlayer) and localPlayer:GetComponent(PlayerAttack) or nil
			if paComp == nil or (paComp.ComboOrbCount or 0) <= 0 then
				log("[SkillManager] 패닉: 콤보 구슬이 없어 사용할 수 없습니다.")
				return
			end
			-- 파워스트라이크와 동일하게 공격속도 배율을 쿨다운(재사용 대기시간)에 함께 적용한다.
			local atkMult = _CharInfoManager:GetAttackSpeedMultiplier()
			self._T.skillOnCooldown = true
			_TimerService:SetTimerOnce(function()
				self._T.skillOnCooldown = false
			end, 0.75 * atkMult)
			local combatPower = _CharInfoManager:CalcCombatPower()
			self:RequestFirePanic(combatPower, atkMult)
			log("[SkillManager] 패닉 사용!")
		elseif slot.name == "코마" then
			-- 코마: 패닉과 동일하게 콤보 어택으로 쌓은 콤보 구슬을 모두 소모한다(다만 다중 대상).
			-- 구슬이 하나도 없으면 사용할 수 없다 - 패닉과 동일한 클라이언트 사전 확인 패턴.
			local localPlayer = _UserService.LocalPlayer
			local paComp = isvalid(localPlayer) and localPlayer:GetComponent(PlayerAttack) or nil
			if paComp == nil or (paComp.ComboOrbCount or 0) <= 0 then
				log("[SkillManager] 코마: 콤보 구슬이 없어 사용할 수 없습니다.")
				return
			end
			-- 패닉과 동일하게 공격속도 배율을 쿨다운(재사용 대기시간)에 함께 적용한다.
			local atkMult = _CharInfoManager:GetAttackSpeedMultiplier()
			self._T.skillOnCooldown = true
			_TimerService:SetTimerOnce(function()
				self._T.skillOnCooldown = false
			end, 0.75 * atkMult)
			local combatPower = _CharInfoManager:CalcCombatPower()
			self:RequestFireComa(combatPower, atkMult)
			log("[SkillManager] 코마 사용!")
		elseif slot.name == "블리자드" then
			-- 블리자드(4차): 자체 쿨타임 20초. 어썰터와 동일하게 퀵슬롯 아이콘 위에 회색 오버레이 + 남은
			-- 초 숫자로 쿨타임을 표시한다(전용 오버레이 엔티티를 쓰므로 어썰터 표시와 서로 간섭하지 않는다).
			if self._T.blizzardOnCooldown then
				log("[SkillManager] 블리자드: 쿨타임 중")
				return
			end
			local atkMult = _CharInfoManager:GetAttackSpeedMultiplier()
			-- 시전 모션/연타 방지용 공용 쿨다운은 다른 스킬과 동일하게 짧게만 건다.
			self._T.skillOnCooldown = true
			_TimerService:SetTimerOnce(function()
				self._T.skillOnCooldown = false
			end, 0.75 * atkMult)
			-- 블리자드 전용 쿨타임 20초 (공격속도와 무관한 고정 값).
			self._T.blizzardOnCooldown = true
			_TimerService:SetTimerOnce(function()
				self._T.blizzardOnCooldown = false
				log("[SkillManager] 블리자드 쿨타임 종료")
			end, 20.0)
			local barPos = self:GetBarPosForKey(key)
			if barPos ~= "" then
				_BlizzardCooldownUI:ShowCooldown(20.0, barPos)
			end
			local combatPower = _CharInfoManager:CalcCombatPower()
			self:RequestFireBlizzard(combatPower, atkMult)
			log("[SkillManager] 블리자드 사용! (쿨타임 20초)")
		elseif slot.name == "돌진" then
			-- 돌진(4차): 자체 쿨타임 1초(요청으로 3초에서 단축).
			if self._T.rushOnCooldown then
				log("[SkillManager] 돌진: 쿨타임 중")
				return
			end
			local atkMult = _CharInfoManager:GetAttackSpeedMultiplier()
			-- (요청) 딜레이 0.27초 - 그 사이 다른 스킬로 캔슬되지 않게 공용 쿨다운을 건다.
			self._T.skillOnCooldown = true
			_TimerService:SetTimerOnce(function()
				self._T.skillOnCooldown = false
			end, 0.27)
			self._T.rushOnCooldown = true
			_TimerService:SetTimerOnce(function()
				self._T.rushOnCooldown = false
				log("[SkillManager] 돌진 쿨타임 종료")
			end, 1.0)
			local combatPower = _CharInfoManager:CalcCombatPower()
			self:RequestFireRush(combatPower, atkMult, self:GetWeaponMotionClass())
			log("[SkillManager] 돌진 사용! (쿨타임 3초)")
		end
	end

	@ExecSpace("Client")
	method void LockSkillUse(number duration)
		-- 파이널어택(PlayerAttack.TryTriggerFinalAttack)처럼 서버가 클라이언트 입력 없이 자체적으로 발동시키는
		-- 추가타 동안, 클라이언트의 스킬 공용 쿨다운(skillOnCooldown)을 그 지속시간만큼 다시 걸어준다 -
		-- 그렇지 않으면 원본 스킬의 쿨다운은 이미 끝나있어서 추가타 모션 중에도 다른 스킬을 딜레이 없이 쓸 수 있다.
		self._T.skillOnCooldown = true
		log("[SkillManager] LockSkillUse: 파이널어택 동안 스킬 쿨다운 재설정 duration=" .. tostring(duration))
		_TimerService:SetTimerOnce(function()
			self._T.skillOnCooldown = false
		end, duration)
	end

	@ExecSpace("Server")
	method void RequestFirePowerStrike(number combatPower, number atkMultiplier, string weaponClass)
		local player = _UserService:GetUserEntityByUserId(senderUserId)
		if not isvalid(player) then
			log_warning("[SkillManager] RequestFirePowerStrike: player not found")
			return
		end
		---@type PlayerAttack
		local pa = player:GetComponent(PlayerAttack)
		if not isvalid(pa) then
			log_warning("[SkillManager] RequestFirePowerStrike: PlayerAttack component not found")
			return
		end
		pa:AttackPowerStrike(combatPower, atkMultiplier, weaponClass)
		log("[SkillManager] 파워스트라이크 발동! combatPower=" .. tostring(combatPower) .. " atkMultiplier=" .. tostring(atkMultiplier))
	end

	@ExecSpace("Server")
	method void RequestFireGuard()
		-- 가드(패링) 사용: 서버의 PlayerHit에 1초 패링 창을 연다. 실제 판정/무적/성공 통지는
		-- PlayerHit.CheckGuardBlock(공격자 MonsterAttack.IsAttackTarget에서 호출)이 처리한다.
		local player = _UserService:GetUserEntityByUserId(senderUserId)
		if not isvalid(player) then return end
		local hit = player.PlayerHit
		if isvalid(hit) then
			hit:StartGuardParry()
		end
	end

	@ExecSpace("Client")
	method void NotifyGuardParrySuccess()
		-- 가드 패링 성공(서버 PlayerHit.CheckGuardBlock에서 호출): 쿨타임을 5초로 단축하고
		-- 우측 상단에 무적(2초) 버프 아이콘을 띄운다.
		local now = _UtilLogic.ElapsedSeconds
		local shortened = (self._T.guardUseAt or now) + 5.0
		if shortened < (self._T.guardCooldownUntil or 0) then
			self._T.guardCooldownUntil = shortened
			local remaining = math.max(shortened - now, 0.1)
			if (self._T.guardBarPos or "") ~= "" then
				_GuardCooldownUI:ShowCooldown(remaining, self._T.guardBarPos)
			end
		end
		_GuardBuffUI:ShowBuff(2.0)
		log("[SkillManager] 가드 성공! 쿨타임 5초로 단축 + 2초 무적 버프")
	end

	@ExecSpace("Server")
	method void RequestFireSlashBlast(number combatPower, number atkMultiplier, string weaponClass)
		local player = _UserService:GetUserEntityByUserId(senderUserId)
		if not isvalid(player) then
			log_warning("[SkillManager] RequestFireSlashBlast: player not found")
			return
		end
		---@type PlayerAttack
		local pa = player:GetComponent(PlayerAttack)
		if not isvalid(pa) then
			log_warning("[SkillManager] RequestFireSlashBlast: PlayerAttack component not found")
			return
		end
		pa:AttackSlashBlast(combatPower, atkMultiplier, weaponClass)
		log("[SkillManager] 슬래시블러스트 발동! combatPower=" .. tostring(combatPower) .. " atkMultiplier=" .. tostring(atkMultiplier))
	end

	@ExecSpace("Server")
	method void RequestFireLuckySeven(number combatPower, number atkMultiplier)
		local player = _UserService:GetUserEntityByUserId(senderUserId)
		if not isvalid(player) then
			log_warning("[SkillManager] RequestFireLuckySeven: player not found")
			return
		end
		---@type PlayerAttack
		local pa = player:GetComponent(PlayerAttack)
		if not isvalid(pa) then
			log_warning("[SkillManager] RequestFireLuckySeven: PlayerAttack component not found")
			return
		end
		pa:AttackLuckySeven(combatPower, atkMultiplier)
