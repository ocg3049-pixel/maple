	@ExecSpace("ClientOnly")
	method void ToggleWindow()
		local w = _EntityService:GetEntityByPath("/ui/DefaultGroup/SkillWindow")
		if not isvalid(w) then return end
		w.Enable = not w.Enable
		if not w.Enable then
			self:HideSkillTooltip()
			self:ClearSkillSelection()
		end
		log("[SkillManager] 스킬창 " .. (w.Enable and "열림" or "닫힘"))
	end

	-- ScreenTouchEvent로 탭/스킬행 클릭 감지 (UITouchDownEvent 대체)
	@ExecSpace("ClientOnly")
	method void OnSkillWindowTouch(ScreenTouchEvent e)
		if e.TouchId ~= 1 then return end
		local win = _EntityService:GetEntityByPath("/ui/DefaultGroup/SkillWindow")
		if not isvalid(win) or not win.Enable then return end
		local tp = e.TouchPoint
		local tux = tp.x - 960
		local tuy = tp.y - 540
		-- 단축키 세팅 창이 위에 겹쳐 있으면 그 영역의 클릭은 키세팅이 전담한다
		if _KeySettingManager:IsPointInWindow(tux, tuy) then return end
		local wp = win.UITransformComponent.anchoredPosition
		local lx = tux - wp.x
		local ly = tuy - wp.y

		-- 탭 클릭 체크 (탭 중앙 y=210, 폭 62·피치 66) - 원작 스타일 8탭(기본/I/II/III/IV/H/V/VI)
		for k = 0, 7 do
			local tx = -231 + 66 * k
			if math.abs(lx - tx) <= 31 and math.abs(ly - 210) <= 14 then
				local tid = tostring(k)
				log("[SkillManager] 탭클릭: " .. tid)
				self:SwitchSkillTab(tid)
				return
			end
		end

		-- 스킬 카드 클릭 체크 (2열×5행, 카드 254×64, 좌측 x=-132/우측 x=+132, y=126에서 72씩 하강)
		for i = 1, 10 do
			local col = (i - 1) % 2
			local row = math.floor((i - 1) / 2)
			local cx = (col == 0) and -132 or 132
			local cy = 126 - 72 * row
			if math.abs(lx - cx) <= 127 and math.abs(ly - cy) <= 32 then
				log("[SkillManager] 카드클릭: " .. i)
				self:OnSkillRowDragStart(i)
				return
			end
		end
	end

	@ExecSpace("ClientOnly")
	method void OnCloseClick(UITouchDownEvent e)
		if e.TouchId ~= -1 then return end
		local w = _EntityService:GetEntityByPath("/ui/DefaultGroup/SkillWindow")
		if isvalid(w) then w.Enable = false end
		self:HideSkillTooltip()
		self:ClearSkillSelection()
		log("[SkillManager] 닫기")
	end

	@ExecSpace("ClientOnly")
	method void OnTitleBarDown(UITouchDownEvent e)
		if e.TouchId ~= -1 then return end
		self:StartDrag()
	end

	@ExecSpace("ClientOnly")
	method void StartDrag()
		local w = _EntityService:GetEntityByPath("/ui/DefaultGroup/SkillWindow")
		if not isvalid(w) then return end
		self._T.isDragging = true
		local cursor = _InputService:GetCursorPosition()
		local cursorUI = Vector2(cursor.x - 960, cursor.y - 540)
		local winPos = w.UITransformComponent.anchoredPosition
		self._T.dragOffsetX = cursorUI.x - winPos.x
		self._T.dragOffsetY = cursorUI.y - winPos.y
		self:BringWindowToFront()
	end

	@ExecSpace("ClientOnly")
	method void BringWindowToFront()
		local paths = {
			"/ui/DefaultGroup/InvenWindow",
			"/ui/DefaultGroup/EquipWindow",
			"/ui/DefaultGroup/EnhanceWindow",
			"/ui/DefaultGroup/SkillWindow"
		}
		local maxIdx = 0
		for _, p in ipairs(paths) do
			local e = _EntityService:GetEntityByPath(p)
			if isvalid(e) then
				local idx = _UILogic:GetSiblingIndex(e.UITransformComponent)
				if idx > maxIdx then maxIdx = idx end
			end
		end
		local target = _EntityService:GetEntityByPath("/ui/DefaultGroup/SkillWindow")
		if isvalid(target) then
			_UILogic:SetSiblingIndex(target.UITransformComponent, maxIdx)
		end
	end

	-- ── SkillBar 드래그 ────────────────────────────────────────────────

	@ExecSpace("ClientOnly")
	method void OnBarSlotDragStart(string pos)
		-- pos = 퀵슬롯 위치 접미사. 실제 키는 barKeys로 조회한다.
		local key = self:GetKeyForBarPos(pos)
		local slot = self._T.slotData[key]
		if slot == nil or slot.ruid == "" then return end
		self._T.isDraggingSkill = true
		self._T.dragSkillRUID   = slot.ruid
		self._T.dragSkillName   = slot.name
		self._T.dragSource      = "bar"
		self._T.dragFromKey     = key
		self._T.slotData[key] = { ruid = "", name = "" }
		self:UpdateBarSlotVisual(pos)
		_KeySettingManager:NotifyHotkeysChanged()
		self:ShowDragGhost(self._T.dragSkillRUID)
		log("[SkillManager] SkillBar 드래그 시작: [" .. key .. "] " .. slot.name)
		-- 슬롯에서 스킬을 떼어내는 것도 단축키 변경이므로 저장 예약
		_CharacterPersistence:MarkDirty("hotkey")
		-- 어썰터를 슬롯에서 떼어냈다면 스택 수 표시를 숨기거나 갱신한다.
		self:UpdateAssaulterStackUI()
	end

	@ExecSpace("ClientOnly")
	method void ShowDragGhost(string ruid)
		local ghost = _EntityService:GetEntityByPath("/ui/DefaultGroup/SkillDragGhost")
		if not isvalid(ghost) then return end
		local spr = ghost.SpriteGUIRendererComponent
		spr.ImageRUID = ruid
		spr.Color = Color(1, 1, 1, 1)
		-- 기능 고스트(KeySettingManager)와 엔티티를 공유하므로 기능 라벨을 지운다
		local labelEnt = _EntityService:GetEntityByPath("/ui/DefaultGroup/SkillDragGhost/Label")
		if isvalid(labelEnt) then labelEnt.TextComponent.Text = "" end
		local cursor = _InputService:GetCursorPosition()
		ghost.UITransformComponent.anchoredPosition = Vector2(cursor.x - 960, cursor.y - 540)
		ghost.Enable = true
		self:BringGhostToFront()
	end

	@ExecSpace("ClientOnly")
	method void BringGhostToFront()
		-- 고스트는 항상 최상단에 - 키세팅 창 등 나중에 만들어진 창이 고스트를 가리지 않게 한다.
		-- (BringWindowToFront와 동일하게 형제들 중 최대 인덱스로 이동)
		local ghost = _EntityService:GetEntityByPath("/ui/DefaultGroup/SkillDragGhost")
		if not isvalid(ghost) then return end
		local dg = _EntityService:GetEntityByPath("/ui/DefaultGroup")
		if isvalid(dg) then
			local maxIdx = 0
			for _, child in ipairs(dg.Children:ToTable()) do
				if isvalid(child) then
					local idx = _UILogic:GetSiblingIndex(child.UITransformComponent)
					if idx > maxIdx then maxIdx = idx end
				end
			end
			_UILogic:SetSiblingIndex(ghost.UITransformComponent, maxIdx)
		end
	end

	@ExecSpace("ClientOnly")
	method void HideSkillTooltip()
		local tp = _EntityService:GetEntityByPath("/ui/DefaultGroup/SkillTooltipPanel")
		if isvalid(tp) then tp.Enable = false end
	end

	@ExecSpace("ClientOnly")
	method void ClearSkillSelection()
		self._T.skillClickMode = false
		self._T.clickModeRUID  = ""
		self._T.clickModeName  = ""
		self._T.clickModeOrigin = ""
		local ghost = _EntityService:GetEntityByPath("/ui/DefaultGroup/SkillDragGhost")
		if isvalid(ghost) then ghost.Enable = false end
		log("[SkillManager] 클릭 배정 모드 해제")
	end

	@ExecSpace("ClientOnly")
	method void ShowSkillTooltip()
		local tp = _EntityService:GetEntityByPath("/ui/DefaultGroup/SkillTooltipPanel")
		if not isvalid(tp) then return end
		local tabSkills = self._T.skillData[self._T.hoverTabId] or {}
		local skill     = tabSkills[self._T.hoverDataIdx]
		if skill == nil then return end

		-- 툴팁 위치: 스킬창 오른쪽 (창 밖으로 나가면 왼쪽)
		local w = _EntityService:GetEntityByPath("/ui/DefaultGroup/SkillWindow")
		if isvalid(w) then
			local winPos = w.UITransformComponent.anchoredPosition
			-- 카드 그리드(2열×5행): 카드 행 중심 Y = 126 - 행번호*72
			local cardRow = math.floor((self._T.hoverRowIdx - 1) / 2)
			local rowCenterY = 126 - cardRow * 72
			local ty = winPos.y + rowCenterY
			local tx = winPos.x + 395
			if tx + 110 > 940 then tx = winPos.x - 395 end
			tp.UITransformComponent.anchoredPosition = Vector2(tx, ty)
		end

		-- 툴팁 내용
		local tipIcon = _EntityService:GetEntityByPath("/ui/DefaultGroup/SkillTooltipPanel/Icon")
		if isvalid(tipIcon) then
			tipIcon.SpriteGUIRendererComponent.ImageRUID = skill.ruid
			tipIcon.SpriteGUIRendererComponent.Color = Color(1, 1, 1, 1)
		end
		local tipTitle = _EntityService:GetEntityByPath("/ui/DefaultGroup/SkillTooltipPanel/Title")
		if isvalid(tipTitle) then tipTitle.TextComponent.Text = skill.name end
		local tipInfo = _EntityService:GetEntityByPath("/ui/DefaultGroup/SkillTooltipPanel/Info")
		if isvalid(tipInfo) and skill.desc then tipInfo.TextComponent.Text = skill.desc end

		tp.Enable = true
	end

	@ExecSpace("ClientOnly")
	method string FindSkillBarSlot(number cx, number cy)
		local bar = _EntityService:GetEntityByPath("/ui/DefaultGroup/SkillBar")
		if not isvalid(bar) then return "" end
		local barPos = bar.UITransformComponent.anchoredPosition
		local row1 = {"Q","W","E","R","1","2","3","4","T","U","V","X"}
		local row2 = {"A","S","D","F","5","6","7","8","G","H","J","L"}
		local xOff = {-224, -160, -96, -32, 32, 96, 160, 224, 288, 352, 416, 480}
		for i, k in ipairs(row1) do
			local sx = barPos.x + xOff[i]
			local sy = barPos.y + 36
			if math.abs(cx - sx) <= 30 and math.abs(cy - sy) <= 30 then return k end
		end
		for i, k in ipairs(row2) do
			local sx = barPos.x + xOff[i]
			local sy = barPos.y - 36
			if math.abs(cx - sx) <= 30 and math.abs(cy - sy) <= 30 then return k end
		end
		return ""
	end

	@ExecSpace("ClientOnly")
	method void OnAssaulterResult(boolean success)
		-- PlayerAttack.NotifyAssaulterResult가 서버 판정 결과를 알려주면 호출된다. 성공했을 때만 스택을
		-- 1개 소모하고 충전 사이클을 (돌고 있지 않다면) 시작한다 - 실패(사거리 내 대상 없음)면 아무것도
		-- 소모하지 않아 즉시 다시 시도할 수 있다.
		self._T.assaulterRequestPending = false
		if not success then
			log("[SkillManager] 어썰터 실패 - 사거리 내 대상 없음(스택 소모 안 함)")
			return
		end
		self._T.assaulterStacks = math.max(0, self._T.assaulterStacks - 1)
		log("[SkillManager] 어썰터 발동 성공 (남은 스택 " .. tostring(self._T.assaulterStacks) .. "/" .. tostring(self._T.assaulterMaxStacks) .. ")")
		-- 시전 진행 중 잠금 - 착지 알림(OnAssaulterChainReady)이 오면 즉시 풀린다. 알림이 유실되는
		-- 비정상 상황 대비 2초 뒤 자동 해제 안전장치(세대 번호로 다음 시전의 잠금을 건드리지 않게 한다).
		self._T.assaulterCastActive = true
		self._T.assaulterCastGuardSerial = self._T.assaulterCastGuardSerial + 1
		local guardSerial = self._T.assaulterCastGuardSerial
		_TimerService:SetTimerOnce(function()
			if self._T.assaulterCastGuardSerial == guardSerial then
				self._T.assaulterCastActive = false
			end
		end, 2.0)
		self:UpdateAssaulterStackUI()
		self:StartAssaulterRecharge()
	end

	@ExecSpace("ClientOnly")
	method void OnAssaulterChainReady()
		-- 서버(PlayerAttack.ReappearAssaulter)가 착지(순간이동 완료)를 알려주면 곧바로 재시전 가능
		-- 상태로 만든다 - "이동 즉시 딜레이 없이 어썰터만은 연속으로 사용" 요청의 핵심 신호.
		self._T.assaulterCastActive = false
		log("[SkillManager] 어썰터 착지 - 연속 시전 가능")
	end

	@ExecSpace("ClientOnly")
	method string FindAssaulterSlotKey()
		-- 어썰터가 현재 배정된 단축키를 찾는다(없으면 빈 문자열).
		for key, slot in pairs(self._T.slotData) do
			if slot ~= nil and slot.name == "어썰터" then return key end
		end
		return ""
	end

	@ExecSpace("ClientOnly")
	method void StartAssaulterRecharge()
		-- 스택이 최대 미만이고 충전 타이머가 없으면 3초 충전 사이클을 시작한다. 사이클 완료 시 스택 +1,
		-- 아직 최대가 아니면 다음 사이클을 이어서 시작한다 - 그림자(회색 오버레이) 효과도 사이클마다
		-- 다시 차오르므로 풀스택까지 최대 3번 반복해서 차오른다 (요청사항).
		if self._T.assaulterRechargeTimerId ~= nil then return end
		if self._T.assaulterStacks >= self._T.assaulterMaxStacks then return end
		local key = self:FindAssaulterSlotKey()
		local barPos = key ~= "" and self:GetBarPosForKey(key) or ""
		if barPos ~= "" then
			_AssaulterCooldownUI:ShowCooldownV2(3.0, barPos)
		end
		self._T.assaulterRechargeTimerId = _TimerService:SetTimerOnce(function()
			self._T.assaulterRechargeTimerId = nil
			self._T.assaulterStacks = math.min(self._T.assaulterMaxStacks, self._T.assaulterStacks + 1)
			log("[SkillManager] 어썰터 스택 충전 완료 (" .. tostring(self._T.assaulterStacks) .. "/" .. tostring(self._T.assaulterMaxStacks) .. ")")
			self:UpdateAssaulterStackUI()
			self:StartAssaulterRecharge()
		end, 3.0)
	end

	@ExecSpace("ClientOnly")
	method void UpdateAssaulterStackUI()
		-- 스택 수 표시(단축키 아이콘 우측 아래)를 최신 상태로 갱신한다.
		-- AssaulterCooldownUI는 Slot_<위치> 경로를 쓰므로 키 이름을 퀵슬롯 위치로 변환해 넘긴다.
		local key = self:FindAssaulterSlotKey()
		local barPos = key ~= "" and self:GetBarPosForKey(key) or ""
		_AssaulterCooldownUI:UpdateStackDisplay(self._T.assaulterStacks, self._T.assaulterMaxStacks, barPos)
	end

	@ExecSpace("ClientOnly")
	method void AssignSkillToSlot(string key, string ruid, string name)
		-- key = 키 이름 (퀵슬롯 위치가 아님). 해당 키가 퀵슬롯에 연결되어 있으면 그 칸도 갱신된다.
		-- 한 키에는 스킬 또는 기능(장비/인벤/공격/점프...) 중 하나만 올 수 있다 - 기능 키는 거부한다.
		if _KeySettingManager:GetFuncOnKey(key) ~= "" then
			log("[SkillManager] 기능 키 [" .. key .. "] 에는 스킬을 배정할 수 없음: " .. tostring(name))
			return
		end
		self._T.slotData[key] = { ruid = ruid, name = name }
		local pos = self:GetBarPosForKey(key)
		if pos ~= "" then self:UpdateBarSlotVisual(pos) end
		_KeySettingManager:NotifyHotkeysChanged()
		log("[SkillManager] 슬롯 배정: [" .. key .. "] = " .. name)
		-- 단축키 배정 변경 영속 저장 예약 (캐릭터별로 저장되어 재접속 시 복원됨)
		_CharacterPersistence:MarkDirty("hotkey")
		-- 어썰터 배정 위치가 바뀌었을 수 있으므로 스택 수 표시 위치/표시 여부를 갱신한다.
		self:UpdateAssaulterStackUI()
	end

	-- 현재 단축키 배정 상태를 저장용 테이블로 내보낸다 (CharacterPersistence 전용).
	@ExecSpace("ClientOnly")
	method table ExportHotkeys()
		local out = {}
		for key, slot in pairs(self._T.slotData) do
			if slot ~= nil and slot.ruid ~= nil and slot.ruid ~= "" then
				out[key] = { ruid = slot.ruid, name = tostring(slot.name or "") }
			end
		end
		return out
	end

	-- 저장된 단축키 배정을 복원한다 (CharacterPersistence/키세팅 프리셋 전용). 전체 초기화 후 저장된 항목만 배정.
	@ExecSpace("ClientOnly")
	method void ImportHotkeys(table hotkeys)
		self._T.slotData = {}
		self:InitBarIcons()
		if hotkeys == nil then return end
		for key, slot in pairs(hotkeys) do
			if slot ~= nil and slot.ruid ~= nil and slot.ruid ~= "" then
				local keyName = tostring(key)
				-- 과거 세이브 호환: 기능 키(E 등)에 배정돼 있던 스킬은 더 이상 발동하지 않으므로
				-- 첫 번째 빈 퀵슬롯 키로 옮겨준다.
				if _KeySettingManager:GetFuncLabel(keyName) ~= "" then
					local moved = ""
					for _, p in ipairs(self._T.barPositions) do
						local cand = self:GetKeyForBarPos(p)
						local existing = self._T.slotData[cand]
						if _KeySettingManager:GetFuncLabel(cand) == "" and (existing == nil or existing.ruid == "") and (hotkeys[cand] == nil or hotkeys[cand].ruid == nil or hotkeys[cand].ruid == "") then
							moved = cand
							break
						end
					end
					if moved ~= "" then
						log("[SkillManager] 기능 키 [" .. keyName .. "]의 스킬을 [" .. moved .. "]로 이동: " .. tostring(slot.name))
						keyName = moved
					end
				end
				self:AssignSkillToSlot(keyName, tostring(slot.ruid), tostring(slot.name or ""))
			end
		end
	end

	-- ── OnUpdate ──────────────────────────────────────────────────────

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		local cursor  = _InputService:GetCursorPosition()
		local ghostUI = Vector2(cursor.x - 960, cursor.y - 540)

		-- 1-frame 지연 툴팁 표시
		if self._T.pendingShow then
			self._T.pendingShow = false
			if self._T.hovering then self:ShowSkillTooltip() end
		end

		-- 창 드래그
		if self._T.isDragging then
			if not _InputService:IsKeyPressed(KeyboardKey.Mouse0) then
				self._T.isDragging = false
			else
				local w = _EntityService:GetEntityByPath("/ui/DefaultGroup/SkillWindow")
				if isvalid(w) then
					local newX = ghostUI.x - self._T.dragOffsetX
					local newY = ghostUI.y - self._T.dragOffsetY
					if newX < -900 then newX = -900 elseif newX > 900 then newX = 900 end
					if newY < -500 then newY = -500 elseif newY > 500 then newY = 500 end
					w.UITransformComponent.anchoredPosition = Vector2(newX, newY)
				end
			end
		end

		-- 스크롤 썸 드래그
		if self._T.isDraggingSkillThumb then
			if not _InputService:IsKeyPressed(KeyboardKey.Mouse0) then
				self._T.isDraggingSkillThumb = false
			else
				local win = _EntityService:GetEntityByPath("/ui/DefaultGroup/SkillWindow")
				if isvalid(win) then
					local winPos   = win.UITransformComponent.anchoredPosition
					local topLimit = 111
					local botLimit = -147
					local newThumbY = ghostUI.y - winPos.y - self._T.skillThumbDragOffsetY
					newThumbY = math.max(botLimit, math.min(topLimit, newThumbY))
					local tabSkills = self._T.skillData[self._T.activeSkillTab] or {}
					local maxRow    = math.max(0, math.ceil(#tabSkills / 2) - 5)
					local progress  = (topLimit - newThumbY) / (topLimit - botLimit)
					local newRow    = math.floor(progress * maxRow + 0.5)
					newRow = math.max(0, math.min(maxRow, newRow))
					local rowChanged = newRow ~= self._T.skillScrollRow
					self._T.skillScrollRow = newRow
					local th = _EntityService:GetEntityByPath("/ui/DefaultGroup/SkillWindow/SkillScrollThumb")
					if isvalid(th) then
						th.UITransformComponent.anchoredPosition = Vector2(268, newThumbY)
					end
					if rowChanged then self:UpdateSkillViewport() end
				end
			end
		end

		-- 스크롤 트랙 홀드
		if self._T.isHoldingSkillTrack and not self._T.isDraggingSkillThumb then
			if not _InputService:IsKeyPressed(KeyboardKey.Mouse0) then
				self._T.isHoldingSkillTrack = false
			else
				self._T.skillTrackTimer = self._T.skillTrackTimer + delta
				if self._T.skillTrackTimer >= 0.12 then
					self._T.skillTrackTimer = 0.0
					self:SkillScrollTrackStep()
				end
			end
		end

		-- 클릭 배정 모드: 고스트 커서 따라다님
		if self._T.skillClickMode then
			local ghost = _EntityService:GetEntityByPath("/ui/DefaultGroup/SkillDragGhost")
			if isvalid(ghost) then
				ghost.UITransformComponent.anchoredPosition = ghostUI
			end
			-- 스킬창/키세팅 창이 모두 닫히면 배정 모드도 취소
			local cWin = _EntityService:GetEntityByPath("/ui/DefaultGroup/SkillWindow")
			local skillWinOpen = isvalid(cWin) and cWin.Enable
			local keySettingOpen = _KeySettingManager:IsWindowOpen()
			if not skillWinOpen and not keySettingOpen then
				self:ClearSkillSelection()
			else
				-- 새 클릭이 스킬바 슬롯/스킬창/키세팅 창 어디에도 해당하지 않으면(빈 곳 클릭) 배정 해제
				local mouseDown = _InputService:IsKeyPressed(KeyboardKey.Mouse0)
				if mouseDown and self._T.clickModePrevMouse ~= true then
					local slotKey = self:FindSkillBarSlot(ghostUI.x, ghostUI.y)
					local insideWin = false
					if skillWinOpen then
						local wp = cWin.UITransformComponent.anchoredPosition
						local ws = cWin.UITransformComponent.RectSize
						if math.abs(ghostUI.x - wp.x) <= ws.x / 2 and math.abs(ghostUI.y - wp.y) <= ws.y / 2 then
							insideWin = true
						end
					end
					local insideKeySetting = _KeySettingManager:IsPointInWindow(ghostUI.x, ghostUI.y)
					if slotKey == "" and not insideWin and not insideKeySetting then
						-- 키세팅/여분 슬롯에서 집은 스킬을 바닥에 놓으면 여분 슬롯으로 보관된다
						if self._T.clickModeOrigin == "keysetting" or self._T.clickModeOrigin == "spare" then
							_KeySettingManager:AddToSpare(self._T.clickModeRUID, self._T.clickModeName)
							log("[SkillManager] 빈 곳 클릭 — 여분 슬롯으로 이동")
						else
							log("[SkillManager] 빈 곳 클릭 — 클릭 배정 취소")
						end
						self:ClearSkillSelection()
					end
				end
				self._T.clickModePrevMouse = mouseDown
			end
		else
			self._T.clickModePrevMouse = _InputService:IsKeyPressed(KeyboardKey.Mouse0)
		end

		-- 스킬 드래그 (고스트 이동 + 드롭)
		if self._T.isDraggingSkill then
			local ghost = _EntityService:GetEntityByPath("/ui/DefaultGroup/SkillDragGhost")
			if isvalid(ghost) then
				ghost.UITransformComponent.anchoredPosition = ghostUI
			end
			if not _InputService:IsKeyPressed(KeyboardKey.Mouse0) then
				self._T.isDraggingSkill = false
				local dropPos = self:FindSkillBarSlot(ghostUI.x, ghostUI.y)
				local ksKey = _KeySettingManager:FindBindKeyAt(ghostUI.x, ghostUI.y)
				local dropKey = ""
				if dropPos ~= "" then dropKey = self:GetKeyForBarPos(dropPos) elseif ksKey ~= "" then dropKey = ksKey end
				if dropKey ~= "" and _KeySettingManager:GetFuncOnKey(dropKey) ~= "" then
					-- 기능이 배정된 키 위에 드랍 → 배정 불가, 원래 자리로 되돌린다 (스킬이 사라지지 않게)
					if isvalid(ghost) then ghost.Enable = false end
					if self._T.dragSource == "bar" and self._T.dragFromKey ~= "" then
						self:AssignSkillToSlot(self._T.dragFromKey, self._T.dragSkillRUID, self._T.dragSkillName)
					end
					log("[SkillManager] 기능 키 [" .. dropKey .. "] 에는 스킬을 놓을 수 없음 — 되돌림")
					self._T.dragSkillRUID = ""
					self._T.dragSkillName = ""
					self._T.dragSource    = ""
					self._T.dragFromKey   = ""
				elseif dropPos ~= "" then
					-- 슬롯 위에서 릴리즈 → 그 슬롯에 연결된 키에 즉시 배정
					if isvalid(ghost) then ghost.Enable = false end
					self:AssignSkillToSlot(dropKey, self._T.dragSkillRUID, self._T.dragSkillName)
					self._T.dragSkillRUID = ""
					self._T.dragSkillName = ""
					self._T.dragSource    = ""
					self._T.dragFromKey   = ""
				elseif ksKey ~= "" then
					-- 키세팅 창의 키 타일 위에서 릴리즈 → 그 키에 즉시 배정
					if isvalid(ghost) then ghost.Enable = false end
					self:AssignSkillToSlot(ksKey, self._T.dragSkillRUID, self._T.dragSkillName)
					self._T.dragSkillRUID = ""
					self._T.dragSkillName = ""
					self._T.dragSource    = ""
					self._T.dragFromKey   = ""
				elseif self._T.dragSource == "window" then
					-- 스킬창에서 드래그 후 빈 곳 릴리즈 → 클릭 배정 모드 진입
					self._T.skillClickMode = true
					self._T.clickModeRUID  = self._T.dragSkillRUID
					self._T.clickModeName  = self._T.dragSkillName
					self._T.clickModeOrigin = "window"
					log("[SkillManager] 클릭 배정 모드 진입: " .. self._T.dragSkillName)
					self._T.dragSkillRUID = ""
					self._T.dragSkillName = ""
					self._T.dragSource    = ""
					self._T.dragFromKey   = ""
				else
					-- 바에서 드래그 후 빈 곳 릴리즈 → 슬롯 비워짐
					if isvalid(ghost) then ghost.Enable = false end
					log("[SkillManager] 허공에 드랍 — [" .. self._T.dragFromKey .. "] 슬롯 비워짐")
					self._T.dragSkillRUID = ""
					self._T.dragSkillName = ""
					self._T.dragSource    = ""
					self._T.dragFromKey   = ""
				end
			end
		end

		-- 스킬 키 홀드 지속 공격: 쿨다운(스킬 딜레이)이 끝난 시점에 키가 아직 눌려있으면
		-- 떼었다 다시 누르지 않아도 자동으로 이어서 재시전한다. HP포션/미구현 스킬 등
		-- 쿨다운을 사용하지 않는 슬롯은 대상에서 제외해 기존 동작을 그대로 유지한다.
		if not self._T.skillOnCooldown then
			for key, held in pairs(self._T.heldSkillKeys) do
				if held and not self._T.skillOnCooldown then
					local slot = self._T.slotData[key]
					if slot ~= nil and (slot.name == "달팽이 세마리" or slot.name == "파워스트라이크" or slot.name == "슬래시블러스트" or slot.name == "슬래쉬블래스트" or slot.name == "럭키세븐" or slot.name == "더블스탭" or slot.name == "매직클로" or slot.name == "썬더볼트" or slot.name == "힐" or slot.name == "파이어에로우" or slot.name == "아이언 에로우" or slot.name == "헤이스트" or slot.name == "스피어 버스터" or slot.name == "어벤져" or slot.name == "드래곤 로어" or slot.name == "새비지블로우") then
						self:UseSkillInSlot(key)
					end
				end
			end
		end

		-- 텔레포트 홀드 지속 사용: 텔레포트는 공용 쿨다운(skillOnCooldown)과 무관한 독립 쿨다운
		-- (teleportOnCooldown)으로 동작하므로, 위 공용 홀드 반복 블록과 별도로 자신의 쿨다운만 확인해
		-- 키를 누르고 있으면 계속 이어서 사용되도록 한다.
		if not self._T.teleportOnCooldown then
			for key, held in pairs(self._T.heldSkillKeys) do
				if held then
					local slot = self._T.slotData[key]
					if slot ~= nil and slot.name == "텔레포트" then
						self:UseSkillInSlot(key)
					end
				end
			end
		end

		-- (기능 변경) 어썰터 홀드 지속 사용 - 스택형 충전으로 바뀌면서, 키를 누르고 있으면 스택이 있고
		-- 시전 중이 아닐 때(착지 즉시 잠금 해제) 계속 이어서 사용된다. 착지하자마자 다음 시전이 나가므로
		-- 스택이 남아있는 한 딜레이 없이 연속 발동된다.
		if self._T.assaulterStacks > 0 and not self._T.assaulterRequestPending and not self._T.assaulterCastActive then
			for key, held in pairs(self._T.heldSkillKeys) do
				if held then
					local slot = self._T.slotData[key]
					if slot ~= nil and slot.name == "어썰터" then
						self:UseSkillInSlot(key)
					end
				end
			end
		end
	end

end
