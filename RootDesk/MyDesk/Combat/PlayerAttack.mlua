		            end
		            local sc = self.Entity.StateComponent
		            if isvalid(sc) then
		                sc:ChangeState("IDLE")
		                log("[DragonRoar] HandleStateChangeEvent forced back to IDLE from " .. tostring(event.CurrentStateName))
		            end
		        end

		        -- 스피어 버스터 전용 처리 (익스플로젼과 동일한 패턴이지만 별도의 플래그를 사용 - 서로 간섭하지 않는다)
		        if self._T.isSpearBurstMotionPlaying then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedSpearBurstDirX
		            end
		            local motionName = self._T.lockedSpearBurstMotionName
		            if not motionName then return end
		            local avatarRenderer = self.Entity.AvatarRendererComponent
		            if not isvalid(avatarRenderer) then return end
		            local body = avatarRenderer:GetBodyEntity()
		            if not isvalid(body) then return end
		            local motionEvent = ActionStateChangedEvent(motionName, motionName, self._T.lockedSpearBurstPlayRate or 1.0, SpriteAnimClipPlayType.Onetime)
		            body:SendEvent(motionEvent)
		            log("[SpearBurst] HandleStateChangeEvent re-applied motion over " .. tostring(event.CurrentStateName) .. ": " .. tostring(motionName))
		            return
		        end
		        if self._T.isSpearBurstDirectionLocked and event.CurrentStateName ~= "IDLE" then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedSpearBurstDirX
		            end
		            local sc = self.Entity.StateComponent
		            if isvalid(sc) then
		                sc:ChangeState("IDLE")
		                log("[SpearBurst] HandleStateChangeEvent forced back to IDLE from " .. tostring(event.CurrentStateName))
		            end
		        end
		        -- (버그 수정) "여러 스킬 사용 후 숨고르기가 발동하지 않는다"는 신고 - 원인은 여기 있던
		        -- StateChangeEvent 즉시-반응 방식이 각 스킬의 모션 정리용 IDLE→MOVE→IDLE 강제 토글(같은
		        -- 서버 호출 안에서 즉시 IDLE로 돌아가는 내부 정리 동작)까지 "실제 이동"으로 오인해, 숨고르기가
		        -- 시작되기도 전에 항상 취소해버리던 것이었다. 이동 감지는 OnUpdate에서 여러 프레임에 걸쳐
		        -- 지속되는 MOVE 상태만 진짜 이동으로 보는 폴링 방식으로 옮겼다(내부 토글은 한 프레임도 안 돼
		        -- 되돌아가므로 폴링에는 걸리지 않는다). 스킬 재사용으로 인한 중단은 각 Attack* 메서드 시작 시
		        -- StopBreather() 호출이 그대로 담당한다.


		        -- 헤이스트 전용 처리 (힐과 동일한 패턴이지만 별도의 플래그를 사용 - 서로 간섭하지 않는다)
		        if self._T.isHasteMotionPlaying then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedHasteDirX
		            end
		            local motionName = self._T.lockedHasteMotionName
		            if not motionName then return end
		            local avatarRenderer = self.Entity.AvatarRendererComponent
		            if not isvalid(avatarRenderer) then return end
		            local body = avatarRenderer:GetBodyEntity()
		            if not isvalid(body) then return end
		            local motionEvent = ActionStateChangedEvent(motionName, motionName, self._T.lockedHastePlayRate or 1.0, SpriteAnimClipPlayType.Onetime)
		            body:SendEvent(motionEvent)
		            log("[Haste] HandleStateChangeEvent re-applied motion over " .. tostring(event.CurrentStateName) .. ": " .. tostring(motionName))
		            return
		        end
		        if self._T.isHasteDirectionLocked and event.CurrentStateName ~= "IDLE" then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedHasteDirX
		            end
		            local sc = self.Entity.StateComponent
		            if isvalid(sc) then
		                sc:ChangeState("IDLE")
		                log("[Haste] HandleStateChangeEvent forced back to IDLE from " .. tostring(event.CurrentStateName))
		            end
		        end

		        -- 부스터 전용 처리 (힐과 동일한 패턴이지만 별도의 플래그를 사용 - 서로 간섭하지 않는다)
		        if self._T.isBoosterMotionPlaying then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedBoosterDirX
		            end
		            local motionName = self._T.lockedBoosterMotionName
		            if not motionName then return end
		            local avatarRenderer = self.Entity.AvatarRendererComponent
		            if not isvalid(avatarRenderer) then return end
		            local body = avatarRenderer:GetBodyEntity()
		            if not isvalid(body) then return end
		            local motionEvent = ActionStateChangedEvent(motionName, motionName, self._T.lockedBoosterPlayRate or 1.0, SpriteAnimClipPlayType.Onetime)
		            body:SendEvent(motionEvent)
		            log("[Booster] HandleStateChangeEvent re-applied motion over " .. tostring(event.CurrentStateName) .. ": " .. tostring(motionName))
		            return
		        end
		        if self._T.isBoosterDirectionLocked and event.CurrentStateName ~= "IDLE" then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedBoosterDirX
		            end
		            local sc = self.Entity.StateComponent
		            if isvalid(sc) then
		                sc:ChangeState("IDLE")
		                log("[Booster] HandleStateChangeEvent forced back to IDLE from " .. tostring(event.CurrentStateName))
		            end
		        end
	end

	@ExecSpace("ServerOnly")
	@EventSender("Self")
	handler HandlePlayerActionEvent(PlayerActionEvent event)
		        -- Fire attack on "Attack" action
		        if event.ActionName == "Attack" then
		            self:AttackNormal()
		        end
	end

	@ExecSpace("ServerOnly")
	method void AttackDoubleStab(number combatPower, number atkMultiplier)
		        -- (기능 추가) "다른 스킬을 쓰면 숨고르기 모션은 중지" 요청 - 이 스킬을 새로 시전하는 시점에 이전 숨고르기가 재생 중이었다면 즉시 정리한다.
		        self:StopBreather()
		        -- 더블스탭 발동: 파워스트라이크와 동일한 전방 박스 판정 구조를 재사용하되, 공격범위는 2/3로 좁히고
		        -- 럭키세븐처럼 같은 대상을 두 번 연속 찔러(2줄 스택 데미지 스킨) 단일 대상에게 타격한다.
		        -- 사다리/로프/사망 상태에서는 사용 불가 (다른 스킬과 동일 가드).
		        local currentState = self.Entity.StateComponent.CurrentStateName
		        if currentState == "DEAD" or currentState == "CLIMB" or currentState == "LADDER" then
		            return
		        end
		        if self._T.isDoubleStabbing then
		            return
		        end
		        self._T.isDoubleStabbing = true

		        local mult = math.max(0.1, math.min(atkMultiplier or 1.0, 3.0))
		        self._T.pendingDoubleStabCombatPower = combatPower

		        local playerCtrl = self.Entity.PlayerControllerComponent
		        local worldPos = self.Entity.TransformComponent.WorldPosition
		        local dirX = playerCtrl.LookDirectionX
		        self._T.pendingDoubleStabDirX = dirX

		        -- 단일 고정 표적: 방향(dirX)을 고려하는 전용 탐색(FindDoubleStabTarget)을 사용한다.
		        -- (파워스트라이크가 쓰는 FindNearestMonster는 방향을 보지 않아, 밀집 몬스터 구역에서 등 뒤의
		        -- 몬스터를 고르면 좁아진 전방 판정 박스가 빗나가는 문제가 있었다 - 럭키세븐과 동일한 방식으로 해결.)
		        self._T.doubleStabTarget = self:FindDoubleStabTarget(Vector2(worldPos.x, worldPos.y), dirX)

		        self._T.pendingDoubleStabWasControllerEnabled = isvalid(playerCtrl) and playerCtrl.Enable
		        if isvalid(playerCtrl) then
		            playerCtrl.Enable = false
		        end
		        if isvalid(self.Entity.MovementComponent) then
		            self.Entity.MovementComponent:Stop()
		        end

		        -- 스킬 사용 사운드 (더블 스탭 리소스팩 skill/400.img/skill/4001334의 "_audio/Use")
		        self:PlayDoubleStabUseSound(self.Entity)

		        -- 캐릭터 모션: 더블스탭은 단검으로 "찌르는" 모션이 맞아야 하므로, 알려진 찌르기(stab) 계열
		        -- 후보를 전부 모아 매 시전마다 순차 순환한다(GetDoubleStabStab) - 사용자가 실제 화면과
		        -- 로그(PlayDoubleStabMotion sent: <이름>)를 대조해 맞는 이름을 확인한다.
		        local swing = self:GetDoubleStabStab()
		        self:PlayDoubleStabMotion(self.Entity, swing.name, dirX, mult)

		        -- 1번째 찌르기는 파워스트라이크와 동일하게 0.45초 뒤, 2번째는 그 직후(0.15초 뒤, 공격속도 배율 적용)에 판정한다.
		        _TimerService:SetTimerOnce(function()
		            self:DealDoubleStabHit(1, mult)
		        end, 0.45 * mult)
		        _TimerService:SetTimerOnce(function()
		            self:DealDoubleStabHit(2, mult)
		        end, 0.60 * mult)

		        -- 컨트롤 잠금 해제: 파워스트라이크와 동일한 고정 여유분(0.65초 * 배율).
		        _TimerService:SetTimerOnce(function()
		            self:RestoreDoubleStabControl()
		        end, 0.65 * mult)
	end

	@ExecSpace("ServerOnly")
	method Entity FindDoubleStabTarget(Vector2 fromPos, number dirX)
		        -- 더블스탭 전용 대상 탐색: 럭키세븐(FindLuckySevenTarget)과 동일하게 바라보는 방향(dirX) 앞쪽에
		        -- 있는 몬스터만 후보로 삼는다. 파워스트라이크가 쓰는 FindNearestMonster는 방향과 무관하게 그냥
		        -- 가장 가까운 몬스터를 고르는데, 밀집 몬스터 구역에서 등 뒤의 몬스터를 고르면 좁아진(2/3) 전방
		        -- 판정 박스가 그 대상을 빗나가는 문제가 실제로 재현되어(테스트로 확인) 방향 필터가 필요했다.
		        local map = self.Entity.CurrentMap
		        if not isvalid(map) then return nil end
		        local monsterComps = map:GetChildComponentsByTypeName("script.Monster", true)
		        local boxSize = 2.0 * (2.0 / 3.0)
		        local nearest = nil
		        local nearestDist = boxSize
		        for _, comp in ipairs(monsterComps) do
		            ---@type Monster
		            local mc = comp
		            if isvalid(mc) and isvalid(mc.Entity) and not mc.IsDead then
		                local pos = mc.Entity.TransformComponent.WorldPosition
		                local dx = pos.x - fromPos.x
		                local dy = pos.y - fromPos.y
		                if dx * dirX >= 0 and math.abs(dx) <= boxSize and math.abs(dy) <= (boxSize / 2.0) then
		                    local dist = math.abs(dx)
		                    if dist <= nearestDist then
		                        nearest = mc.Entity
		                        nearestDist = dist
		                    end
		                end
		            end
		        end
		        return nearest
	end

	method table GetDoubleStabStab()
		        -- 더블스탭 전용 찌르기(stab) 모션 - 사용자가 실제 화면으로 재확인해 stabO1/stabO2 2개로 최종 확정.
		        -- 매 시전마다 이 둘 중 하나를 무작위로 골라 재생한다(파워스트라이크의 GetPowerStrikeSwing과 동일한 랜덤 방식).
		        local candidates = {
		            { name = "stabO1" },
		            { name = "stabO2" },
		        }
		        local index = _UtilLogic:RandomIntegerRange(1, #candidates)
		        return candidates[index]
	end

	@ExecSpace("Server")
	method void RestoreDoubleStabControl()
		        self._T.isDoubleStabbing = false
		        local playerCtrl = self.Entity.PlayerControllerComponent
		        if isvalid(playerCtrl) and self._T.pendingDoubleStabWasControllerEnabled then
		            playerCtrl.Enable = true
		        end
		        -- (기능 추가) "다른 스킬들을 사용하고 난 다음도 모두 숨고르기 모션을 3번 하도록 해달라"는 요청 -
		        -- 컨트롤이 복구된 이 시점에 공용 숨고르기(PlayBreather)를 시작한다.
		        self:PlayBreather(self.Entity, self._T.pendingDoubleStabDirX or 1)
	end

	@ExecSpace("Server")
	method void DealDoubleStabHit(integer idx, number atkMultiplier)
		        -- 예약된 딜레이(0.45초/0.60초 * 배율) 뒤 호출되어 같은 단일 대상을 향해 전방 박스 판정을 1회 실행한다.
		        -- 대상이 1타에 이미 죽었더라도 2타 판정은 그대로 진행한다 - 럭키세븐과 동일하게, 1타가 오버킬이어도
		        -- 2줄 모두 표시되는 것이 의도된 동작이다(Monster.HandleHitEvent가 IsDead면 실제 Hp 적용만 막고,
		        -- 판정 자체는 DestroyDelay(0.6초) 전까지 유효해 정상적으로 명중 처리된다).
		        if not isvalid(self.Entity) then return end
		        local target = self._T.doubleStabTarget
		        if not isvalid(target) then return end

		        local dirX = self._T.pendingDoubleStabDirX or 1
		        local curWorldPos = self.Entity.TransformComponent.WorldPosition
		        -- 파워스트라이크 판정 박스(2x2, 오프셋 1.0*dirX)의 2/3 크기로 좁힌다. 오프셋도 박스 크기의 절반(=boxSize/2)으로
		        -- 동일한 비율을 유지해, 캐릭터 바로 앞에서 시작해 앞으로 boxSize만큼 뻗는 판정 형태를 그대로 보존한다.
		        local boxSize = 2.0 * (2.0 / 3.0)
		        local attackOffset = Vector2(
		            curWorldPos.x + (boxSize / 2.0) * dirX,
		            curWorldPos.y
		        )

		        -- PlayerAttack이 직접 판정한다 (전용 DoubleStabAttack 컴포넌트에 위임하던 방식은 제거됨 - 플레이어
		        -- 엔티티에 AttackComponent 상속 컴포넌트가 2개(PlayerAttack + DoubleStabAttack) 붙어 있으면
		        -- 엔진이 [LWA-3048] DuplicateComponent로 취급해 자동 데미지 스킨이 우리 수동 표시와 별개로
		        -- 추가 발동되어 "2줄이 2번(총 4줄)" 뜨는 문제가 실측됨. IsAttackTarget/CalcDamage/CalcCritical/
		        -- GetDisplayHitCount를 전부 attackInfo 분기로 PlayerAttack 하나에 합쳐서 이 충돌을 없앤다.)
		        local shape = BoxShape(attackOffset, Vector2(boxSize, boxSize), 0)
		        -- 대상의 DamageSkinSpawnerComponent를 판정 직전 잠깐 떼었다가 붙인다 - 이 컴포넌트가 붙어있는 채로
		        -- 같은 AttackComponent 인스턴스가 같은 대상에게 두 번 연속 Attack()을 걸면(더블스탭 1타/2타),
		        -- GetDisplayHitCount=0을 반환해도 엔진이 히트마다 자동 데미지 숫자를 하나씩 추가로 띄워
		        -- "2줄이 2번(총 4줄)" 뜨는 문제가 있었다(럭키세븐은 매 타격마다 별도 투사체 엔티티를 새로 스폰해
		        -- 이 문제가 없었음 - 동일 컴포넌트 인스턴스 재사용이 근본 원인으로 추정).
		        local targetSkinSpawner = target:GetComponent("MOD.Core.DamageSkinSpawnerComponent")
		        if isvalid(targetSkinSpawner) then target:RemoveComponent("MOD.Core.DamageSkinSpawnerComponent") end
		        local hitComps = self:Attack(shape, "skill.doublestab", CollisionGroups.HitBox)
		        if not isvalid(target:GetComponent("MOD.Core.DamageSkinSpawnerComponent")) then target:AddComponent("MOD.Core.DamageSkinSpawnerComponent") end
		        local actuallyHit = false
		        for _, hc in ipairs(hitComps) do
		            if isvalid(hc) and isvalid(hc.Entity) and hc.Entity == target then
		                actuallyHit = true
		                break
		            end
		        end
		        local damage = self._T.lastDoubleStabDamage or 0
		        if not actuallyHit then
		            -- 대상이 1타에 이미 죽어 판정 자체가 실패해도(코르프스가 더 이상 충돌 판정에 걸리지 않음),
		            -- 럭키세븐과 동일하게 표시용 데미지를 동일 공식으로 새로 굴려 2줄이 항상 뜨도록 한다
		            -- (실제 Hp에는 영향 없는 표시 전용 값 - 이미 죽은 대상이므로 실제 데미지 적용은 불필요).
		            local mult = 1.0 + _UtilLogic:RandomDouble() * (2.6 - 1.0)
		            damage = math.floor((self._T.pendingDoubleStabCombatPower or 0) * mult)
		        end
		        self:ShowDoubleStabDamageSkin(target, damage, idx)
		        self:PlayDoubleStabHitEffect(target, dirX)
		        log("PlayerAttack: AttackDoubleStab hit idx=" .. tostring(idx) .. " actuallyHit=" .. tostring(actuallyHit) .. " damage=" .. tostring(damage))
	end

	@ExecSpace("Multicast")
	method void PlayDoubleStabUseSound(Entity attacker)
		        -- 더블 스탭 리소스팩(skill/400.img/skill/4001334)의 "_audio/Use" 사운드.
		        -- Multicast는 서버 자신도 함께 실행하므로 클라이언트에서만 실행되게 막는다.
		        if not self:IsClient() then return end
		        if not isvalid(attacker) then return end
		        _SoundService:PlaySound("ca4f802052184c0ba47f6971fde80bd0", 1.0)
	end

	@ExecSpace("Client")
	method void ShowDoubleStabDamageSkin(Entity target, integer damage, integer hitIndex)
		        -- 다른 스킬과 동일한 기본 히트 데미지 스킨(RUID)을 사용해 룩앤필을 통일한다.
		        -- 럭키세븐과 동일한 간격(±0.2)으로 1번째/2번째 찌르기가 위아래로 나뉘어 2줄로 쌓인 것처럼 보이게 한다.
		        if not isvalid(target) then return end
		        local offsetY = -0.2
		        if hitIndex == 2 then offsetY = 0.2 end
		        _DamageSkinService:Play(
		            target, "3271c3e79bf04ecba9a107d55495970d", 0,
		            { damage }, DamageSkinTweenType.Default, false,
		            Vector2(0, offsetY), Vector2(1, 1), 1.0, 1.0, LitMode.Default
		        )
		        log("[DoubleStab] ShowDoubleStabDamageSkin hitIndex=" .. tostring(hitIndex) .. " damage=" .. tostring(damage) .. " offsetY=" .. tostring(offsetY))
	end

	@ExecSpace("Client")
	method void PlayDoubleStabHitEffect(Entity target, number dirX)
		        -- 몬스터 몸에서 나타나는 타격 이펙트 (더블 스탭 리소스팩의 CharLevel/20/hit/0)
		        if not isvalid(target) then return end
		        local flipBack = dirX > 0
		        local hitOptions = { ["FlipX"] = flipBack }
		        local serial = _EffectService:PlayEffectAttached("8de01c7022964b1b9d6cf96070073446", target, Vector3(0, 0, 0), 0, Vector3(1, 1, 1), false, hitOptions)
		        -- 몬스터에 어태치된 이펙트가 자연 종료 전에 몬스터가 죽고(Enable=false) 다시 리젠(Enable=true)되면
		        -- 재생이 멈췄다가 리젠 순간 다시 보이는 문제가 있었다 - 짧은 타이머로 명시적으로 제거해 방지한다.
		        _TimerService:SetTimerOnce(function()
		            _EffectService:RemoveEffect(serial)
		        end, 0.5)
	end

	@ExecSpace("Multicast")
	method void PlayDoubleStabMotion(Entity attacker, string motionName, number dirX, number atkMultiplier)
		        -- 더블스탭 전용 세부 모션 재생. 파워스트라이크(PlayAttackMotion)와 동일한 방식 - 별도 플래그로 서로 간섭하지 않는다.
		        if not self:IsClient() then return end
		        if not isvalid(attacker) then return end
		        local avatarRenderer = attacker.AvatarRendererComponent
		        if not isvalid(avatarRenderer) then return end
		        local body = avatarRenderer:GetBodyEntity()
		        if not isvalid(body) then return end

		        avatarRenderer.ShowDefaultWeaponEffects = false

		        local playerCtrl = attacker.PlayerControllerComponent
		        if isvalid(attacker.MovementComponent) then
		            attacker.MovementComponent:Stop()
		        end
		        if isvalid(playerCtrl) then
		            playerCtrl.LookDirectionX = dirX
		        end
		        self._T.isDoubleStabDirectionLocked = true
		        self._T.lockedDoubleStabDirX = dirX
		        self._T.lockedDoubleStabMotionName = motionName
		        self._T.isDoubleStabMotionPlaying = true

		        local mult = math.max(atkMultiplier or 1.0, 0.001)
		        local playRate = 1.0 / mult
		        self._T.lockedDoubleStabPlayRate = playRate

		        local motionEvent = ActionStateChangedEvent(motionName, motionName, playRate, SpriteAnimClipPlayType.Onetime)
		        body:SendEvent(motionEvent)
		        log("[DoubleStab] PlayDoubleStabMotion sent: " .. tostring(motionName) .. " playRate=" .. tostring(playRate))

		        _TimerService:SetTimerOnce(function()
		            if isvalid(avatarRenderer) then
		                avatarRenderer.ShowDefaultWeaponEffects = true
		            end
		            self._T.isDoubleStabMotionPlaying = false
		        end, 0.60 * mult)

		        _TimerService:SetTimerOnce(function()
		            self._T.isDoubleStabDirectionLocked = false
		            local sc = self.Entity.StateComponent
		            if isvalid(sc) and sc.CurrentStateName ~= "DEAD" then
		                sc:ChangeState("IDLE")
		                sc:ChangeState("MOVE")
		                sc:ChangeState("IDLE")
		            end
		        end, 0.80 * mult)
	end

	@ExecSpace("ServerOnly")
	method void AttackMagicClaw(number combatPower, number atkMultiplier)
		        -- (기능 추가) "다른 스킬을 쓰면 숨고르기 모션은 중지" 요청 - 이 스킬을 새로 시전하는 시점에 이전 숨고르기가 재생 중이었다면 즉시 정리한다.
		        self:StopBreather()
		        -- 매직클로 발동: 럭키세븐과 같은 단일 대상·2타·2줄 스택 데미지 스킨이지만, 표창을 던지지 않고
		        -- 더블스탭처럼 그 자리에서 즉시 전방 판정으로 데미지를 준다(리소스/이펙트만 다름).
		        -- 사다리/로프/사망 상태에서는 사용 불가 (다른 스킬과 동일 가드).
		        local currentState = self.Entity.StateComponent.CurrentStateName
		        if currentState == "DEAD" or currentState == "CLIMB" or currentState == "LADDER" then
		            return
		        end
		        if self._T.isMagicClawing then
		            return
		        end
		        self._T.isMagicClawing = true

		        local mult = math.max(0.1, math.min(atkMultiplier or 1.0, 3.0))
		        self._T.pendingMagicClawCombatPower = combatPower

		        local playerCtrl = self.Entity.PlayerControllerComponent
		        local worldPos = self.Entity.TransformComponent.WorldPosition
		        local dirX = playerCtrl.LookDirectionX
		        self._T.pendingMagicClawDirX = dirX

		        -- 단일 고정 표적: 더블스탭과 동일한 방향 인식 탐색(파워스트라이크 판정 박스 크기 그대로 사용).
		        self._T.magicClawTarget = self:FindMagicClawTarget(Vector2(worldPos.x, worldPos.y), dirX)

		        self._T.pendingMagicClawWasControllerEnabled = isvalid(playerCtrl) and playerCtrl.Enable
		        if isvalid(playerCtrl) then
		            playerCtrl.Enable = false
		        end
		        if isvalid(self.Entity.MovementComponent) then
		            self.Entity.MovementComponent:Stop()
		        end

		        -- 스킬 사용 사운드 (즉시)
		        self:PlayMagicClawUseSound(self.Entity)
		        -- 스킬 시전 시작 이펙트 (사용자 몸에서 발현)
		        self:PlayMagicClawStartEffect(self.Entity, dirX)

		        local swing = self:GetMagicClawSwing()
		        self:PlayMagicClawMotion(self.Entity, swing.name, dirX, mult)

		        -- 1번째 할큄은 파워스트라이크와 동일하게 0.45초 뒤, 2번째는 0.1초 텀을 두고 0.55초 뒤에 판정한다.
		        _TimerService:SetTimerOnce(function()
		            self:DealMagicClawHit(1, mult)
		        end, 0.45 * mult)
		        _TimerService:SetTimerOnce(function()
		            self:DealMagicClawHit(2, mult)
		        end, 0.55 * mult)

		        -- 컨트롤 잠금 해제: 2번째 타격 직후(0.60초 * 배율).
		        _TimerService:SetTimerOnce(function()
		            self:RestoreMagicClawControl()
		        end, 0.60 * mult)
	end

	@ExecSpace("ServerOnly")
	method Entity FindMagicClawTarget(Vector2 fromPos, number dirX)
		        -- 매직클로 전용 대상 탐색: 더블스탭(FindDoubleStabTarget)과 동일한 방향 인식 방식.
		        -- 사거리는 파워스트라이크 기준 박스(2칸) 대비 x축(전방) 2.5배·y축(위아래) 1.5배로 늘렸다.
		        local map = self.Entity.CurrentMap
		        if not isvalid(map) then return nil end
		        local monsterComps = map:GetChildComponentsByTypeName("script.Monster", true)
		        local forwardSize = 2.0 * 2.5
		        local verticalSize = 2.0 * 1.5
		        local nearest = nil
		        local nearestDist = forwardSize
		        for _, comp in ipairs(monsterComps) do
		            ---@type Monster
		            local mc = comp
		            if isvalid(mc) and isvalid(mc.Entity) and not mc.IsDead then
		                local pos = mc.Entity.TransformComponent.WorldPosition
		                local dx = pos.x - fromPos.x
		                local dy = pos.y - fromPos.y
		                if dx * dirX >= 0 and math.abs(dx) <= forwardSize and math.abs(dy) <= (verticalSize / 2.0) then
		                    local dist = math.abs(dx)
		                    if dist <= nearestDist then
		                        nearest = mc.Entity
		                        nearestDist = dist
		                    end
		                end
		            end
		        end
		        return nearest
	end

	method table GetMagicClawSwing()
		        -- 매직클로 전용 모션 - 우선 럭키세븐과 동일한 swingO1/O2/O3(한손무기 계열, "아대"로 확인됐던 것과
		        -- 동일 계열)을 순차 순환시켜 사용자가 화면으로 확인 후 확정할 수 있게 한다.
		        local candidates = {
		            { name = "swingO1" },
		            { name = "swingO2" },
		            { name = "swingO3" },
		        }
		        self._T.magicClawSwingIndex = (self._T.magicClawSwingIndex or 0) % #candidates + 1
		        return candidates[self._T.magicClawSwingIndex]
	end

	@ExecSpace("Server")
	method void RestoreMagicClawControl()
		        self._T.isMagicClawing = false
		        local playerCtrl = self.Entity.PlayerControllerComponent
		        if isvalid(playerCtrl) and self._T.pendingMagicClawWasControllerEnabled then
		            playerCtrl.Enable = true
		        end
		        -- (기능 추가) "다른 스킬들을 사용하고 난 다음도 모두 숨고르기 모션을 3번 하도록 해달라"는 요청 -
		        -- 컨트롤이 복구된 이 시점에 공용 숨고르기(PlayBreather)를 시작한다.
		        self:PlayBreather(self.Entity, self._T.pendingMagicClawDirX or 1)
	end

	@ExecSpace("Server")
	method void DealMagicClawHit(integer idx, number atkMultiplier)
		        -- 예약된 딜레이(0.45초/0.55초 * 배율) 뒤 호출되어 같은 단일 대상을 향해 전방 박스 판정을 1회 실행한다.
		        -- 더블스탭과 동일하게, 대상이 1타에 이미 죽었더라도 2타 판정은 그대로 진행해 럭키세븐과 같이
		        -- 1타가 오버킬이어도 2줄 모두 표시되도록 한다.
		        if not isvalid(self.Entity) then return end
		        local target = self._T.magicClawTarget
		        if not isvalid(target) then return end

		        local dirX = self._T.pendingMagicClawDirX or 1
		        local curWorldPos = self.Entity.TransformComponent.WorldPosition
		        -- FindMagicClawTarget과 동일한 사거리(x축 2.5배·y축 1.5배 확장)를 실제 판정 박스에도 적용한다.
		        local forwardSize = 2.0 * 2.5
		        local verticalSize = 2.0 * 1.5
		        local attackOffset = Vector2(
		            curWorldPos.x + (forwardSize / 2.0) * dirX,
		            curWorldPos.y
		        )

		        -- PlayerAttack이 직접 판정한다 (전용 MagicClawAttack 컴포넌트에 위임하던 방식은 제거됨 - 더블스탭과
		        -- 동일하게, 플레이어 엔티티에 AttackComponent 상속 컴포넌트가 2개 붙어 있으면 엔진이
		        -- [LWA-3048] DuplicateComponent로 취급해 자동 데미지 스킨이 추가로 발동되는 문제가 있었다.)
		        -- 대상의 DamageSkinSpawnerComponent도 판정 직전 잠깐 떼었다가 붙인다 - 더블스탭과 동일한 이유
		        -- (같은 AttackComponent 인스턴스로 같은 대상에게 두 번 연속 Attack()을 걸면 GetDisplayHitCount=0을
		        -- 반환해도 히트마다 자동 데미지 숫자가 추가로 뜨는 문제가 있었음 - 럭키세븐은 타격마다 별도
		        -- 투사체 엔티티를 새로 스폰해 이 문제가 없었던 것에서 착안).
		        local shape = BoxShape(attackOffset, Vector2(forwardSize, verticalSize), 0)
		        local targetSkinSpawner = target:GetComponent("MOD.Core.DamageSkinSpawnerComponent")
		        if isvalid(targetSkinSpawner) then target:RemoveComponent("MOD.Core.DamageSkinSpawnerComponent") end
		        local hitComps = self:Attack(shape, "skill.magicclaw", CollisionGroups.HitBox)
		        if not isvalid(target:GetComponent("MOD.Core.DamageSkinSpawnerComponent")) then target:AddComponent("MOD.Core.DamageSkinSpawnerComponent") end
		        local actuallyHit = false
		        for _, hc in ipairs(hitComps) do
		            if isvalid(hc) and isvalid(hc.Entity) and hc.Entity == target then
		                actuallyHit = true
		                break
		            end
		        end
		        local damage = self._T.lastMagicClawDamage or 0
		        if not actuallyHit then
		            -- 대상이 1타에 이미 죽어 판정 자체가 실패해도, 럭키세븐과 동일하게 표시용 데미지를
		            -- 동일 공식으로 새로 굴려 2줄이 항상 뜨도록 한다(실제 Hp에는 영향 없는 표시 전용 값).
		            local mult = 1.0 + _UtilLogic:RandomDouble() * (1.5 - 1.0)
		            damage = math.floor((self._T.pendingMagicClawCombatPower or 0) * mult)
		        end
		        self:ShowMagicClawDamageSkin(target, damage, idx)
		        self:PlayMagicClawHitEffect(target, dirX)
		        log("PlayerAttack: AttackMagicClaw hit idx=" .. tostring(idx) .. " actuallyHit=" .. tostring(actuallyHit) .. " damage=" .. tostring(damage))
	end

	@ExecSpace("Multicast")
	method void PlayMagicClawUseSound(Entity attacker)
		        -- 매직클로 리소스팩(skill/800032.img/skill/80003294)의 사용 사운드. 사용 즉시 재생.
		        if not self:IsClient() then return end
		        if not isvalid(attacker) then return end
		        _SoundService:PlaySound("96edfa618f6a4fe4a4620a5c56eb93b6", 1.0)
	end

	@ExecSpace("Multicast")
	method void PlayMagicClawStartEffect(Entity attacker, number dirX)
		        -- 스킬 사용과 동시에 캐릭터 몸에서 발현되는 시작 이펙트
		        if not self:IsClient() then return end
		        if not isvalid(attacker) then return end
		        local startOptions = { ["FlipX"] = dirX > 0 }
		        _EffectService:PlayEffectAttached("2a0d72e836fb4862aae83087035f3d2a", attacker, Vector3(0, 0, 0), 0, Vector3(1, 1, 1), false, startOptions)
	end

	@ExecSpace("Client")
	method void ShowMagicClawDamageSkin(Entity target, integer damage, integer hitIndex)
		        -- 다른 스킬과 동일한 기본 히트 데미지 스킨(RUID)을 사용해 룩앤필을 통일한다.
		        -- 럭키세븐/더블스탭과 동일한 간격(±0.2)으로 1번째/2번째 타격이 위아래로 나뉘어 2줄로 쌓인 것처럼 보이게 한다.
		        if not isvalid(target) then return end
		        local offsetY = -0.2
		        if hitIndex == 2 then offsetY = 0.2 end
		        _DamageSkinService:Play(
		            target, "3271c3e79bf04ecba9a107d55495970d", 0,
		            { damage }, DamageSkinTweenType.Default, false,
		            Vector2(0, offsetY), Vector2(1, 1), 1.0, 1.0, LitMode.Default
		        )
	end

	@ExecSpace("Client")
	method void PlayMagicClawHitEffect(Entity target, number dirX)
		        -- 맞는 몬스터 몸에서 나타나는 타격 이펙트 + 타격 사운드 (0.1초 텀을 두고 2번 재생됨 - 각 히트마다 1번씩)
		        if not isvalid(target) then return end
		        local flipBack = dirX > 0
		        local hitOptions = { ["FlipX"] = flipBack }
		        local serial = _EffectService:PlayEffectAttached("598d2d1859e84eaab18ae460a0a1e0a4", target, Vector3(0, 0, 0), 0, Vector3(1, 1, 1), false, hitOptions)
		        _SoundService:PlaySound("5f0c2e9b04ee4a3a9d493a863b8a1379", 1.0)
		        -- 몬스터에 어태치된 이펙트가 자연 종료 전에 몬스터가 죽고(Enable=false) 다시 리젠(Enable=true)되면
		        -- 재생이 멈췄다가 리젠 순간 다시 보이는 문제가 있었다 - 짧은 타이머로 명시적으로 제거해 방지한다.
		        _TimerService:SetTimerOnce(function()
		            _EffectService:RemoveEffect(serial)
		        end, 0.5)
	end

	@ExecSpace("Multicast")
	method void PlayMagicClawMotion(Entity attacker, string motionName, number dirX, number atkMultiplier)
		        -- 매직클로 전용 모션 재생. 다른 스킬과 동일한 방식 - 별도 플래그로 서로 간섭하지 않는다.
		        if not self:IsClient() then return end
		        if not isvalid(attacker) then return end
		        local avatarRenderer = attacker.AvatarRendererComponent
		        if not isvalid(avatarRenderer) then return end
		        local body = avatarRenderer:GetBodyEntity()
		        if not isvalid(body) then return end

		        avatarRenderer.ShowDefaultWeaponEffects = false

		        local playerCtrl = attacker.PlayerControllerComponent
		        if isvalid(attacker.MovementComponent) then
		            attacker.MovementComponent:Stop()
		        end
		        if isvalid(playerCtrl) then
		            playerCtrl.LookDirectionX = dirX
		        end
		        self._T.isMagicClawDirectionLocked = true
		        self._T.lockedMagicClawDirX = dirX
		        self._T.lockedMagicClawMotionName = motionName
		        self._T.isMagicClawMotionPlaying = true
		        -- 홀드 지속발동 중 다음 시전이 쿨다운(0.75*mult)만큼 뒤에 시작될 수 있는데, 이 잠금 해제 타이머는
		        -- 그보다 늦은 0.80*mult 뒤에 실행된다. 새 시전이 이미 방향을 다시 잠근 뒤에 이전 시전의 해제
		        -- 타이머가 뒤늦게 실행되며 새 시전의 잠금을 잘못 풀어버려, 그 틈에 방향이 갑자기 바뀌는 문제가
		        -- 있었다(파워스트라이크에서 동일하게 발견·수정한 것과 같은 원인). 시전마다 토큰을 발급해
		        -- "그 사이 더 최근 시전이 없었을 때만" 해제한다.
		        self._T.magicClawLockToken = (self._T.magicClawLockToken or 0) + 1
		        local myMagicClawLockToken = self._T.magicClawLockToken

		        local mult = math.max(atkMultiplier or 1.0, 0.001)
		        local playRate = 1.0 / mult
		        self._T.lockedMagicClawPlayRate = playRate

		        local motionEvent = ActionStateChangedEvent(motionName, motionName, playRate, SpriteAnimClipPlayType.Onetime)
		        body:SendEvent(motionEvent)
		        log("[MagicClaw] PlayMagicClawMotion sent: " .. tostring(motionName) .. " playRate=" .. tostring(playRate))

		        _TimerService:SetTimerOnce(function()
		            if isvalid(avatarRenderer) then
		                avatarRenderer.ShowDefaultWeaponEffects = true
		            end
		            self._T.isMagicClawMotionPlaying = false
		        end, 0.55 * mult)

		        _TimerService:SetTimerOnce(function()
		            if self._T.magicClawLockToken ~= myMagicClawLockToken then return end
		            self._T.isMagicClawDirectionLocked = false
		            local sc = self.Entity.StateComponent
		            if isvalid(sc) and sc.CurrentStateName ~= "DEAD" then
		                sc:ChangeState("IDLE")
		                sc:ChangeState("MOVE")
		                sc:ChangeState("IDLE")
		            end
		        end, 0.80 * mult)
	end

	@ExecSpace("ServerOnly")
	method void AttackTeleport(string direction)
		        -- 텔레포트: 즉시 순간이동 스킬 - 판정/데미지가 없고 모션 재생 딜레이도 없어 다른 스킬처럼 컨트롤러를 잠그지 않는다.
		        if not isvalid(self.Entity) then return end
		        local rb = self.Entity.RigidbodyComponent
		        if not isvalid(rb) then return end
		        local map = self.Entity.CurrentMap
		        if not isvalid(map) then return end
		        local fh = map.FootholdComponent
		        if not isvalid(fh) then return end

		        -- "짧은 거리를 순간이동한다"는 스킬 설명에 맞춰 다른 스킬 사거리(2.0~5.0)와 비슷한 수준으로 고정.
		        -- 기존 3.0 → 30% 감소로 2.1 → 사용자 요청으로 다시 10% 증가해 2.31로 조정.
		        local TELEPORT_DISTANCE = 2.31
		        -- 도착지점에 발판이 없을 때 위/아래로 이 거리 이내에 있는 발판을 대신 찾는다.
		        -- 기존 1.2에서 사용자 요청으로 절반(0.6)으로 축소 - 너무 높은/낮은 발판까지 끌어당겨지는 문제 완화.
		        local VERTICAL_TOLERANCE = 0.6
		        -- 발판 가장자리/벽에 딱 붙어 착지하지 않도록 살짝 여유를 둔다.
		        local EDGE_MARGIN = 0.15
		        -- 발판 표면에 살짝 파묻히지 않도록 위로 띄우는 높이 (다음 프레임에 중력이 바로 붙잡아준다).
		        local LAND_OFFSET = 0.05

		        local curPos3 = self.Entity.TransformComponent.WorldPosition
		        local curPos = Vector2(curPos3.x, curPos3.y)
		        local landing = nil

		        if direction == "up" or direction == "down" then
		            local dirY = (direction == "up") and 1 or -1
		            -- 현재 밟고 있는 발판 표면에서 그대로 위쪽으로 레이캐스트하면 자기 자신(현재 서있는 발판)을
		            -- 거리 0에서 다시 주워버리는 문제가 있다(한쪽면 충돌 판정) - 이동 방향으로 살짝 띄운 지점에서 시작한다.
		            local rayEpsilon = 0.05
		            local rayStart = Vector2(curPos.x, curPos.y + dirY * rayEpsilon)
		            -- 사거리 안에 발판이 여러 겹 있으면(예: 층층이 쌓인 발판) 가장 가까운 것이 아니라
		            -- 갈 수 있는 가장 먼 발판을 우선한다 - RaycastAll로 사거리 내 전부 찾아 거리가 최대인 것을 채택.
		            local hits = fh:RaycastAll(rayStart, Vector2(0, dirY), TELEPORT_DISTANCE - rayEpsilon)
		            local hit = nil
		            local farthestDist = -1
		            for _, h in ipairs(hits) do
		                local d = math.abs(h:GetYByX(curPos.x) - curPos.y)
		                if d > farthestDist then
		                    farthestDist = d
		                    hit = h
		                end
		            end
		            if hit ~= nil then
		                landing = Vector2(curPos.x, hit:GetYByX(curPos.x) + LAND_OFFSET)
		            end
		            -- 조건3: 거리 안에 발판이 없으면 사용 자체가 무효 - 사운드/이펙트도 재생하지 않는다.
		            if landing == nil then
		                log("[PlayerAttack] AttackTeleport 실패: " .. direction .. " 방향 " .. tostring(TELEPORT_DISTANCE) .. " 이내에 발판 없음")
		                return
		            end
		        else
		            local dirX = (direction == "left") and -1 or 1
		            local desiredX = curPos.x + dirX * TELEPORT_DISTANCE

		            -- 경로상에 진짜 벽(IsBlockVerticalLine=true)이 있으면 그 앞에서 멈추도록 목표 X를 앞당긴다.
		            -- 단순히 서로 다른 높이의 발판을 잇는 수직 연결선(절벽 가장자리, IsBlockVerticalLine=false)은
		            -- 실제로 이동을 막지 않으므로 벽으로 취급하지 않는다.
		            local wallHit = fh:Raycast(curPos, Vector2(dirX, 0), TELEPORT_DISTANCE)
		            if wallHit ~= nil and wallHit:IsVertical() and wallHit.IsBlockVerticalLine then
		                local wallX = wallHit:GetCenter().x
		                local clampedByWall = wallX - dirX * EDGE_MARGIN
		                if (dirX > 0 and clampedByWall < desiredX) or (dirX < 0 and clampedByWall > desiredX) then
		                    desiredX = clampedByWall
		                end
		            end

		            -- 조건1: 도착지점에 발판이 없으면 위아래 근접 발판을 찾는다.
		            local nearFh = self:FindNearbyFootholdAtX(fh, desiredX, curPos.y, VERTICAL_TOLERANCE)
		            if nearFh ~= nil then
		                landing = Vector2(desiredX, nearFh:GetYByX(desiredX) + LAND_OFFSET)
		            else
		                -- 조건2: 지금 서있는 발판이 목표 거리보다 먼저 끝나면 끝나는 지점까지만 이동한다.
		                local curFh = rb:GetCurrentFoothold()
		                if curFh ~= nil then
		                    -- 같은 지면이 여러 조각(발판 ID)으로 나뉘어 있을 수 있으므로, 지금 밟은 조각의
		                    -- StartPoint/EndPoint만 보지 않고 이동 방향으로 NextFootholdId/PreviousFootholdId
		                    -- 체인을 바라가며 실제로 지면이 끊기는 진짜 가장자리를 찾는다.
		                    local chainFh = curFh
		                    local farEdgeX = (dirX > 0) and math.max(curFh.StartPoint.x, curFh.EndPoint.x) or math.min(curFh.StartPoint.x, curFh.EndPoint.x)
		                    for _ = 1, 50 do
		                        if (dirX > 0 and farEdgeX >= desiredX) or (dirX < 0 and farEdgeX <= desiredX) then break end
		                        local nextId = (dirX > 0) and chainFh.NextFootholdId or chainFh.PreviousFootholdId
		                        if nextId == nil or nextId == 0 then break end
		                        local nextFh = fh:GetFoothold(nextId)
		                        if nextFh == nil then break end
		                        chainFh = nextFh
		                        farEdgeX = (dirX > 0) and math.max(nextFh.StartPoint.x, nextFh.EndPoint.x) or math.min(nextFh.StartPoint.x, nextFh.EndPoint.x)
		                    end
		                    local clampedX = farEdgeX - dirX * EDGE_MARGIN
		                    local reachesFullDistance = (dirX > 0 and clampedX >= desiredX) or (dirX < 0 and clampedX <= desiredX)
		                    if not reachesFullDistance then
		                        -- 축소된 지점에서도 위아래 발판을 다시 확인한다 (조건2의 "그 지점에서도 위아래 발판 구분" 요구사항).
		                        local nearFh2 = self:FindNearbyFootholdAtX(fh, clampedX, curPos.y, VERTICAL_TOLERANCE)
		                        if nearFh2 ~= nil then
		                            landing = Vector2(clampedX, nearFh2:GetYByX(clampedX) + LAND_OFFSET)
		                        else
		                            landing = Vector2(clampedX, curFh:GetYByX(clampedX) + LAND_OFFSET)
		                        end
		                    end
		                end
		            end

		            if landing == nil then
		                log("[PlayerAttack] AttackTeleport 실패: " .. direction .. " 방향에 착지 가능한 발판 없음")
		                return
		            end
		        end

		        if isvalid(self.Entity.MovementComponent) then
		            self.Entity.MovementComponent:Stop()
		        end
		        -- 실측 결과: SetWorldPosition을 짧은 시간 동안 여러 프레임에 걸쳐 나눠 호출하는 "대시" 방식을 시도했으나,
		        -- 몇 틱 뒤 위치가 원래 자리로 되돌아가는 현상이 재현됨(엔진의 물리/동기화 쪽에서 반복적인 위치
		        -- 갱신을 되돌리는 것으로 추정 - 정확한 내부 매커니즘은 불명). 한 번만 호출하는 방식은 이 세션
		        -- 내내 안정적으로 확인되었으므로, 검증된 단일 호출 방식을 유지한다.
		        rb:SetWorldPosition(landing)
		        self:PlayTeleportEffects(self.Entity, curPos)
		        log("[PlayerAttack] AttackTeleport 성공! direction=" .. direction .. " from=(" .. tostring(curPos.x) .. "," .. tostring(curPos.y) .. ") to=(" .. tostring(landing.x) .. "," .. tostring(landing.y) .. ")")
	end

	method Foothold FindNearbyFootholdAtX(FootholdComponent fh, number x, number y, number tolerance)
		        -- 지정한 x좌표에서 위/아래로 tolerance 거리 이내에 있는 가장 가까운 발판을 찾는다 (없으면 nil).
		        -- 이 지점이 마침 어떤 발판과 정확히 겹쳐 거리 0으로 찾아지는 것은 정상(그 발판 위에 착지)이므로,
		        -- AttackTeleport의 위/아래 이동 분기와 달리 여기서는 시작점을 띄우지 않는다.
		        local upHit = fh:Raycast(Vector2(x, y), Vector2(0, 1), tolerance)
		        local downHit = fh:Raycast(Vector2(x, y), Vector2(0, -1), tolerance)
		        if upHit ~= nil and downHit ~= nil then
		            local upDist = math.abs(upHit:GetYByX(x) - y)
		            local downDist = math.abs(downHit:GetYByX(x) - y)
		            if upDist <= downDist then return upHit end
		            return downHit
		        elseif upHit ~= nil then
		            return upHit
		        elseif downHit ~= nil then
		            return downHit
		        end
		        return nil
	end

	@ExecSpace("Multicast")
	method void PlayTeleportEffects(Entity attacker, Vector2 originPos)
		        -- 텔레포트 사용 사운드 + 이동 전 위치에 잠깐 나타나는 잔상 이펙트. Multicast는 서버도 함께 실행하므로 클라이언트에서만 실행되게 막는다.
		        if not self:IsClient() then return end
		        if not isvalid(attacker) then return end
		        _SoundService:PlaySound("4c1eb6001e9c47eda239cc58443b79cd", 1.0)
		        local serial = _EffectService:PlayEffect("b34e818d784f4a3891c2d50e48ca559d", attacker, Vector3(originPos.x, originPos.y, 0), 0, Vector3(1, 1, 1), false, {})
		        _TimerService:SetTimerOnce(function()
		            _EffectService:RemoveEffect(serial)
		        end, 0.1)
		        -- 텔레포트 전용 카메라 제어(Damping 임시 조정)는 사용자 요청으로 제거함 - 기본 카메라 동작만 남긴다.
	end

	@ExecSpace("ServerOnly")
	method void AttackThunderbolt(number combatPower, number atkMultiplier)
		-- (기능 추가) "다른 스킬을 쓰면 숨고르기 모션은 중지" 요청 - 이 스킬을 새로 시전하는 시점에 이전 숨고르기가 재생 중이었다면 즉시 정리한다.
		self:StopBreather()
		-- 썬더볼트 발동: 방향(앞/뒤) 무관하게 캐릭터 주변의 몬스터 최대 6명을 동시에 타격한다.
		-- 사다리/로프/사망 상태에서는 사용 불가 (다른 스킬과 동일 가드).
		local currentState = self.Entity.StateComponent.CurrentStateName
		if currentState == "DEAD" or currentState == "CLIMB" or currentState == "LADDER" then
			return
		end
		if self._T.isThunderbolting then
			return
		end
		self._T.isThunderbolting = true

		local mult = math.max(0.1, math.min(atkMultiplier or 1.0, 3.0))
		self._T.pendingThunderboltCombatPower = combatPower

		local playerCtrl = self.Entity.PlayerControllerComponent
		local worldPos = self.Entity.TransformComponent.WorldPosition
		local dirX = playerCtrl.LookDirectionX
		self._T.pendingThunderboltDirX = dirX

		-- 방향과 무관하게 앞뒤 모두에서 가까운 순으로 최대 6명을 미리 골라둔다 (실제 Attack 판정 없이 위치만으로 탐색).
		local targets = self:FindThunderboltTargets(Vector2(worldPos.x, worldPos.y), 6)
		self._T.thunderboltTargets = targets

		self._T.pendingThunderboltWasControllerEnabled = isvalid(playerCtrl) and playerCtrl.Enable
		if isvalid(playerCtrl) then
			playerCtrl.Enable = false
		end
		if isvalid(self.Entity.MovementComponent) then
			self.Entity.MovementComponent:Stop()
		end

		-- 스킬 사용 사운드 + 몸쪽 시전 이펙트 (즉시, 1회) + 캐릭터 모션(매직클로와 동일한 후보군/재생 방식)
		self:PlayThunderboltUseSound(self.Entity)
		self:PlayThunderboltStartEffect(self.Entity, dirX)
		local swing = self:GetThunderboltSwing()
		self:PlayThunderboltMotion(self.Entity, swing.name, dirX, mult)

		-- 딜레이 후 미리 골라둔 대상 전원에게 동시에 타격 판정 + 이펙트를 발생시킨다
		-- (슬래쉬블래스트처럼 대상마다 나눠서 순차 타격하는 것이 아니라, 같은 프레임 안에서 한꺼번에 처리).
		_TimerService:SetTimerOnce(function()
			self:DealThunderboltHits(targets)
		end, 0.4 * mult)

		-- 컨트롤 잠금 해제: 타격 판정 직후 여유(0.2초)를 두고, 배율을 적용한다.
		_TimerService:SetTimerOnce(function()
			self:RestoreThunderboltControl()
		end, 0.6 * mult)
	end

	@ExecSpace("ServerOnly")
	method table FindThunderboltTargets(Vector2 fromPos, integer maxCount)
		-- 썬더볼트 대상 선정: 다른 스킬과 달리 방향(dirX) 무관 - 앞뒤 판정 범위(가로 6칸, 세로 1칸) 안의
		-- 살아있는 script.Monster를 가까운 순으로 정렬해 최대 maxCount명까지 후보로 반환한다
		-- (실제 Attack 판정 없이 위치만으로 탐색). 좌우(가로) 범위는 기존 2.0에서 사용자 요청으로 1.5배인 3.0으로 확대.
		local map = self.Entity.CurrentMap
		if not isvalid(map) then return {} end
		local monsterComps = map:GetChildComponentsByTypeName("script.Monster", true)
		local candidates = {}
		for _, comp in ipairs(monsterComps) do
			---@type Monster
			local mc = comp
			if isvalid(mc) and isvalid(mc.Entity) and not mc.IsDead then
				local pos = mc.Entity.TransformComponent.WorldPosition
				local dx = pos.x - fromPos.x
				local dy = pos.y - fromPos.y
				if math.abs(dx) <= 3.0 and math.abs(dy) <= 1.0 then
					table.insert(candidates, { entity = mc.Entity, dist = math.abs(dx) })
				end
			end
		end
		table.sort(candidates, function(a, b) return a.dist < b.dist end)
		local result = {}
		for i = 1, math.min(#candidates, maxCount) do
			table.insert(result, candidates[i].entity)
		end
		return result
	end

	@ExecSpace("Server")
	method void RestoreThunderboltControl()
		self._T.isThunderbolting = false
		local playerCtrl = self.Entity.PlayerControllerComponent
		if isvalid(playerCtrl) and self._T.pendingThunderboltWasControllerEnabled then
			playerCtrl.Enable = true
		end
		-- (기능 추가) "다른 스킬들을 사용하고 난 다음도 모두 숨고르기 모션을 3번 하도록 해달라"는 요청 -
		-- 컨트롤이 복구된 이 시점에 공용 숨고르기(PlayBreather)를 시작한다.
		self:PlayBreather(self.Entity, self._T.pendingThunderboltDirX or 1)
	end

	@ExecSpace("Server")
	method void DealThunderboltHits(table targets)
		-- 예약된 딜레이 뒤 호출되어, 미리 골라둔 대상 전원에게 같은 프레임 안에서 동시에 타격 판정과
		-- 이펙트를 발생시킨다 (슬래쉬블래스트처럼 대상마다 나눠서 순차 타격하지 않음).
		if not isvalid(self.Entity) then return end
		local hitIndex = 0
		for _, target in ipairs(targets) do
			if isvalid(target) then
				-- 이번 Attack() 호출은 이 대상 하나만 통과하도록 지정 (몬스터 밀집 지역에서 이웃까지
				-- 겹쳐 중복 피해가 들어가는 것을 방지 - IsAttackTarget의 thunderboltCurrentTarget 체크 참고).
				self._T.thunderboltCurrentTarget = target
				local targetPos = target.TransformComponent.WorldPosition
				local shape = CircleShape(Vector2(targetPos.x, targetPos.y), 0.6)
				local hitComps = self:Attack(shape, "skill.thunderbolt", CollisionGroups.HitBox)
				local actuallyHit = false
				for _, hc in ipairs(hitComps) do
					if isvalid(hc) and isvalid(hc.Entity) and hc.Entity == target then
						actuallyHit = true
						break
					end
				end
				if actuallyHit then
					-- 피격 이펙트/데미지는 동시에 처리하되, 타격음만 맞은 순서대로 0.04초 간격으로 재생한다
					-- (예: 6마리가 맞으면 0.04초 간격으로 6번 소리가 들림).
					self:PlayThunderboltHitEffect(target)
					local soundDelay = hitIndex * 0.04
					_TimerService:SetTimerOnce(function()
						self:PlayThunderboltHitSound()
					end, soundDelay)
					hitIndex = hitIndex + 1
				end
			end
		end
		log("PlayerAttack: AttackThunderbolt " .. tostring(#targets) .. "명 동시 타격, 실제 명중 " .. tostring(hitIndex) .. "명")
	end

	@ExecSpace("Multicast")
	method void PlayThunderboltUseSound(Entity attacker)
		-- 스킬 사용 즉시 재생되는 사운드. Multicast는 서버 자신도 함께 실행하므로 클라이언트에서만 실행되게 막는다.
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		_SoundService:PlaySound("3a8cf5d7d10f47f79f7bc9bdad81a746", 1.0)
	end

	@ExecSpace("Multicast")
	method void PlayThunderboltStartEffect(Entity attacker, number dirX)
		-- 스킬 사용과 동시에 캐릭터 몸에서 발현되는 시작 이펙트 (1회).
		-- 오프셋: 캐릭터 살짝 앞쪽 위에 있던 것을 사용자 요청으로 살짝 아래·몸쪽으로 이동 -
		-- x는 0.2*dirX(앞쪽으로 치우침) → 0.08*dirX(몸에 더 가깝게), y는 0.15 → 0.0으로 낮춤.
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		local startOptions = { ["FlipX"] = dirX > 0 }
		_EffectService:PlayEffectAttached("7b1fbc817b9a478e9f5c384dfc1a7176", attacker, Vector3(0.08 * dirX, 0.0, 0), 0, Vector3(1, 1, 1), false, startOptions)
	end

	method table GetThunderboltSwing()
		-- 매직클로와 동일한 모션 후보군(swingO1/O2/O3, 한손무기 계열)을 그대로 사용해 매 시전마다 순환 재생한다.
		local candidates = {
			{ name = "swingO1" },
			{ name = "swingO2" },
			{ name = "swingO3" },
		}
		self._T.thunderboltSwingIndex = (self._T.thunderboltSwingIndex or 0) % #candidates + 1
		return candidates[self._T.thunderboltSwingIndex]
	end

	@ExecSpace("Multicast")
	method void PlayThunderboltMotion(Entity attacker, string motionName, number dirX, number atkMultiplier)
		-- 썬더볼트 전용 모션 재생. 매직클로(PlayMagicClawMotion)와 완전히 동일한 방식 - 별도 플래그로 서로 간섭하지 않는다.
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		local avatarRenderer = attacker.AvatarRendererComponent
		if not isvalid(avatarRenderer) then return end
		local body = avatarRenderer:GetBodyEntity()
		if not isvalid(body) then return end

		avatarRenderer.ShowDefaultWeaponEffects = false

		local playerCtrl = attacker.PlayerControllerComponent
		if isvalid(attacker.MovementComponent) then
			attacker.MovementComponent:Stop()
		end
		if isvalid(playerCtrl) then
			playerCtrl.LookDirectionX = dirX
		end
		self._T.isThunderboltDirectionLocked = true
		self._T.lockedThunderboltDirX = dirX
		self._T.lockedThunderboltMotionName = motionName
		self._T.isThunderboltMotionPlaying = true

		local mult = math.max(atkMultiplier or 1.0, 0.001)
		local playRate = 1.0 / mult
		self._T.lockedThunderboltPlayRate = playRate

		local motionEvent = ActionStateChangedEvent(motionName, motionName, playRate, SpriteAnimClipPlayType.Onetime)
		body:SendEvent(motionEvent)
		log("[Thunderbolt] PlayThunderboltMotion sent: " .. tostring(motionName) .. " playRate=" .. tostring(playRate))

		_TimerService:SetTimerOnce(function()
			if isvalid(avatarRenderer) then
				avatarRenderer.ShowDefaultWeaponEffects = true
			end
			self._T.isThunderboltMotionPlaying = false
		end, 0.55 * mult)

		_TimerService:SetTimerOnce(function()
			self._T.isThunderboltDirectionLocked = false
			local sc = self.Entity.StateComponent
			if isvalid(sc) and sc.CurrentStateName ~= "DEAD" then
				sc:ChangeState("IDLE")
				sc:ChangeState("MOVE")
				sc:ChangeState("IDLE")
			end
		end, 0.80 * mult)
	end

	@ExecSpace("Multicast")
	method void PlayThunderboltHitEffect(Entity target)
		-- 타격받는 몬스터 머리 위에 나타나는 이펙트 (대상마다 1회, 전원 동시에 재생됨).
		-- 높이 오프셋은 기존 0.6에서 사용자 요청으로 조금 낮춰 0.3으로 조정.
		if not self:IsClient() then return end
		if not isvalid(target) then return end
		local serial = _EffectService:PlayEffectAttached("bb8d0c3c8b9940dfa5e4678bc642fa8d", target, Vector3(0, 0.3, 0), 0, Vector3(1, 1, 1), false, {})
		_TimerService:SetTimerOnce(function()
			_EffectService:RemoveEffect(serial)
		end, 1.0)
	end

	@ExecSpace("Multicast")
	method void PlayThunderboltHitSound()
		-- 몬스터 타격음. 맞은 몬스터 수만큼, 0.04초 간격으로 순서대로 재생된다
		-- (호출 시점 자체가 DealThunderboltHits에서 인덱스*0.04초 딜레이로 예약되어 있음).
		if not self:IsClient() then return end
		_SoundService:PlaySound("d3205fdd08e34b68bc01292a997531ed", 1.0)
	end

	@ExecSpace("ServerOnly")
	method void AttackHeal(number combatPower, number atkMultiplier)
		-- (기능 추가) "다른 스킬을 쓰면 숨고르기 모션은 중지" 요청 - 이 스킬을 새로 시전하는 시점에 이전 숨고르기가 재생 중이었다면 즉시 정리한다.
		self:StopBreather()
		-- 힐 발동: 항상 자기 자신을 회복시키고, 주변(썬더볼트와 동일한 탐색 범위/최대 6명, 방향 무관)의
		-- 다른 플레이어는 함께 회복시키며, 그 범위 안의 언데드 몬스터(script.Monster.IsUndead=true)는 대신 피해를 입힌다.
		local currentState = self.Entity.StateComponent.CurrentStateName
		if currentState == "DEAD" or currentState == "CLIMB" or currentState == "LADDER" then
			return
		end
		if self._T.isHealing then
			return
		end
		self._T.isHealing = true

		local mult = math.max(0.1, math.min(atkMultiplier or 1.0, 3.0))
		self._T.pendingHealCombatPower = combatPower

		local playerCtrl = self.Entity.PlayerControllerComponent
		local worldPos = self.Entity.TransformComponent.WorldPosition
		local dirX = playerCtrl.LookDirectionX
		self._T.pendingHealDirX = dirX

		-- 자신을 제외한 범위 내 대상(다른 플레이어 + 언데드 몬스터)을 미리 골라둔다 (썬더볼트와 동일한 탐색 범위/최대 6명).
		local targets = self:FindHealTargets(Vector2(worldPos.x, worldPos.y), 6)
		self._T.healTargets = targets

		self._T.pendingHealWasControllerEnabled = isvalid(playerCtrl) and playerCtrl.Enable
		if isvalid(playerCtrl) then
			playerCtrl.Enable = false
		end
		if isvalid(self.Entity.MovementComponent) then
			self.Entity.MovementComponent:Stop()
		end

		-- 스킬 사용 사운드 + 몸쪽 시전 이펙트 (즉시, 1회) + 캐릭터 모션(버프/숨고르기 계열 후보 - 사용자가 화면으로 확인 후 확정 예정)
		self:PlayHealUseSound(self.Entity)
		self:PlayHealStartEffect(self.Entity)
		local motion = self:GetHealMotion()
		self:PlayHealMotion(self.Entity, motion.name, dirX, mult)

		-- 딜레이 후 자신을 무조건 회복시키고, 미리 골라둔 대상 전원에게 동시에 회복/피해를 적용한다.
		_TimerService:SetTimerOnce(function()
			self:DealHealEffects(targets)
		end, 0.4 * mult)

		-- 컨트롤 잠금 해제: 처리 직후 여유(0.2초)를 두고, 배율을 적용한다.
		_TimerService:SetTimerOnce(function()
			self:RestoreHealControl()
		end, 0.6 * mult)
	end

	@ExecSpace("ServerOnly")
	method table FindHealTargets(Vector2 fromPos, integer maxCount)
		-- 힐 대상 선정: 썬더볼트와 동일한 탐색 범위(방향 무관, 가로 6칸·세로 1칸)에서 자신을 제외한
		-- 다른 플레이어(회복 대상)와 언데드 몬스터(script.Monster.IsUndead=true, 피해 대상)를 함께 찾아
		-- 가까운 순으로 정렬해 최대 maxCount명까지 후보로 반환한다. 각 항목은 { entity, kind = "player"|"undead" }.
		local map = self.Entity.CurrentMap
		if not isvalid(map) then return {} end
		local candidates = {}

		local mapComp = map.MapComponent
		if isvalid(mapComp) then
			local users = _UserService:GetUsersByMapComponent(mapComp)
			if users ~= nil then
				for _, userEntity in ipairs(users) do
					if isvalid(userEntity) and userEntity ~= self.Entity then
						local pc = userEntity.PlayerComponent
						if isvalid(pc) and not pc:IsDead() then
							local pos = userEntity.TransformComponent.WorldPosition
							local dx = pos.x - fromPos.x
							local dy = pos.y - fromPos.y
							if math.abs(dx) <= 3.0 and math.abs(dy) <= 1.0 then
								table.insert(candidates, { entity = userEntity, dist = math.abs(dx), kind = "player" })
							end
						end
					end
				end
			end
		end

		local monsterComps = map:GetChildComponentsByTypeName("script.Monster", true)
		for _, comp in ipairs(monsterComps) do
			---@type Monster
			local mc = comp
			if isvalid(mc) and isvalid(mc.Entity) and not mc.IsDead and mc.IsUndead then
				local pos = mc.Entity.TransformComponent.WorldPosition
				local dx = pos.x - fromPos.x
				local dy = pos.y - fromPos.y
				if math.abs(dx) <= 3.0 and math.abs(dy) <= 1.0 then
					table.insert(candidates, { entity = mc.Entity, dist = math.abs(dx), kind = "undead" })
				end
			end
		end

		table.sort(candidates, function(a, b) return a.dist < b.dist end)
		local result = {}
		for i = 1, math.min(#candidates, maxCount) do
			table.insert(result, candidates[i])
		end
		return result
	end

	@ExecSpace("Server")
	method void RestoreHealControl()
		self._T.isHealing = false
		local playerCtrl = self.Entity.PlayerControllerComponent
		if isvalid(playerCtrl) and self._T.pendingHealWasControllerEnabled then
			playerCtrl.Enable = true
		end
		-- (기능 추가) "다른 스킬들을 사용하고 난 다음도 모두 숨고르기 모션을 3번 하도록 해달라"는 요청 -
		-- 컨트롤이 복구된 이 시점에 공용 숨고르기(PlayBreather)를 시작한다.
		self:PlayBreather(self.Entity, self._T.pendingHealDirX or 1)
	end

	@ExecSpace("Server")
	method void DealHealEffects(table targets)
		-- 예약된 딜레이 뒤 호출된다. 자신은 무조건 회복시키고(대상 목록과 무관), 목록의 각 대상은
		-- 종류(kind)에 따라 회복 또는 언데드 피해를 동시에 처리한다 (썬더볼트처럼 순차 딜레이 없음).
		if not isvalid(self.Entity) then return end

		self:ApplyHealToPlayer(self.Entity, self._T.pendingHealCombatPower or 0)

		for _, t in ipairs(targets) do
			if isvalid(t.entity) then
				if t.kind == "player" then
					self:ApplyHealToPlayer(t.entity, self._T.pendingHealCombatPower or 0)
				elseif t.kind == "undead" then
					-- 이번 Attack() 호출은 이 대상 하나만 통과하도록 지정 (썬더볼트와 동일한 교차 히트 방지 패턴).
					self._T.healCurrentUndeadTarget = t.entity
					local targetPos = t.entity.TransformComponent.WorldPosition
					local shape = CircleShape(Vector2(targetPos.x, targetPos.y), 0.6)
					local hitComps = self:Attack(shape, "skill.heal", CollisionGroups.HitBox)
					local actuallyHit = false
					for _, hc in ipairs(hitComps) do
						if isvalid(hc) and isvalid(hc.Entity) and hc.Entity == t.entity then
							actuallyHit = true
							break
						end
					end
					if actuallyHit then
						self:PlayHealUndeadHitSound()
						self:PlayHealUndeadHitEffect(t.entity)
					end
				end
			end
		end
		log("PlayerAttack: AttackHeal 처리 완료 대상=" .. tostring(#targets))
	end

	@ExecSpace("Server")
	method void ApplyHealToPlayer(Entity target, number combatPower)
		-- 전투력의 10%를 기준으로 ±50% 범위(즉 전투력의 5%~15%) 내에서 랜덤한 양만큼 HP를 회복시킨다
		-- (보유 중인 최대 HP를 넘지 않도록 클램프). 실제로 회복된 양만큼만 데미지스킨으로 숫자 표시 + 대상 머리 위 이펙트 재생.
		if not isvalid(target) then return end
		local pc = target.PlayerComponent
		if not isvalid(pc) then return end
		local baseHeal = combatPower * 0.10
		local mult = 0.5 + _UtilLogic:RandomDouble() * 1.0
		local healAmount = math.floor(baseHeal * mult)
		if healAmount <= 0 then return end
		local newHp = math.min(pc.Hp + healAmount, pc.MaxHp)
		local actualHealed = newHp - pc.Hp
		if actualHealed <= 0 then return end
		pc.Hp = newHp
		self:PlayHealTargetEffect(target)
		self:ShowHealDamageSkin(target, actualHealed)
	end

	@ExecSpace("Multicast")
	method void PlayHealUseSound(Entity attacker)
		-- 스킬 사용 즉시 재생되는 사운드. Multicast는 서버 자신도 함께 실행하므로 클라이언트에서만 실행되게 막는다.
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		_SoundService:PlaySound("a1a425ae3c1c49afa068ee212676c5dc", 1.0)
	end

	@ExecSpace("Multicast")
	method void PlayHealStartEffect(Entity attacker)
		-- 스킬 사용과 동시에 캐릭터 몸에서 발현되는 시작 이펙트 (1회).
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		_EffectService:PlayEffectAttached("26a8af1751324d2c9f14b1719a28d3c8", attacker, Vector3(0, 0, 0), 0, Vector3(1, 1, 1), false, {})
	end

	@ExecSpace("Multicast")
	method void PlayHealTargetEffect(Entity target)
		-- 힐을 받은 대상(자신 포함) 머리 위에 나타나는 이펙트 (1회).
		if not self:IsClient() then return end
		if not isvalid(target) then return end
		local serial = _EffectService:PlayEffectAttached("26a8af1751324d2c9f14b1719a28d3c8", target, Vector3(0, 0.6, 0), 0, Vector3(1, 1, 1), false, {})
		_TimerService:SetTimerOnce(function()
			_EffectService:RemoveEffect(serial)
		end, 1.0)
	end

	@ExecSpace("Multicast")
	method void PlayHealUndeadHitSound()
		-- 언데드 몬스터가 힐로 피해를 입을 때 재생되는 사운드.
		if not self:IsClient() then return end
		_SoundService:PlaySound("38052d3003a941759a340ae28611d4dd", 1.0)
	end

	@ExecSpace("Multicast")
	method void PlayHealUndeadHitEffect(Entity target)
		-- 언데드 몬스터가 힐로 피해를 입을 때만 머리 위에 나타나는 이펙트 (1회). 다른 공격에는 재생되지 않는다.
		if not self:IsClient() then return end
		if not isvalid(target) then return end
		local headY = 0.5
		local hit = target.HitComponent
		if isvalid(hit) then
			headY = hit.ColliderOffset.y + hit.BoxSize.y / 2
		end
		local serial = _EffectService:PlayEffectAttached("e81f0ba3f2b545d7895b98b1cf9be879", target, Vector3(0, headY, 0), 0, Vector3(1, 1, 1), false, {})
		_TimerService:SetTimerOnce(function()
			_EffectService:RemoveEffect(serial)
		end, 1.0)
	end

	@ExecSpace("Client")
	method void ShowHealDamageSkin(Entity target, integer healAmount)
		-- 회복된 양을 데미지처럼 숫자로 표시한다 (전용 데미지스킨 RUID 사용).
		if not isvalid(target) then return end
		_DamageSkinService:Play(
			target, "d58b67cf0f3a4eaf9fe1ad87c0ffac8a", 0,
			{ healAmount }, DamageSkinTweenType.Default, false,
			Vector2(0, 0), Vector2(1, 1), 1.0, 1.0, LitMode.Default
		)
	end

	method table GetHealMotion()
		-- 사용자가 실제 화면으로 비교한 뒤 "alert" 동작으로 최종 확정.
		return { name = "alert" }
	end

	@ExecSpace("Multicast")
	method void PlayHealMotion(Entity attacker, string motionName, number dirX, number atkMultiplier)
		-- 힐 전용 모션 재생. 썬더볼트/매직클로와 동일한 방식 - 별도 플래그로 서로 간섭하지 않는다.
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		local avatarRenderer = attacker.AvatarRendererComponent
		if not isvalid(avatarRenderer) then return end
		local body = avatarRenderer:GetBodyEntity()
		if not isvalid(body) then return end

		avatarRenderer.ShowDefaultWeaponEffects = false

		local playerCtrl = attacker.PlayerControllerComponent
		if isvalid(attacker.MovementComponent) then
			attacker.MovementComponent:Stop()
		end
		if isvalid(playerCtrl) then
			playerCtrl.LookDirectionX = dirX
		end
		self._T.isHealDirectionLocked = true
		self._T.lockedHealDirX = dirX
		self._T.lockedHealMotionName = motionName
		self._T.isHealMotionPlaying = true

		local mult = math.max(atkMultiplier or 1.0, 0.001)
		local playRate = 1.0 / mult
		self._T.lockedHealPlayRate = playRate

		local motionEvent = ActionStateChangedEvent(motionName, motionName, playRate, SpriteAnimClipPlayType.Onetime)
		body:SendEvent(motionEvent)
		log("[Heal] PlayHealMotion sent: " .. tostring(motionName) .. " playRate=" .. tostring(playRate))

		_TimerService:SetTimerOnce(function()
			if isvalid(avatarRenderer) then
				avatarRenderer.ShowDefaultWeaponEffects = true
			end
			self._T.isHealMotionPlaying = false
		end, 0.55 * mult)

		_TimerService:SetTimerOnce(function()
			self._T.isHealDirectionLocked = false
			local sc = self.Entity.StateComponent
			if isvalid(sc) and sc.CurrentStateName ~= "DEAD" then
				sc:ChangeState("IDLE")
				sc:ChangeState("MOVE")
				sc:ChangeState("IDLE")
			end
		end, 0.80 * mult)
	end

	@ExecSpace("ServerOnly")
	method void AttackHaste(number atkMultiplier)
		-- (기능 추가) "다른 스킬을 쓰면 숨고르기 모션은 중지" 요청 - 이 스킬을 새로 시전하는 시점에 이전 숨고르기가 재생 중이었다면 즉시 정리한다.
		self:StopBreather()
		-- 헤이스트: 이동속도 40%, 점프력 20% 증가(5분). 최초 사용 시 원본 값을 한 번만 캡처해두고
		-- 이후에는 항상 그 원본 값 기준으로 배율을 재계산하므로, 지속 중 다시 사용해도 중첩되지 않고
		-- 지속시간만 갱신된다(토큰 비교로 먼저 걸린 타이머의 원복을 무시).
		local currentState = self.Entity.StateComponent.CurrentStateName
		if currentState == "DEAD" then
			return
		end

		local movement = self.Entity.MovementComponent
		if not isvalid(movement) then
			return
		end

		-- 힐과 동일한 모션(alert)을 재생하고, 그동안 다른 행동을 제한한다.
		local mult = math.max(atkMultiplier or 1.0, 0.001)
		local playerCtrl = self.Entity.PlayerControllerComponent
		local dirX = isvalid(playerCtrl) and playerCtrl.LookDirectionX or 1
		self._T.pendingHasteDirX = dirX
		self._T.pendingHasteWasControllerEnabled = isvalid(playerCtrl) and playerCtrl.Enable
		if isvalid(playerCtrl) then
			playerCtrl.Enable = false
		end
		movement:Stop()
		self:PlayHasteMotion(self.Entity, "alert", dirX, mult)
		_TimerService:SetTimerOnce(function()
			self:RestoreHasteControl()
		end, 0.6 * mult)

		if not self._T.hasteBaseCaptured then
			self._T.hasteBaseInputSpeed = movement.InputSpeed
			self._T.hasteBaseJumpForce = movement.JumpForce
			self._T.hasteBaseCaptured = true
		end

		movement.InputSpeed = self._T.hasteBaseInputSpeed * 1.4
		movement.JumpForce = self._T.hasteBaseJumpForce * 1.2

		self._T.hasteToken = (self._T.hasteToken or 0) + 1
		local myHasteToken = self._T.hasteToken
		local duration = 300

		self:PlayHasteCastEffect(self.Entity)

		local userId = self.Entity.PlayerComponent.UserId
		self:NotifyHasteStart(duration, userId)

		_TimerService:SetTimerOnce(function()
			if self._T.hasteToken ~= myHasteToken then return end
			if isvalid(movement) then
				movement.InputSpeed = self._T.hasteBaseInputSpeed
				movement.JumpForce = self._T.hasteBaseJumpForce
			end
		end, duration)
	end

	@ExecSpace("Multicast")
	method void PlayHasteCastEffect(Entity attacker)
		-- 헤이스트 시전 이펙트: 캐릭터 몸쪽에서 1회 재생 + 사용 사운드.
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		local serial = _EffectService:PlayEffectAttached("410e6a09f8ec471f87bd8d55c34cc48d", attacker, Vector3(0, 0, 0), 0, Vector3(1, 1, 1), false, {})
		_SoundService:PlaySound("64795afda95e4b7dbdbdfe731e7d405a", 1.0)
		_TimerService:SetTimerOnce(function()
			_EffectService:RemoveEffect(serial)
		end, 1.5)
	end

	@ExecSpace("Client")
	method void NotifyHasteStart(number duration)
		-- 헤이스트 버프 타이머 UI 표시(본인 클라이언트에게만 - 호출부에서 UserId를 마지막 인자로 추가해 타겟팅).
		_HasteBuffUI:ShowBuff(duration)
	end

	@ExecSpace("Multicast")
	method void PlayHasteMotion(Entity attacker, string motionName, number dirX, number atkMultiplier)
		-- 헤이스트 전용 모션 재생 (힐과 동일한 방식/모션 - 별도 플래그로 서로 간섭하지 않는다).
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		local avatarRenderer = attacker.AvatarRendererComponent
		if not isvalid(avatarRenderer) then return end
		local body = avatarRenderer:GetBodyEntity()
		if not isvalid(body) then return end

		avatarRenderer.ShowDefaultWeaponEffects = false

		local playerCtrl = attacker.PlayerControllerComponent
		if isvalid(attacker.MovementComponent) then
			attacker.MovementComponent:Stop()
		end
		if isvalid(playerCtrl) then
			playerCtrl.LookDirectionX = dirX
		end
		self._T.isHasteDirectionLocked = true
		self._T.lockedHasteDirX = dirX
		self._T.lockedHasteMotionName = motionName
		self._T.isHasteMotionPlaying = true

		local mult = math.max(atkMultiplier or 1.0, 0.001)
		local playRate = 1.0 / mult
		self._T.lockedHastePlayRate = playRate

		local motionEvent = ActionStateChangedEvent(motionName, motionName, playRate, SpriteAnimClipPlayType.Onetime)
		body:SendEvent(motionEvent)
		log("[Haste] PlayHasteMotion sent: " .. tostring(motionName) .. " playRate=" .. tostring(playRate))

		_TimerService:SetTimerOnce(function()
			if isvalid(avatarRenderer) then
				avatarRenderer.ShowDefaultWeaponEffects = true
			end
			self._T.isHasteMotionPlaying = false
		end, 0.55 * mult)

		_TimerService:SetTimerOnce(function()
			self._T.isHasteDirectionLocked = false
			local sc = self.Entity.StateComponent
			if isvalid(sc) and sc.CurrentStateName ~= "DEAD" then
				sc:ChangeState("IDLE")
				sc:ChangeState("MOVE")
				sc:ChangeState("IDLE")
			end
		end, 0.80 * mult)
	end

	@ExecSpace("Server")
	method void RestoreHasteControl()
		local playerCtrl = self.Entity.PlayerControllerComponent
		if isvalid(playerCtrl) and self._T.pendingHasteWasControllerEnabled then
			playerCtrl.Enable = true
		end
		-- (기능 추가) "다른 스킬들을 사용하고 난 다음도 모두 숨고르기 모션을 3번 하도록 해달라"는 요청 -
		-- 컨트롤이 복구된 이 시점에 공용 숨고르기(PlayBreather)를 시작한다.
		self:PlayBreather(self.Entity, self._T.pendingHasteDirX or 1)
	end

	@ExecSpace("ServerOnly")
	method void AttackComboAttack(number atkMultiplier)
		-- (기능 추가) "다른 스킬을 쓰면 숨고르기 모션은 중지" 요청 - 이 스킬을 새로 시전하는 시점에 이전 숨고르기가 재생 중이었다면 즉시 정리한다.
		self:StopBreather()
		-- 콤보 어택(3차 버프, 30분): 시전 이펙트(skill/1111.img/skill/11111001의 effect 클립) +
		-- 사용 사운드(_audio/Use)를 1회 재생하고, 버프 지속 중 적을 hit할 때마다(OnAttack) 콤보
		-- 구슬이 1개씩(최대 10개, 물리적 구슬 엔티티는 5개까지만 스폰되고 6~10번째는 색 전환으로 표시)
		-- 몸 주위를 공전하며 쌓인다. 구슬 1개당 데미지 +20%(10개 = +200%,
		-- CalcDamage의 ApplyComboAttackBonus에서 일괄 적용). 헤이스트와 동일하게 시전 중에는
		-- 컨트롤을 잠그고(딜레이), 지속 중 재사용하면 중첩 없이 지속시간만 갱신된다(토큰 비교).
		local currentState = self.Entity.StateComponent.CurrentStateName
		if currentState == "DEAD" then
			return
		end

		local mult = math.max(atkMultiplier or 1.0, 0.001)
		local playerCtrl = self.Entity.PlayerControllerComponent
		local dirX = isvalid(playerCtrl) and playerCtrl.LookDirectionX or 1
		self._T.pendingComboDirX = dirX
		self._T.pendingComboWasControllerEnabled = isvalid(playerCtrl) and playerCtrl.Enable
		if isvalid(playerCtrl) then
			playerCtrl.Enable = false
		end
		if isvalid(self.Entity.MovementComponent) then
			self.Entity.MovementComponent:Stop()
		end

		-- 시전 모션: 정확한 전용 자세를 아직 실측 확정하지 못해 사용할 때마다 후보를 순서대로
		-- 하나씩 바꿔가며 재생하고 로그로 남긴다 - 화면과 로그를 대조해 마음에 드는 이름을
		-- 알려주면 그걸로 고정한다(스피어 버스터의 stabT2 확정 때와 동일한 절차).
		local motionName = self:GetComboAttackMotionName()
		self:PlayComboAttackMotion(self.Entity, dirX, mult, motionName)
		_TimerService:SetTimerOnce(function()
			self:RestoreComboAttackControl()
		end, 0.6 * mult)

		self:PlayComboAttackCastEffect(self.Entity, dirX)

		self._T.comboAttackToken = (self._T.comboAttackToken or 0) + 1
		local myToken = self._T.comboAttackToken
		local duration = 1800 -- 30분
		self._T.comboAttackActive = true

		local userId = self.Entity.PlayerComponent.UserId
		self:NotifyComboAttackStart(duration, userId)

		_TimerService:SetTimerOnce(function()
			if self._T.comboAttackToken ~= myToken then return end
			self._T.comboAttackActive = false
			self:ClearComboOrbs()
			log("[ComboAttack] 버프 종료(30분 경과)")
		end, duration)
		log("[ComboAttack] 버프 시작 duration=" .. tostring(duration))
	end

	method string GetComboAttackMotionName()
		-- 시전 자세 모션. 후보 순환 테스트 결과 첫 번째 후보(alert)로 확정했다 - 고정 재생.
		return "alert"
	end

	@ExecSpace("Multicast")
	method void PlayComboAttackMotion(Entity attacker, number dirX, number atkMultiplier, string motionName)
		-- 시전 모션을 1회 재생한다(헤이스트의 PlayHasteMotion과 동일한 방식 - 별도 플래그 없이
		-- 컨트롤 잠금(0.6*mult) 구간 동안만 재생되는 짧은 자세라 상태 재적용 훅은 두지 않는다).
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		local avatarRenderer = attacker.AvatarRendererComponent
		if not isvalid(avatarRenderer) then return end
		local body = avatarRenderer:GetBodyEntity()
		if not isvalid(body) then return end

		local playerCtrl = attacker.PlayerControllerComponent
		if isvalid(attacker.MovementComponent) then
			attacker.MovementComponent:Stop()
		end
		if isvalid(playerCtrl) then
			playerCtrl.LookDirectionX = dirX
		end

		local mult = math.max(atkMultiplier or 1.0, 0.001)
		local playRate = 1.0 / mult
		local motionEvent = ActionStateChangedEvent(motionName, motionName, playRate, SpriteAnimClipPlayType.Onetime)
		body:SendEvent(motionEvent)
		log("[ComboAttack] PlayComboAttackMotion sent " .. tostring(motionName) .. " playRate=" .. tostring(playRate))

		_TimerService:SetTimerOnce(function()
			local sc = attacker.StateComponent
			if isvalid(sc) and sc.CurrentStateName ~= "DEAD" then
				sc:ChangeState("IDLE")
				sc:ChangeState("MOVE")
				sc:ChangeState("IDLE")
			end
		end, 0.80 * mult)
	end

	@ExecSpace("Multicast")
	method void PlayComboAttackCastEffect(Entity attacker, number dirX)
		-- 시전 이펙트(마법진 버스트, 참고 영상 '콤보어택 사용시') 1회 + 사용 사운드.
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		local flipX = dirX > 0
		_EffectService:PlayEffectAttached("19e3ba3ab994431b81a3d4ee7a1b86e0", attacker, Vector3(0, 0, 0), 0, Vector3(1, 1, 1), false, { ["FlipX"] = flipX })
		_SoundService:PlaySound("4b254b65adbe4df4885acbe2e2fa3671", 1.0)
		log("[ComboAttack] 시전 이펙트/사운드 재생")
	end

	@ExecSpace("Client")
	method void NotifyComboAttackStart(number duration)
		-- 콤보 어택 버프 타이머 UI 표시(본인 클라이언트에게만 - 호출부에서 UserId를 마지막 인자로 타겟팅).
		_ComboBuffUI:ShowBuff(duration)
	end

	@ExecSpace("Server")
	method void RestoreComboAttackControl()
		local playerCtrl = self.Entity.PlayerControllerComponent
		if isvalid(playerCtrl) and self._T.pendingComboWasControllerEnabled then
			playerCtrl.Enable = true
		end
		-- (기능 추가) "다른 스킬들을 사용하고 난 다음도 모두 숨고르기 모션을 3번 하도록 해달라"는 요청 -
		-- 컨트롤이 복구된 이 시점에 공용 숨고르기(PlayBreather)를 시작한다.
		self:PlayBreather(self.Entity, self._T.pendingComboDirX or 1)
	end

	method void OnAttack(Entity defender)
		-- 콤보 어택 버프 지속 중 적을 실제로 적중시킬 때마다 콤보 구슬 +1(최대 10).
		-- 부모 AttackComponent.OnAttack은 ExecSpace 미지정(All)이라 어노테이션 없이 오버라이드해야
		-- 한다(LEA-3014 방지). 실제 히트 파이프라인은 서버에서만 돌지만 안전하게 한 번 더 거른다.
		-- 스피어 버스터(3연타)/더블스탭(2연타)/썬더볼트(최대 6대상 동시)처럼 스킬 1회 사용이 여러 번
		-- OnAttack을 호출하는 경우에도 스택은 1회만 쌓여야 한다 - 같은 사용(cast) 안의 모든 히트는
		-- 0.4초 이내에 몰려서 들어오고(가장 느린 스피어버스터도 히트 간격 최대 ~0.3초), 다음 재사용은
		-- 쿨다운(0.7초 이상)이 지난 뒤라 서로 겹치지 않는다는 실측 타이밍에 기반한 시간창 방식.
		if not self:IsServer() then return end
		-- (기능 추가) "패닉 공격으로는 콤보 어택이 차면 안 된다"는 요청 - 패닉은 구슬을 모두 소모하는
		-- 스킬이라, 그 판정 자체가 다시 구슬을 채워버리면 소모한 의미가 없어진다. 패닉 판정(Attack)이
		-- 진행 중인 구간(AttackPanic~RestorePanicControl 사이, isPanicking=true)에는 구슬 획득을 건너뛴다.
		if self._T.isPanicking then return end
		if not self._T.comboAttackActive then return end
		if not isvalid(defender) then return end
		local now = _UtilLogic.ElapsedSeconds
		if self._T.lastComboStackTime and (now - self._T.lastComboStackTime) < 0.4 then
			return
		end
		self._T.lastComboStackTime = now
		-- (기능 추가) "히트 시 50% 확률로 구슬이 생기게 해달라"는 요청 - 매 히트마다 확정 지급하던 것을
		-- 절반 확률로 바꾼다. math.random() 대신 _UtilLogic:RandomDouble()을 쓴다 - 이 파일에서 이미
		-- 실측 확인된 버그(스피어 버스터 등 여러 히트가 0.1~0.2초 간격으로 잇따라 호출되면 math.random()이
		-- 같은 값을 두 번 반환)를 피하기 위해서다.
		if _UtilLogic:RandomDouble() >= 0.5 then return end
		-- (기능 추가) "어드밴스드 콤보(4차 패시브)가 있으면 여기서 다시 확률로 구슬 1개가 아니라
		-- 2개가 한번에 찬다"는 요청. (버그 수정) 패시브 스킬은 파이널어택(2차 패시브 - TryTriggerFinalAttack
		-- 참고)과 동일하게 스킬바 슬롯 배정과 무관하게 항상 적용되는 효과다 - "패시브는 클릭-클릭으로
		-- 슬롯에 옮길 수 없다"는 피드백으로, 슬롯 배정 여부를 확인하던 이전 방식(HasAdvancedCombo +
		-- SkillManager 동기화)은 실제 플레이에서 조건이 절대 참이 될 수 없어 항상 적용되지 않던 원인이었다 -
		-- 제거하고 파이널어택과 같은 방식(무조건 적용)으로 되돌린다.
		-- (기능 추가) "콤보어택이 차는 속도가 너무 빠르다"는 피드백으로 2개 동시 지급 확률을 50%→20%로 낮춘다.
		-- (구슬 10개 상한은 AddComboOrb 자체가 개별 호출마다 다시 확인하므로, 9개 상태에서 두 번째
		-- AddComboOrb 호출은 자동으로 무시되어 10개를 넘지 않는다 - 아래에서 실제로 몇 개가 늘었는지
		-- 확인해 로그도 그 실제 증가량만 "2개 동시 지급"으로 표시한다.)
		local before = self.ComboOrbCount
		if _UtilLogic:RandomDouble() < 0.2 then
			self:AddComboOrb()
			self:AddComboOrb()
		else
			self:AddComboOrb()
		end
		if self.ComboOrbCount - before >= 2 then
			log("[ComboAttack] 어드밴스드 콤보 발동 - 구슬 2개 동시 지급")
		end
	end

	method string GetComboOrbSpriteRuid(integer idx)
		-- state 클립(8c563f54...)의 프레임 1~5가 룬 문양 구슬 스프라이트다(msw-search 실측). 기본(파란) 색상.
		local ruids = {
			"594f34c4103145a28951780047e71e42",
			"eefe86c8b370407aa16c9fe34f12c98d",
			"dfb6702ddc994b8b8b24acf3c695020b",
			"18b94fa75cc54db0a806f522564ba449",
			"1c603235dffd468f8b28b36aa8cb3df2",
		}
		return ruids[math.max(1, math.min(idx, #ruids))]
	end

	method string GetComboOrbPinkSpriteRuid(integer idx)
		-- (기능 추가) "6콤보 이상일 때 구슬 색을 분홍색으로 바꿔달라"는 요청 - 파란 룬 클립과 동일한
		-- 6프레임 구조를 가진 분홍 버전 클립(113a68a27b50432eb00a82e131c2dd72, msw-search 실측)의
		-- 프레임 1~5.
		local ruids = {
			"4711c880fffd4da694871cf1fe331e7d",
			"8abd73b1954e42f5af565af4426ae582",
			"eaede9190e7f48e5a78123777220ebbf",
			"6360c35bf2ad47b0b68235182c063f80",
			"45c5effa123f463296b9c861fe017215",
		}
		return ruids[math.max(1, math.min(idx, #ruids))]
	end

	@ExecSpace("ServerOnly")
	method void AddComboOrb()
		-- 콤보 구슬 1개를 추가한다: 카운트(@Sync) 증가 + 플레이어의 자식으로 구슬 엔티티 스폰.
		-- 공전/크기 연출은 ComboOrb 컴포넌트가 클라이언트에서 담당한다. 첫 구슬이 생길 때 캐릭터
		-- 중심에 고정되는 큰 원(8c563f54... 클립 프레임0)도 함께 스폰한다.
		-- (기능 추가) "최대 10콤보까지 쌓을 수 있게 해달라"는 요청으로 상한을 5→10으로 올린다.
		-- 다만 궤도 슬롯은 ComboOrb.mlua에 5칸(2π/5 간격)으로 고정되어 있어 구슬 엔티티 자체는
		-- 여전히 최대 5개만 스폰한다 - 6번째부터는 새 구슬을 만들지 않고, 기존 구슬 중 하나(그리고
		-- 6번째가 되는 순간 가운데 큰 원)를 분홍색으로 전환해 6~10콤보를 표시한다.
		if self.ComboOrbCount >= 10 then return end
		local idx = self.ComboOrbCount + 1
		self.ComboOrbCount = idx

		if idx == 1 then
			self:SpawnComboOrbCenter()
		end

		if idx <= 5 then
			local fx = _SpawnService:SpawnByModelId("spearburstfadingeffect", "ComboOrb" .. idx, Vector3(0, 0.35, 0), self.Entity)
			if isvalid(fx) then
				fx:AddComponent("script.ComboOrb")
				local comp = fx:GetComponent("script.ComboOrb")
				if isvalid(comp) then
					comp.OrbIndex = idx
					comp.OrbSpriteRUID = self:GetComboOrbSpriteRuid(idx)
				end
				self._T.comboOrbEntities = self._T.comboOrbEntities or {}
				table.insert(self._T.comboOrbEntities, fx)
			end
			log("[ComboAttack] 콤보 구슬 +1 → " .. tostring(idx) .. "/10 (데미지 +" .. tostring(idx * 20) .. "%)")
		else
			-- 6번째부터는 새 구슬 엔티티 없이, (idx-5)번째 기존 구슬을 분홍으로 전환한다.
			-- 6번째가 되는 순간(처음 분홍이 등장하는 시점) 가운데 큰 원도 함께 분홍으로 바뀐다.
			if idx == 6 then
				self:SetComboOrbCenterPink()
			end
			self:UpgradeComboOrbToPink(idx - 5)
			log("[ComboAttack] 콤보 구슬 +1 → " .. tostring(idx) .. "/10 (분홍 전환 " .. tostring(idx - 5) .. "/5, 데미지 +" .. tostring(idx * 20) .. "%)")
		end
	end

	@ExecSpace("ServerOnly")
	method void UpgradeComboOrbToPink(integer orbIndex)
		-- 기존에 떠 있는 구슬 중 슬롯 번호가 orbIndex인 것을 찾아 분홍 스프라이트로 바꾼다.
		-- OrbSpriteRUID는 @Sync라 값이 바뀌면 ComboOrb.OnSyncProperty가 재적용을 감지하고,
		-- 거기서 생성 연출(커졌다 작아지는 이펙트) 타이머도 함께 리셋해 색이 바뀌는 순간 다시 재생된다.
		local orbs = self._T.comboOrbEntities or {}
		for _, e in ipairs(orbs) do
			if isvalid(e) then
				---@type ComboOrb
				local comp = e:GetComponent("script.ComboOrb")
				if isvalid(comp) and comp.OrbIndex == orbIndex then
					comp.OrbSpriteRUID = self:GetComboOrbPinkSpriteRuid(orbIndex)
					log("[ComboAttack] 구슬 " .. tostring(orbIndex) .. "번 분홍 전환")
					break
				end
			end
		end
	end

	@ExecSpace("ServerOnly")
	method void SetComboOrbCenterPink()
		-- 가운데 큰 원을 분홍 버전(분홍 클립 프레임0)으로 전환한다.
		if isvalid(self._T.comboOrbCenterEntity) then
			---@type ComboOrb
			local comp = self._T.comboOrbCenterEntity:GetComponent("script.ComboOrb")
			if isvalid(comp) then
				comp.OrbSpriteRUID = "5f5348ebeb2345f0869d1682828a848d"
				log("[ComboAttack] 가운데 원 분홍 전환")
			end
		end
	end

	@ExecSpace("ServerOnly")
	method void SpawnComboOrbCenter()
		-- 구슬들 한가운데(캐릭터 중심)에 고정되는 큰 원. state 클립 프레임0 스프라이트(72x76,
		-- 작은 구슬보다 큼)를 사용하고 IsCenterOrb=true라 공전하지 않는다.
		local center = _SpawnService:SpawnByModelId("spearburstfadingeffect", "ComboOrbCenter", Vector3(0, 0.35, 0), self.Entity)
		if isvalid(center) then
			center:AddComponent("script.ComboOrb")
			local comp = center:GetComponent("script.ComboOrb")
			if isvalid(comp) then
				comp.IsCenterOrb = true
				comp.OrbSpriteRUID = "9cfc22d7db1842608b648d9d7b5d216e"
			end
			self._T.comboOrbCenterEntity = center
		end
	end

	@ExecSpace("ServerOnly")
	method void ClearComboOrbs()
		-- 버프 종료 시 구슬 전부 + 중앙 큰 원 제거, 카운트 초기화.
		self.ComboOrbCount = 0
		local orbs = self._T.comboOrbEntities or {}
		for _, e in ipairs(orbs) do
			if isvalid(e) then
				e:Destroy()
			end
		end
		self._T.comboOrbEntities = {}
		if isvalid(self._T.comboOrbCenterEntity) then
			self._T.comboOrbCenterEntity:Destroy()
		end
		self._T.comboOrbCenterEntity = nil
	end

	method integer ApplyComboAttackBonus(integer damage)
		-- 콤보 어택 버프 보너스: 구슬 1개당 +20%(최대 10개 = +200%). CalcDamage의 모든 분기 반환값에
		-- 일괄 적용된다. 부모 훅(CalcDamage)에서 호출되므로 ExecSpace 어노테이션 없이 선언한다.
		if not self._T.comboAttackActive then return damage end
		local count = self.ComboOrbCount or 0
		if count <= 0 then return damage end
		return math.floor(damage * (1 + 0.2 * count))
	end

	@ExecSpace("ServerOnly")
	method void AttackPanic(number combatPower, number atkMultiplier)
		-- (기능 추가) "다른 스킬을 쓰면 숨고르기 모션은 중지" 요청 - 이 스킬을 새로 시전하는 시점에 이전 숨고르기가 재생 중이었다면 즉시 정리한다.
		self:StopBreather()
		-- 패닉: 콤보 어택 버프로 쌓인 콤보 구슬을 전부 소모해 단일 대상에게 강력한 피해를 입힌다.
		-- 구슬이 하나도 없으면 사용할 수 없다(요청사항). 모션/히트 타이밍은 파워스트라이크와 동일하게
		-- GetPowerStrikeSwing + PlayAttackMotion을 그대로 재사용하고, 판정도 동일한 고정 딜레이(0.45초 * 배율)
		-- 뒤에 진행한다. 재시전 방지 게이트(isPanicking)/컨트롤 잠금 관련 필드는 다른 스킬들과 동일한 관례대로
		-- 패닉 전용 필드로 완전히 분리해, 클라이언트 공용 쿨다운(SkillManager.skillOnCooldown)이 스킬 간
		-- 사용을 이미 직렬화하는 것과 별개로 서버 쪽에서도 안전하게 독립적으로 동작하게 한다.
		local currentState = self.Entity.StateComponent.CurrentStateName
		if currentState == "DEAD" or currentState == "CLIMB" or currentState == "LADDER" then
			return
		end
		if self._T.isPanicking then
			log("PlayerAttack: AttackPanic 요청 차단됨(이미 진행 중)")
			return
		end
		-- 콤보 구슬이 하나도 없으면 사용 불가 - 클라이언트(SkillManager)도 미리 확인하지만 서버가 최종 판정한다.
		local orbCount = self.ComboOrbCount
		if orbCount <= 0 then
			log("PlayerAttack: AttackPanic 요청 차단됨(콤보 구슬 없음)")
			return
		end
		self._T.isPanicking = true
		self._T.panicMotionEndHandled = false

		local mult = math.max(0.1, math.min(atkMultiplier or 1.0, 3.0))
		self._T.pendingPanicCombatPower = combatPower
		-- 소모할 구슬 개수(1~10)를 시전 시점 값으로 스냅샷해둔다 - 바로 아래에서 ClearComboOrbs로
		-- ComboOrbCount를 0으로 되돌리기 때문에, 데미지 공식/이펙트 선택은 반드시 이 스냅샷 값을 써야 한다.
		self._T.pendingPanicOrbCount = orbCount

		local playerCtrl = self.Entity.PlayerControllerComponent
		local worldPos = self.Entity.TransformComponent.WorldPosition
		local dirX = playerCtrl.LookDirectionX
		self._T.pendingPanicDirX = dirX

		-- 단일 대상 스킬: 판정 전에 가장 가까운 몬스터 하나만 골라 IsAttackTarget에서 그 대상만 통과시킨다(파워스트라이크와 동일).
		-- (기능 추가) "데미지를 입히는 범위를 전방·위아래로 2배 늘려달라"는 요청으로, 판정 박스가
		-- 넓어진 것과 함께 탐색 반경도 2.0→4.0으로 늘려 더 먼 대상도 실제로 판정 박스 안에 들어오게 한다.
		self._T.panicTarget = self:FindNearestMonster(Vector2(worldPos.x, worldPos.y), 4.0)

		self._T.pendingPanicWasControllerEnabled = isvalid(playerCtrl) and playerCtrl.Enable
		if isvalid(playerCtrl) then
			playerCtrl.Enable = false
		end
		if isvalid(self.Entity.MovementComponent) then
			self.Entity.MovementComponent:Stop()
		end

		-- 구슬은 시전 즉시(모션 시작과 동시에) 전부 소모한다 - ApplyComboAttackBonus가 CalcDamage 반환값에
		-- 자동으로 얹는 구슬 보너스(+20%/개)보다 먼저 ComboOrbCount를 0으로 비워둬야, 패닉 자체 공식
		-- (구슬 1개당 1000~1200%)에 그 보너스가 중복으로 얹히지 않는다.
		self:ClearComboOrbs()

		-- (기능 추가) "패닉 전용 사운드로 바꿔달라"는 요청 - 파워스트라이크와 공유하던
		-- PlaySkillUseSound 대신 패닉 전용 PlayPanicUseSound(d01b135e62a74129b1515c8e0250a2f5)를 재생한다.
		self:PlayPanicUseSound(self.Entity)
		self:PlayPanicCastEffect(self.Entity, dirX, orbCount)

		-- 캐릭터 모션은 파워스트라이크와 동일한 후보군(GetPowerStrikeSwing)에서 하나를 골라 재생한다.
		local swing = self:GetPowerStrikeSwing()
		self._T.pendingPanicSwing = swing
		self:PlayAttackMotion(self.Entity, swing.name, dirX, mult)

		-- 타격 판정 타이밍은 파워스트라이크와 동일하게 고정 딜레이(0.45초 * 배율) 뒤에 진행한다.
		_TimerService:SetTimerOnce(function()
			self:NotifyPanicMotionEnded()
		end, 0.45 * mult)

		-- 컨트롤 잠금 해제도 파워스트라이크와 동일한 총 딜레이(0.65초 * 배율).
		_TimerService:SetTimerOnce(function()
			self:RestorePanicControl()
		end, 0.65 * mult)

		log("[Panic] 발동 orbCount=" .. tostring(orbCount))
	end

	@ExecSpace("Server")
	method void RestorePanicControl()
		-- AttackPanic에서 예약한 고정 딜레이(0.65초 = 모션 0.25초 + 추가 이동 봉인 0.4초, 파워스트라이크와 동일) 뒤 호출된다.
		self._T.isPanicking = false
		local playerCtrl = self.Entity.PlayerControllerComponent
		if isvalid(playerCtrl) and self._T.pendingPanicWasControllerEnabled then
			playerCtrl.Enable = true
		end
		-- (기능 추가) "다른 스킬들을 사용하고 난 다음도 모두 숨고르기 모션을 3번 하도록 해달라"는 요청 -
		-- 컨트롤이 복구된 이 시점에 공용 숨고르기(PlayBreather)를 시작한다.
		self:PlayBreather(self.Entity, self._T.pendingPanicDirX or 1)
	end

	method void NotifyPanicMotionEnded()
		-- AttackPanic에서 예약한 고정 딜레이(0.25초 * 배율, 파워스트라이크와 동일) 타이머로 호출된다.
		if self._T.panicMotionEndHandled then return end
		self._T.panicMotionEndHandled = true

		if not isvalid(self.Entity) then return end
		local dirX = self._T.pendingPanicDirX or 1
		local curWorldPos = self.Entity.TransformComponent.WorldPosition
		-- 판정 범위: 원래 파워스트라이크와 동일(전방 가로 2칸·세로 2칸)했으나, "전방·위아래로 2배
		-- 늘려달라"는 요청으로 전방 오프셋과 박스 가로/세로 크기를 모두 2배로 늘렸다(가로 4칸·세로 4칸,
		-- 전방 오프셋 1.0→2.0 - 뒤쪽 경계는 그대로 캐릭터 위치에 걸쳐 있고 앞/위/아래로만 넓어진다).
		local attackOffset = Vector2(
			curWorldPos.x + 2.0 * dirX,
			curWorldPos.y
		)
		local shape = BoxShape(attackOffset, Vector2(4, 4), 0)
		local hitComps = self:Attack(shape, "skill.panic", CollisionGroups.HitBox)
		local targets = {}
		for _, hc in ipairs(hitComps) do
			if isvalid(hc) and isvalid(hc.Entity) then
				table.insert(targets, hc.Entity)
			end
		end

		local swing = self._T.pendingPanicSwing or { ruid = "", name = "?" }
		self:PlayPanicEffects(self.Entity, dirX, targets, self._T.pendingPanicOrbCount or 0, swing.ruid)
		log("PlayerAttack: AttackPanic dir=" .. tostring(dirX) .. " targets=" .. tostring(#targets))
	end

	method string GetPanicEffectRuid(integer orbCount)
		-- 소모한 콤보 구슬 개수(1~10)별 캐릭터 이펙트(시전 시 재생).
		local ruids = {
			"73ca2da2e4174b88b79b2f53aec7d231",
			"59220240d7004a439c16329b829a6900",
			"e150a53e0a61454b9fde4e53380cd9ab",
			"3e7aef83235b4e8ebd28ba9462d9b8c0",
			"1be23b85b0b44b84bc6e88a2caf986de",
			"8cbbf339d9de40b09d933cc9d4e8b803",
			"9c267e7da01c4c34992cfbfd02132a5f",
			"4561e55a44f74a3086d4e88a4c2c8f01",
			"aab1604317524fc78ab79e23416d6947",
			"aab1604317524fc78ab79e23416d6947",
		}
		return ruids[math.max(1, math.min(orbCount, #ruids))]
	end

	@ExecSpace("Multicast")
	method void PlayPanicUseSound(Entity attacker)
		-- 패닉 전용 사용 사운드. Multicast는 서버 자신도 함께 실행하므로 클라이언트에서만 실행되게 막는다.
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		local panicSoundRUID = "d01b135e62a74129b1515c8e0250a2f5"
		_SoundService:PlaySound(panicSoundRUID, 1.0)
	end

	@ExecSpace("Multicast")
	method void PlayPanicCastEffect(Entity attacker, number dirX, integer orbCount)
		-- 소모한 구슬 개수에 맞는 캐릭터 이펙트를 시전 즉시 1회 재생한다. Multicast는 서버 자신도
		-- 함께 실행하므로 클라이언트에서만 실행되게 막는다.
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		local effectRuid = self:GetPanicEffectRuid(orbCount)
		local options = { ["FlipX"] = dirX > 0 }
		-- (기능 추가) "캐릭터 이펙트 크기를 10% 상승시키고 y축을 약간 위로 올려달라"는 요청 -
		-- 기본 스케일(1,1,1)을 10% 키운다(1.1,1.1,1.1).
		-- (기능 추가) "패닉 이펙트의 전체적인 위치를 조금 아래로 내려달라"는 요청 - 이전에 위로
		-- 올렸던 y오프셋(0.15)을 다시 낮춰 원래 높이(0)로 되돌린다.
		_EffectService:PlayEffectAttached(effectRuid, attacker, Vector3(0, 0, 0), 0, Vector3(1.1, 1.1, 1.1), false, options)
		log("[Panic] 시전 이펙트 재생 orbCount=" .. tostring(orbCount) .. " ruid=" .. tostring(effectRuid))
	end

	@ExecSpace("Multicast")
	method void PlayPanicEffects(Entity attacker, number dirX, table targets, integer orbCount, string swingEffectRUID)
		-- 파워스트라이크와 동일한 스윙 궤적 이펙트를 재생하고(모션 재사용), 실제로 맞은 대상에게는
		-- 패닉 전용 몬스터 히트 이펙트를 재생한다. Multicast는 서버 자신도 함께 실행하므로
		-- 클라이언트에서만 실행되게 막는다 - 안 그러면 서버 쪽 실행이 이펙트를 한 번 더 재생해 겹쳐 보인다.
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		local hitEffectRUID  = "4b8e5b7b21f74a26a54cf3a17d91930c"
		local swingSoundRUID = "d3205fdd08e34b68bc01292a997531ed"

		if swingEffectRUID ~= "" then
			local swingOptions = { ["FlipX"] = dirX > 0, ["Alpha"] = 0.8 }
			_EffectService:PlayEffectAttached(swingEffectRUID, attacker, Vector3(0.1 * dirX, 0, 0), 0, Vector3(1, 1, 1), false, swingOptions)
		end

		-- (기능 추가) "히트 이펙트 크기를 소모한 구슬 개수에 따라 1.1배씩 크게 하고 y축을 약간 위로
		-- 올려달라"는 요청 - 구슬 1개당 1.1배씩 복리로 커진다(1개=1.1배, 2개=1.21배, 3개=1.331배 ...).
		-- (기능 추가) "패닉 이펙트의 전체적인 위치를 조금 아래로 내려달라"는 요청 - 이전에 위로
		-- 올렸던 y오프셋(0.15)을 다시 낮춰 원래 높이(0)로 되돌렸었다.
		-- (기능 추가) "히트 이펙트는 y를 0.1로 올려달라"는 요청으로 다시 0.1로 조정.
		local hitScale = 1.1 ^ math.max(orbCount, 0)
		for _, target in ipairs(targets) do
			if isvalid(target) then
				local hitOptions = { ["FlipX"] = dirX > 0 }
				_EffectService:PlayEffectAttached(hitEffectRUID, target, Vector3(0, 0.1, 0), 0, Vector3(hitScale, hitScale, hitScale), false, hitOptions)
				_SoundService:PlaySound(swingSoundRUID, 1.0)
			end
		end
		log("[Panic] 히트 이펙트 스케일 orbCount=" .. tostring(orbCount) .. " scale=" .. tostring(hitScale))
		log("[Panic] 히트 이펙트 재생 orbCount=" .. tostring(orbCount) .. " targets=" .. tostring(#targets))
	end

	@ExecSpace("ServerOnly")
	method void AttackBooster(boolean isMage, number atkMultiplier)
		-- (기능 추가) "다른 스킬을 쓰면 숨고르기 모션은 중지" 요청 - 이 스킬을 새로 시전하는 시점에 이전 숨고르기가 재생 중이었다면 즉시 정리한다.
		self:StopBreather()
		-- 부스터: 실제 공격속도 상승 효과는 CharInfoManager가 클라이언트에서 이미 즉시 적용했다(서버에
		-- 대응 데이터가 없는 클라이언트 전용 스탯이라). 여기서는 다른 플레이어에게 보이는 시전
		-- 이펙트/사운드만 재생한다.
		local currentState = self.Entity.StateComponent.CurrentStateName
		if currentState == "DEAD" then
			return
		end

		-- 힐과 동일한 모션(alert)을 재생하고, 그동안 다른 행동을 제한한다.
		local mult = math.max(atkMultiplier or 1.0, 0.001)
		local playerCtrl = self.Entity.PlayerControllerComponent
		local dirX = isvalid(playerCtrl) and playerCtrl.LookDirectionX or 1
		self._T.pendingBoosterDirX = dirX
		self._T.pendingBoosterWasControllerEnabled = isvalid(playerCtrl) and playerCtrl.Enable
		if isvalid(playerCtrl) then
			playerCtrl.Enable = false
		end
		if isvalid(self.Entity.MovementComponent) then
			self.Entity.MovementComponent:Stop()
		end
		self:PlayBoosterMotion(self.Entity, "alert", dirX, mult)
		_TimerService:SetTimerOnce(function()
			self:RestoreBoosterControl()
		end, 0.6 * mult)

		self:PlayBoosterCastEffect(self.Entity, isMage)
	end

	@ExecSpace("Multicast")
	method void PlayBoosterCastEffect(Entity attacker, boolean isMage)
		-- 마법사 계열(썬콜/불독 아크메이지, 비숍)과 나머지 직업 모두 캐릭터 몸쪽에서 1회 재생(사용 리소스만 다름).
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		local ruid = isMage and "b65a4879ddf44d2a9fcdc09fa00c610c" or "c960275509274d72b540f18f5f53f01f"
		local serial = _EffectService:PlayEffectAttached(ruid, attacker, Vector3(0, 0, 0), 0, Vector3(1, 1, 1), false, {})
		_SoundService:PlaySound("a83d56a314fd449cad236fd7d9b2fa63", 1.0)
		_TimerService:SetTimerOnce(function()
			_EffectService:RemoveEffect(serial)
		end, 1.5)
	end

	@ExecSpace("Multicast")
	method void PlayBoosterMotion(Entity attacker, string motionName, number dirX, number atkMultiplier)
		-- 부스터 전용 모션 재생 (힐과 동일한 방식/모션 - 별도 플래그로 서로 간섭하지 않는다).
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		local avatarRenderer = attacker.AvatarRendererComponent
		if not isvalid(avatarRenderer) then return end
		local body = avatarRenderer:GetBodyEntity()
		if not isvalid(body) then return end

		avatarRenderer.ShowDefaultWeaponEffects = false

		local playerCtrl = attacker.PlayerControllerComponent
		if isvalid(attacker.MovementComponent) then
			attacker.MovementComponent:Stop()
		end
		if isvalid(playerCtrl) then
			playerCtrl.LookDirectionX = dirX
		end
		self._T.isBoosterDirectionLocked = true
		self._T.lockedBoosterDirX = dirX
		self._T.lockedBoosterMotionName = motionName
		self._T.isBoosterMotionPlaying = true

		local mult = math.max(atkMultiplier or 1.0, 0.001)
		local playRate = 1.0 / mult
		self._T.lockedBoosterPlayRate = playRate

		local motionEvent = ActionStateChangedEvent(motionName, motionName, playRate, SpriteAnimClipPlayType.Onetime)
		body:SendEvent(motionEvent)
		log("[Booster] PlayBoosterMotion sent: " .. tostring(motionName) .. " playRate=" .. tostring(playRate))

		_TimerService:SetTimerOnce(function()
			if isvalid(avatarRenderer) then
				avatarRenderer.ShowDefaultWeaponEffects = true
			end
			self._T.isBoosterMotionPlaying = false
		end, 0.55 * mult)

		_TimerService:SetTimerOnce(function()
			self._T.isBoosterDirectionLocked = false
			local sc = self.Entity.StateComponent
			if isvalid(sc) and sc.CurrentStateName ~= "DEAD" then
				sc:ChangeState("IDLE")
				sc:ChangeState("MOVE")
				sc:ChangeState("IDLE")
			end
		end, 0.80 * mult)
	end

	@ExecSpace("Server")
	method void RestoreBoosterControl()
		local playerCtrl = self.Entity.PlayerControllerComponent
		if isvalid(playerCtrl) and self._T.pendingBoosterWasControllerEnabled then
			playerCtrl.Enable = true
		end
		-- (기능 추가) "다른 스킬들을 사용하고 난 다음도 모두 숨고르기 모션을 3번 하도록 해달라"는 요청 -
		-- 컨트롤이 복구된 이 시점에 공용 숨고르기(PlayBreather)를 시작한다.
		self:PlayBreather(self.Entity, self._T.pendingBoosterDirX or 1)
	end

	@ExecSpace("ServerOnly")
	method void AttackPoisonMist(number combatPower, number atkMultiplier)
		-- (기능 추가) "다른 스킬을 쓰면 숨고르기 모션은 중지" 요청 - 이 스킬을 새로 시전하는 시점에 이전 숨고르기가 재생 중이었다면 즉시 정리한다.
		self:StopBreather()
		-- 포이즌 미스트: 시전 위치에 독안개(PoisonMist)를 소환한다. 실제 독 데미지는 안개가
		-- 대상에게 부착하는 PoisonDebuffComponent가 독립적인 1초 틱으로 처리한다(공격속도 영향 없음,
		-- 헤이스트/부스터처럼 여기서는 시전 이펙트/사운드 재생과 소환만 담당한다).
		local currentState = self.Entity.StateComponent.CurrentStateName
		if currentState == "DEAD" then
			return
		end

		-- 힐과 동일한 모션(alert)을 재생하고, 그동안 다른 행동을 제한한다.
		local mult = math.max(atkMultiplier or 1.0, 0.001)
		local playerCtrl = self.Entity.PlayerControllerComponent
		local dirX = isvalid(playerCtrl) and playerCtrl.LookDirectionX or 1
		self._T.pendingPoisonMistDirX = dirX
		self._T.pendingPoisonMistWasControllerEnabled = isvalid(playerCtrl) and playerCtrl.Enable
		if isvalid(playerCtrl) then
			playerCtrl.Enable = false
		end
		if isvalid(self.Entity.MovementComponent) then
			self.Entity.MovementComponent:Stop()
		end
		self:PlayPoisonMistMotion(self.Entity, "alert", dirX, mult)
		_TimerService:SetTimerOnce(function()
			self:RestorePoisonMistControl()
		end, 0.6 * mult)

		self:PlayPoisonMistCastEffect(self.Entity)

		local map = self.Entity.CurrentMap
		if not isvalid(map) then return end
		self._T.poisonMistCount = (self._T.poisonMistCount or 0) + 1
		local name = "poisonmist_" .. tostring(self._T.poisonMistCount)
		local pos = self.Entity.TransformComponent.WorldPosition
		local mist = _SpawnService:SpawnByModelId("poisonmist", name, Vector3(pos.x, pos.y, pos.z), map)
		if not isvalid(mist) then
			log_warning("[PoisonMist] 스폰 실패")
			return
		end
		local zone = mist:GetComponent("script.PoisonMistZone")
		if zone ~= nil then
			zone:Init(combatPower)
		end
		log("[PoisonMist] 소환 x=" .. tostring(pos.x) .. " y=" .. tostring(pos.y))
	end

	@ExecSpace("Multicast")
	method void PlayPoisonMistCastEffect(Entity attacker)
		-- 사용 시 캐릭터 몸쪽 이펙트 + 사용 사운드 (skill/211.img/skill/2111003 리소스팩의 "effect"/"_audio/Use" 노드)
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		local serial = _EffectService:PlayEffectAttached("b0d47a8948314a5ea04a00690d921fc3", attacker, Vector3(0, 0, 0), 0, Vector3(1, 1, 1), false, {})
		_SoundService:PlaySound("eb7f504670a14802a48cc94f4eb66848", 1.0)
		_TimerService:SetTimerOnce(function()
			_EffectService:RemoveEffect(serial)
		end, 1.5)
	end

	@ExecSpace("Multicast")
	method void PlayPoisonMistMotion(Entity attacker, string motionName, number dirX, number atkMultiplier)
		-- 포이즌 미스트 전용 모션 재생 (힐과 동일한 방식/모션 - 별도 플래그로 서로 간섭하지 않는다).
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		local avatarRenderer = attacker.AvatarRendererComponent
		if not isvalid(avatarRenderer) then return end
		local body = avatarRenderer:GetBodyEntity()
		if not isvalid(body) then return end

		avatarRenderer.ShowDefaultWeaponEffects = false

		local playerCtrl = attacker.PlayerControllerComponent
		if isvalid(attacker.MovementComponent) then
			attacker.MovementComponent:Stop()
		end
		if isvalid(playerCtrl) then
			playerCtrl.LookDirectionX = dirX
		end
		self._T.isPoisonMistDirectionLocked = true
		self._T.lockedPoisonMistDirX = dirX
		self._T.lockedPoisonMistMotionName = motionName
		self._T.isPoisonMistMotionPlaying = true

		local mult = math.max(atkMultiplier or 1.0, 0.001)
		local playRate = 1.0 / mult
		self._T.lockedPoisonMistPlayRate = playRate

		local motionEvent = ActionStateChangedEvent(motionName, motionName, playRate, SpriteAnimClipPlayType.Onetime)
		body:SendEvent(motionEvent)
		log("[PoisonMist] PlayPoisonMistMotion sent: " .. tostring(motionName) .. " playRate=" .. tostring(playRate))

		_TimerService:SetTimerOnce(function()
			if isvalid(avatarRenderer) then
				avatarRenderer.ShowDefaultWeaponEffects = true
			end
			self._T.isPoisonMistMotionPlaying = false
		end, 0.55 * mult)

		_TimerService:SetTimerOnce(function()
			self._T.isPoisonMistDirectionLocked = false
			local sc = self.Entity.StateComponent
			if isvalid(sc) and sc.CurrentStateName ~= "DEAD" then
				sc:ChangeState("IDLE")
				sc:ChangeState("MOVE")
				sc:ChangeState("IDLE")
			end
		end, 0.80 * mult)
	end

	@ExecSpace("Server")
	method void RestorePoisonMistControl()
		local playerCtrl = self.Entity.PlayerControllerComponent
		if isvalid(playerCtrl) and self._T.pendingPoisonMistWasControllerEnabled then
			playerCtrl.Enable = true
		end
		-- (기능 추가) "다른 스킬들을 사용하고 난 다음도 모두 숨고르기 모션을 3번 하도록 해달라"는 요청 -
		-- 컨트롤이 복구된 이 시점에 공용 숨고르기(PlayBreather)를 시작한다.
		self:PlayBreather(self.Entity, self._T.pendingPoisonMistDirX or 1)
	end

	@ExecSpace("ServerOnly")
	method void AttackExplosion(number combatPower, number atkMultiplier)
		-- (기능 추가) "다른 스킬을 쓰면 숨고르기 모션은 중지" 요청 - 이 스킬을 새로 시전하는 시점에 이전 숨고르기가 재생 중이었다면 즉시 정리한다.
		self:StopBreather()
		-- 익스플로젼: 시전 이펙트 재생 후 1초 뒤 실제로 터진다(몸쪽 스페셜 이펙트 + 전방 무관 최대 6명 500~700%
		-- 데미지). 폭발 시점에 주변(독구름의 확대된 시각적 크기의 1.0배)에 있는 독구름을 최대 6개까지 0.1초
		-- 간격으로 하나씩 터뜨리며, 터진 자리마다 이펙트/사운드와 함께 500~700% 추가 데미지를 준다.
		local currentState = self.Entity.StateComponent.CurrentStateName
		if currentState == "DEAD" or currentState == "CLIMB" or currentState == "LADDER" then
			return
		end
		if self._T.isExploding then
			log("PlayerAttack: AttackExplosion 요청 차단됨(이미 진행 중)")
			return
		end
		self._T.isExploding = true
		self._T.pendingExplosionCombatPower = combatPower

		-- 힐과 동일한 모션(alert)을 재생하고, 그동안 다른 행동을 제한한다.
		local mult = math.max(atkMultiplier or 1.0, 0.001)
		local playerCtrl = self.Entity.PlayerControllerComponent
		local dirX = isvalid(playerCtrl) and playerCtrl.LookDirectionX or 1
		self._T.pendingExplosionDirX = dirX
		self._T.pendingExplosionWasControllerEnabled = isvalid(playerCtrl) and playerCtrl.Enable
		if isvalid(playerCtrl) then
			playerCtrl.Enable = false
		end
		if isvalid(self.Entity.MovementComponent) then
			self.Entity.MovementComponent:Stop()
		end
		self:PlayExplosionMotion(self.Entity, "alert", dirX, mult)
		_TimerService:SetTimerOnce(function()
			self:RestoreExplosionControl()
		end, 0.6 * mult)

		self:PlayExplosionCastEffect(self.Entity)

		_TimerService:SetTimerOnce(function()
			self:DetonateExplosion()
		end, 1.0)
	end

	@ExecSpace("Multicast")
	method void PlayExplosionMotion(Entity attacker, string motionName, number dirX, number atkMultiplier)
		-- 익스플로젼 전용 모션 재생 (힐과 동일한 방식/모션 - 별도 플래그로 서로 간섭하지 않는다).
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		local avatarRenderer = attacker.AvatarRendererComponent
		if not isvalid(avatarRenderer) then return end
		local body = avatarRenderer:GetBodyEntity()
		if not isvalid(body) then return end

		avatarRenderer.ShowDefaultWeaponEffects = false

		local playerCtrl = attacker.PlayerControllerComponent
		if isvalid(attacker.MovementComponent) then
			attacker.MovementComponent:Stop()
		end
		if isvalid(playerCtrl) then
			playerCtrl.LookDirectionX = dirX
		end
		self._T.isExplosionDirectionLocked = true
		self._T.lockedExplosionDirX = dirX
		self._T.lockedExplosionMotionName = motionName
		self._T.isExplosionMotionPlaying = true

		local mult = math.max(atkMultiplier or 1.0, 0.001)
		local playRate = 1.0 / mult
		self._T.lockedExplosionPlayRate = playRate

		local motionEvent = ActionStateChangedEvent(motionName, motionName, playRate, SpriteAnimClipPlayType.Onetime)
		body:SendEvent(motionEvent)
		log("[Explosion] PlayExplosionMotion sent: " .. tostring(motionName) .. " playRate=" .. tostring(playRate))

		_TimerService:SetTimerOnce(function()
			if isvalid(avatarRenderer) then
				avatarRenderer.ShowDefaultWeaponEffects = true
			end
			self._T.isExplosionMotionPlaying = false
		end, 0.55 * mult)

		_TimerService:SetTimerOnce(function()
			self._T.isExplosionDirectionLocked = false
			local sc = self.Entity.StateComponent
			if isvalid(sc) and sc.CurrentStateName ~= "DEAD" then
				sc:ChangeState("IDLE")
				sc:ChangeState("MOVE")
				sc:ChangeState("IDLE")
			end
		end, 0.80 * mult)
	end

	@ExecSpace("Server")
	method void RestoreExplosionControl()
		local playerCtrl = self.Entity.PlayerControllerComponent
		if isvalid(playerCtrl) and self._T.pendingExplosionWasControllerEnabled then
			playerCtrl.Enable = true
		end
		-- (기능 추가) "다른 스킬들을 사용하고 난 다음도 모두 숨고르기 모션을 3번 하도록 해달라"는 요청 -
		-- 컨트롤이 복구된 이 시점에 공용 숨고르기(PlayBreather)를 시작한다.
		self:PlayBreather(self.Entity, self._T.pendingExplosionDirX or 1)
	end

	@ExecSpace("Multicast")
	method void PlayExplosionCastEffect(Entity attacker)
		-- 시전 즉시 캐릭터 몸쪽에서 1회 재생되는 준비 이펙트 (skill/211.img/skill/2111002 리소스팩의 "prepare" 노드)
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		_EffectService:PlayEffectAttached("419e26654a5e470fa386a8a4e92e9eb3", attacker, Vector3(0, 0, 0), 0, Vector3(1, 1, 1), false, {})
	end

	@ExecSpace("ServerOnly")
	method void DetonateExplosion()
		-- 시전 2초 뒤 호출되어 실제 폭발 판정을 진행한다.
		self._T.isExploding = false
		if not isvalid(self.Entity) then return end

		self:PlayExplosionMainEffect(self.Entity)

		local worldPos = self.Entity.TransformComponent.WorldPosition
		local targets = self:FindExplosionTargets(Vector2(worldPos.x, worldPos.y), 6)
		for _, t in ipairs(targets) do
			self:DealExplosionHit(t)
		end
		log("PlayerAttack: AttackExplosion 폭발! targets=" .. tostring(#targets))

		self:PopNearbyPoisonMists(worldPos)
	end

	@ExecSpace("Multicast")
	method void PlayExplosionMainEffect(Entity attacker)
		-- 몸쪽 이펙트(38f9aa42...) 재생 후, 같은 리소스팩의 special 3종 중 하나를 이어서 재생한다.
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		_EffectService:PlayEffectAttached("38f9aa42ec39406987a9fd92ba2c14ad", attacker, Vector3(0, 0, 0), 0, Vector3(1, 1, 1), false, {})
		local specials = {
			"154a7b585c474b07ae77d96a465756e6",
			"ff046ea8281f4ed48430594340ddf6af",
			"49621e22bbab410d87318e2f8cd57899",
		}
		local index = _UtilLogic:RandomIntegerRange(1, #specials)
		_EffectService:PlayEffectAttached(specials[index], attacker, Vector3(0, 0, 0), 0, Vector3(1, 1, 1), false, {})
	end

	-- 익스플로젼 판정 범위(전방위 - 방향 무관) 안의 살아있는 script.Monster를 가까운 순으로 최대 maxCount명까지 반환한다.
	@ExecSpace("ServerOnly")
	method table FindExplosionTargets(Vector2 fromPos, integer maxCount)
		local map = self.Entity.CurrentMap
		if not isvalid(map) then return {} end
		local monsterComps = map:GetChildComponentsByTypeName("script.Monster", true)
		local candidates = {}
		for _, comp in ipairs(monsterComps) do
			---@type Monster
			local mc = comp
			if isvalid(mc) and isvalid(mc.Entity) and not mc.IsDead then
				local pos = mc.Entity.TransformComponent.WorldPosition
				local dx = pos.x - fromPos.x
				local dy = pos.y - fromPos.y
				if math.abs(dx) <= 3.0 and math.abs(dy) <= 1.5 then
					table.insert(candidates, { entity = mc.Entity, dist = math.abs(dx) })
				end
			end
		end
		table.sort(candidates, function(a, b) return a.dist < b.dist end)
		local result = {}
		for i = 1, math.min(#candidates, maxCount) do
			table.insert(result, candidates[i].entity)
		end
		return result
	end

	-- 드래곤 로어 전용 판정 범위(전방위 - 방향 무관) 안의 살아있는 script.Monster를 가까운 순으로
	-- 최대 maxCount명까지 반환한다. 익스플로젼의 FindExplosionTargets와 같은 구조이지만, 범위가
	-- 5배(가로 3.0→15.0, 세로 1.5→7.5)라 별도 함수로 분리한다(익스플로젼 쪽 범위는 그대로 유지).
	@ExecSpace("ServerOnly")
	method table FindDragonRoarTargets(Vector2 fromPos, integer maxCount)
		local map = self.Entity.CurrentMap
		if not isvalid(map) then return {} end
		local monsterComps = map:GetChildComponentsByTypeName("script.Monster", true)
		local candidates = {}
		for _, comp in ipairs(monsterComps) do
			---@type Monster
			local mc = comp
			if isvalid(mc) and isvalid(mc.Entity) and not mc.IsDead then
				local pos = mc.Entity.TransformComponent.WorldPosition
				local dx = pos.x - fromPos.x
				local dy = pos.y - fromPos.y
				if math.abs(dx) <= 15.0 and math.abs(dy) <= 7.5 then
					-- 몬스터가 많을 때 진짜 가까운 순으로 뽑히도록 dx만이 아니라 실제 유클리드 거리로 정렬한다.
					table.insert(candidates, { entity = mc.Entity, dist = math.sqrt(dx * dx + dy * dy) })
				end
			end
		end
		table.sort(candidates, function(a, b) return a.dist < b.dist end)
		local result = {}
		for i = 1, math.min(#candidates, maxCount) do
			table.insert(result, candidates[i].entity)
		end
		return result
	end

	-- 대상 하나에게만 익스플로젼 데미지를 적중시킨다(썬더볼트와 동일한 단일 대상 패턴 - 밀집 지역에서
	-- 판정 박스가 이웃까지 겹쳐 맞히는 것을 막는다).
	@ExecSpace("ServerOnly")
	method void DealExplosionHit(Entity target)
		if not isvalid(target) then return end
		self._T.explosionCurrentTarget = target
		local pos = target.TransformComponent.WorldPosition
		local shape = BoxShape(Vector2(pos.x, pos.y), Vector2(1.0, 1.6), 0)
		self:Attack(shape, "skill.explosion", CollisionGroups.HitBox)
	end

	-- 폭발 지점 주변(독구름의 확대된 시각적 크기의 1.0배 - 1.5배의 2/3로 축소) 안에 있는 독구름을 최대 6개까지 찾아 0.1초 간격으로 하나씩 터뜨린다.
	@ExecSpace("ServerOnly")
	method void PopNearbyPoisonMists(Vector3 fromPos)
		local map = self.Entity.CurrentMap
		if not isvalid(map) then return end
		local children = map.Children:ToTable()
		local found = {}
		for _, c in ipairs(children) do
			if isvalid(c) then
				local mz = c:GetComponent("script.PoisonMistZone")
				if isvalid(mz) then
					-- Visual 자식의 실제 Scale을 읽어 "확대된 시각적 크기"를 구한다 - 하드코딩된 배율을 쓰면
					-- 나중에 독구름 크기를 또 조절할 때마다 여기도 같이 고쳐야 하는 문제가 생긴다.
					local visualScale = 1.0
					local visual = c:GetChildByName("Visual")
					if isvalid(visual) then
						visualScale = visual.TransformComponent.Scale.x
					end
					local pos = c.TransformComponent.WorldPosition
					local dx = math.abs(pos.x - fromPos.x)
					local dy = math.abs(pos.y - fromPos.y)
					-- 독구름의 확대된 시각적 크기(가로 mz.Radius, 세로 1.5를 visualScale배 한 값)의 1.0배(=1.5배의 2/3)를 탐지 범위로 쓴다.
					if dx <= mz.Radius * visualScale * 1.0 and dy <= 1.5 * visualScale * 1.0 then
						table.insert(found, c)
						if #found >= 6 then break end
					end
				end
			end
		end
		log("PlayerAttack: PopNearbyPoisonMists 탐지된 독구름 수=" .. tostring(#found))
		for i, mistEntity in ipairs(found) do
			local delay = (i - 1) * 0.1
			_TimerService:SetTimerOnce(function()
				self:PopOnePoisonMist(mistEntity)
			end, delay)
		end
	end

	@ExecSpace("ServerOnly")
	method void PopOnePoisonMist(Entity mistEntity)
		if not isvalid(mistEntity) then return end
		local pos = mistEntity.TransformComponent.WorldPosition
		local mz = mistEntity:GetComponent("script.PoisonMistZone")
		-- 폭발이펙트를 흩뿌릴 범위 - "확대된 시각적 크기" 전체(탐지범위와 동일한 크기)로 흩뿌리면 눈에 보이는
		-- 독구름 그림보다 훨씬 멀리 떨어진 곳에서 이펙트가 터지는 것처럼 보여서(실측 확인됨), 30%로 줄여
		-- 실제 구름 그림 주변에만 모여서 터지도록 한다.
		local visualScale = 1.0
		local visual = mistEntity:GetChildByName("Visual")
		if isvalid(visual) then
			visualScale = visual.TransformComponent.Scale.x
		end
		local radiusX = 1.8
		if mz ~= nil then radiusX = mz.Radius end
		self:PlayPoisonPopBursts(pos.x, pos.y, pos.z, radiusX * visualScale * 0.3, 1.5 * visualScale * 0.3)
		local targets = self:FindExplosionTargets(Vector2(pos.x, pos.y), 6)
		for _, t in ipairs(targets) do
			self:DealExplosionHit(t)
		end
		if mz ~= nil then
			mz:Pop()
		end
		log("PlayerAttack: PopOnePoisonMist 독구름 파열! pos=(" .. tostring(pos.x) .. "," .. tostring(pos.y) .. ") targets=" .. tostring(#targets))
	end

	-- 독구름 하나가 터질 때 주변 랜덤 위치에서 폭발이펙트를 0.3초 간격으로 3번 재생한다.
	@ExecSpace("ServerOnly")
	method void PlayPoisonPopBursts(number cx, number cy, number cz, number rangeX, number rangeY)
		for i = 1, 3 do
			local delay = (i - 1) * 0.3
			_TimerService:SetTimerOnce(function()
				local offsetX = (_UtilLogic:RandomDouble() * 2.0 - 1.0) * rangeX
				local offsetY = (_UtilLogic:RandomDouble() * 2.0 - 1.0) * rangeY
				self:PlayPoisonPopEffect(cx + offsetX, cy + offsetY, cz)
				log("PlayerAttack: PlayPoisonPopBursts 폭발 " .. tostring(i) .. "/3 offset=(" .. tostring(offsetX) .. "," .. tostring(offsetY) .. ")")
			end, delay)
		end
	end

	@ExecSpace("Multicast")
	method void PlayPoisonPopEffect(number px, number py, number pz)
		-- 독구름이 터질 때 그 주변 랜덤 위치에서 재생되는 폭발 이펙트(skill/211.img/skill/2111002의 special 3종
		-- 중 랜덤 하나) + 사운드.
		if not self:IsClient() then return end
		local mapEntity = self.Entity.CurrentMap
		if not isvalid(mapEntity) then return end
		local specials = {
			"154a7b585c474b07ae77d96a465756e6",
			"ff046ea8281f4ed48430594340ddf6af",
			"49621e22bbab410d87318e2f8cd57899",
		}
		local index = _UtilLogic:RandomIntegerRange(1, #specials)
		_EffectService:PlayEffect(specials[index], mapEntity, Vector3(px, py, pz), 0, Vector3(1, 1, 1), false)
		_SoundService:PlaySound("3edd6d189b9b4bf1ac48162339848e36", 1.0)
	end

	@ExecSpace("ServerOnly")
	method void AttackDragonRoar(number combatPower, number atkMultiplier)
		-- (기능 추가) "다른 스킬을 쓰면 숨고르기 모션은 중지" 요청 - 이 스킬을 새로 시전하는 시점에 이전 숨고르기가 재생 중이었다면 즉시 정리한다.
		self:StopBreather()
		-- 드래곤 로어: 전방위 최대 20명(범위는 익스플로젼의 5배), 시전 뒤 1.5초 지연 폭발, 데미지 배율(1000~1300%).
		-- 추가로 시전 즉시 2초짜리 스턴에 걸린다(모션 자체의 짧은 잠금과는 별개의 독립된 고정 길이 잠금 -
		-- 공격속도 영향을 받지 않는다). 사용 즉시 현재 HP의 40%를 소모한다.
		local currentState = self.Entity.StateComponent.CurrentStateName
		if currentState == "DEAD" or currentState == "CLIMB" or currentState == "LADDER" then
			return
		end
		if self._T.isDragonRoaring then
			log("PlayerAttack: AttackDragonRoar 요청 차단됨(이미 진행 중)")
			return
		end
		self._T.isDragonRoaring = true
		self._T.pendingDragonRoarCombatPower = combatPower

		-- 사용 즉시 현재 HP의 40%를 소모한다(스킬 사용 자체로 죽지 않도록 최소 1은 남긴다).
		local pc = self.Entity.PlayerComponent
		if isvalid(pc) then
			local hpCost = math.floor(pc.Hp * 0.4)
			pc.Hp = math.max(pc.Hp - hpCost, 1)
			log("PlayerAttack: AttackDragonRoar HP 소모=" .. tostring(hpCost) .. " 남은Hp=" .. tostring(pc.Hp))
		end

		-- 익스플로젼과 동일한 모션(alert) 재생 - 별도 플래그 사용.
		local mult = math.max(atkMultiplier or 1.0, 0.001)
		local playerCtrl = self.Entity.PlayerControllerComponent
		local dirX = isvalid(playerCtrl) and playerCtrl.LookDirectionX or 1
		self._T.pendingDragonRoarDirX = dirX
		self._T.pendingDragonRoarWasControllerEnabled = isvalid(playerCtrl) and playerCtrl.Enable
		if isvalid(playerCtrl) then
			playerCtrl.Enable = false
		end
		if isvalid(self.Entity.MovementComponent) then
			self.Entity.MovementComponent:Stop()
		end
		self:PlayDragonRoarMotion(self.Entity, "alert", dirX, mult)

		-- 스턴 잠금: 익스플로젼의 짧은 모션 잠금(0.6*mult)과 달리, 공격속도와 무관하게 항상 고정 2초.
		_TimerService:SetTimerOnce(function()
			self:RestoreDragonRoarControl()
		end, 2.0)

		self:PlayDragonRoarCastEffect(self.Entity)
		self:PlayDragonRoarStunEffect(self.Entity)

		_TimerService:SetTimerOnce(function()
			self:DetonateDragonRoar()
		end, 1.5)
	end

	@ExecSpace("Multicast")
	method void PlayDragonRoarMotion(Entity attacker, string motionName, number dirX, number atkMultiplier)
		-- 드래곤 로어 전용 모션 재생 (익스플로젼과 동일한 방식/모션 - 별도 플래그로 서로 간섭하지 않는다).
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		local avatarRenderer = attacker.AvatarRendererComponent
		if not isvalid(avatarRenderer) then return end
		local body = avatarRenderer:GetBodyEntity()
		if not isvalid(body) then return end

		avatarRenderer.ShowDefaultWeaponEffects = false

		local playerCtrl = attacker.PlayerControllerComponent
		if isvalid(attacker.MovementComponent) then
			attacker.MovementComponent:Stop()
		end
		if isvalid(playerCtrl) then
			playerCtrl.LookDirectionX = dirX
		end
		self._T.isDragonRoarDirectionLocked = true
		self._T.lockedDragonRoarDirX = dirX
		self._T.lockedDragonRoarMotionName = motionName
		self._T.isDragonRoarMotionPlaying = true

		local mult = math.max(atkMultiplier or 1.0, 0.001)
		local playRate = 1.0 / mult
		self._T.lockedDragonRoarPlayRate = playRate

		local motionEvent = ActionStateChangedEvent(motionName, motionName, playRate, SpriteAnimClipPlayType.Onetime)
		body:SendEvent(motionEvent)
		log("[DragonRoar] PlayDragonRoarMotion sent: " .. tostring(motionName) .. " playRate=" .. tostring(playRate))

		_TimerService:SetTimerOnce(function()
			if isvalid(avatarRenderer) then
				avatarRenderer.ShowDefaultWeaponEffects = true
			end
			self._T.isDragonRoarMotionPlaying = false
		end, 0.55 * mult)

		_TimerService:SetTimerOnce(function()
			self._T.isDragonRoarDirectionLocked = false
			local sc = self.Entity.StateComponent
			if isvalid(sc) and sc.CurrentStateName ~= "DEAD" then
				sc:ChangeState("IDLE")
				sc:ChangeState("MOVE")
				sc:ChangeState("IDLE")
			end
		end, 0.80 * mult)
	end

	@ExecSpace("Server")
	method void RestoreDragonRoarControl()
		self._T.isDragonRoaring = false
		local playerCtrl = self.Entity.PlayerControllerComponent
		if isvalid(playerCtrl) and self._T.pendingDragonRoarWasControllerEnabled then
			playerCtrl.Enable = true
		end
		-- (기능 추가) "다른 스킬들을 사용하고 난 다음도 모두 숨고르기 모션을 3번 하도록 해달라"는 요청 -
		-- 컨트롤이 복구된 이 시점에 공용 숨고르기(PlayBreather)를 시작한다.
		self:PlayBreather(self.Entity, self._T.pendingDragonRoarDirX or 1)
	end

	@ExecSpace("Multicast")
	method void PlayDragonRoarCastEffect(Entity attacker)
		-- 시전 즉시 캐릭터 몸쪽에서 1회 재생되는 이펙트 + 사운드 + 화면 흔들림.
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		_EffectService:PlayEffectAttached("5468cadd2f60428e925bc368968e1a1e", attacker, Vector3(0, 0, 0), 0, Vector3(1, 1, 1), false, {})
		_SoundService:PlaySound("7dd03981265b4d9a8c638bf0b18649cc", 1.0)
		local cam = _CameraService:GetCurrentCameraComponent()
		if isvalid(cam) then
			cam:ShakeCamera(0.3, 0.4)
		end
	end

	@ExecSpace("Multicast")
	method void PlayDragonRoarStunEffect(Entity attacker)
		-- 스턴 표시 이펙트 - 사용 즉시 캐릭터에게 2초간 뜬다(고정 길이 - 공격속도 영향 없음).
		-- 발밑(0,0,0)이 아니라 머리 높이(y=0.7)에 뜨도록 위로 올린다(1.0은 너무 높다는 피드백으로 낮춤).
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		local serial = _EffectService:PlayEffectAttached("6337b66c57a947e7b2cda8bbf8697094", attacker, Vector3(0, 0.7, 0), 0, Vector3(1, 1, 1), true, {})
		_TimerService:SetTimerOnce(function()
			_EffectService:RemoveEffect(serial)
		end, 2.0)
	end

	@ExecSpace("ServerOnly")
	method void DetonateDragonRoar()
		-- 시전 1.5초 뒤 호출되어 실제 판정을 진행한다(전방위 최대 20명, 범위는 익스플로젼의 5배 - FindDragonRoarTargets 참고).
		if not isvalid(self.Entity) then return end
		local worldPos = self.Entity.TransformComponent.WorldPosition
		local targets = self:FindDragonRoarTargets(Vector2(worldPos.x, worldPos.y), 20)
		for _, t in ipairs(targets) do
			self:DealDragonRoarHit(t)
		end
		log("PlayerAttack: AttackDragonRoar 발동! targets=" .. tostring(#targets))
	end

	-- 대상 하나에게만 드래곤 로어 데미지를 적중시킨다(익스플로젼/썬더볼트와 동일한 단일 대상 패턴).
	@ExecSpace("ServerOnly")
	method void DealDragonRoarHit(Entity target)
		if not isvalid(target) then return end
		self._T.dragonRoarCurrentTarget = target
		local pos = target.TransformComponent.WorldPosition
		local shape = BoxShape(Vector2(pos.x, pos.y), Vector2(1.0, 1.6), 0)
		local hitComps = self:Attack(shape, "skill.dragonroar", CollisionGroups.HitBox)
		local actuallyHit = false
		for _, hc in ipairs(hitComps) do
			if isvalid(hc) and isvalid(hc.Entity) and hc.Entity == target then
				actuallyHit = true
				break
			end
		end
		if actuallyHit then
			self:PlayDragonRoarHitEffect(target)
		end
	end

	@ExecSpace("Multicast")
	method void PlayDragonRoarHitEffect(Entity target)
		-- 드래곤 로어에 맞은 몬스터 전용 히트 이펙트.
		if not self:IsClient() then return end
		if not isvalid(target) then return end
		local serial = _EffectService:PlayEffectAttached("01c803531e2c4e5aa3c3ef66f14711b8", target, Vector3(0, 0, 0), 0, Vector3(1, 1, 1), false, {})
		_TimerService:SetTimerOnce(function()
			_EffectService:RemoveEffect(serial)
		end, 1.0)
	end

	@ExecSpace("ServerOnly")
	method void AttackFireArrow(number combatPower, number atkMultiplier, number rawDirX, number rawDirY, number level)
		-- (기능 추가) "다른 스킬을 쓰면 숨고르기 모션은 중지" 요청 - 이 스킬을 새로 시전하는 시점에 이전 숨고르기가 재생 중이었다면 즉시 정리한다.
		self:StopBreather()
		-- 파이어에로우: 방향키(위/아래/대각선) 입력으로 각도를 바꿔 화살을 발사한다. 입력이 없으면 캐릭터가
		-- 바라보는 방향(전방)으로 발사. 레벨(50 기준)에 따라 몸쪽 이펙트와 화살 RUID가 달라진다.
		-- level은 SkillManager에서 combatPower와 동일하게 클라이언트에서 계산해 전달받는다 -
		-- _UIMyInfoManager.CharLevel은 서버에서 InitStats() 최초 1회 1로 고정된 뒤 갱신되지 않는 값이라 사용 불가.
		local currentState = self.Entity.StateComponent.CurrentStateName
		if currentState == "DEAD" or currentState == "CLIMB" or currentState == "LADDER" then
			return
		end

		local dirX, dirY = rawDirX, rawDirY
		local mag = math.sqrt(dirX * dirX + dirY * dirY)
		if mag > 0.0001 then
			dirX = dirX / mag
			dirY = dirY / mag
		else
			local playerCtrl = self.Entity.PlayerControllerComponent
			dirX = (isvalid(playerCtrl) and playerCtrl.LookDirectionX >= 0) and 1 or -1
			dirY = 0
		end
		self._T.pendingFireArrowDirX = dirX

		local castRuid = (level >= 50) and "c04324310b7d43219ec0d0fa400c4a5b" or "f3d1726f78be40beae0b32960858f132"
		local arrowRuid = (level >= 50) and "17e6f8af37eb4be09b95304e7854c3db" or "bf1fda424a06413d9617789715d0470e"

		-- 기모으는 딜레이 동안 이동이 되지 않도록 컨트롤러를 잠근다 (매직클로/썬더볼트 등과 동일한 패턴).
		-- 홀드 지속발동(공격속도가 빨라지면 다음 시전이 이전 시전의 잠금 해제보다 먼저 겹쳐 들어올 수 있음) 중에도
		-- 안전하도록, "원래 활성화 상태였는지"는 잠금 체인의 첫 시전에서만 기록하고(이미 잠긴 상태에서 캡처하면
		-- false가 저장되어 영원히 안 풀리는 버그가 생김), 실제 복구도 토큰으로 가장 최근 시전에서만 실행되게 한다.
		local playerCtrl = self.Entity.PlayerControllerComponent
		if not self._T.isFireArrowMovementLocked then
			self._T.pendingFireArrowWasControllerEnabled = isvalid(playerCtrl) and playerCtrl.Enable
			self._T.isFireArrowMovementLocked = true
		end
		if isvalid(playerCtrl) then
			playerCtrl.Enable = false
		end
		if isvalid(self.Entity.MovementComponent) then
			self.Entity.MovementComponent:Stop()
		end
		self._T.fireArrowMoveLockToken = (self._T.fireArrowMoveLockToken or 0) + 1
		local myMoveLockToken = self._T.fireArrowMoveLockToken

		-- 순수 상하 방향(dirX==0)은 캐릭터가 원래 보던 좌우 방향을 그대로 유지한다.
		local horizDirX
		if dirX ~= 0 then
			horizDirX = (dirX > 0) and 1 or -1
		else
			horizDirX = (isvalid(playerCtrl) and playerCtrl.LookDirectionX >= 0) and 1 or -1
		end

		-- 기모으는 느낌: 활 쏘는 모션 + 시전 이펙트/사운드는 즉시 재생하고, 실제 화살 발사는 약간의 딜레이 후에 한다.
		self:PlayFireArrowCastEffect(self.Entity, castRuid, dirX, dirY)
		self:PlayFireArrowMotion(self.Entity, "shoot1", horizDirX, atkMultiplier)
		_TimerService:SetTimerOnce(function()
			self:SpawnFireArrowProjectile(arrowRuid, combatPower, dirX, dirY)
		end, 0.25 * atkMultiplier)
		-- 이동 잠금은 모션 재생 시간이 아니라 스킬 재사용 대기시간(SkillManager의 0.75*atkMultiplier 쿨다운)과
		-- 동일하게 끝까지 유지한다 - "스킬 딜레이 동안 계속 못 움직여야 한다"는 요구사항 반영.
		_TimerService:SetTimerOnce(function()
			self:RestoreFireArrowControl(myMoveLockToken)
		end, 0.75 * atkMultiplier)
	end

	@ExecSpace("Multicast")
	method void PlayFireArrowMotion(Entity attacker, string motionName, number dirX, number atkMultiplier)
		-- 파이어에로우 전용 활 쏘는 모션 재생. 다른 스킬과 동일한 방식 - 별도 플래그로 서로 간섭하지 않는다.
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		local avatarRenderer = attacker.AvatarRendererComponent
		if not isvalid(avatarRenderer) then return end
		local body = avatarRenderer:GetBodyEntity()
		if not isvalid(body) then return end

		avatarRenderer.ShowDefaultWeaponEffects = false

		local playerCtrl = attacker.PlayerControllerComponent
		if isvalid(attacker.MovementComponent) then
			attacker.MovementComponent:Stop()
		end
		if isvalid(playerCtrl) then
			playerCtrl.LookDirectionX = dirX
		end
		self._T.isFireArrowDirectionLocked = true
		self._T.lockedFireArrowDirX = dirX
		self._T.lockedFireArrowMotionName = motionName
		self._T.isFireArrowMotionPlaying = true
		self._T.fireArrowLockToken = (self._T.fireArrowLockToken or 0) + 1
		local myFireArrowLockToken = self._T.fireArrowLockToken

		local mult = math.max(atkMultiplier or 1.0, 0.001)
		local playRate = 1.0 / mult
		self._T.lockedFireArrowPlayRate = playRate

		local motionEvent = ActionStateChangedEvent(motionName, motionName, playRate, SpriteAnimClipPlayType.Onetime)
		body:SendEvent(motionEvent)
		log("[FireArrow] PlayFireArrowMotion sent: " .. tostring(motionName) .. " playRate=" .. tostring(playRate))

		-- 모션 재생 자체(포즈 유지)는 화살이 발사되는 시점(0.25*mult)에 끝나지만, 이동 잠금(방향 고정)은
		-- 스킬 재사용 대기시간 전체(0.75*mult, SkillManager 쿨다운과 동일)까지 유지한다.
		_TimerService:SetTimerOnce(function()
			if isvalid(avatarRenderer) then
				avatarRenderer.ShowDefaultWeaponEffects = true
			end
			self._T.isFireArrowMotionPlaying = false
		end, 0.25 * mult)

		_TimerService:SetTimerOnce(function()
			if self._T.fireArrowLockToken ~= myFireArrowLockToken then return end
			self._T.isFireArrowDirectionLocked = false
			local sc = self.Entity.StateComponent
			if isvalid(sc) and sc.CurrentStateName ~= "DEAD" then
				sc:ChangeState("IDLE")
				sc:ChangeState("MOVE")
				sc:ChangeState("IDLE")
			end
		end, 0.75 * mult)
	end

	@ExecSpace("Server")
	method void RestoreFireArrowControl(integer moveLockToken)
		-- 기모으는 딜레이가 끝나 화살이 발사된 직후 컨트롤러를 되돌린다. 홀드 지속발동으로 더 최근 시전이
		-- 이미 다시 잠가둔 상태라면(토큰 불일치) 여기서 섣불리 풀지 않는다 - 그 최근 시전의 복구 타이머가 처리한다.
		if self._T.fireArrowMoveLockToken ~= moveLockToken then return end
		self._T.isFireArrowMovementLocked = false
		local playerCtrl = self.Entity.PlayerControllerComponent
		if isvalid(playerCtrl) and self._T.pendingFireArrowWasControllerEnabled then
			playerCtrl.Enable = true
		end
		-- (기능 추가) "다른 스킬들을 사용하고 난 다음도 모두 숨고르기 모션을 3번 하도록 해달라"는 요청 -
		-- 컨트롤이 복구된 이 시점에 공용 숨고르기(PlayBreather)를 시작한다.
		self:PlayBreather(self.Entity, self._T.pendingFireArrowDirX or 1)
	end

	@ExecSpace("ServerOnly")
	method void SpawnFireArrowProjectile(string arrowRuid, number combatPower, number dirX, number dirY)
		local map = self.Entity.CurrentMap
		if not isvalid(map) then return end
		self._T.fireArrowCount = (self._T.fireArrowCount or 0) + 1
		local name = "firearrow_" .. tostring(self.Entity.Name) .. "_" .. tostring(self._T.fireArrowCount)
		-- 발쪽(원점)이 아니라 몸통 중심 높이에서 날아가도록 y를 올린다 (다른 스킬들의 body-center 기준값 0.35 재사용)
		local myPos = self.Entity.TransformComponent.WorldPosition
		local proj = _SpawnService:SpawnByModelId("firearrowprojectile", name, Vector3(myPos.x, myPos.y + 0.35, myPos.z), map)
		if not isvalid(proj) then
			log_warning("[PlayerAttack] FireArrow 발사체 스폰 실패")
			return
		end

		local sprite = proj.SpriteRendererComponent
		if isvalid(sprite) then
			sprite.SpriteRUID = arrowRuid
		end

		---@type FireArrowProjectile
		local projComp = proj:GetComponent("script.FireArrowProjectile")
		if isvalid(projComp) then
			projComp.CombatPower = combatPower
			projComp:Fire(dirX, dirY)
		end
	end

	@ExecSpace("Multicast")
	method void PlayFireArrowCastEffect(Entity attacker, string effectRuid, number dirX, number dirY)
		-- 사용자 몸 쪽에서 1회 재생되는 시전 이펙트 + 사운드.
		-- 순수 좌우 방향(dirY==0)은 회전 대신 FlipX로 반전한다 - 180도 회전을 쓰면 이펙트 원점이 발밑까지
		-- 밀려 내려가는 문제가 있어서(사용자 확인 - 왼쪽은 정상, 오른쪽만 밀림), 회전 없이 좌우만 미러링한다.
		-- 위/아래/대각선 방향은 회전이 필요하므로 그대로 두되, 방향별로 사용자가 실제 화면으로 확인해 지적한
		-- 어긋난 위치를 방향별 로컬 오프셋으로 보정한다(위=좌측+상단으로, 아래=우측으로, 우측아래=우측으로, 우측위=상단으로 더).
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		local angleDeg = 0
		local flipX = false
		local offsetX = 0
		local offsetY = 0
		if dirY == 0 then
			flipX = dirX > 0
		elseif dirX == 0 and dirY > 0 then
			-- 위
			angleDeg = math.deg(math.atan(dirY, dirX)) + 180
			offsetX = -0.15
			offsetY = 0.2
		elseif dirX == 0 and dirY < 0 then
			-- 아래
			angleDeg = math.deg(math.atan(dirY, dirX)) + 180
			offsetX = 0.15
		elseif dirX > 0 and dirY > 0 then
			-- 우측위
			angleDeg = math.deg(math.atan(dirY, dirX)) + 180
			offsetY = 0.3
		elseif dirX > 0 and dirY < 0 then
			-- 우측아래
			angleDeg = math.deg(math.atan(dirY, dirX)) + 180
			offsetX = 0.15
		else
			-- 좌측위/좌측아래 (아직 별도 피드백 없음 - 기존 기본 보정 유지)
			angleDeg = math.deg(math.atan(dirY, dirX)) + 180
			if dirY > 0 then
				offsetY = 0.2
			end
		end
		local castOptions = { ["FlipX"] = flipX }
		local serial = _EffectService:PlayEffectAttached(effectRuid, attacker, Vector3(offsetX, offsetY, 0), angleDeg, Vector3(1, 1, 1), false, castOptions)
		_SoundService:PlaySound("6f972ab4e14841398281f3fc2a8f376e", 1.0)
		_TimerService:SetTimerOnce(function()
			_EffectService:RemoveEffect(serial)
		end, 1.0)
	end

	@ExecSpace("ServerOnly")
	method void AttackIronArrow(number combatPower, number atkMultiplier, number rawDirX, number rawDirY)
		-- (기능 추가) "다른 스킬을 쓰면 숨고르기 모션은 중지" 요청 - 이 스킬을 새로 시전하는 시점에 이전 숨고르기가 재생 중이었다면 즉시 정리한다.
		self:StopBreather()
		-- 아이언에로우: 파이어에로우와 완전히 동일한 구조(8방향 발사·기모으는 딜레이·이동봉인)를 그대로
		-- 재사용하되, 전용 이펙트/사운드를 쓰고 레벨에 따른 분기는 없다(고정 1종). 파이어에로우와 서로
		-- 간섭하지 않도록 모든 _T 필드는 별도로 둔다.
		local currentState = self.Entity.StateComponent.CurrentStateName
		if currentState == "DEAD" or currentState == "CLIMB" or currentState == "LADDER" then
			return
		end

		local dirX, dirY = rawDirX, rawDirY
		local mag = math.sqrt(dirX * dirX + dirY * dirY)
		if mag > 0.0001 then
			dirX = dirX / mag
			dirY = dirY / mag
		else
			local playerCtrl = self.Entity.PlayerControllerComponent
			dirX = (isvalid(playerCtrl) and playerCtrl.LookDirectionX >= 0) and 1 or -1
			dirY = 0
		end
		self._T.pendingIronArrowDirX = dirX

		local castRuid = "dcac510901fe451282ad7b93abc3032d"
		local arrowRuid = "1e06841cc18a47c9975303520f3429d6"

		-- 기모으는 딜레이 동안 이동이 되지 않도록 컨트롤러를 잠근다 (파이어에로우와 동일한 첫-시전-캡처 +
		-- 토큰 가드 패턴 - 홀드 지속발동 중에도 안전).
		local playerCtrl = self.Entity.PlayerControllerComponent
		if not self._T.isIronArrowMovementLocked then
			self._T.pendingIronArrowWasControllerEnabled = isvalid(playerCtrl) and playerCtrl.Enable
			self._T.isIronArrowMovementLocked = true
		end
		if isvalid(playerCtrl) then
			playerCtrl.Enable = false
		end
		if isvalid(self.Entity.MovementComponent) then
			self.Entity.MovementComponent:Stop()
		end
		self._T.ironArrowMoveLockToken = (self._T.ironArrowMoveLockToken or 0) + 1
		local myMoveLockToken = self._T.ironArrowMoveLockToken

		-- 순수 상하 방향(dirX==0)은 캐릭터가 원래 보던 좌우 방향을 그대로 유지한다.
		local horizDirX
		if dirX ~= 0 then
			horizDirX = (dirX > 0) and 1 or -1
		else
			horizDirX = (isvalid(playerCtrl) and playerCtrl.LookDirectionX >= 0) and 1 or -1
		end

		self:PlayIronArrowCastEffect(self.Entity, castRuid, dirX, dirY)
		self:PlayIronArrowMotion(self.Entity, "shoot1", horizDirX, atkMultiplier)
		-- 화살이 실제로 발사되기까지의 기모으는 딜레이: 사용자 지정값 0.7로 직접 설정.
		_TimerService:SetTimerOnce(function()
			self:SpawnIronArrowProjectile(arrowRuid, combatPower, dirX, dirY)
		end, 0.7 * atkMultiplier)
		-- 이동 잠금은 모션 재생 시간이 아니라 스킬 재사용 대기시간(SkillManager의 0.75*atkMultiplier 쿨다운)과
		-- 동일하게 끝까지 유지한다.
		_TimerService:SetTimerOnce(function()
			self:RestoreIronArrowControl(myMoveLockToken)
		end, 0.75 * atkMultiplier)
	end

	@ExecSpace("Multicast")
	method void PlayIronArrowMotion(Entity attacker, string motionName, number dirX, number atkMultiplier)
		-- 아이언에로우 전용 활 쏘는 모션 재생. 파이어에로우와 동일한 방식 - 별도 플래그로 서로 간섭하지 않는다.
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		local avatarRenderer = attacker.AvatarRendererComponent
		if not isvalid(avatarRenderer) then return end
		local body = avatarRenderer:GetBodyEntity()
		if not isvalid(body) then return end

		avatarRenderer.ShowDefaultWeaponEffects = false

		local playerCtrl = attacker.PlayerControllerComponent
		if isvalid(attacker.MovementComponent) then
			attacker.MovementComponent:Stop()
		end
		if isvalid(playerCtrl) then
			playerCtrl.LookDirectionX = dirX
		end
		self._T.isIronArrowDirectionLocked = true
		self._T.lockedIronArrowDirX = dirX
		self._T.lockedIronArrowMotionName = motionName
		self._T.isIronArrowMotionPlaying = true
		self._T.ironArrowLockToken = (self._T.ironArrowLockToken or 0) + 1
		local myIronArrowLockToken = self._T.ironArrowLockToken

		local mult = math.max(atkMultiplier or 1.0, 0.001)
		local playRate = 1.0 / mult
		self._T.lockedIronArrowPlayRate = playRate

		local motionEvent = ActionStateChangedEvent(motionName, motionName, playRate, SpriteAnimClipPlayType.Onetime)
		body:SendEvent(motionEvent)
		log("[IronArrow] PlayIronArrowMotion sent: " .. tostring(motionName) .. " playRate=" .. tostring(playRate))

		-- 모션 재생 자체(포즈 유지)는 화살이 발사되는 시점(0.7*mult, 기모으는 딜레이와 동일하게 맞춤)에 끝나지만,
		-- 이동 잠금(방향 고정)은 스킬 재사용 대기시간 전체(0.75*mult, SkillManager 쿨다운과 동일)까지 유지한다.
		_TimerService:SetTimerOnce(function()
			if isvalid(avatarRenderer) then
				avatarRenderer.ShowDefaultWeaponEffects = true
			end
			self._T.isIronArrowMotionPlaying = false
		end, 0.7 * mult)

		_TimerService:SetTimerOnce(function()
			if self._T.ironArrowLockToken ~= myIronArrowLockToken then return end
			self._T.isIronArrowDirectionLocked = false
			local sc = self.Entity.StateComponent
			if isvalid(sc) and sc.CurrentStateName ~= "DEAD" then
				sc:ChangeState("IDLE")
				sc:ChangeState("MOVE")
				sc:ChangeState("IDLE")
			end
		end, 0.75 * mult)
	end

	@ExecSpace("Server")
	method void RestoreIronArrowControl(integer moveLockToken)
		-- 기모으는 딜레이가 끝나 화살이 발사된 직후 컨트롤러를 되돌린다. 홀드 지속발동으로 더 최근 시전이
		-- 이미 다시 잠가둔 상태라면(토큰 불일치) 여기서 섣불리 풀지 않는다.
		if self._T.ironArrowMoveLockToken ~= moveLockToken then return end
		self._T.isIronArrowMovementLocked = false
		local playerCtrl = self.Entity.PlayerControllerComponent
		if isvalid(playerCtrl) and self._T.pendingIronArrowWasControllerEnabled then
			playerCtrl.Enable = true
		end
		-- (기능 추가) "다른 스킬들을 사용하고 난 다음도 모두 숨고르기 모션을 3번 하도록 해달라"는 요청 -
		-- 컨트롤이 복구된 이 시점에 공용 숨고르기(PlayBreather)를 시작한다.
		self:PlayBreather(self.Entity, self._T.pendingIronArrowDirX or 1)
	end

	@ExecSpace("ServerOnly")
	method void SpawnIronArrowProjectile(string arrowRuid, number combatPower, number dirX, number dirY)
		local map = self.Entity.CurrentMap
		if not isvalid(map) then return end
		self._T.ironArrowCount = (self._T.ironArrowCount or 0) + 1
		local name = "ironarrow_" .. tostring(self.Entity.Name) .. "_" .. tostring(self._T.ironArrowCount)
		-- 발쪽(원점)이 아니라 몸통 중심 높이에서 날아가도록 y를 올린다 (파이어에로우와 동일한 body-center 기준값 0.35).
		local myPos = self.Entity.TransformComponent.WorldPosition
		local proj = _SpawnService:SpawnByModelId("ironarrowprojectile", name, Vector3(myPos.x, myPos.y + 0.35, myPos.z), map)
		if not isvalid(proj) then
			log_warning("[PlayerAttack] IronArrow 발사체 스폰 실패")
			return
		end

		local sprite = proj.SpriteRendererComponent
		if isvalid(sprite) then
			sprite.SpriteRUID = arrowRuid
		end

		---@type IronArrowProjectile
		local projComp = proj:GetComponent("script.IronArrowProjectile")
		if isvalid(projComp) then
			projComp.CombatPower = combatPower
			projComp:Fire(dirX, dirY)
		end
	end

	@ExecSpace("Multicast")
	method void PlayIronArrowCastEffect(Entity attacker, string effectRuid, number dirX, number dirY)
		-- 사용자 몸 쪽에서 1회 재생되는 시전 이펙트 + 사운드. 파이어에로우와 동일한 방향별 오프셋/회전
		-- 보정 로직을 그대로 재사용한다(사용자가 이미 화면으로 확인해 맞춰둔 값).
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		local angleDeg = 0
		local flipX = false
		local offsetX = 0
		local offsetY = 0
		if dirY == 0 then
			-- 좌/우: 이전값(0.15)과 직전값(0.0)의 중간 - 0.075.
			flipX = dirX > 0
			offsetY = 0.075
		elseif dirX == 0 and dirY > 0 then
			-- 위(대각선 아님): 왼쪽을 보고 쏠 때는 더 왼쪽으로(-0.3, 기존 유지), 오른쪽을 보고 쏠 때는
			-- 몸에서 너무 멀어졌다는 피드백으로 좌측으로 옮김(0.3 -> -0.15, 원래의 좌측 기본값 수준으로).
			angleDeg = math.deg(math.atan(dirY, dirX)) + 180
			local playerCtrl = attacker.PlayerControllerComponent
			local facingLeft = isvalid(playerCtrl) and playerCtrl.LookDirectionX < 0
			offsetX = facingLeft and -0.3 or -0.15
			offsetY = 0.2
		elseif dirX == 0 and dirY < 0 then
			-- 아래(대각선 아님): 오른쪽을 보고 쏠 때는 더 오른쪽으로(0.3, 기존 유지), 왼쪽을 보고 쏠 때는
			-- 몸에서 너무 멀어졌다는 피드백으로 우측으로 옮김(-0.3 -> 0.15, 원래의 우측 기본값 수준으로).
			angleDeg = math.deg(math.atan(dirY, dirX)) + 180
			local playerCtrl = attacker.PlayerControllerComponent
			local facingRight = isvalid(playerCtrl) and playerCtrl.LookDirectionX >= 0
			offsetX = facingRight and 0.3 or 0.15
		elseif dirX > 0 and dirY > 0 then
			-- 우측위: 방금 올라간 정도(0.5->0.65, +0.15)만큼 한번 더 올림 - 0.65 -> 0.8.
			angleDeg = math.deg(math.atan(dirY, dirX)) + 180
			offsetX = 0.3
			offsetY = 0.8
		elseif dirX > 0 and dirY < 0 then
			-- 우측아래: 조금만 더 올림 - offsetY 0.1->0.2.
			angleDeg = math.deg(math.atan(dirY, dirX)) + 180
			offsetX = 0.45
			offsetY = 0.2
		elseif dirX < 0 and dirY > 0 then
			-- 좌측위: 우측위와 높이를 맞추는 기준(0.5) - 좌측 당김은 그대로 유지.
			angleDeg = math.deg(math.atan(dirY, dirX)) + 180
			offsetX = -0.7
			offsetY = 0.5
		else
			-- 좌측아래: 살짝 왼쪽으로 더 - offsetX -0.15 추가(offsetY -0.2 유지).
			angleDeg = math.deg(math.atan(dirY, dirX)) + 180
			offsetX = -0.15
			offsetY = -0.2
		end
		local castOptions = { ["FlipX"] = flipX }
		local serial = _EffectService:PlayEffectAttached(effectRuid, attacker, Vector3(offsetX, offsetY, 0), angleDeg, Vector3(1, 1, 1), false, castOptions)
		_SoundService:PlaySound("7d5ef2c392a34251990a9dc8b51deb12", 1.0)
		_TimerService:SetTimerOnce(function()
			_EffectService:RemoveEffect(serial)
		end, 1.0)
	end

	@ExecSpace("ServerOnly")
	method void AttackSpearBurst(number combatPower, number atkMultiplier)
		-- (기능 추가) "다른 스킬을 쓰면 숨고르기 모션은 중지" 요청 - 이 스킬을 새로 시전하는 시점에 이전 숨고르기가 재생 중이었다면 즉시 정리한다.
		self:StopBreather()
		-- 스피어 버스터: 타격감을 위해 "3번 찌르는" 스킬로 재설계한다(더블스탭과 동일하게 대상
		-- 하나당 실제 판정을 3회 진행) - 찌르기 자세 모션(시전 즉시) + 찌르는 이펙트 3종(852883a5→
		-- 3c2ee6e6→521bf9f6) + 고정해둔 대상 전원에 대한 실제 데미지 판정(DealSpearBurstStabWave,
		-- 데미지 표시 3줄 + 피격 이펙트 84c06a06 + 몬스터 피격음)은 스킬 사용 damageStartDelay=0.7s
		-- 뒤 + 0.1s/0.2s*mult에 진행되고, 찌르는 이펙트 3종은 그와 별개로 스킬 사용 즉시
		-- (effectStartDelay=0.0s) + 0.1s/0.2s*mult에 진행된다(요청: "852883a5 등 3종 찌르기 이펙트를
		-- 스킬 사용 즉시 보여주는 걸로 우선"). → 3타 판정 이후 여유를 두고 컨트롤 복구.
		-- 모든 리소스는 왼쪽을 보는 기준으로 제작돼, 오른쪽을 보고 있으면(dirX>0) 좌우 반전(FlipX) +
		-- 위치 반전이 필요하다.
		local currentState = self.Entity.StateComponent.CurrentStateName
		if currentState == "DEAD" or currentState == "CLIMB" or currentState == "LADDER" then
			return
		end
		if self._T.isSpearBursting then
			log("PlayerAttack: AttackSpearBurst 요청 차단됨(이미 진행 중)")
			return
		end
		self._T.isSpearBursting = true
		self._T.pendingSpearBurstCombatPower = combatPower

		local mult = math.max(atkMultiplier or 1.0, 0.001)
		local playerCtrl = self.Entity.PlayerControllerComponent
		local dirX = isvalid(playerCtrl) and playerCtrl.LookDirectionX or 1
		self._T.pendingSpearBurstDirX = dirX
		self._T.pendingSpearBurstWasControllerEnabled = isvalid(playerCtrl) and playerCtrl.Enable
		if isvalid(playerCtrl) then
			playerCtrl.Enable = false
		end
		if isvalid(self.Entity.MovementComponent) then
			self.Entity.MovementComponent:Stop()
		end

		-- 대상을 시전 시작 시점에 한 번만 찾아 고정한다(더블스탭/럭키세븐과 동일한 방식) - 드래곤머리가
		-- 발사되는 1.1초 시점까지 몬스터가 다른 공격으로 죽어 후보에서 빠지는 것을 방지한다.
		local worldPos = self.Entity.TransformComponent.WorldPosition
		self._T.spearBurstLockedTargets = self:FindSlashBlastTargets(Vector2(worldPos.x, worldPos.y), dirX, 3)

		-- 날개 이펙트는 진짜 라이브 트윈이 가능한 전용 엔티티(SpearBurstFadingEffect)로 재생한다
		-- (PlayEffectAttached 재생-재생 반복 방식은 깜빡임을 완전히 없앨 수 없어 실측 확인됨).
		-- 캐릭터의 자식 엔티티로 스폰해(로컬 오프셋 좌표) 캐릭터가 움직여도 같이 따라오게 한다 -
		-- 이전에는 맵의 자식으로 스폰 시점 월드좌표에 고정돼, 캐릭터가 움직이면 이펙트만 그 자리에 남는
		-- 문제가 있었다. X는 등 쪽으로 살짝만 떨어지도록 바라보는 방향 반대쪽으로 오프셋(-0.2*dirX, 기존
		-- -0.4에서 캐릭터 쪽으로 더 붙임)을 주고, Y는 등/어깨보다 살짝 낮게(0.05) 내렸다. 존재 시간(hold+tween)은
		-- 기존 0.3+0.3(총 0.6초)에서 1.5배인 0.45+0.45(총 0.9초)로 늘렸다.
		self:SpawnSpearBurstFadingEffect(
			"c7051cc242c54208a7c22df2b4bcc28e", Vector2(-0.2 * dirX, 0.05), dirX > 0,
			1.0, 1.0, 1.0, 0.0, 0.45, 0.45, -1, false, "", 0, 0, 0, 0
		)
		-- 몸쪽 마법진 이펙트(176da561...)도 전용 엔티티(SpawnSpearBurstFadingEffect)로 재생해 투명도 50%→0%로
		-- 서서히 사라지면서 살짝 커지는 라이브 트윈을 재현한다 - PlayEffectAttached로 한 번 바꿨었지만
		-- 그러면 이 트윈 자체가 불가능해서(정적 1회 재생만 지원) 되돌렸다.
		-- (실측 이력) orderInLayer -1~-20은 캐릭터보다 뒤로 가지 않고, -30은 세션에 따라 보였다 안 보였다
		-- 하는 불안정한 값, -40 이하는 지형보다도 뒤로 밀려 항상 안 보였다 - 그래서 한 번은 -20(캐릭터
		-- 기준으로는 딱히 뒤도 아니지만 항상 보이는 안전값)으로 고정했었다. 이번 피드백은 "다른 이펙트(날개,
		-- 찌르는 이펙트 3종)와 겹칠 때 마법진이 앞에 보여야 한다"는 것으로, 그 이펙트들은 PlayEffectAttached
		-- 기본값(OrderInLayer 0 근방)을 쓰므로 마법진을 그보다 높은 양수로 올려 확실히 앞에 오도록 한다.
		-- (버그 수정) "마법진이 2번 재생된다"는 진짜 원인을 찾았다 - 애니메이션클립(176da561...)의
		-- RUID를 SpriteRUID에 그대로 넣으면 world용 SpriteRendererComponent엔 재생 방식(Loop/Onetime)을
		-- 제어하는 프로퍼티 자체가 없어(UI용과 달리) 엔진이 프레임을 계속 반복 재생했다. 대신 그 클립의
		-- 개별 프레임 스프라이트(마법진=d757a7ca..., 용머리=7d52e3968f...)를 직접 교체하는 방식으로
		-- 바꿔 반복 없이 정확히 한 번만 전환되게 한다.
		-- (기능 추가) 투명도 85%, 크기 75%→160%, 전체 속도 1.5배(0.6초, 각 구간 0.3초)로 조정.
		-- (버그 수정) "확대될 때 중앙에서 퍼지지 않고 한쪽에서 잡아당기듯 커진다" - 두 스프라이트의
		-- Pivot이 이미지 중앙이 아니라 좌하단 쪽으로 치우쳐 있어서였다(msw-search 실측: 마법진 pivot
		-- nx=0.6724,ny=0.1638, 116x116 → 중심오프셋(-0.20,0.39); 용머리 pivot nx=0.625,ny=0.1917,
		-- 168x120 → 중심오프셋(-0.21,0.37)). SpawnSpearBurstFadingEffect의 pivotOffset 인자로 넘겨
		-- 매 프레임 그만큼 반대로 위치를 보정해 이미지 중심이 고정된 채 커지도록 한다.
		-- (기능 추가) "좀 더 몸쪽 캐릭터 쪽으로 이동" - localOffset을 (0,0)에서 (0,0.25)로 올려 몸통
		-- 높이 쪽으로 옮겼다(추가 피드백으로 0.15→0.25로 한 번 더 올림). 투명도는 85%→60%로 낮췄고,
		-- 2번째 구간(용머리)이 95%만큼 커진 시점부터 투명도를 0%로 서서히 낮추는 처리는
		-- SpearBurstFadingEffect.mlua의 UpdateSplitGrowth에서 담당한다(StartAlpha=0.6 기준으로 페이드).
		-- (기능 추가) "버튼을 누르고 0.15초 뒤에 재생돼야 한다"는 피드백으로 스폰 자체를 0.15초 지연시켰다
		-- (날개 이펙트(c7051cc2)는 그대로 즉시 재생 - 이 마법진 이펙트만 지연).
		-- (되돌림) "캐릭터보다 앞은 Z-order(OrderInLayer)가 아니라 X축 이동으로 해야 한다"는 피드백으로
		-- OrderInLayer는 10으로 되돌리고(찌르기 3종의 OrderInLayer도 11로 함께 되돌림), 대신 localOffset.x를
		-- 캐릭터가 바라보는 방향(dirX)으로 0.2만큼 옮겨 앞쪽으로 이동시켰다.
		-- (기능 추가) "이펙트 속도를 50% 더 늘려달라(더 빠르게 커지고 더 빠르게 사라지도록)"는 피드백으로
		-- 전체 길이를 0.8→0.8/1.5초(≈0.533초)로 줄였다(1.5배 빠름).
		-- (기능 추가) "최대치를 10% 더 늘려달라"는 피드백으로 EndScale을 1.6→1.76(1.6*1.1)로 올렸다.
		-- (기능 추가) "Y축을 더 올려달라"는 피드백으로 localOffset.y를 0.25→0.35로 올렸다.
		-- (기능 추가) "커지는 속도를 5% 늦춰달라"는 피드백으로 전체 길이를 0.533→0.533*1.05(≈0.56초)로
		-- 늘렸다(5% 느리게).
		-- (기능 추가) "발동 시작 시간을 0.2초 더 미뤄달라"는 피드백으로 스폰 지연을 0.15→0.35초로 늘렸다.
		_TimerService:SetTimerOnce(function()
			self:SpawnSpearBurstFadingEffect(
				"d757a7ca9e3b417fb2d0d5b725baa12c", Vector2(0.2 * dirX, 0.35), dirX > 0,
				0.75, 1.76, 0.6, 0.6, 0.0, 0.8 / 1.5 * 1.05, 10, true, "7d52e3968f954e2dabc8f5a050adcd40",
				-0.20, 0.39, -0.21, 0.37
			)
		end, 0.35)
		-- 찌르는 이펙트 3종은 852883a5 → 3c2ee6e6 → 521bf9f6 순서대로 재생돼야 한다는 피드백으로,
		-- 동시 재생이 아니라 짧은 간격을 두고 순서대로 트리거한다. 타격감을 위해 "3번 찌르는 스킬"답게
		-- 데미지 판정과 무관하게 이 3번의 찌르기 각각에 공격 사운드를 재생한다(기존에는 시전 시점에
		-- 한 번만 재생돼 3번 찌르는 느낌이 안 산다는 피드백) - 사운드 호출은 각 PlaySpearBurst*Effect
		-- 메서드 안으로 옮겼다.
		-- (기능 추가) 이 3번의 찌르기 이펙트와 같은 타이밍에 실제 데미지 판정(DealSpearBurstStabWave)도
		-- 함께 진행해, 대상 몬스터의 데미지 표시 3줄 + 피격 이펙트 + 피격음이 이 3번의 순간에 맞춰
		-- 나도록 한다(요청: "3줄로 스킬 한번에 3대 때리는 느낌").
		-- (버그 수정) 이펙트 클립 자체(852883a5/3c2ee6e6/521bf9f6)의 0번 프레임이 msw-search 리소스
		-- 조회로 확인한 결과 4x4 사실상 투명 프레임이라, 이펙트 호출과 정확히 같은 프레임에 데미지를
		-- 넣으면 화면상 이펙트가 아직 안 보이는 상태에서 데미지가 먼저 들어간 것처럼 보였다(실측 확인).
		-- 이펙트 재생 자체(StartFrameIndex)는 원래대로 되돌리고, 대신 데미지 판정 쪽을 이펙트 호출
		-- 시점보다 이 투명 프레임 길이만큼(effectVisualDelay) 뒤로 미뤄 실제로 이펙트가 보이는 시점에
		-- 데미지가 들어가도록 한다.
		-- (기능 추가) 이펙트 시점과 데미지(히트) 시점을 하나의 hitStartDelay로 합쳐서 순차 조정해왔는데
		-- (0.8→0.4→0.1), "히트 속도는 0.7초 뒤로 하고 찌르기 3종 이펙트 시점은 그보다 0.5초 앞당겨
		-- 달라"는 피드백으로 다시 둘을 분리했다 - damageStartDelay(히트)=0.7, effectStartDelay(이펙트
		-- 3종)=damageStartDelay-0.5=0.2로 고정했었다.
		-- (기능 추가) "852883a5/3c2ee6e6/521bf9f6 이펙트 시점이 느리다 - 스킬버튼 누른 시점에서
		-- 0.2초 뒤로 해달라"는 피드백을 받았다. 계산상으로는 이미 0.2(damageStartDelay-0.5)였지만,
		-- damageStartDelay 파생값이 아니라 요청받은 절대값 그대로 명시적 리터럴로 고정해 앞으로
		-- damageStartDelay(히트 속도)만 따로 바뀌어도 이펙트 시점이 의도치 않게 함께 밀리지 않도록
		-- 한다.
		-- (되돌림) "852883a5/3c2ee6e6/521bf9f6 사이 간격을 늘리면 안 되고 다시 줄여야 한다"는
		-- 피드백으로 이펙트 3종 사이 간격을 0.2*mult/0.4*mult에서 다시 원래의 0.1*mult/0.2*mult로
		-- 되돌린다.
		-- (기능 추가) "852883a5와 c7051cc242c54208a7c22df2b4bcc28e(날개 이펙트, 시전 즉시 재생)
		-- 사이 간격을 절반으로 줄여달라"는 요청으로 한때 0.2 → 0.1로 줄였었으나, "그 간격은 다시
		-- 0.2초여야 한다"는 피드백으로 0.2로 되돌렸었다.
		-- (버그 수정) OrderInLayer로 마법진에 가려지는 문제로 착각했었으나, "852883a5는 날개 이펙트와
		-- 위치 자체가 달라 가려질 수 없다 - Z-order 문제가 아니라 보여지는 시점(딜레이) 자체가
		-- 문제다. 찌르기 이펙트 3종을 스킬 사용 즉시 보이는 것으로 우선 해보자"는 피드백으로
		-- effectStartDelay를 0(시전 즉시)으로 바꿨었다.
		-- (기능 추가) StartFrameIndex 수정으로 "852883a5 시작 시점이 스킬 사용 즉시로 바뀌었다"고
		-- 확인받은 뒤, "이 시작 시점에서 0.5초 후에 뜨는 것으로 바꿔달라"는 피드백으로
		-- effectStartDelay를 0 → 0.5로 조정한다.
		-- (기능 추가) "데미지가 들어가는 시점을 0.2초 앞당겨달라"는 피드백으로 damageStartDelay를
		-- 0.7→0.5로 줄였다(effectStartDelay는 그대로 0.5 유지 - 이제 데미지와 이펙트 시작이 같은
		-- 시점이 된다). SkillManager.mlua의 재사용 대기시간도 damageStartDelay와 반드시 동일해야
		-- 하므로 0.7→0.5로 함께 맞췄다.
		-- (버그 수정) "공격속도를 올려도 실제 공격 횟수(DPS)가 거의 안 오른다 - 파워스트라이크는
		-- 공속을 올리면 확실히 공격 횟수가 늘어난다"는 피드백. 원인은 damageStartDelay/effectStartDelay가
		-- atkMult와 무관한 고정값(0.5초)이었던 것 - 공속을 올려 mult가 작아져도 이 0.5초 고정 구간은
		-- 줄지 않아 스킬 전체 주기(SkillManager 쿨다운의 하한선)가 거의 안 줄었다. 다른 스킬들처럼
		-- 전체 주기가 mult에 비례하도록 두 값 모두 mult를 곱해 스케일링한다(공속을 올렸을 때 파워스트라이크와
		-- 동일한 비율로 스킬 전체 주기가 짧아지도록).
		local damageStartDelay = 0.5 * mult
		local effectStartDelay = 0.5 * mult
		-- (기능 추가) "3종 찌르기 이펙트 간 시간 간격을 1.5배 늘려달라"는 피드백으로 간격 상수를
		-- 0.1/0.2*mult → 0.15/0.3*mult로 1.5배 늘렸다. 데미지 판정(DealSpearBurstStabWave) 타이밍도
		-- 화면 이펙트와 항상 함께 맞아야 하므로("3줄 데미지가 실제 3연타 이펙트와 같은 순간에 뜬다")
		-- 동일하게 1.5배로 같이 늘렸다.
		_TimerService:SetTimerOnce(function()
			self:PlaySpearBurstCircleEffect(self.Entity, dirX)
		end, effectStartDelay)
		_TimerService:SetTimerOnce(function()
			self:DealSpearBurstStabWave(1, dirX)
		end, damageStartDelay)
		_TimerService:SetTimerOnce(function()
			self:PlaySpearBurstBuildupEffect1(self.Entity, dirX)
		end, effectStartDelay + 0.15 * mult)
		_TimerService:SetTimerOnce(function()
			self:DealSpearBurstStabWave(2, dirX)
		end, damageStartDelay + 0.15 * mult)
		_TimerService:SetTimerOnce(function()
			self:PlaySpearBurstBuildupEffect2(self.Entity, dirX)
		end, effectStartDelay + 0.3 * mult)
		_TimerService:SetTimerOnce(function()
			self:DealSpearBurstStabWave(3, dirX)
		end, damageStartDelay + 0.3 * mult)

		-- 찌르기 모션 이름이 아직 실측 확인되지 않아 사용할 때마다 순서대로(무작위 아님) 후보를 하나씩
		-- 넘겨가며 로그에 남긴다. 화면과 로그(PlaySpearBurstStabMotion sent <이름>)를 대조해 실제로
		-- 찌르기 자세처럼 보이는 이름을 찾으면 알려달라 - 그걸로 고정한다.
		-- (기능 추가) "모션이 즉시 시작해야 한다"는 피드백으로, 기존에 딜레이(0.55*mult 등)를 두고
		-- 타이머로 예약하던 것을 제거하고 시전 즉시(0초) 동기 호출로 바꿨다.
		local motionName = self:GetSpearBurstMotionName()
		self:PlaySpearBurstStabMotion(self.Entity, dirX, mult, motionName)

		-- (버그 수정) "반대 방향키를 누르고 있으면 찌르는 모션인 채로 뒤로 돌게 된다"는 피드백의 원인 -
		-- 컨트롤 복구(playerCtrl.Enable=true) 시점이 damageStartDelay+0.3*mult 공식만으로 계산돼,
		-- PlaySpearBurstStabMotion의 3단계 콤보(beat1Hold=0.12*mult+beat2Hold=0.25*mult+beat3Hold=0.2*mult)가
		-- 아직 안 끝났는데도 먼저 풀려버리는 경우가 있었다. 두 시점 중 항상 더 늦은 쪽을 기준으로 삼도록
		-- math.max로 묶어, 모션이 실제로 다 끝난 뒤에만 컨트롤이 풀리게 한다(모션 콤보 상수는
		-- PlaySpearBurstStabMotion의 beat1Hold/beat2Hold/beat3Hold와 반드시 일치해야 한다 - DPS 스케일링을
		-- 위해 이제 세 값 모두 mult가 곱해진다).
		-- (버그 수정) "공속을 올려도 DPS가 파워스트라이크만큼 안 오른다"는 추가 피드백 - 안전 여유였던
		-- "+0.05"가 mult와 무관한 고정값이라 공속이 빨라질수록 전체 주기에서 차지하는 비중이 커져 DPS
		-- 스케일링을 계속 깎아먹고 있었다. 두 안전 여유 모두 mult에 비례하도록(0.05*mult) 바꿔, 최종
		-- 주기가 damageStartDelay/motionComboEnd와 마찬가지로 순수하게 0.85*mult 형태(파워스트라이크의
		-- 0.75*atkMult와 동일한 단일 비례식)가 되도록 한다.
		-- (버그 수정) beat3Hold를 0.2→0.35로 늘린 것과 맞춰(방향전환 버그 수정) 여기 수식도 함께 갱신한다 -
		-- 실제 restoreDelay 값은 여전히 damageStartDelay 쪽 분기(0.85*mult)가 더 커서 바뀌지 않는다.
		local motionComboEnd = (0.12 + 0.25 + 0.35) * mult
		local restoreDelay = math.max(damageStartDelay + 0.3 * mult + 0.05 * mult, motionComboEnd + 0.05 * mult)
		_TimerService:SetTimerOnce(function()
			self:RestoreSpearBurstControl()
		end, restoreDelay)
	end

	-- PlayEffectAttached 재생-재생 반복으로 알파/스케일 페이드를 흉내내면 깜빡임을 완전히 없앨 수
	-- 없다는 것이 실측 확인됐다(엔진에 재생 중인 이펙트의 실시간 트윈 API가 없음). 대신 전용 엔티티
	-- (RootDesk/MyDesk/Models/Effects/SpearBurstFadingEffect.model, script.SpearBurstFadingEffect)를
	-- 스폰해 그 엔티티 자신의 SpriteRendererComponent.Color/TransformComponent.Scale을 매 프레임
	-- 직접 갱신하는 진짜 라이브 트윈으로 대체한다 - 깜빡임 없이 부드럽게 페이드/스케일된다.
	-- 캐릭터와의 앞/뒤 순서는 orderInLayer로 결정한다. (실측 확인) 같은 SortingLayer(Default)에서
	-- Position.z만 다르게 줘서는 이 전용 엔티티가 캐릭터(아바타 바디)보다 확실히 뒤로 가지 않았다 -
	-- OrderInLayer는 Z보다 우선순위가 높은 정렬 기준이라, 캐릭터 기준값(0)보다 1 작은/큰 값을 명시적으로
	-- 줘야 확실하게 뒤/앞이 결정된다. -100/100처럼 극단값을 주면 캐릭터가 아니라 맵의 다른 레이어(배경/지형)
	-- 까지 밀려날 위험이 있어, 캐릭터 기준 ±1의 작은 값만 사용한다.
	-- localOffset: 맵이 아니라 캐릭터 엔티티(self.Entity)의 자식으로 스폰해서 캐릭터 로컬 좌표로 해석된다 -
	-- 이전에는 맵의 자식으로 스폰 시점 월드좌표에 고정돼, 캐릭터가 움직이면 이펙트만 그 자리에 남는(따라오지
	-- 않는) 문제가 있었다. 자식으로 붙이면 부모(캐릭터) Transform을 따라 매 프레임 자동으로 같이 움직인다.
	@ExecSpace("ServerOnly")
	method void SpawnSpearBurstFadingEffect(string ruid, Vector2 localOffset, boolean flipX, number startScale, number endScale, number startAlpha, number endAlpha, number holdDuration, number tweenDuration, integer orderInLayer, boolean useSplitGrowth, string secondRuid, number pivotOffsetX, number pivotOffsetY, number secondPivotOffsetX, number secondPivotOffsetY)
		local fxEntity = _SpawnService:SpawnByModelId("spearburstfadingeffect", "SpearBurstFX", Vector3(localOffset.x, localOffset.y, 0), self.Entity)
		if not isvalid(fxEntity) then return end
		fxEntity:AddComponent("script.SpearBurstFadingEffect")
		local comp = fxEntity:GetComponent("script.SpearBurstFadingEffect")
		if isvalid(comp) then
			comp.ClipRUID = ruid
			comp.IsFlipX = flipX
			comp.StartScale = startScale
			comp.EndScale = endScale
			comp.StartAlpha = startAlpha
			comp.EndAlpha = endAlpha
			comp.HoldDuration = holdDuration
			comp.TweenDuration = tweenDuration
			comp.OrderInLayerValue = orderInLayer
			comp.UseSplitGrowth = useSplitGrowth
			comp.SecondClipRUID = secondRuid
			comp.PivotOffsetX = pivotOffsetX
			comp.PivotOffsetY = pivotOffsetY
			comp.SecondPivotOffsetX = secondPivotOffsetX
			comp.SecondPivotOffsetY = secondPivotOffsetY
		end
		_TimerService:SetTimerOnce(function()
			if isvalid(fxEntity) then
				fxEntity:Destroy()
			end
		end, holdDuration + tweenDuration + 0.2)
	end

	@ExecSpace("Multicast")
	method void PlaySpearBurstCircleEffect(Entity attacker, number dirX)
		-- 찌르는 이펙트 3종 중 첫 번째로, 스킬을 사용하는 시점에 몸쪽 높이에서 뜨는 마법진(발밑이
		-- 아니라 몸통 높이여야 한다는 피드백으로 Y 오프셋을 제거했다).
		-- (버그 수정) "날개/마법진 이펙트가 사라진 뒤에야 찌르기 이펙트가 보인다"는 피드백 원인을
		-- 찾았다 - 몸쪽 마법진(176da561...)의 OrderInLayer가 10으로, 이 찌르기 이펙트 3종의 기본값
		-- (미지정 시 0 근방)보다 높아 마법진이 다 사라지기 전까지 찌르기 이펙트를 가리고 있었다.
		-- 찌르기 이펙트가 effectStartDelay(0.2초) 시점에 마법진과 무관하게 항상 눈에 보이도록,
		-- 마법진(10)보다 높은 OrderInLayer(11)를 명시적으로 지정해 항상 앞에 그려지게 한다.
		-- (버그 수정) 그 뒤에도 "이펙트가 보이는 속도가 전혀 변하지 않는다"는 피드백이 계속돼
		-- effectStartDelay를 0.8→0.4→0.2→0.1→0까지 바꿔봐도 체감이 그대로였다 - 원인은 스케줄링
		-- 딜레이가 아니라 이펙트 클립 자체였다. msw-search로 852883a5/3c2ee6e6/521bf9f6 세 클립을
		-- 모두 재조회한 결과 셋 다 0번 프레임이 4x4 투명 placeholder이고 실제 형상은 1번 프레임부터
		-- 시작한다 - 호출 시점과 무관하게 클립이 항상 이 투명한 0번 프레임부터 재생을 시작해, 실제
		-- 형상이 보이기까지 클립 자체의 0번 프레임 재생 시간만큼 항상 고정 지연이 있었던 것이다(그래서
		-- effectStartDelay를 아무리 줄여도 체감이 변하지 않았다). StartFrameIndex=1을 지정해 투명한
		-- 0번 프레임을 건너뛰고 실제 형상이 있는 1번 프레임부터 바로 재생되도록 한다.
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		local flipX = dirX > 0
		-- (기능 추가) 마법진 이펙트의 OrderInLayer를 10→15로 올리면서, 이 찌르기 이펙트가 다시 가려지지
		-- (되돌림) 마법진이 X축 이동으로 앞에 오도록 바뀌어 OrderInLayer 경쟁이 더 이상 없으므로
		-- 원래 값(11)으로 되돌린다.
		_EffectService:PlayEffectAttached("852883a5b27442e88ac5a23f5a218a58", attacker, Vector3(0, 0, 0), 0, Vector3(1, 1, 1), false, { ["FlipX"] = flipX, ["OrderInLayer"] = 11, ["StartFrameIndex"] = 1 })
		self:PlaySpearBurstAttackSound(attacker)
	end

	method string GetSpearBurstMotionName()
		-- 스피어 버스터 전용 찌르기 자세 모션. 실제 화면으로 후보(stabT1/T2, stabO1/O2, swingT1~T3,
		-- swingO1~O3)를 순차 테스트해 stabT2로 확정했다 - 더 이상 순환하지 않고 고정 재생한다.
		local name = "stabT2"
		log("PlayerAttack: GetSpearBurstMotionName 고정 모션 [" .. tostring(name) .. "]")
		return name
	end

	@ExecSpace("Multicast")
	method void PlaySpearBurstStabMotion(Entity attacker, number dirX, number atkMultiplier, string motionName)
		-- (되돌림) "stabO1이 도중에 창이 사라지는 버그를 유발한다"는 피드백 + 참고 영상(123.mp4) 224프레임
		-- 전수 분석 결과, 실제 원본도 몸 자세는 창을 든 채 거의 고정돼 있고 "3연타 찌르기" 느낌은 몸동작이
		-- 아니라 용머리가 창을 타고 뻗어나가는 이펙트가 반복되는 데서 나온다는 것을 확인했다(이미 구현된
		-- 852883a5/3c2ee6e6/521bf9f6 3종 이펙트 + 마법진/용머리 이펙트가 그 역할). 위-아래-위 합성 모션
		-- 실험은 안전하지 않은 액션 이름(stabO1)이 무기 렌더링을 깨뜨리는 부작용만 낳았으므로, 실측으로
		-- 안전 확인된 단일 모션(stabT2) 재생으로 되돌린다.
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		local avatarRenderer = attacker.AvatarRendererComponent
		if not isvalid(avatarRenderer) then return end
		local body = avatarRenderer:GetBodyEntity()
		if not isvalid(body) then return end

		avatarRenderer.ShowDefaultWeaponEffects = false

		local playerCtrl = attacker.PlayerControllerComponent
		if isvalid(attacker.MovementComponent) then
			attacker.MovementComponent:Stop()
		end
		if isvalid(playerCtrl) then
			playerCtrl.LookDirectionX = dirX
		end
		self._T.isSpearBurstDirectionLocked = true
		self._T.lockedSpearBurstDirX = dirX
		self._T.lockedSpearBurstMotionName = motionName
		self._T.isSpearBurstMotionPlaying = true
		-- 재시전 시 이전 숨고르기가 남아있으면 새 콤보를 방해하지 않도록 즉시 정리한다.
		self._T.isBreatherPlaying = false

		local mult = math.max(atkMultiplier or 1.0, 0.001)
		local playRate = 1.0 / mult
		self._T.lockedSpearBurstPlayRate = playRate

		-- (사용자 정확 지정, 3단계) "마지막 모션 → 0.12초 뒤 마지막 전 모션(역방향, 0.25초 유지) →
		-- 마지막 모션 다시". ZigzagLoop는 끊는 시점까지 영원히 왕복하므로(직전 버그: ChangeState("IDLE")는
		-- 상태가 실제로 안 바뀌면 no-op라 못 끊음), 3단계에서 Onetime으로 덮어써 왕복을 확실히 멈춘다.
		local motionEvent = ActionStateChangedEvent(motionName, motionName, playRate, SpriteAnimClipPlayType.Onetime)
		body:SendEvent(motionEvent)
		log("[SpearBurst] 1단계(마지막 모션) sent " .. tostring(motionName) .. " playRate=" .. tostring(playRate))

		-- (버그 수정) "공속을 올려도 공격 횟수가 거의 안 는다"는 피드백 - 이 세 박자 길이가 mult와
		-- 무관한 고정 초 단위였던 것이 스킬 전체 주기의 하한선이 돼 DPS 스케일링을 막고 있었다.
		-- 재생 속도(playRate=1/mult)와 같은 비율로 박자 길이도 mult를 곱해, 공속이 빨라지면 콤보 전체가
		-- 비례해서 짧아지도록 한다(0.12:0.25:0.2 비율 자체는 그대로 유지).
		local beat1Hold = 0.12 * mult
		local beat2Hold = 0.25 * mult
		-- 2단계: beat1Hold초 뒤 마지막 전 모션(역방향 시작).
		_TimerService:SetTimerOnce(function()
			if not isvalid(body) then return end
			local beat2Event = ActionStateChangedEvent(motionName, motionName, playRate, SpriteAnimClipPlayType.ZigzagLoop)
			body:SendEvent(beat2Event)
			log("[SpearBurst] 2단계(마지막 전 모션, 역방향 시작) sent " .. tostring(motionName))
		end, beat1Hold)

		-- 3단계: 2단계를 0.25초 유지한 뒤 마지막 모션을 다시 재생.
		_TimerService:SetTimerOnce(function()
			if not isvalid(body) then return end
			local beat3Event = ActionStateChangedEvent(motionName, motionName, playRate, SpriteAnimClipPlayType.Onetime)
			body:SendEvent(beat3Event)
			log("[SpearBurst] 3단계(마지막 모션 다시) sent " .. tostring(motionName))
		end, beat1Hold + beat2Hold)

		-- (기능 추가) "숨고르기 전 마지막 모션의 길이를 0.2로 늘려달라"는 요청으로 고정 0.2를 기준값으로
		-- 삼았고, 이후 DPS 스케일링 수정으로 다른 두 박자와 동일하게 mult를 곱해 비례하도록 한다.
		-- (버그 수정) "모션보다 딜레이가 짧아 모션 중 방향전환이 된다"는 신고로 0.2→0.35로 늘려 3단계
		-- 모션(Onetime)이 화면에서 완전히 끝날 때까지 방향/모션 잠금이 유지되도록 여유를 더 준다.
		local beat3Hold = 0.35 * mult
		_TimerService:SetTimerOnce(function()
			self._T.isSpearBurstMotionPlaying = false
			self._T.isSpearBurstDirectionLocked = false
			log("[SpearBurst] 방향/모션 잠금 해제 t=" .. tostring(_UtilLogic.ElapsedSeconds))
		end, beat1Hold + beat2Hold + beat3Hold)
	end

	@ExecSpace("Multicast")
	method void PlaySpearBurstBuildupEffect1(Entity attacker, number dirX)
		-- 찌르는 이펙트 3종 중 두 번째(852883a5 다음). 몸통 높이(Y=0)에서 재생된다.
		-- (버그 수정) PlaySpearBurstCircleEffect와 동일한 이유로 마법진(OrderInLayer=10)에 가리지
		-- 않도록 OrderInLayer=11을 명시한다. 3c2ee6e6도 0번 프레임이 4x4 투명이라 StartFrameIndex=1로
		-- 건너뛴다(PlaySpearBurstCircleEffect와 동일한 원인/조치).
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		local flipX = dirX > 0
		-- (기능 추가) "몸쪽으로 조금 땡겨달라"는 피드백으로 앞쪽 오프셋을 0.3→0.15로 줄였다. 마법진
		-- (되돌림) 마법진이 X축 이동으로 앞에 오도록 바뀌어 OrderInLayer는 원래 값(11)으로 되돌린다.
		_EffectService:PlayEffectAttached("3c2ee6e636924e179cca843f819f9b30", attacker, Vector3(0.15 * dirX, 0, 0), 0, Vector3(1, 1, 1), false, { ["FlipX"] = flipX, ["OrderInLayer"] = 11, ["StartFrameIndex"] = 1 })
		self:PlaySpearBurstAttackSound(attacker)
	end

	@ExecSpace("Multicast")
	method void PlaySpearBurstBuildupEffect2(Entity attacker, number dirX)
		-- 찌르는 이펙트 3종 중 세 번째(마지막). 몸통 높이(Y=0)에서 재생된다.
		-- (버그 수정) PlaySpearBurstCircleEffect와 동일한 이유로 마법진(OrderInLayer=10)에 가리지
		-- 않도록 OrderInLayer=11을 명시한다. 521bf9f6도 0번 프레임이 4x4 투명이라 StartFrameIndex=1로
		-- 건너뛴다(PlaySpearBurstCircleEffect와 동일한 원인/조치).
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		local flipX = dirX > 0
		-- (기능 추가) "몸쪽으로 조금 땡겨달라"는 피드백으로 앞쪽 오프셋을 0.3→0.15로 줄였다. 마법진
		-- (되돌림) 마법진이 X축 이동으로 앞에 오도록 바뀌어 OrderInLayer는 원래 값(11)으로 되돌린다.
		_EffectService:PlayEffectAttached("521bf9f60cb94a7fb9890ba2e0ede109", attacker, Vector3(0.15 * dirX, 0, 0), 0, Vector3(1, 1, 1), false, { ["FlipX"] = flipX, ["OrderInLayer"] = 11, ["StartFrameIndex"] = 1 })
		self:PlaySpearBurstAttackSound(attacker)
	end

	-- (버그 수정) 이전에는 @ExecSpace("Multicast")였는데, 이 메서드를 서버가 직접 부르지 않고
	-- PlaySpearBurstCircleEffect/BuildupEffect1/2(이미 Multicast로 각 클라이언트에서 실행 중인 메서드) 안에서
	-- 호출하는 구조로 바뀌면서, 클라이언트 실행 컨텍스트 안에서 또 다른 Multicast 메서드를 호출하는 셈이 돼
	-- 실제로는 아무 데도 전달되지 않고 조용히 무시됐다(로그로 실측 확인 - 호출은 되지만 재생 로그가 전혀
	-- 안 찍힘). Multicast는 서버가 직접 호출해야 클라이언트들로 퍼진다 - 이미 클라이언트에서 실행 중인
	-- 호출부에서는 어노테이션 없는(호출한 쪽에서 그대로 실행되는) 일반 메서드여야 한다.
	method void PlaySpearBurstAttackSound(Entity attacker)
		-- 공격 사운드(fcac442d...). 공격속도에 따른 재생 속도 변경은 소리가 이상하게 들린다는
		-- 피드백으로 제거하고, 다른 스킬과 동일하게 고정 속도로 재생한다.
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		_SoundService:PlaySound("fcac442d953049d980da4b8d7bd766d8", 1.0)
		log("[SpearBurst] PlaySpearBurstAttackSound 재생됨 t=" .. tostring(_UtilLogic.ElapsedSeconds))
	end

	@ExecSpace("Server")
	method void RestoreSpearBurstControl()
		self._T.isSpearBursting = false
		local playerCtrl = self.Entity.PlayerControllerComponent
		if isvalid(playerCtrl) and self._T.pendingSpearBurstWasControllerEnabled then
			playerCtrl.Enable = true
		end
		if isvalid(self.Entity.AvatarRendererComponent) then
			self.Entity.AvatarRendererComponent.ShowDefaultWeaponEffects = true
		end

		local sc = self.Entity.StateComponent
		if isvalid(sc) and sc.CurrentStateName ~= "DEAD" then
			sc:ChangeState("IDLE")
			sc:ChangeState("MOVE")
			sc:ChangeState("IDLE")
		end

		-- (버그 수정) "idle 모션이 호출되는 순간 숨고르기로 전환되어야 하는데 안 된다"는 신고 - 처음엔 위
		-- 토글보다 먼저 PlayBreather(무장)를 호출해 HandleStateChangeEvent가 토글의 StateChangeEvent를 잡게
		-- 했는데, 실측 결과 이 서버 메서드 안에서 순서대로 보낸 Multicast RPC(PlayBreather)와 StateComponent
		-- 상태 동기화(위 ChangeState)가 서로 다른 네트워크 경로를 타 클라이언트 도착 순서가 보장되지 않았고,
		-- 실제로는 상태 동기화가 먼저 도착해 이벤트를 놓치고 5초 안전망 타이머로만 겨우 시작되는 문제가 있었다.
		-- 이 메서드는 서버가 위에서 토글을 "이미" 동기적으로 완료한 뒤이므로, 클라이언트의 이벤트를 기다릴
		-- 필요 없이 곧장 시작을 지시하는 전용 Multicast(PlayBreatherImmediate)를 쓴다 - 무장/이벤트 대기 없이
		-- 도착하는 즉시 재생한다.
		self:PlayBreatherImmediate(self.Entity, self._T.pendingSpearBurstDirX or 1)
	end

	@ExecSpace("Multicast")
	method void PlayBreatherImmediate(Entity attacker, number dirX)
		-- RestoreSpearBurstControl처럼 서버가 IDLE→MOVE→IDLE 토글을 이미 동기적으로 끝낸 뒤 호출하는 전용
		-- 경로. PlayBreather(무장 후 StateChangeEvent 대기)와 달리 곧장 재생을 시작한다 - 자세한 이유는
		-- RestoreSpearBurstControl의 주석 참고.
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		self._T.breatherToken = (self._T.breatherToken or 0) + 1
		local myToken = self._T.breatherToken
		self:StartBreatherNow(attacker, myToken)
	end

	@ExecSpace("Multicast")
	method void PlayBreather(Entity attacker, number dirX)
		-- (기능 추가) "가만히 있을 때 기본모션으로 돌아갔다가 다시 숨고르기로 가서 불안정해 보인다 -
		-- 기본모션으로 바뀌는 타이밍에 숨고르기를 넣어달라"는 요청 - 고정 시간을 기다리는 대신, 각
		-- 스킬의 모션 정리용 IDLE→MOVE→IDLE 토글이 실제로 "IDLE"(기본 모션)로 전환되는 순간을 감지해
		-- 그 즉시 숨고르기로 덮어쓴다(HandleStateChangeEvent 참고 - 기본 모션이 화면에 보일 틈이 없다).
		--
		-- (버그 수정) "idle 모션이 호출되는 순간 숨고르기로 전환돼야 하는데 안 된다"는 신고 - 예전에는
		-- 여기 도착 시점에 CurrentStateName이 이미 "IDLE"이면 곧장 시작했는데, 파워스트라이크류 스킬은
		-- ATTACK으로 상태 전환을 아예 하지 않고 raw 모션 이벤트만 보내기 때문에(PlayAttackMotion 참고)
		-- 스킬을 시전하는 내내 CurrentStateName이 계속 "IDLE"로 남아있다 - 즉 "이미 IDLE"이 "정말로 기본
		-- 모션으로 복귀하는 순간"을 의미하지 않았다. 그 결과 이 즉시-시작 경로가 실제 모션 정리 토글
		-- (0.8*mult초 뒤)보다 훨씬 먼저 숨고르기를 시작시켰고, 뒤늦게 진짜 토글이 발생하면서 그 토글이
		-- 만드는 진짜 StateChangeEvent(IDLE)가 방금 시작한 숨고르기 alert 애니메이션을 덮어써 기본 모션으로
		-- 되돌려버렸다(겉보기엔 "숨고르기가 시작 안 됨"). 이제는 무조건 "무장(armed)"만 하고, 실제 시작은
		-- HandleStateChangeEvent가 진짜 IDLE 전환 이벤트를 잡는 시점에서만 한다 - 모든 스킬이 결국 이 토글을
		-- 거치므로(클라이언트 쪽이든, 스피어 버스터처럼 서버 쪽이든) 항상 이벤트가 온다. 혹시 어느 스킬이
		-- 이 토글 없이 DEAD 등으로 빠지는 경우를 대비해서만 넉넉한 안전망 타이머를 둔다(공격속도 배율
		-- 최댓값 3.0 기준 최대 토글 지연 0.8*3.0=2.4초보다 충분히 긴 5초).
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end

		self._T.breatherToken = (self._T.breatherToken or 0) + 1
		local myToken = self._T.breatherToken
		self._T.isBreatherArmed = true
		self._T.breatherArmedAttacker = attacker

		_TimerService:SetTimerOnce(function()
			if self._T.breatherToken ~= myToken then return end
			if not self._T.isBreatherArmed then return end
			self._T.isBreatherArmed = false
			self:StartBreatherNow(attacker, myToken)
		end, 5.0)
	end

	method void StartBreatherNow(Entity attacker, integer myToken)
		-- PlayBreather가 IDLE 전환 감지(또는 안전망 타이머)로 판단한 시점에 실제로 alert 모션을 재생한다.
		-- (참고) 이 메서드는 @ExecSpace를 지정하지 않는다 - PlayBreather의 클라이언트 측 이벤트 핸들러/
		-- 타이머 콜백(이미 IsClient()를 통과한 상태) 안에서 호출되므로 그대로 같은 컨텍스트에서
		-- 실행돼야 한다. Multicast로 지정하면 그 안에서 재호출 시 실행되지 않는 문제가 실측 확인됐다.
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		local avatarRenderer = attacker.AvatarRendererComponent
		if not isvalid(avatarRenderer) then return end
		local body = avatarRenderer:GetBodyEntity()
		if not isvalid(body) then return end

		self._T.isBreatherPlaying = true

		local breatherEvent = ActionStateChangedEvent("alert", "alert", 1.0, SpriteAnimClipPlayType.Loop)
		body:SendEvent(breatherEvent)
		log("[Breather] 숨고르기 시작 (alert, 3초 또는 다른 행동 시까지)")

		_TimerService:SetTimerOnce(function()
			if self._T.breatherToken ~= myToken then return end
			if not self._T.isBreatherPlaying then return end
			self._T.isBreatherPlaying = false
			-- (버그 수정) "스피어 버스터 사용 후 숨고르기가 계속 지속된다"는 신고 - 원인은 여기서
			-- ChangeState("IDLE") 한 번만 불렀던 것. 컨트롤 복구 시점(RestoreSpearBurstControl 등)에서
			-- 이미 IDLE→MOVE→IDLE 토글을 거쳐 CurrentStateName이 이미 "IDLE"인 상태였기 때문에, 같은
			-- 상태로 다시 ChangeState("IDLE")를 부르면 실제 상태 전이가 없어 StateChangeEvent가 발생하지
			-- 않고, body에 직접 보낸 "alert" Loop 애니메이션을 덮어쓸 계기가 전혀 생기지 않아 화면에서
			-- 영원히 반복 재생되는 상태로 남았다. 이 파일의 다른 곳(PlayAttackMotion 등)에서 이미
			-- 검증된 것과 동일하게 IDLE→MOVE→IDLE 강제 토글로 반드시 새 StateChangeEvent를 일으켜야
			-- AvatarStateAnimationComponent가 기본 stand/walk 클립을 다시 내보내 alert를 확실히 덮어쓴다.
			local sc = attacker.StateComponent
			if isvalid(sc) and sc.CurrentStateName ~= "DEAD" then
				sc:ChangeState("IDLE")
				sc:ChangeState("MOVE")
				sc:ChangeState("IDLE")
			end
			log("[Breather] 숨고르기 자동 종료(3초 경과)")
		end, 3.0)
	end

	@ExecSpace("Multicast")
	method void StopBreather()
		-- (기능 추가) "움직이거나 다른 스킬을 쓰면 숨고르기 모션은 중지하여야 합니다"는 요청 - 각
		-- Attack* 스킬 진입 시점에 호출해 취소한다. IDLE 전환을 기다리는 중(isBreatherArmed)이든
		-- 재생 중(isBreatherPlaying)이든 상관없이 토큰을 무조건 올리고 두 플래그 모두 내려, 대기
		-- 중이던 시작(HandleStateChangeEvent의 IDLE 감지 / 0.3초 안전망 타이머)과 재생 중이던
		-- 자동종료 타이머를 모두 무력화한다.
		if not self:IsClient() then return end
		self._T.breatherToken = (self._T.breatherToken or 0) + 1
		self._T.isBreatherArmed = false
		if self._T.isBreatherPlaying then
			self._T.isBreatherPlaying = false
			log("[Breather] 숨고르기 중단(다른 스킬 사용)")
		end
	end

	-- 찌르는 이펙트 3종(852883a5/3c2ee6e6/521bf9f6)이 뜨는 매 순간(0.0s/0.1s/0.2s*mult)마다, 고정해둔
	-- 대상 전원(최대 3명)에게 한 번씩 실제 데미지 판정을 진행한다(hitIndex=1/2/3, "3번 찌르기").
	-- (실측 확인) 여러 대상이 같은 프레임에서 동시에 Attack()하면 히트 사운드가 하나로 합쳐지는
	-- 문제가 있었다(슬래쉬블래스트/스피어 버스터 멀티타깃 사례) - 대상마다 짧게(0.05초) 간격을 두고
	-- 순차 처리한다. 0.05초는 다음 찌르기 이펙트 타이밍(0.1초 간격)과 겹치지 않을 정도로 짧게 잡았다.
	@ExecSpace("ServerOnly")
	method void DealSpearBurstStabWave(integer hitIndex, number dirX)
		if not isvalid(self.Entity) then return end
		local targets = self._T.spearBurstLockedTargets or {}
		self:DealNextSpearBurstStabHit(targets, 1, hitIndex, dirX)
	end

	@ExecSpace("Server")
	method void DealNextSpearBurstStabHit(table targets, integer idx, integer hitIndex, number dirX)
		if idx > #targets then return end
		if not isvalid(self.Entity) then return end
		local target = targets[idx]
		if isvalid(target) then
			self:DealSpearBurstStabHit(target, dirX, hitIndex)
		end
		if idx < #targets then
			_TimerService:SetTimerOnce(function()
				self:DealNextSpearBurstStabHit(targets, idx + 1, hitIndex, dirX)
			end, 0.05)
		end
	end

	-- 대상 하나에게 스피어 버스터의 3연타 중 hitIndex번째 타격을 적중시킨다. 더블스탭과 동일하게
	-- Client 메서드(ShowSpearBurstStabDamageSkin)를 직접 호출하므로 ExecSpace도 더블스탭의
	-- DealDoubleStabHit과 동일하게 "Server"로 맞춘다.
	-- (버그 수정 이력 참고) 더블스탭에서, 같은 AttackComponent 인스턴스로 같은 대상에게 짧은 간격으로
	-- 반복 Attack()을 걸면 GetDisplayHitCount=0을 반환해도 엔진이 히트마다 자동 데미지 숫자를 하나씩
	-- 추가로 띄우는 문제가 실측 확인됐다 - 대상의 DamageSkinSpawnerComponent를 판정 직전 잠깐
	-- 떼었다가 붙이는 방식으로 해결했다. 스피어 버스터의 3연타도 동일한 반복-Attack() 패턴이라
	-- 같은 조치를 쓴다.
	@ExecSpace("Server")
	method void DealSpearBurstStabHit(Entity target, number dirX, integer hitIndex)
		if not isvalid(target) then return end
		self._T.spearBurstCurrentTarget = target
		---@type Monster
		local monsterComp = target:GetComponent("script.Monster")
		-- Attack() 호출 전에 미리 확인해둔다 - Monster.HandleHitEvent는 호출 시점에 이미 죽어있으면
		-- (IsDead) 자기 히트음을 건너뛰므로, 이 값을 "네이티브가 이미 히트음을 냈는지" 판단 기준으로 쓴다.
		local wasAlreadyDead = isvalid(monsterComp) and monsterComp.IsDead
		local pos = target.TransformComponent.WorldPosition
		local shape = BoxShape(Vector2(pos.x, pos.y), Vector2(1.0, 1.6), 0)
		local targetSkinSpawner = target:GetComponent("MOD.Core.DamageSkinSpawnerComponent")
		if isvalid(targetSkinSpawner) then target:RemoveComponent("MOD.Core.DamageSkinSpawnerComponent") end
		local hitComps = self:Attack(shape, "skill.spearburst", CollisionGroups.HitBox)
		if not isvalid(target:GetComponent("MOD.Core.DamageSkinSpawnerComponent")) then target:AddComponent("MOD.Core.DamageSkinSpawnerComponent") end
		local actuallyHit = false
		for _, hc in ipairs(hitComps) do
			if isvalid(hc) and isvalid(hc.Entity) and hc.Entity == target then
				actuallyHit = true
				break
			end
		end
		local damage = self._T.lastSpearBurstDamage or 0
		if not actuallyHit then
			-- 더블스탭과 동일하게, 앞선 타격에 대상이 이미 죽어 판정 자체가 실패해도(콜라이더가 더
			-- 이상 걸리지 않음) 3줄이 항상 뜨도록 표시 전용 데미지를 동일 공식으로 새로 굴린다(실제
			-- Hp에는 영향 없음). CalcDamage의 skill.spearburst 분기와 반드시 같은 배율을 유지해야 한다.
			local combatPower = self._T.pendingSpearBurstCombatPower or 0
			local mult = 0.1 + _UtilLogic:RandomDouble() * (0.2 - 0.1)
			-- 콤보 어택 버프 보너스도 실제 판정(CalcDamage)과 동일하게 표시 전용 값에 반영한다.
			damage = self:ApplyComboAttackBonus(math.floor(combatPower * mult))
		end
		self:ShowSpearBurstStabDamageSkin(target, damage, hitIndex)
		-- 타격 이펙트는 실제 판정 성공 여부와 무관하게 매번 재생한다(항상 3번 느껴지도록).
		self:PlaySpearBurstHitEffect(target, dirX, hitIndex)
		-- (버그 수정) 실제로 명중했고(actuallyHit) 대상이 이번 타격 전까지 살아있었다면
		-- Monster.HandleHitEvent(Monster.mlua, 이 스킬과 무관하게 항상 동작)가 이미 자기 히트음을
		-- 재생했으므로 여기서 또 재생하면 같은 히트에 소리가 2번 겹친다(실측 확인). 대상이 이미
		-- 죽어있었거나(3연타 중 첫 타에 죽어 HandleHitEvent가 IsDead로 건너뜀) 판정 자체가 실패한
		-- 경우에만 이 스킬 전용으로 직접 재생해 3번의 히트음이 항상 나도록 보충한다.
		if isvalid(monsterComp) and (not actuallyHit or wasAlreadyDead) then
			monsterComp:PlayHitSound()
		end
		log("[SpearBurst] DealSpearBurstStabHit hitIndex=" .. tostring(hitIndex) .. " actuallyHit=" .. tostring(actuallyHit) .. " wasAlreadyDead=" .. tostring(wasAlreadyDead) .. " damage=" .. tostring(damage))
	end

	@ExecSpace("Client")
	method void ShowSpearBurstStabDamageSkin(Entity target, integer damage, integer hitIndex)
		-- 다른 스킬과 동일한 기본 히트 데미지 스킨(RUID)을 사용한다. 3번의 찌르기가 위/중간/아래로
		-- 나뉘어 3줄로 쌓인 것처럼 보이도록 세로 오프셋을 준다(더블스탭의 ±0.2 2줄 배치와 동일한 방식).
		if not isvalid(target) then return end
		local offsetY = 0.0
		if hitIndex == 1 then
			offsetY = -0.3
		elseif hitIndex == 3 then
			offsetY = 0.3
		end
		_DamageSkinService:Play(
			target, "3271c3e79bf04ecba9a107d55495970d", 0,
			{ damage }, DamageSkinTweenType.Default, false,
			Vector2(0, offsetY), Vector2(1, 1), 1.0, 1.0, LitMode.Default
		)
		log("[SpearBurst] ShowSpearBurstStabDamageSkin hitIndex=" .. tostring(hitIndex) .. " damage=" .. tostring(damage) .. " offsetY=" .. tostring(offsetY))
	end

	@ExecSpace("Multicast")
	method void PlaySpearBurstHitEffect(Entity target, number dirX, integer hitIndex)
		-- 스피어 버스터에 맞은 몬스터 전용 히트 이펙트. 여러 명이 맞으면 대상마다 각각 재생되고,
		-- 3연타의 hitIndex마다(찌르는 이펙트 3종과 같은 타이밍) 매번 새로 재생된다.
		-- 오른쪽을 보고 공격할 때(dirX>0) 좌우 반전한다(캐릭터 쪽 이펙트와 동일한 관례).
		-- (실측 확인) PlayEffectAttached로 몬스터에 붙이면 각 몬스터 자신의 좌우 방향(스스로 걷는
		-- 방향)에 따라 반전 결과가 뒤섞여 "몇 개는 오른쪽, 몇 개는 왼쪽"으로 들쭉날쭉하게 나온다 -
		-- 몬스터에 붙이지 않고 그 순간의 월드 좌표에 독립적으로 재생해 이 간섭을 없앤다.
		-- (실측 확인) 알파를 낮춰가며 재생을 반복해 페이드를 흉내내면 클립이 매번 처음부터 다시
		-- 시작돼 "깜빡거림"으로 보인다 - 한 번만 재생하고 클립 자체의 자연스러운 소멸에 맡긴다.
		if not self:IsClient() then return end
		if not isvalid(target) then return end
		local pos = target.TransformComponent.WorldPosition
		local flipX = dirX > 0
		_EffectService:PlayEffect("84c06a061ae74a10a96fd55947769868", target, Vector3(pos.x, pos.y, 0), 0, Vector3(1, 1, 1), false, { ["FlipX"] = flipX })
		log("[SpearBurst] PlaySpearBurstHitEffect hitIndex=" .. tostring(hitIndex) .. " t=" .. tostring(_UtilLogic.ElapsedSeconds))
	end

end