	@ExecSpace("Server")
	method void RestoreExplosionControl()
		local playerCtrl = self.Entity.PlayerControllerComponent
		if isvalid(playerCtrl) and self._T.pendingExplosionWasControllerEnabled then
			playerCtrl.Enable = true
		end
		-- (기능 추가) "다른 스킬들을 사용하고 난 다음도 모두 숨고르기 모션을 3번 하도록 해달라"는 요청 -
		-- 컨트롤이 복구된 이 시점에 공용 숨고르기(PlayBreather)를 시작한다.
		self:PlayBreather(self.Entity, self._T.pendingExplosionDirX or 1)
	end

	@ExecSpace("Multicast")
	method void PlayExplosionCastEffect(Entity attacker)
		-- 시전 즉시 캐릭터 몸쪽에서 1회 재생되는 준비 이펙트 (skill/211.img/skill/2111002 리소스팩의 "prepare" 노드)
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		_EffectService:PlayEffectAttached("419e26654a5e470fa386a8a4e92e9eb3", attacker, Vector3(0, 0, 0), 0, Vector3(1, 1, 1), false, {})
		-- 쉐도우 파트너: 같은 준비 이펙트를 x축 뒤쪽에서 투명도 70%로 복제 재생(그림자 몫 - 데미지 없음)
		self:EchoShadowSkillEffectAttached("419e26654a5e470fa386a8a4e92e9eb3", attacker, Vector3(0, 0, 0), 0, Vector3(1, 1, 1), {}, 0)
	end

	@ExecSpace("ServerOnly")
	method void DetonateExplosion()
		-- 시전 2초 뒤 호출되어 실제 폭발 판정을 진행한다.
		self._T.isExploding = false
		if not isvalid(self.Entity) then return end

		self:PlayExplosionMainEffect(self.Entity)

		local worldPos = self.Entity.TransformComponent.WorldPosition
		local targets = self:FindExplosionTargets(Vector2(worldPos.x, worldPos.y), 6)
		for _, t in ipairs(targets) do
			self:DealExplosionHit(t)
		end
		log("PlayerAttack: AttackExplosion 폭발! targets=" .. tostring(#targets))

		self:PopNearbyPoisonMists(worldPos)
	end

	@ExecSpace("Multicast")
	method void PlayExplosionMainEffect(Entity attacker)
		-- 몸쪽 이펙트(38f9aa42...) 재생 후, 같은 리소스팩의 special 3종 중 하나를 이어서 재생한다.
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		_EffectService:PlayEffectAttached("38f9aa42ec39406987a9fd92ba2c14ad", attacker, Vector3(0, 0, 0), 0, Vector3(1, 1, 1), false, {})
		-- 쉐도우 파트너: 몸쪽/스페셜 이펙트를 x축 뒤쪽에서 투명도 70%로 복제 재생(그림자 몫 - 데미지 없음)
		self:EchoShadowSkillEffectAttached("38f9aa42ec39406987a9fd92ba2c14ad", attacker, Vector3(0, 0, 0), 0, Vector3(1, 1, 1), {}, 0)
		local specials = {
			"154a7b585c474b07ae77d96a465756e6",
			"ff046ea8281f4ed48430594340ddf6af",
			"49621e22bbab410d87318e2f8cd57899",
		}
		local index = _UtilLogic:RandomIntegerRange(1, #specials)
		_EffectService:PlayEffectAttached(specials[index], attacker, Vector3(0, 0, 0), 0, Vector3(1, 1, 1), false, {})
		self:EchoShadowSkillEffectAttached(specials[index], attacker, Vector3(0, 0, 0), 0, Vector3(1, 1, 1), {}, 0)
	end

	-- 익스플로젼 판정 범위(전방위 - 방향 무관) 안의 살아있는 script.Monster를 가까운 순으로 최대 maxCount명까지 반환한다.
	@ExecSpace("ServerOnly")
	method table FindExplosionTargets(Vector2 fromPos, integer maxCount)
		local map = self.Entity.CurrentMap
		if not isvalid(map) then return {} end
		local monsterComps = map:GetChildComponentsByTypeName("script.Monster", true)
		local candidates = {}
		for _, comp in ipairs(monsterComps) do
			---@type Monster
			local mc = comp
			if isvalid(mc) and isvalid(mc.Entity) and not mc.IsDead then
				local pos = mc.Entity.TransformComponent.WorldPosition
				local dx = pos.x - fromPos.x
				local dy = pos.y - fromPos.y
				if math.abs(dx) <= 3.0 and math.abs(dy) <= 1.5 then
					table.insert(candidates, { entity = mc.Entity, dist = math.abs(dx) })
				end
			end
		end
		table.sort(candidates, function(a, b) return a.dist < b.dist end)
		local result = {}
		for i = 1, math.min(#candidates, maxCount) do
			table.insert(result, candidates[i].entity)
		end
		return result
	end

	-- 드래곤 로어 전용 판정 범위(전방위 - 방향 무관) 안의 살아있는 script.Monster를 가까운 순으로
	-- 최대 maxCount명까지 반환한다. 익스플로젼의 FindExplosionTargets와 같은 구조이지만, 범위가
	-- 5배(가로 3.0→15.0, 세로 1.5→7.5)라 별도 함수로 분리한다(익스플로젼 쪽 범위는 그대로 유지).
	@ExecSpace("ServerOnly")
	method table FindDragonRoarTargets(Vector2 fromPos, integer maxCount)
		local map = self.Entity.CurrentMap
		if not isvalid(map) then return {} end
		local monsterComps = map:GetChildComponentsByTypeName("script.Monster", true)
		local candidates = {}
		for _, comp in ipairs(monsterComps) do
			---@type Monster
			local mc = comp
			if isvalid(mc) and isvalid(mc.Entity) and not mc.IsDead then
				local pos = mc.Entity.TransformComponent.WorldPosition
				local dx = pos.x - fromPos.x
				local dy = pos.y - fromPos.y
				if math.abs(dx) <= 15.0 and math.abs(dy) <= 7.5 then
					-- 몬스터가 많을 때 진짜 가까운 순으로 뽑히도록 dx만이 아니라 실제 유클리드 거리로 정렬한다.
					table.insert(candidates, { entity = mc.Entity, dist = math.sqrt(dx * dx + dy * dy) })
				end
			end
		end
		table.sort(candidates, function(a, b) return a.dist < b.dist end)
		local result = {}
		for i = 1, math.min(#candidates, maxCount) do
			table.insert(result, candidates[i].entity)
		end
		return result
	end

	-- 대상 하나에게만 익스플로젼 데미지를 적중시킨다(썬더볼트와 동일한 단일 대상 패턴 - 밀집 지역에서
	-- 판정 박스가 이웃까지 겹쳐 맞히는 것을 막는다).
	@ExecSpace("ServerOnly")
	method void DealExplosionHit(Entity target)
		if not isvalid(target) then return end
		self._T.explosionCurrentTarget = target
		local pos = target.TransformComponent.WorldPosition
		local shape = BoxShape(Vector2(pos.x, pos.y), Vector2(1.0, 1.6), 0)
		self:AttackShadowSafe(shape, "skill.explosion", target)
	end

	-- 폭발 지점 주변(독구름의 확대된 시각적 크기의 1.0배 - 1.5배의 2/3로 축소) 안에 있는 독구름을 최대 6개까지 찾아 0.1초 간격으로 하나씩 터뜨린다.
	@ExecSpace("ServerOnly")
	method void PopNearbyPoisonMists(Vector3 fromPos)
		local map = self.Entity.CurrentMap
		if not isvalid(map) then return end
		local children = map.Children:ToTable()
		local found = {}
		for _, c in ipairs(children) do
			if isvalid(c) then
				local mz = c:GetComponent("script.PoisonMistZone")
				if isvalid(mz) then
					-- Visual 자식의 실제 Scale을 읽어 "확대된 시각적 크기"를 구한다 - 하드코딩된 배율을 쓰면
					-- 나중에 독구름 크기를 또 조절할 때마다 여기도 같이 고쳐야 하는 문제가 생긴다.
					local visualScale = 1.0
					local visual = c:GetChildByName("Visual")
					if isvalid(visual) then
						visualScale = visual.TransformComponent.Scale.x
					end
					local pos = c.TransformComponent.WorldPosition
					local dx = math.abs(pos.x - fromPos.x)
					local dy = math.abs(pos.y - fromPos.y)
					-- 독구름의 확대된 시각적 크기(가로 mz.Radius, 세로 1.5를 visualScale배 한 값)의 1.0배(=1.5배의 2/3)를 탐지 범위로 쓴다.
					if dx <= mz.Radius * visualScale * 1.0 and dy <= 1.5 * visualScale * 1.0 then
						table.insert(found, c)
						if #found >= 6 then break end
					end
				end
			end
		end
		log("PlayerAttack: PopNearbyPoisonMists 탐지된 독구름 수=" .. tostring(#found))
		for i, mistEntity in ipairs(found) do
			local delay = (i - 1) * 0.1
			_TimerService:SetTimerOnce(function()
				self:PopOnePoisonMist(mistEntity)
			end, delay)
		end
	end

	@ExecSpace("ServerOnly")
	method void PopOnePoisonMist(Entity mistEntity)
		if not isvalid(mistEntity) then return end
		local pos = mistEntity.TransformComponent.WorldPosition
		local mz = mistEntity:GetComponent("script.PoisonMistZone")
		-- 폭발이펙트를 흩뿌릴 범위 - "확대된 시각적 크기" 전체(탐지범위와 동일한 크기)로 흩뿌리면 눈에 보이는
		-- 독구름 그림보다 훨씬 멀리 떨어진 곳에서 이펙트가 터지는 것처럼 보여서(실측 확인됨), 30%로 줄여
		-- 실제 구름 그림 주변에만 모여서 터지도록 한다.
		local visualScale = 1.0
		local visual = mistEntity:GetChildByName("Visual")
		if isvalid(visual) then
			visualScale = visual.TransformComponent.Scale.x
		end
		local radiusX = 1.8
		if mz ~= nil then radiusX = mz.Radius end
		self:PlayPoisonPopBursts(pos.x, pos.y, pos.z, radiusX * visualScale * 0.3, 1.5 * visualScale * 0.3)
		local targets = self:FindExplosionTargets(Vector2(pos.x, pos.y), 6)
		for _, t in ipairs(targets) do
			self:DealExplosionHit(t)
		end
		if mz ~= nil then
			mz:Pop()
		end
		log("PlayerAttack: PopOnePoisonMist 독구름 파열! pos=(" .. tostring(pos.x) .. "," .. tostring(pos.y) .. ") targets=" .. tostring(#targets))
	end

	-- 독구름 하나가 터질 때 주변 랜덤 위치에서 폭발이펙트를 0.3초 간격으로 3번 재생한다.
	@ExecSpace("ServerOnly")
	method void PlayPoisonPopBursts(number cx, number cy, number cz, number rangeX, number rangeY)
		for i = 1, 3 do
			local delay = (i - 1) * 0.3
			_TimerService:SetTimerOnce(function()
				local offsetX = (_UtilLogic:RandomDouble() * 2.0 - 1.0) * rangeX
				local offsetY = (_UtilLogic:RandomDouble() * 2.0 - 1.0) * rangeY
				self:PlayPoisonPopEffect(cx + offsetX, cy + offsetY, cz)
				log("PlayerAttack: PlayPoisonPopBursts 폭발 " .. tostring(i) .. "/3 offset=(" .. tostring(offsetX) .. "," .. tostring(offsetY) .. ")")
			end, delay)
		end
	end

	@ExecSpace("Multicast")
	method void PlayPoisonPopEffect(number px, number py, number pz)
		-- 독구름이 터질 때 그 주변 랜덤 위치에서 재생되는 폭발 이펙트(skill/211.img/skill/2111002의 special 3종
		-- 중 랜덤 하나) + 사운드.
		if not self:IsClient() then return end
		local mapEntity = self.Entity.CurrentMap
		if not isvalid(mapEntity) then return end
		local specials = {
			"154a7b585c474b07ae77d96a465756e6",
			"ff046ea8281f4ed48430594340ddf6af",
			"49621e22bbab410d87318e2f8cd57899",
		}
		local index = _UtilLogic:RandomIntegerRange(1, #specials)
		_EffectService:PlayEffect(specials[index], mapEntity, Vector3(px, py, pz), 0, Vector3(1, 1, 1), false)
		-- 쉐도우 파트너: 독구름 파열 이펙트를 x축 뒤쪽에서 투명도 70%로 복제 재생(그림자 몫 - 데미지 없음)
		self:EchoShadowSkillEffect(specials[index], Vector3(px, py, pz), 0, Vector3(1, 1, 1), {}, 0)
		_SoundService:PlaySound("3edd6d189b9b4bf1ac48162339848e36", 1.0)
	end

	@ExecSpace("ServerOnly")
	method void AttackDragonRoar(number combatPower, number atkMultiplier)
		-- (기능 추가) "다른 스킬을 쓰면 숨고르기 모션은 중지" 요청 - 이 스킬을 새로 시전하는 시점에 이전 숨고르기가 재생 중이었다면 즉시 정리한다.
		self:StopBreather()
		-- 드래곤 로어: 전방위 최대 20명(범위는 익스플로젼의 5배), 시전 뒤 1.5초 지연 폭발, 데미지 배율(1000~1300%).
		-- 추가로 시전 즉시 2초짜리 스턴에 걸린다(모션 자체의 짧은 잠금과는 별개의 독립된 고정 길이 잠금 -
		-- 공격속도 영향을 받지 않는다). 사용 즉시 현재 HP의 40%를 소모한다.
		local currentState = self.Entity.StateComponent.CurrentStateName
		if currentState == "DEAD" or currentState == "CLIMB" or currentState == "LADDER" then
			return
		end
		if self._T.isDragonRoaring then
			log("PlayerAttack: AttackDragonRoar 요청 차단됨(이미 진행 중)")
			return
		end
		self._T.isDragonRoaring = true
		self._T.pendingDragonRoarCombatPower = combatPower

		-- 사용 즉시 현재 HP의 40%를 소모한다(스킬 사용 자체로 죽지 않도록 최소 1은 남긴다).
		local pc = self.Entity.PlayerComponent
		if isvalid(pc) then
			local hpCost = math.floor(pc.Hp * 0.4)
			pc.Hp = math.max(pc.Hp - hpCost, 1)
			log("PlayerAttack: AttackDragonRoar HP 소모=" .. tostring(hpCost) .. " 남은Hp=" .. tostring(pc.Hp))
		end

		-- 익스플로젼과 동일한 모션(alert) 재생 - 별도 플래그 사용.
		local mult = math.max(atkMultiplier or 1.0, 0.001)
		local playerCtrl = self.Entity.PlayerControllerComponent
		local dirX = isvalid(playerCtrl) and playerCtrl.LookDirectionX or 1
		self._T.pendingDragonRoarDirX = dirX
		self._T.pendingDragonRoarWasControllerEnabled = isvalid(playerCtrl) and playerCtrl.Enable
		if isvalid(playerCtrl) then
			playerCtrl.Enable = false
		end
		if isvalid(self.Entity.MovementComponent) then
			self.Entity.MovementComponent:Stop()
		end
		self:PlayDragonRoarMotion(self.Entity, "alert", dirX, mult)

		-- 스턴 잠금: 익스플로젼의 짧은 모션 잠금(0.6*mult)과 달리, 공격속도와 무관하게 항상 고정 2초.
		_TimerService:SetTimerOnce(function()
			self:RestoreDragonRoarControl()
		end, 2.0)

		self:PlayDragonRoarCastEffect(self.Entity)
		self:PlayDragonRoarStunEffect(self.Entity)

		_TimerService:SetTimerOnce(function()
			self:DetonateDragonRoar()
		end, 1.5)
	end

	@ExecSpace("Multicast")
	method void PlayDragonRoarMotion(Entity attacker, string motionName, number dirX, number atkMultiplier)
		-- 드래곤 로어 전용 모션 재생 (익스플로젼과 동일한 방식/모션 - 별도 플래그로 서로 간섭하지 않는다).
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		local avatarRenderer = attacker.AvatarRendererComponent
		if not isvalid(avatarRenderer) then return end
		local body = avatarRenderer:GetBodyEntity()
		if not isvalid(body) then return end

		avatarRenderer.ShowDefaultWeaponEffects = false

		local playerCtrl = attacker.PlayerControllerComponent
		if isvalid(attacker.MovementComponent) then
			attacker.MovementComponent:Stop()
		end
		if isvalid(playerCtrl) then
			playerCtrl.LookDirectionX = dirX
		end
		self._T.isDragonRoarDirectionLocked = true
		self._T.lockedDragonRoarDirX = dirX
		self._T.lockedDragonRoarMotionName = motionName
		self._T.isDragonRoarMotionPlaying = true

		local mult = math.max(atkMultiplier or 1.0, 0.001)
		local playRate = 1.0 / mult
		self._T.lockedDragonRoarPlayRate = playRate

		local motionEvent = ActionStateChangedEvent(motionName, motionName, playRate, SpriteAnimClipPlayType.Onetime)
		body:SendEvent(motionEvent)
		log("[DragonRoar] PlayDragonRoarMotion sent: " .. tostring(motionName) .. " playRate=" .. tostring(playRate))

		_TimerService:SetTimerOnce(function()
			if isvalid(avatarRenderer) then
				avatarRenderer.ShowDefaultWeaponEffects = true
			end
			self._T.isDragonRoarMotionPlaying = false
		end, 0.55 * mult)

		_TimerService:SetTimerOnce(function()
			self._T.isDragonRoarDirectionLocked = false
			local sc = self.Entity.StateComponent
			if isvalid(sc) and sc.CurrentStateName ~= "DEAD" then
				sc:ChangeState("IDLE")
				sc:ChangeState("MOVE")
				sc:ChangeState("IDLE")
			end
		end, 0.80 * mult)
	end

	@ExecSpace("Server")
	method void RestoreDragonRoarControl()
		self._T.isDragonRoaring = false
		local playerCtrl = self.Entity.PlayerControllerComponent
		if isvalid(playerCtrl) and self._T.pendingDragonRoarWasControllerEnabled then
			playerCtrl.Enable = true
		end
		-- (기능 추가) "다른 스킬들을 사용하고 난 다음도 모두 숨고르기 모션을 3번 하도록 해달라"는 요청 -
		-- 컨트롤이 복구된 이 시점에 공용 숨고르기(PlayBreather)를 시작한다.
		self:PlayBreather(self.Entity, self._T.pendingDragonRoarDirX or 1)
	end

	@ExecSpace("Multicast")
	method void PlayDragonRoarCastEffect(Entity attacker)
		-- 시전 즉시 캐릭터 몸쪽에서 1회 재생되는 이펙트 + 사운드 + 화면 흔들림.
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		_EffectService:PlayEffectAttached("5468cadd2f60428e925bc368968e1a1e", attacker, Vector3(0, 0, 0), 0, Vector3(1, 1, 1), false, {})
		-- 쉐도우 파트너: 같은 시전 이펙트를 x축 뒤쪽에서 투명도 70%로 복제 재생(그림자 몫 - 데미지 없음)
		self:EchoShadowSkillEffectAttached("5468cadd2f60428e925bc368968e1a1e", attacker, Vector3(0, 0, 0), 0, Vector3(1, 1, 1), {}, 0)
		_SoundService:PlaySound("7dd03981265b4d9a8c638bf0b18649cc", 1.0)
		local cam = _CameraService:GetCurrentCameraComponent()
		if isvalid(cam) then
			cam:ShakeCamera(0.3, 0.4)
		end
	end

	@ExecSpace("Multicast")
	method void PlayDragonRoarStunEffect(Entity attacker)
		-- 스턴 표시 이펙트 - 사용 즉시 캐릭터에게 2초간 뜬다(고정 길이 - 공격속도 영향 없음).
		-- 발밑(0,0,0)이 아니라 머리 높이(y=0.7)에 뜨도록 위로 올린다(1.0은 너무 높다는 피드백으로 낮춤).
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		local serial = _EffectService:PlayEffectAttached("6337b66c57a947e7b2cda8bbf8697094", attacker, Vector3(0, 0.7, 0), 0, Vector3(1, 1, 1), true, {})
		_TimerService:SetTimerOnce(function()
			_EffectService:RemoveEffect(serial)
		end, 2.0)
	end

	@ExecSpace("ServerOnly")
	method void DetonateDragonRoar()
		-- 시전 1.5초 뒤 호출되어 실제 판정을 진행한다(전방위 최대 20명, 범위는 익스플로젼의 5배 - FindDragonRoarTargets 참고).
		if not isvalid(self.Entity) then return end
		local worldPos = self.Entity.TransformComponent.WorldPosition
		local targets = self:FindDragonRoarTargets(Vector2(worldPos.x, worldPos.y), 20)
		for _, t in ipairs(targets) do
			self:DealDragonRoarHit(t)
		end
		log("PlayerAttack: AttackDragonRoar 발동! targets=" .. tostring(#targets))
	end

	-- 대상 하나에게만 드래곤 로어 데미지를 적중시킨다(익스플로젼/썬더볼트와 동일한 단일 대상 패턴).
	@ExecSpace("ServerOnly")
	method void DealDragonRoarHit(Entity target)
		if not isvalid(target) then return end
		self._T.dragonRoarCurrentTarget = target
		local pos = target.TransformComponent.WorldPosition
		local shape = BoxShape(Vector2(pos.x, pos.y), Vector2(1.0, 1.6), 0)
		local hitComps = self:AttackShadowSafe(shape, "skill.dragonroar", target)
		local actuallyHit = false
		for _, hc in ipairs(hitComps) do
			if isvalid(hc) and isvalid(hc.Entity) and hc.Entity == target then
				actuallyHit = true
				break
			end
		end
		if actuallyHit then
			self:PlayDragonRoarHitEffect(target)
		end
	end

	@ExecSpace("Multicast")
	method void PlayDragonRoarHitEffect(Entity target)
		-- 드래곤 로어에 맞은 몬스터 전용 히트 이펙트.
		if not self:IsClient() then return end
		if not isvalid(target) then return end
		local serial = _EffectService:PlayEffectAttached("01c803531e2c4e5aa3c3ef66f14711b8", target, Vector3(0, 0, 0), 0, Vector3(1, 1, 1), false, {})
		-- 쉐도우 파트너: 같은 히트 이펙트를 0.25초 시간차를 두고 그 자리에 한 번 더(70% 투명도) 재생
		self:EchoShadowHitEffect("01c803531e2c4e5aa3c3ef66f14711b8", target, Vector3(0, 0, 0), 0, Vector3(1, 1, 1), {})
		_TimerService:SetTimerOnce(function()
			_EffectService:RemoveEffect(serial)
		end, 1.0)
	end

	-- ── 블리자드 (4차) ────────────────────────────────────────────────────
	-- 리소스팩: skill/800033.img/skill/80003323 (블리자드)
	--   effect  = 96b261657b0c4aa792bd6f3e7d6c6681 (시전자 몸쪽 이펙트)
	--   tile/0~8 + hit/0 = 바닥에 흩뿌려지는 이펙트 10종 (아래 GetBlizzardTileClips)

	method table GetBlizzardTileClips()
		-- 블리자드 팩의 바닥 이펙트 10종(tile/0~8, hit/0).
		--   frames   = 그 클립의 총 프레임 수 - BlizzardTileVisual이 "지금 재생 중인 것이 정말 이 클립인지"를
		--              판별하는 데 쓴다(모델 기본 클립의 프레임 이벤트를 우리 것으로 오인하는 것 방지).
		--   hitFrame = 하늘에서 내려온 고드름이 실제로 바닥에 꽂히는 프레임(요청받은 값).
		--              이 프레임에 도달한 순간 그 자리에 데미지가 들어간다.
		--
		-- (기능 수정) 예전처럼 "생성 후 2.4초" 같은 고정 지연을 쓰지 않는다 - 클립마다 길이도, 고드름이
		-- 닿는 시점도 달라서 어떤 타일은 이르고 어떤 타일은 늦었다. 클립의 실제 재생 프레임(FrameIndex)을
		-- 보고 때리므로 재생 속도/프레임레이트를 몰라도 항상 "꽂히는 순간"에 정확히 맞는다.
		return {
			{ ruid = "d9d44fb072ec4ccfacad6fe43959c7c9", frames = 25, hitFrame = 18 }, -- tile/0
			{ ruid = "0806f2b09d904519bb5c4b136109268d", frames = 25, hitFrame = 18 }, -- tile/1
			{ ruid = "50249344d7ed4203ac6f00a46c31fc9c", frames = 25, hitFrame = 18 }, -- tile/2
			{ ruid = "43e522b840ce4529aed13a8911f906b4", frames = 20, hitFrame = 16 }, -- tile/3
			{ ruid = "25791d83eda1436a9de855d4c5441e51", frames = 23, hitFrame = 16 }, -- tile/4
			{ ruid = "1889792ff11046859a0a08f171f4feff", frames = 23, hitFrame = 16 }, -- tile/5
			{ ruid = "12299cffd6244ffa81e117d65205f4f1", frames = 21, hitFrame = 14 }, -- tile/6
			{ ruid = "53e7e89799844616b82d85d81decc54f", frames = 20, hitFrame = 14 }, -- tile/7
			{ ruid = "b52555b494544c46a99cbb238802f939", frames = 21, hitFrame = 14 }, -- tile/8
			{ ruid = "735ad75ae1f64d88a9444cf9832f4abc", frames = 21, hitFrame = 15 }, -- hit/0
		}
	end

	@ExecSpace("ServerOnly")
	method void DealBlizzardTileArea(Vector2 pos)
		-- 타일 하나가 "꽂힌" 자리에 데미지를 준다. 타일 하나당 최대 6명까지만 때린다(요청사항).
		-- 초기 타일 15개와 이후 타일 10개가 모두 이 경로를 쓴다 - 데미지 방식이 완전히 동일하다.
		if not isvalid(self.Entity) then return end
		local targets = self:FindBlizzardShardTargets(pos, 1.2)
		local hit = 0
		for _, t in ipairs(targets) do
			if hit >= 6 then break end
			self:DealBlizzardPillarHit(t)
			hit = hit + 1
		end
		log("PlayerAttack: 블리자드 타일 피해 pos=(" .. tostring(pos.x) .. "," .. tostring(pos.y) .. ") 맞은 몬스터=" .. tostring(hit) .. "/" .. tostring(#targets) .. " (타일당 최대 6)")
	end

	@ExecSpace("ServerOnly")
	method void AttackBlizzard(number combatPower, number atkMultiplier)
		-- 블리자드 타임라인 (쿨타임 20초는 클라이언트 SkillManager가 관리/표시):
		--   0.0s      시전 이펙트(96b261) + 사운드(267aa4 1회 + c50b1e30 20초간 작게 반복)
		--             + 맵이 서서히 살짝 어두워짐(15초 뒤 복귀)
		--             + 맵 메인 BGM이 서서히 20%로 작아짐(13초 뒤부터 서서히 원상복귀)
		--             + 데미지 스킨이 얼음 스킨(d0bbfb14)으로 교체됨(19초 뒤 원래 스킨으로 복구)
		--             + 조작 잠금 3초
		--             (얼음책 5db175 / 바닥 서리 a428e9f4·1c0dd97b / 얼음조각 낙하는 현재 주석 처리됨)
		--   ~0.5-0.9s 팩 바닥 이펙트(tile/hit 10종 중 랜덤) 15개 생성 - 클립마다 고드름이 꽂히는 프레임이
		--             달라서, 생성 시점을 그만큼 앞당겨 보정한다(모두 약 2.3초에 "동시에" 착지 = 동시 데미지)
		--   3.0s      화면 폭설 시작(UI 오버레이, 우상→좌하) - 7초간 전량 → 절반 소멸 → 4초 더 → 나머지 소멸
		--   3~18s     팩 바닥 이펙트 10종을 10번, 범위 안 몬스터 위치에 추가 생성
		--
		--   데미지는 오직 "타일"에서만 나온다(기존의 시전자 주위 30명 일괄 판정은 제거됨).
		--   타일 하나가 자기 클립의 hitFrame(고드름이 바닥에 꽂히는 프레임)에 도달한 순간,
		--   그 자리(반경 1.2)의 몬스터를 타일당 최대 6명까지 전투력의 700~1000%로 때린다.
		--   → 초기 타일 15개와 이후 타일 10개가 완전히 같은 방식(SpawnOneBlizzardTile).
		--   0~15s     반짝임 이펙트(90ff4f10) 5회 + 배경 이펙트(6da13ae8) 5회
		self:StopBreather()
		local currentState = self.Entity.StateComponent.CurrentStateName
		if currentState == "DEAD" or currentState == "CLIMB" or currentState == "LADDER" then
			return
		end
		if self._T.isBlizzarding then
			log("PlayerAttack: AttackBlizzard 요청 차단됨(이미 진행 중)")
			return
		end
		self._T.isBlizzarding = true
		self._T.pendingBlizzardCombatPower = combatPower

		-- 얼음조각/반짝임은 캐릭터가 움직여도 "시전한 위치" 기준으로 떨어져야 하므로 시전 좌표를 고정해둔다.
		local castPos = self.Entity.TransformComponent.WorldPosition
		self._T.blizzardCastX = castPos.x
		self._T.blizzardCastY = castPos.y
		-- 배경 이펙트 5회가 서로 겹치지 않게 쓰는 "이미 사용한 자리" 목록 - 시전마다 새로 시작한다.
		self._T.blizzardBackFXSpots = {}

		local playerCtrl = self.Entity.PlayerControllerComponent
		local dirX = (isvalid(playerCtrl) and playerCtrl.LookDirectionX >= 0) and 1 or -1

		-- (기능 추가) 시전 후 3초 동안은 이동/점프/공격 등 다른 행동을 할 수 없다(다른 스킬과 동일한 방식:
		-- PlayerControllerComponent를 끄고 복구 타이머에서 다시 켠다).
		-- 다른 이유로 이미 꺼져 있었다면(예: 사망 처리) 그 상태를 되살리지 않도록 이전 값을 기억해둔다.
		self._T.pendingBlizzardWasControllerEnabled = isvalid(playerCtrl) and playerCtrl.Enable
		if isvalid(playerCtrl) then
			playerCtrl.Enable = false
		end
		log("PlayerAttack: 블리자드 조작 잠금 시작 (3초) Enable=" .. tostring(isvalid(playerCtrl) and playerCtrl.Enable))
		-- 이동 중 시전한 경우 관성으로 계속 미끄러지지 않도록 서버 쪽에서도 즉시 멈춘다.
		if isvalid(self.Entity.MovementComponent) then
			self.Entity.MovementComponent:Stop()
		end
		_TimerService:SetTimerOnce(function()
			self:RestoreBlizzardControl()
		end, 3.0)

		-- (기능 추가) 15초 동안 데미지 스킨을 얼음 스킨으로 교체(끝나면 원상복구).
		self:ApplyBlizzardDamageSkin()

		self:PlayBlizzardCastEffect(self.Entity)
		-- (임시 비활성) 캐릭터 앞 얼음책(5db17594) - 요청에 따라 호출만 주석 처리했다.
		-- 메서드(SpawnBlizzardCastBook)는 그대로 남겨뒀으니 아래 줄의 주석만 풀면 원래대로 돌아온다.
		-- self:SpawnBlizzardCastBook(dirX)
		self:PlayBlizzardScreenDim()
		-- (기능 추가) 맵 메인 BGM을 20%까지 낮췄다가 13초 뒤 원상복귀.
		self:PlayBlizzardBgmDuck()
		-- (기능 추가) 15초 동안 화면에 폭설이 내린다.
		self:PlayBlizzardSnowfall()

		-- 팩 바닥 이펙트 22개는 0.5~2.5초 사이 각각 다른 랜덤 시점에 하나씩 생성된다(요청사항).
		self:SpawnBlizzardTiles()

		-- (기능 수정) "시전자 주위 30명을 무조건 때리는" 일괄 판정(DetonateBlizzard)을 없앴다(요청사항).
		-- 이제 데미지는 오직 타일에서만 나온다 - 타일 하나가 고드름을 꽂는 순간, 그 자리(반경 1.2)의
		-- 몬스터를 타일당 최대 6명까지 때린다(초기 타일 15개 + 이후 타일 10개 모두 동일).
		-- DetonateBlizzard / FindDragonRoarTargets 기반 일괄 판정 메서드는 지우지 않고 남겨뒀다(미사용).
		-- 재시전 잠금(isBlizzarding)만 예전 판정 시점과 같은 타이밍에 풀어준다.
		_TimerService:SetTimerOnce(function()
			self._T.isBlizzarding = false
		end, 4.5)

		-- (임시 비활성) 바닥 서리 이펙트(a428e9f4 / 1c0dd97b) 45개 - 요청에 따라 호출만 주석 처리했다.
		-- 메서드(SpawnBlizzardFrostEffects / SpawnOneBlizzardFrost)는 그대로 남겨뒀으니 아래 3줄의
		-- 주석만 풀면 원래대로 돌아온다. 다른 연출/판정과는 독립적이라 꺼도 블리자드에 영향이 없다.
		-- _TimerService:SetTimerOnce(function()
		-- 	self:SpawnBlizzardFrostEffects()
		-- end, 3.5)

		-- (기능 수정) 팩(80003323)의 바닥 이펙트 10종 중 하나를, 3~18초 사이 각자 다른 랜덤 시점에
		-- 최대 10번(20 → 절반), "범위 안 몬스터가 있는 위치"에 생성한다(랜덤 발판 → 몬스터 위치로 변경).
		-- 그 자리의 몬스터는 고드름이 떨어지는 2.2초 뒤에 전투력의 700~1000% 피해.
		for i = 1, 10 do
			local delay = 3.0 + _UtilLogic:RandomDouble() * 15.0
			_TimerService:SetTimerOnce(function()
				self:SpawnBlizzardPillarOnGround()
			end, delay)
		end

		-- (기능 수정) 배경 이펙트는 15초 동안 5번 재생한다 - 서로 최소 2초 이상 텀이 생기도록
		-- 3초 간격 슬롯(2.5 / 5.5 / 8.5 / 11.5 / 14.5초)마다 0~1초의 랜덤 지터만 얹는다.
		for i = 1, 5 do
			local delay = 2.5 + (i - 1) * 3.0 + _UtilLogic:RandomDouble() * 1.0
			_TimerService:SetTimerOnce(function()
				self:SpawnBlizzardBackgroundEffect()
			end, delay)
		end

		-- 0~15초 사이 랜덤한 시점에 반짝임 이펙트 5회.
		for i = 1, 5 do
			local delay = _UtilLogic:RandomDouble() * 15.0
			_TimerService:SetTimerOnce(function()
				self:SpawnBlizzardSparkle()
			end, delay)
		end

		-- (임시 비활성) 얼음조각 30개 낙하(3~18초 사이 랜덤 시점, 맞으면 0.3초 뒤 100~150% 피해) -
		-- 요청에 따라 호출만 주석 처리했다. 메서드(DropBlizzardIceShard / PlayBlizzardIceShardEffect /
		-- FindBlizzardShardTargets / DealBlizzardShardHit)와 데미지 공식(skill.blizzard.shard)은 그대로
		-- 남겨뒀으니 아래 6줄의 주석만 풀면 원래대로 돌아온다.
		-- 얼음조각은 블리자드의 주 판정(DetonateBlizzard)이나 기둥 피해와는 별개의 추가 피해라, 꺼도
		-- 스킬의 나머지 동작(시전/판정/쿨타임/연출)에는 영향이 없다.
		-- for i = 1, 30 do
		-- 	local delay = 3.0 + _UtilLogic:RandomDouble() * 15.0
		-- 	_TimerService:SetTimerOnce(function()
		-- 		self:DropBlizzardIceShard()
		-- 	end, delay)
		-- end
	end

	@ExecSpace("Multicast")
	method void PlayBlizzardCastEffect(Entity attacker)
		-- 시전 즉시 캐릭터 몸쪽에서 1회 재생되는 이펙트 + 사운드.
		-- (기능 수정) "화면 흔들림 효과 제거" 요청 - ShakeCamera 호출을 뺐다.
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		-- (버그 수정) "시전 이펙트가 캐릭터를 가린다" - OrderInLayer = -1 만으로는 안 됐다. 캐릭터 아바타는
		-- SortingLayer="MapLayer0" / OrderInLayer=4 로 그려지는데(실측), 이펙트는 기본 SortingLayer라
		-- 레이어 자체가 아바타보다 앞이라 OrderInLayer 비교가 소용없었다.
		-- → 아바타와 같은 SortingLayer(MapLayer0)에 올리고, OrderInLayer를 아바타(4)보다 작게(2) 준다.
		--   (지형 타일이 1이므로 2는 "지형보다 앞, 캐릭터보다 뒤"가 된다.)
		-- (기능 수정) Y를 조금(-0.35) 내려 캐릭터 발치 쪽에서 퍼지게 한다.
		local backOption = { ["SortingLayer"] = "MapLayer0", ["OrderInLayer"] = 2 }
		local castOffset = Vector3(0, -0.35, 0)
		_EffectService:PlayEffectAttached("96b261657b0c4aa792bd6f3e7d6c6681", attacker, castOffset, 0, Vector3(1, 1, 1), false, backOption)
		-- 쉐도우 파트너: 같은 시전 이펙트를 x축 뒤쪽에서 투명도 70%로 복제 재생(그림자 몫 - 데미지 없음)
		self:EchoShadowSkillEffectAttached("96b261657b0c4aa792bd6f3e7d6c6681", attacker, castOffset, 0, Vector3(1, 1, 1), backOption, 0)
		_SoundService:PlaySound("267aa4a9324f460b80bc04600aa4d0e0", 1.0)
		-- 시전 시점부터 c50b1e30을 20초간 재생한다(클립이 20초보다 짧을 수 있어 반복 재생 후 20초에 정지).
		-- (기능 수정) "배경 소리가 잘 안 들린다" - 볼륨 0.5 → 0.8.
		_SoundService:PlayLoopSound("c50b1e30210d4019a97da3e76c33079f", 0.8)
		_TimerService:SetTimerOnce(function()
			_SoundService:StopSound("c50b1e30210d4019a97da3e76c33079f")
		end, 20.0)
	end

	@ExecSpace("ServerOnly")
	method void ApplyBlizzardDamageSkin()
		-- (기능 수정) 블리자드 시전 후 19초 동안(15초 → +4초 연장) 데미지 스킨(공격 숫자 모양)을
		-- 얼음 스킨으로 바꿨다가 시간이 끝나면 원래 스킨으로 되돌린다.
		-- 데미지 스킨은 "공격자" 쪽 DamageSkinSettingComponent.DamageSkinId 가 결정한다
		-- (맞는 쪽에는 DamageSkinSpawnerComponent가 있어야 숫자가 뜬다 - 몬스터 모델에 이미 있다).
		if not isvalid(self.Entity) then return end
		local skinComp = self.Entity:GetComponent("MOD.Core.DamageSkinSettingComponent")
		if not isvalid(skinComp) then
			-- DefaultPlayer.model의 Components 배열엔 없고 엔진이 붙여주는 형태라, 혹시 없을 때를 대비해 직접 붙인다.
			self.Entity:AddComponent("MOD.Core.DamageSkinSettingComponent")
			skinComp = self.Entity:GetComponent("MOD.Core.DamageSkinSettingComponent")
		end
		if not isvalid(skinComp) then
			log_warning("[PlayerAttack] DamageSkinSettingComponent를 찾지 못해 블리자드 데미지 스킨을 적용하지 못했습니다")
			return
		end
		-- 원래 스킨은 "문자열 id"로 기억한다(DataRef 객체를 그대로 들고 있으면 나중에 값이 바뀔 수 있다).
		-- 19초 안에 다시 시전되는 경우(쿨타임 20초라 정상적으론 없다)에도 원본이 덮이지 않게 한 번만 저장한다.
		if self._T.blizzardSkinOriginalId == nil then
			local cur = skinComp.DamageSkinId
			self._T.blizzardSkinOriginalId = (cur ~= nil) and cur.DataId or ""
		end
		skinComp.DamageSkinId = DataRef("d0bbfb140e164860b8b30281613a42c3")
		log("PlayerAttack: 블리자드 데미지 스킨 적용 (19초) 원본=" .. tostring(self._T.blizzardSkinOriginalId))

		-- (기능 수정) 유지 시간 15초 → 19초(+4초 연장 요청).
		_TimerService:SetTimerOnce(function()
			self:RestoreBlizzardDamageSkin()
		end, 19.0)
	end

	@ExecSpace("ServerOnly")
	method void RestoreBlizzardDamageSkin()
		-- 15초 뒤 원래 데미지 스킨으로 복구한다.
		if not isvalid(self.Entity) then return end
		local skinComp = self.Entity:GetComponent("MOD.Core.DamageSkinSettingComponent")
		if not isvalid(skinComp) then return end
		local originalId = self._T.blizzardSkinOriginalId
		if originalId == nil then return end
		if originalId == "" then
			-- 원본이 비어 있었다면(컴포넌트를 새로 붙인 경우 등) 기본 공격 데미지 스킨으로 되돌린다.
			originalId = "3271c3e79bf04ecba9a107d55495970d"
		end
		skinComp.DamageSkinId = DataRef(originalId)
		self._T.blizzardSkinOriginalId = nil
		log("PlayerAttack: 블리자드 데미지 스킨 원상복구 -> " .. tostring(originalId))
	end

	@ExecSpace("ServerOnly")
	method void RestoreBlizzardControl()
		-- 시전 3초 뒤 조작을 되돌린다. 시전 전에 이미 꺼져 있었다면(사망 등) 그대로 둔다.
		if not isvalid(self.Entity) then return end
		local playerCtrl = self.Entity.PlayerControllerComponent
		local wasLocked = isvalid(playerCtrl) and (not playerCtrl.Enable)
		if isvalid(playerCtrl) and self._T.pendingBlizzardWasControllerEnabled then
			playerCtrl.Enable = true
		end
		-- 복구 직전에 실제로 잠겨 있었는지(=3초 내내 잠금이 유지됐는지)를 함께 남긴다.
		log("PlayerAttack: 블리자드 조작 잠금 해제 (3초 유지됨=" .. tostring(wasLocked) .. ")")
	end

	-- ── 블리자드 폭설 연출 ────────────────────────────────────────────────
	-- 눈송이는 원본 시트(2d507f2d)에서 결정/눈발/알갱이를 잘라 3종으로 만들어 업로드했다.
	-- 대응표: msw-dev-tools/resources/블리자드눈/RUID.md
	-- 실제 낙하는 클라이언트 UI 오버레이(BlizzardSnowfall)가 담당한다.

	@ExecSpace("Multicast")
	method void PlayBlizzardSnowfall()
		-- 화면 오른쪽 위 → 왼쪽 아래로 눈이 빠르게 쏟아지는 폭설(클라이언트 UI 오버레이).
		-- 시전 3초 뒤부터: 7초간 전량 → 절반 먼저 소멸 → 4초 더 → 나머지 소멸(요청사항).
		if not self:IsClient() then return end
		_TimerService:SetTimerOnce(function()
			_BlizzardSnowfall:StartSnow(7.0, 4.0)
		end, 3.0)
	end

	@ExecSpace("Multicast")
	method void PlayBlizzardBgmDuck()
		-- (기능 수정) 시전하는 동안 맵의 메인 BGM을 서서히 50%까지만 낮추고(20% → 50%), 13초 뒤부터 원상복귀.
		-- 1.5초에 걸쳐 줄어들고(→ 50%), 11.5초 유지(= 시전 후 13초 시점), 2.5초에 걸쳐 원래대로.
		-- 블리자드 자체 사운드(시전음/눈보라 루프)는 BGM 채널이 아니라 그대로 들린다.
		if not self:IsClient() then return end
		_BlizzardBgmDucker:StartDuck(1.5, 11.5, 2.5, 0.5)
	end

	@ExecSpace("Multicast")
	method void PlayBlizzardScreenDim()
		-- 맵 전체가 서서히 "약간만" 어두워졌다가(최대 알파 0.35) 서서히 밝아진다.
		-- (기능 수정) "밝아지는 시점을 2초 앞당겨달라" - 유지 시간 15초 → 13초.
		if not self:IsClient() then return end
		_BlizzardScreenDim:StartDim(1.5, 13.0, 2.5, 0.35)
	end

	@ExecSpace("ServerOnly")
	method void SpawnBlizzardCastBook(number dirX)
		-- 시전 시 캐릭터 앞에 얼음책(5db17594)이 생겨 위로 떠오르면서 1.5초에 걸쳐 사라진다.
		local map = self.Entity.CurrentMap
		if not isvalid(map) then return end
		local pos = self.Entity.TransformComponent.WorldPosition
		local fx = _SpawnService:SpawnByModelId("spearburstfadingeffect", "BlizzardCastBook", Vector3(pos.x + dirX * 0.45, pos.y + 0.35, 0), map)
		if not isvalid(fx) then return end
		fx:AddComponent("script.BlizzardFadingEffect")
		local comp = fx:GetComponent("script.BlizzardFadingEffect")
		if isvalid(comp) then
			comp.StartAlpha = 1.0
			comp.HoldSeconds = 0.0
			comp.FadeSeconds = 1.5
			comp.RiseSpeed = 0.5
			comp.OrderInLayerValue = 10   -- 캐릭터 앞
			comp.ScaleValue = 1.0
			comp.ClipRUID = "5db175946e27401f8203d7a01e632631"
		end
		_TimerService:SetTimerOnce(function()
			if isvalid(fx) then fx:Destroy() end
		end, 2.0)
	end

	@ExecSpace("ServerOnly")
	method void SpawnBlizzardTiles()
		-- 시전자 주변의 "발판이 있는 자리"를 골라 바닥 이펙트 30개를 생성한다.
		-- 서로 겹치지 않도록 이미 고른 자리들과 최소 거리(MIN_GAP) 이상 떨어진 후보만 채택하고,
		-- 후보 뽑기가 실패해도 무한 루프에 빠지지 않도록 시도 횟수를 제한한다.
		if not isvalid(self.Entity) then return end
		local map = self.Entity.CurrentMap
		if not isvalid(map) then return end
		local fh = map.FootholdComponent
		local myPos = self.Entity.TransformComponent.WorldPosition
		local clips = self:GetBlizzardTileClips()

		-- (기능 수정) 생성 개수 30 → 22 → 15개. 최소 간격은 0.9 유지.
		local WANT = 15
		local MIN_GAP = 0.9      -- 이펙트 간 최소 거리(월드 유닛)
		local RANGE_X = 10.4     -- 시전자 기준 좌우 탐색 범위
		local RANGE_Y = 3.9      -- 시전자 기준 상하 탐색 범위(다른 층 발판도 포함)
		local MAX_TRIES = 2000

		local placed = {}
		local tries = 0
		while #placed < WANT and tries < MAX_TRIES do
			tries = tries + 1
			local x = myPos.x + (_UtilLogic:RandomDouble() * 2.0 - 1.0) * RANGE_X
			local probeY = myPos.y + (_UtilLogic:RandomDouble() * 2.0 - 1.0) * RANGE_Y
			local y = nil
			if isvalid(fh) then
				local hit = self:FindNearbyFootholdAtX(fh, x, probeY, 3.0)
				if hit ~= nil then
					y = hit:GetYByX(x) + 0.05
				end
			end
			if y ~= nil then
				local ok = true
				for _, p in ipairs(placed) do
					local dx = p.x - x
					local dy = p.y - y
					if math.sqrt(dx * dx + dy * dy) < MIN_GAP then
						ok = false
						break
					end
				end
				if ok then
					table.insert(placed, { x = x, y = y })
				end
			end
		end

		-- (기능 수정) "초기 타일들의 데미지가 한꺼번에 들어가도록" - 타일마다 고드름이 꽂히는 프레임
		-- (hitFrame: 14~18)이 달라서, 같은 시점에 생성하면 착지(=데미지) 시점이 최대 4프레임만큼 어긋난다.
		-- 그래서 생성 시점을 hitFrame만큼 앞당겨 보정한다:
		--     생성지연 = 기준지연 - hitFrame * 프레임당시간   (hitFrame이 큰 클립일수록 먼저 생성)
		-- 이렇게 하면 모든 초기 타일이 "기준지연" 시점에 동시에 착지한다.
		-- 데미지 자체는 여전히 실제 재생 프레임(FrameIndex) 이벤트로 들어가므로, 아래 프레임당시간
		-- 값이 조금 틀려도 착지 순간에는 정확히 맞는다(동시성만 그만큼 흐트러진다).
		local FRAME_SEC = 0.1        -- 클립 프레임당 재생 시간(초) 추정치 - 실측 후 조정 가능
		local MAX_HIT_FRAME = 18     -- 클립들 중 가장 늦게 꽂히는 프레임(tile/0~2)
		local LAND_AT = 0.5 + MAX_HIT_FRAME * FRAME_SEC   -- 모든 초기 타일이 착지하는 시점(≈2.3초)

		for i, p in ipairs(placed) do
			local clip = clips[_UtilLogic:RandomIntegerRange(1, #clips)]
			-- 착지 시점(LAND_AT)에서 이 클립이 꽂히는 데 걸리는 시간을 빼면 이 타일의 생성 시점이 된다.
			local delay = LAND_AT - clip.hitFrame * FRAME_SEC
			if delay < 0.1 then
				delay = 0.1
			end
			local px, py = p.x, p.y
			local idx = i
			_TimerService:SetTimerOnce(function()
				self:SpawnOneBlizzardTile(map, clip.ruid, clip.frames, clip.hitFrame, Vector3(px, py, 0), idx)
			end, delay)
		end
		log("PlayerAttack: 블리자드 바닥 이펙트 생성 " .. tostring(#placed) .. "/" .. tostring(WANT) .. "개 (시도 " .. tostring(tries) .. "회, 착지 " .. tostring(LAND_AT) .. "초에 동시)")
	end

	@ExecSpace("ServerOnly")
	method void SpawnOneBlizzardTile(Entity map, string clipRuid, integer clipFrames, integer hitFrame, Vector3 pos, integer index)
		-- 바닥 이펙트 1개 생성. 클립을 처음부터 끝까지 한 번 재생하고 사라진다(클라이언트 BlizzardTileVisual).
		-- 데미지는 클립이 hitFrame(고드름이 바닥에 꽂히는 프레임)에 도달한 순간 그 자리에 들어간다 -
		-- 시전자 클라이언트의 BlizzardTileVisual이 프레임 이벤트를 보고 서버(DealBlizzardTileArea)를 호출한다.
		local fxEntity = _SpawnService:SpawnByModelId("spearburstfadingeffect", "BlizzardTile_" .. tostring(index), pos, map)
		if not isvalid(fxEntity) then
			log_warning("PlayerAttack: 블리자드 바닥 이펙트 스폰 실패 index=" .. tostring(index))
			return
		end
		fxEntity:AddComponent("script.BlizzardTileVisual")
		local comp = fxEntity:GetComponent("script.BlizzardTileVisual")
		if isvalid(comp) then
			comp.ExpectedFrames = clipFrames
			comp.HitFrameIndex = hitFrame
			comp.CasterEntity = self.Entity
			-- "블리자드 이펙트의 zorder는 사용자 캐릭터보다 뒤" 요청 - 캐릭터(기본 4)보다 확실히 뒤로
			-- 가도록 음수 OrderInLayer를 준다(Z값만으로는 확실하게 뒤로 가지 않는다).
			comp.OrderInLayerValue = -1
			-- (되돌림) 팩(skill/800033.img/skill/80003323)의 이펙트는 색/투명도를 건드리지 않고 원본 그대로,
			-- 좌우 반전도 하지 않는다(요청사항).
			comp.AlphaValue = 1.0
			comp.TintR = 1.0
			comp.TintG = 1.0
			comp.TintB = 1.0
			comp.IsFlipX = false
			-- ClipRUID는 마지막에 넣는다 - 클라이언트의 OnSyncProperty(ClipRUID)가 실제 적용을 트리거하므로,
			-- 그 시점엔 나머지 값들이 이미 도착해 있어야 한다.
			comp.ClipRUID = clipRuid
		end
		-- 클립 1회 재생분(길어야 3초 남짓)만큼만 살려두고 정리한다.
		_TimerService:SetTimerOnce(function()
			if isvalid(fxEntity) then
				fxEntity:Destroy()
			end
		end, 6.0)
	end

	-- 시전 위치 주변에서 "발판이 있는" 좌표 하나를 랜덤으로 고른다(없으면 nil). 얼음조각/반짝임/서리
	-- 이펙트가 공통으로 쓴다. 기준점은 시전 시점에 고정해둔 좌표(blizzardCastX/Y)다 - 캐릭터가 움직여도
	-- 연출은 "블리자드를 사용한 위치" 범위 안에서 계속된다.
	@ExecSpace("ServerOnly")
	method Vector2 PickBlizzardGroundSpot(number rangeX, number rangeY)
		local map = self.Entity.CurrentMap
		if not isvalid(map) then return nil end
		local fh = map.FootholdComponent
		if not isvalid(fh) then return nil end
		local cx = self._T.blizzardCastX or self.Entity.TransformComponent.WorldPosition.x
		local cy = self._T.blizzardCastY or self.Entity.TransformComponent.WorldPosition.y
		for i = 1, 40 do
			local x = cx + (_UtilLogic:RandomDouble() * 2.0 - 1.0) * rangeX
			local probeY = cy + (_UtilLogic:RandomDouble() * 2.0 - 1.0) * rangeY
			local hit = self:FindNearbyFootholdAtX(fh, x, probeY, 3.0)
			if hit ~= nil then
				return Vector2(x, hit:GetYByX(x) + 0.05)
			end
		end
		return nil
	end

	@ExecSpace("ServerOnly")
	method void SpawnBlizzardFrostEffects()
		-- 시전 2.5초 뒤: 캐릭터 주변 발판 위에 서리 이펙트(a428e9f4 / 1c0dd97b) 15개를 랜덤 배치한다.
		-- 각각 15~20초 사이 랜덤한 시간 뒤에 사라지며, 사라질 때 1.5초에 걸쳐 서서히 투명해진다.
		local map = self.Entity.CurrentMap
		if not isvalid(map) then return end
		local clips = { "a428e9f4129141e7a6dd1f48ffda4147", "1c0dd97b95b440b3ad512646db0ee079" }
		local placed = {}
		local made = 0
		local tries = 0
		-- (기능 수정) 서리 이펙트 개수 3배(15 → 45). 최소 간격 때문에 후보가 버려지는 경우가 많아
		-- 목표 개수가 찰 때까지(또는 시도 상한까지) 반복한다.
		while made < 45 and tries < 400 do
			tries = tries + 1
			local i = made + 1
			local spot = self:PickBlizzardGroundSpot(8.0, 3.0)
			if spot ~= nil then
				-- 개수가 3배로 늘고 크기도 작아졌으므로(30~70%) 최소 간격도 0.5로 좁힌다.
				local ok = true
				for _, p in ipairs(placed) do
					local dx = p.x - spot.x
					local dy = p.y - spot.y
					if math.sqrt(dx * dx + dy * dy) < 0.5 then
						ok = false
						break
					end
				end
				if ok then
					table.insert(placed, spot)
					local clip = clips[_UtilLogic:RandomIntegerRange(1, #clips)]
					-- 총 수명 15~20초 = 유지시간 + 페이드아웃 1.5초.
					local life = 15.0 + _UtilLogic:RandomDouble() * 5.0
					-- (기능 수정) 원본 크기의 30%~70% 사이 랜덤한 크기.
					local scale = 0.3 + _UtilLogic:RandomDouble() * 0.4
					self:SpawnOneBlizzardFrost(map, clip, Vector3(spot.x, spot.y, 0), life - 1.5, scale, i)
					made = made + 1
				end
			end
		end
		log("PlayerAttack: 블리자드 서리 이펙트 생성 " .. tostring(made) .. "개")
	end

	@ExecSpace("ServerOnly")
	method void SpawnOneBlizzardFrost(Entity map, string clipRuid, Vector3 pos, number holdSeconds, number scale, integer index)
		local fx = _SpawnService:SpawnByModelId("spearburstfadingeffect", "BlizzardFrost_" .. tostring(index), pos, map)
		if not isvalid(fx) then return end
		fx:AddComponent("script.BlizzardFadingEffect")
		local comp = fx:GetComponent("script.BlizzardFadingEffect")
		if isvalid(comp) then
			-- 서리 이펙트: 투명도 90%, 원본 크기의 30~70% 랜덤, 좌우 반전, 참고 이미지 평균색
			-- (RGB 149,179,187)의 청회색 보정. 팩(80003323) 이펙트는 원본 그대로 두고 이 두 클립만 바꾼다.
			comp.StartAlpha = 0.9
			comp.HoldSeconds = holdSeconds
			comp.FadeSeconds = 1.5
			comp.RiseSpeed = 0
			comp.OrderInLayerValue = -1   -- 캐릭터보다 뒤
			comp.ScaleValue = scale
			-- (기능 수정) 좌우 반전을 한 번 더 뒤집어(true → false) 원래 방향으로 되돌린다.
			comp.IsFlipX = false
			comp.TintR = 0.58
			comp.TintG = 0.70
			comp.TintB = 0.73
			comp.ClipRUID = clipRuid
		end
		_TimerService:SetTimerOnce(function()
			if isvalid(fx) then fx:Destroy() end
		end, holdSeconds + 2.0)
	end

	@ExecSpace("ServerOnly")
	method void SpawnBlizzardBackgroundEffect()
		-- 시전 2.5초 뒤: 배경 이펙트(6da13ae8)를 지형지물보다 뒤에서 희미하게 1회 재생한다.
		-- (버그 수정) OrderInLayer를 -100으로 두면 맵 배경 이미지 뒤로 완전히 밀려 화면에 아예 보이지
		-- 않았다 - 지형 타일(기본 OrderInLayer 1)보다는 뒤, 배경보다는 앞이 되도록 -1로 올린다.
		local map = self.Entity.CurrentMap
		if not isvalid(map) then return end
		-- (기능 추가) 5번 재생되는 배경 이펙트가 매번 같은 자리(시전자 머리 위)에 겹치지 않도록,
		-- 서리 이펙트와 같은 방식으로 범위 안에서 자리를 뽑되 이미 쓴 자리와 최소 거리(4.0)를 둔다.
		if self._T.blizzardBackFXSpots == nil then
			self._T.blizzardBackFXSpots = {}
		end
		local basePos = self.Entity.TransformComponent.WorldPosition
		local pos = Vector2(basePos.x, basePos.y + 1.0)
		local fallback = nil
		for i = 1, 30 do
			local cand = self:PickBlizzardGroundSpot(8.0, 3.0)
			if cand ~= nil then
				fallback = cand
				local ok = true
				for _, p in ipairs(self._T.blizzardBackFXSpots) do
					local dx = p.x - cand.x
					local dy = p.y - cand.y
					-- 최소 간격 2.5 - 4.0으로 두면 발판이 좁은 맵에서 후보가 다 걸러져 매번 같은
					-- 대체 위치(시전자 머리 위)에 겹쳐 뜨는 문제가 있었다(실측).
					if math.sqrt(dx * dx + dy * dy) < 2.5 then
						ok = false
						break
					end
				end
				if ok then
					fallback = nil
					pos = Vector2(cand.x, cand.y + 1.5)
					table.insert(self._T.blizzardBackFXSpots, Vector2(cand.x, cand.y))
					break
				end
			end
		end
		if fallback ~= nil then
			-- 간격 조건을 만족하는 자리를 못 찾았으면, 시전자 머리 위에 또 겹치지 말고 마지막 랜덤 자리를 쓴다.
			pos = Vector2(fallback.x, fallback.y + 1.5)
			table.insert(self._T.blizzardBackFXSpots, Vector2(fallback.x, fallback.y))
		end
		local fx = _SpawnService:SpawnByModelId("spearburstfadingeffect", "BlizzardBackFX", Vector3(pos.x, pos.y, 0), map)
		if not isvalid(fx) then return end
		fx:AddComponent("script.BlizzardFadingEffect")
		local comp = fx:GetComponent("script.BlizzardFadingEffect")
		if isvalid(comp) then
			-- (버그 수정) 이 클립은 흰빛 계열이라 알파 0.35로는 밝은 하늘 배경에 완전히 묻혀 보이지 않았다
			-- ("배경에 6da13ae8가 보이지 않습니다") - 알파를 0.8로 올리고 크기도 키운다. 그래도 지형 타일보다
			-- 뒤(OrderInLayer -1, 같은 MapLayer0)라 배경 연출로만 보인다.
			-- (기능 수정) 요청사항 - 크기 절반(3.0 → 1.5), 투명도 50%(0.8 → 0.5), 재생속도 절반(1.0 → 0.5).
			comp.StartAlpha = 0.5
			-- 재생속도가 절반이라 클립 1회 재생 분량도 두 배가 된다(1.6초 → 3.2초). 안 늘리면 재생 도중에
			-- 페이드아웃이 시작돼 끝까지 못 보고 사라진다.
			comp.HoldSeconds = 3.2
			comp.FadeSeconds = 0.6
			comp.RiseSpeed = 0
			comp.SortingLayerName = "MapLayer0"
			comp.OrderInLayerValue = -1   -- 지형 타일보다는 뒤, 맵 배경보다는 앞
			comp.ScaleValue = 1.5
			comp.PlayRateValue = 0.5
			comp.ClipRUID = "6da13ae8587b4931b9c3ecd556e052ec"
		end
		_TimerService:SetTimerOnce(function()
			if isvalid(fx) then fx:Destroy() end
		end, 4.5)
		log("PlayerAttack: 블리자드 배경 이펙트 재생 pos=(" .. tostring(pos.x) .. "," .. tostring(pos.y) .. ")")
	end

	@ExecSpace("ServerOnly")
	method void SpawnBlizzardPillarOnGround()
		-- (기능 수정) 팩(80003323)의 바닥 이펙트 10종 중 하나를 "범위 안 몬스터가 있는 자리"에 생성한다.
		-- 랜덤 발판에 뿌리면 몬스터가 없는 허공에 떨어지는 경우가 많아, 범위 안 살아있는 몬스터 중
		-- 하나를 골라 그 발밑(몬스터 위치)에 떨어뜨린다. 몬스터가 하나도 없으면 아무것도 하지 않는다.
		--
		-- (기능 수정) 초기 타일과 완전히 같은 경로(SpawnOneBlizzardTile)를 쓴다 - 같은 엔티티/같은 클립 재생/
		-- 같은 데미지 방식(클립의 hitFrame에 도달한 순간, 그 자리 반경 1.2, 타일당 최대 6명).
		-- 예전의 "고정 2.4초 뒤 피해 + _EffectService 재생" 방식은 클립마다 고드름이 닿는 시점이 달라
		-- 이르거나 늦었다.
		if not isvalid(self.Entity) then return end
		local map = self.Entity.CurrentMap
		if not isvalid(map) then return end
		local cx = self._T.blizzardCastX or self.Entity.TransformComponent.WorldPosition.x
		local cy = self._T.blizzardCastY or self.Entity.TransformComponent.WorldPosition.y
		-- 판정 범위(드래곤 로어와 동일: 가로 15.0 / 세로 7.5) 안의 살아있는 몬스터들.
		local candidates = self:FindDragonRoarTargets(Vector2(cx, cy), 30)
		if #candidates == 0 then return end
		local target = candidates[_UtilLogic:RandomIntegerRange(1, #candidates)]
		if not isvalid(target) then return end
		local tpos = target.TransformComponent.WorldPosition

		local clips = self:GetBlizzardTileClips()
		local clip = clips[_UtilLogic:RandomIntegerRange(1, #clips)]
		self._T.blizzardPillarCount = (self._T.blizzardPillarCount or 0) + 1
		local idx = 1000 + self._T.blizzardPillarCount   -- 초기 타일(1~15)과 이름이 겹치지 않게
		self:SpawnOneBlizzardTile(map, clip.ruid, clip.frames, clip.hitFrame, Vector3(tpos.x, tpos.y, 0), idx)
		log("PlayerAttack: 블리자드 추가 타일 생성 (몬스터 위치) pos=(" .. tostring(tpos.x) .. "," .. tostring(tpos.y) .. ") hitFrame=" .. tostring(clip.hitFrame))
	end

	@ExecSpace("Multicast")
	method void PlayBlizzardPillarEffect(string clipRuid, number px, number py)
		if not self:IsClient() then return end
		local map = self.Entity.CurrentMap
		if not isvalid(map) then return end
		_EffectService:PlayEffect(clipRuid, map, Vector3(px, py, 0), 0, Vector3(1, 1, 1), false, { ["OrderInLayer"] = -1 })
	end

	@ExecSpace("ServerOnly")
	method void DealBlizzardPillarHit(Entity target)
		-- 기둥 이펙트가 뜬 발판 자리에 있던 몬스터 1마리에게 피해를 준다(이번 호출 전용 단일 대상 패턴).
		if not isvalid(target) then return end
		self._T.blizzardPillarCurrentTarget = target
		local pos = target.TransformComponent.WorldPosition
		local shape = BoxShape(Vector2(pos.x, pos.y), Vector2(1.0, 1.6), 0)
		self:AttackShadowSafe(shape, "skill.blizzard.pillar", target)
	end

	@ExecSpace("ServerOnly")
	method void SpawnBlizzardSparkle()
		-- 시전 후 15초 동안 랜덤한 시점에 5번 정도, 블리자드 범위 안 랜덤 위치에서 반짝임 이펙트(90ff4f10)를 재생한다.
		if not isvalid(self.Entity) then return end
		local spot = self:PickBlizzardGroundSpot(8.0, 3.0)
		if spot == nil then return end
		self:PlayBlizzardSparkleEffect(spot.x, spot.y + 0.3)
		log("PlayerAttack: 블리자드 반짝임 이펙트 재생 pos=(" .. tostring(spot.x) .. "," .. tostring(spot.y) .. ")")
	end

	@ExecSpace("Multicast")
	method void PlayBlizzardSparkleEffect(number px, number py)
		if not self:IsClient() then return end
		local map = self.Entity.CurrentMap
		if not isvalid(map) then return end
		_EffectService:PlayEffect("90ff4f1089ed4adba09908e19ee5290a", map, Vector3(px, py, 0), 0, Vector3(1, 1, 1), false, { ["OrderInLayer"] = -1 })
	end

	@ExecSpace("ServerOnly")
	method void DropBlizzardIceShard()
		-- 시전 3초 뒤부터 15초 동안 랜덤한 시점에 5개 정도, 블리자드 범위 안 랜덤 위치에 얼음조각(46893ddb)이
		-- 떨어진다. 그 자리에 몬스터가 있었으면 0.3초 뒤에 전투력의 100%~150% 피해를 준다.
		if not isvalid(self.Entity) then return end
		local spot = self:PickBlizzardGroundSpot(8.0, 3.0)
		if spot == nil then return end
		self:PlayBlizzardIceShardEffect(spot.x, spot.y)

		local hitTargets = self:FindBlizzardShardTargets(spot, 1.2)
		log("PlayerAttack: 블리자드 얼음조각 낙하 pos=(" .. tostring(spot.x) .. "," .. tostring(spot.y) .. ") 맞은 몬스터=" .. tostring(#hitTargets))
		if #hitTargets == 0 then return end
		_TimerService:SetTimerOnce(function()
			for _, t in ipairs(hitTargets) do
				self:DealBlizzardShardHit(t)
			end
		end, 0.3)
	end

	@ExecSpace("Multicast")
	method void PlayBlizzardIceShardEffect(number px, number py)
		-- (기능 수정) 얼음조각 이펙트는 4종 중 랜덤으로 하나를 재생한다.
		if not self:IsClient() then return end
		local map = self.Entity.CurrentMap
		if not isvalid(map) then return end
		local shardClips = {
			"31e46cc996124cef90b00cb3df7511d3",
			"1337ffe04c53468b87d591dfc6e73ad6",
			"243dc71d00f14282b669b0ccb2e5e406",
			"21061252ec4545ecb9007fab4ef73839",
		}
		local clip = shardClips[_UtilLogic:RandomIntegerRange(1, #shardClips)]
		-- (기능 수정) 얼음조각 크기를 원본의 2/4(=50%)로 한다.
		_EffectService:PlayEffect(clip, map, Vector3(px, py, 0), 0, Vector3(0.5, 0.5, 0.5), false, { ["OrderInLayer"] = -1 })
		_SoundService:PlaySoundAtPos("3edd6d189b9b4bf1ac48162339848e36", Vector3(px, py, 0), self.Entity, 0.7)
	end

	@ExecSpace("ServerOnly")
	method table FindBlizzardShardTargets(Vector2 pos, number radius)
		-- 얼음조각이 떨어진 자리 근처의 살아있는 몬스터 목록.
		local map = self.Entity.CurrentMap
		if not isvalid(map) then return {} end
		local monsterComps = map:GetChildComponentsByTypeName("script.Monster", true)
		local result = {}
		for _, comp in ipairs(monsterComps) do
			---@type Monster
			local mc = comp
			if isvalid(mc) and isvalid(mc.Entity) and not mc.IsDead then
				local p = mc.Entity.TransformComponent.WorldPosition
				local dx = p.x - pos.x
				local dy = p.y - pos.y
				if math.sqrt(dx * dx + dy * dy) <= radius then
					table.insert(result, mc.Entity)
				end
			end
		end
		return result
	end

	@ExecSpace("ServerOnly")
	method void DealBlizzardShardHit(Entity target)
		-- 얼음조각 피해(전투력의 100%~150%) - 다른 다중 대상 스킬과 동일하게 이번 호출 전용 단일 대상만 통과시킨다.
		if not isvalid(target) then return end
		self._T.blizzardShardCurrentTarget = target
		local pos = target.TransformComponent.WorldPosition
		local shape = BoxShape(Vector2(pos.x, pos.y), Vector2(1.0, 1.6), 0)
		self:AttackShadowSafe(shape, "skill.blizzard.shard", target)
	end

	@ExecSpace("ServerOnly")
	method void DetonateBlizzard()
		-- 바닥 이펙트 생성 1.5초 뒤 호출되어 실제 판정을 진행한다 - 시전자 주위, 범위는 드래곤 로어와 동일
		-- (FindDragonRoarTargets 재사용: 가로 15.0 / 세로 7.5, 전방위, 가까운 순 최대 20명).
		if not isvalid(self.Entity) then return end
		local worldPos = self.Entity.TransformComponent.WorldPosition
		-- (기능 수정) 최대 대상 20명 → 30명.
		local targets = self:FindDragonRoarTargets(Vector2(worldPos.x, worldPos.y), 30)
		for _, t in ipairs(targets) do
			self:DealBlizzardHit(t)
		end
		log("PlayerAttack: 블리자드 발동! targets=" .. tostring(#targets))
	end

	@ExecSpace("ServerOnly")
	method void DealBlizzardHit(Entity target)
		-- 대상 하나에게만 블리자드 데미지를 적중시킨다(드래곤 로어와 동일한 단일 대상 패턴).
		if not isvalid(target) then return end
		self._T.blizzardCurrentTarget = target
		local pos = target.TransformComponent.WorldPosition
		local shape = BoxShape(Vector2(pos.x, pos.y), Vector2(1.0, 1.6), 0)
		local hitComps = self:AttackShadowSafe(shape, "skill.blizzard", target)
		local actuallyHit = false
		for _, hc in ipairs(hitComps) do
			if isvalid(hc) and isvalid(hc.Entity) and hc.Entity == target then
				actuallyHit = true
				break
			end
		end
		if actuallyHit then
			self:PlayBlizzardHitEffect(target)
		end
	end

	@ExecSpace("Multicast")
	method void PlayBlizzardHitEffect(Entity target)
		-- 블리자드에 맞은 몬스터 전용 히트 이펙트(팩의 hit/0 클립).
		if not self:IsClient() then return end
		if not isvalid(target) then return end
		local serial = _EffectService:PlayEffectAttached("735ad75ae1f64d88a9444cf9832f4abc", target, Vector3(0, 0, 0), 0, Vector3(1, 1, 1), false, {})
		self:EchoShadowHitEffect("735ad75ae1f64d88a9444cf9832f4abc", target, Vector3(0, 0, 0), 0, Vector3(1, 1, 1), {})
		_TimerService:SetTimerOnce(function()
			_EffectService:RemoveEffect(serial)
		end, 1.5)
	end

	@ExecSpace("ServerOnly")
	method void AttackParryCounter(number combatPower)
		-- 패링(1차) 성공 반격. PlayerHit.CheckParryBlock이 "가드 표시" 0.5초 뒤에 호출한다.
		-- 시전자 주위(반경 3.0) 가까운 순 최대 6명에게 전투력의 500%~700% 피해를 준다(요청사항).
		-- 판정 방식은 블리자드/드래곤로어와 동일 - 대상마다 그 대상 전용 단일 판정을 따로 돌려
		-- 밀집 지역에서 판정 박스가 이웃까지 겹쳐 맞히는 것을 막는다.
		if not isvalid(self.Entity) then return end
		self._T.pendingParryCombatPower = combatPower
		local worldPos = self.Entity.TransformComponent.WorldPosition
		local targets = self:FindMonstersInRadius(Vector2(worldPos.x, worldPos.y + 0.5), 3.0, 6)
		local hitCount = 0
		for _, t in ipairs(targets) do
			if self:DealParryCounterHit(t) then hitCount = hitCount + 1 end
		end
		log("PlayerAttack: 패링 반격! combatPower=" .. tostring(combatPower) .. " targets=" .. tostring(#targets) .. " hit=" .. tostring(hitCount) .. " lastDamage=" .. tostring(self._T.lastParryDamage))
	end

	@ExecSpace("ServerOnly")
	method boolean DealParryCounterHit(Entity target)
		-- 대상 하나에게만 패링 반격 데미지를 적중시킨다(블리자드와 동일한 단일 대상 패턴).
		-- 실제 판정이 성사됐는지(true/false)를 돌려줘 호출부가 적중 수를 로그로 남길 수 있게 한다.
		if not isvalid(target) then return false end
		self._T.parryCurrentTarget = target
		local pos = target.TransformComponent.WorldPosition
		local shape = BoxShape(Vector2(pos.x, pos.y), Vector2(1.0, 1.6), 0)
		local hitComps = self:AttackShadowSafe(shape, "skill.parry", target)
		for _, hc in ipairs(hitComps) do
			if isvalid(hc) and isvalid(hc.Entity) and hc.Entity == target then
				return true
			end
		end
		return false
	end

	@ExecSpace("ServerOnly")
	method void AttackFireArrow(number combatPower, number atkMultiplier, number rawDirX, number rawDirY, number level)
		-- (기능 추가) "다른 스킬을 쓰면 숨고르기 모션은 중지" 요청 - 이 스킬을 새로 시전하는 시점에 이전 숨고르기가 재생 중이었다면 즉시 정리한다.
		self:StopBreather()
		-- 파이어에로우: 방향키(위/아래/대각선) 입력으로 각도를 바꿔 화살을 발사한다. 입력이 없으면 캐릭터가
		-- 바라보는 방향(전방)으로 발사. 레벨(50 기준)에 따라 몸쪽 이펙트와 화살 RUID가 달라진다.
		-- level은 SkillManager에서 combatPower와 동일하게 클라이언트에서 계산해 전달받는다 -
		-- _UIMyInfoManager.CharLevel은 서버에서 InitStats() 최초 1회 1로 고정된 뒤 갱신되지 않는 값이라 사용 불가.
		local currentState = self.Entity.StateComponent.CurrentStateName
		if currentState == "DEAD" or currentState == "CLIMB" or currentState == "LADDER" then
			return
		end

		local dirX, dirY = rawDirX, rawDirY
		local mag = math.sqrt(dirX * dirX + dirY * dirY)
		if mag > 0.0001 then
			dirX = dirX / mag
			dirY = dirY / mag
		else
			local playerCtrl = self.Entity.PlayerControllerComponent
			dirX = (isvalid(playerCtrl) and playerCtrl.LookDirectionX >= 0) and 1 or -1
			dirY = 0
		end
		self._T.pendingFireArrowDirX = dirX

		local castRuid = (level >= 50) and "c04324310b7d43219ec0d0fa400c4a5b" or "f3d1726f78be40beae0b32960858f132"
		local arrowRuid = (level >= 50) and "17e6f8af37eb4be09b95304e7854c3db" or "bf1fda424a06413d9617789715d0470e"

		-- 기모으는 딜레이 동안 이동이 되지 않도록 컨트롤러를 잠근다 (매직클로/썬더볼트 등과 동일한 패턴).
		-- 홀드 지속발동(공격속도가 빨라지면 다음 시전이 이전 시전의 잠금 해제보다 먼저 겹쳐 들어올 수 있음) 중에도
		-- 안전하도록, "원래 활성화 상태였는지"는 잠금 체인의 첫 시전에서만 기록하고(이미 잠긴 상태에서 캡처하면
		-- false가 저장되어 영원히 안 풀리는 버그가 생김), 실제 복구도 토큰으로 가장 최근 시전에서만 실행되게 한다.
		local playerCtrl = self.Entity.PlayerControllerComponent
		if not self._T.isFireArrowMovementLocked then
			self._T.pendingFireArrowWasControllerEnabled = isvalid(playerCtrl) and playerCtrl.Enable
			self._T.isFireArrowMovementLocked = true
		end
		if isvalid(playerCtrl) then
			playerCtrl.Enable = false
		end
		if isvalid(self.Entity.MovementComponent) then
			self.Entity.MovementComponent:Stop()
		end
		self._T.fireArrowMoveLockToken = (self._T.fireArrowMoveLockToken or 0) + 1
		local myMoveLockToken = self._T.fireArrowMoveLockToken

		-- 순수 상하 방향(dirX==0)은 캐릭터가 원래 보던 좌우 방향을 그대로 유지한다.
		local horizDirX
		if dirX ~= 0 then
			horizDirX = (dirX > 0) and 1 or -1
		else
			horizDirX = (isvalid(playerCtrl) and playerCtrl.LookDirectionX >= 0) and 1 or -1
		end

		-- 기모으는 느낌: 활 쏘는 모션 + 시전 이펙트/사운드는 즉시 재생하고, 실제 화살 발사는 약간의 딜레이 후에 한다.
		self:PlayFireArrowCastEffect(self.Entity, castRuid, dirX, dirY)
		self:PlayFireArrowMotion(self.Entity, "shoot1", horizDirX, atkMultiplier)
		_TimerService:SetTimerOnce(function()
			self:SpawnFireArrowProjectile(arrowRuid, combatPower, dirX, dirY)
		end, 0.25 * atkMultiplier)
		-- 이동 잠금은 모션 재생 시간이 아니라 스킬 재사용 대기시간(SkillManager의 0.75*atkMultiplier 쿨다운)과
		-- 동일하게 끝까지 유지한다 - "스킬 딜레이 동안 계속 못 움직여야 한다"는 요구사항 반영.
		_TimerService:SetTimerOnce(function()
			self:RestoreFireArrowControl(myMoveLockToken)
		end, 0.75 * atkMultiplier)
	end

	@ExecSpace("Multicast")
	method void PlayFireArrowMotion(Entity attacker, string motionName, number dirX, number atkMultiplier)
		-- 파이어에로우 전용 활 쏘는 모션 재생. 다른 스킬과 동일한 방식 - 별도 플래그로 서로 간섭하지 않는다.
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		local avatarRenderer = attacker.AvatarRendererComponent
		if not isvalid(avatarRenderer) then return end
		local body = avatarRenderer:GetBodyEntity()
		if not isvalid(body) then return end

		avatarRenderer.ShowDefaultWeaponEffects = false

		local playerCtrl = attacker.PlayerControllerComponent
		if isvalid(attacker.MovementComponent) then
			attacker.MovementComponent:Stop()
		end
		if isvalid(playerCtrl) then
			playerCtrl.LookDirectionX = dirX
		end
		self._T.isFireArrowDirectionLocked = true
		self._T.lockedFireArrowDirX = dirX
		self._T.lockedFireArrowMotionName = motionName
		self._T.isFireArrowMotionPlaying = true
		self._T.fireArrowLockToken = (self._T.fireArrowLockToken or 0) + 1
		local myFireArrowLockToken = self._T.fireArrowLockToken

		local mult = math.max(atkMultiplier or 1.0, 0.001)
		local playRate = 1.0 / mult
		self._T.lockedFireArrowPlayRate = playRate

		local motionEvent = ActionStateChangedEvent(motionName, motionName, playRate, SpriteAnimClipPlayType.Onetime)
		body:SendEvent(motionEvent)
		log("[FireArrow] PlayFireArrowMotion sent: " .. tostring(motionName) .. " playRate=" .. tostring(playRate))

		-- 모션 재생 자체(포즈 유지)는 화살이 발사되는 시점(0.25*mult)에 끝나지만, 이동 잠금(방향 고정)은
		-- 스킬 재사용 대기시간 전체(0.75*mult, SkillManager 쿨다운과 동일)까지 유지한다.
		_TimerService:SetTimerOnce(function()
			if isvalid(avatarRenderer) then
				avatarRenderer.ShowDefaultWeaponEffects = true
			end
			self._T.isFireArrowMotionPlaying = false
		end, 0.25 * mult)

		_TimerService:SetTimerOnce(function()
			if self._T.fireArrowLockToken ~= myFireArrowLockToken then return end
			self._T.isFireArrowDirectionLocked = false
			local sc = self.Entity.StateComponent
			if isvalid(sc) and sc.CurrentStateName ~= "DEAD" then
				sc:ChangeState("IDLE")
				sc:ChangeState("MOVE")
				sc:ChangeState("IDLE")
			end
		end, 0.75 * mult)
	end

	@ExecSpace("Server")
	method void RestoreFireArrowControl(integer moveLockToken)
		-- 기모으는 딜레이가 끝나 화살이 발사된 직후 컨트롤러를 되돌린다. 홀드 지속발동으로 더 최근 시전이
		-- 이미 다시 잠가둔 상태라면(토큰 불일치) 여기서 섣불리 풀지 않는다 - 그 최근 시전의 복구 타이머가 처리한다.
		if self._T.fireArrowMoveLockToken ~= moveLockToken then return end
		self._T.isFireArrowMovementLocked = false
		local playerCtrl = self.Entity.PlayerControllerComponent
		if isvalid(playerCtrl) and self._T.pendingFireArrowWasControllerEnabled then
			playerCtrl.Enable = true
		end
		-- (기능 추가) "다른 스킬들을 사용하고 난 다음도 모두 숨고르기 모션을 3번 하도록 해달라"는 요청 -
		-- 컨트롤이 복구된 이 시점에 공용 숨고르기(PlayBreather)를 시작한다.
		self:PlayBreather(self.Entity, self._T.pendingFireArrowDirX or 1)
	end

	@ExecSpace("ServerOnly")
	method void SpawnFireArrowProjectile(string arrowRuid, number combatPower, number dirX, number dirY)
		local map = self.Entity.CurrentMap
		if not isvalid(map) then return end
		self._T.fireArrowCount = (self._T.fireArrowCount or 0) + 1
		local name = "firearrow_" .. tostring(self.Entity.Name) .. "_" .. tostring(self._T.fireArrowCount)
		-- 발쪽(원점)이 아니라 몸통 중심 높이에서 날아가도록 y를 올린다 (다른 스킬들의 body-center 기준값 0.35 재사용)
		local myPos = self.Entity.TransformComponent.WorldPosition
		local proj = _SpawnService:SpawnByModelId("firearrowprojectile", name, Vector3(myPos.x, myPos.y + 0.35, myPos.z), map)
		if not isvalid(proj) then
			log_warning("[PlayerAttack] FireArrow 발사체 스폰 실패")
			return
		end

		local sprite = proj.SpriteRendererComponent
		if isvalid(sprite) then
			sprite.SpriteRUID = arrowRuid
		end

		---@type FireArrowProjectile
		local projComp = proj:GetComponent("script.FireArrowProjectile")
		if isvalid(projComp) then
			projComp.CombatPower = combatPower
			projComp.CritRate = self._T.currentCritRatePercent or 50
			-- 쉐도우 파트너 활성 여부를 원본 화살에 새겨둔다 - 히트 시 원본+보너스(타수 2배) 합산과 2줄 표시에 쓰인다.
			projComp.ShadowEchoOn = self._T.shadowPartnerActive == true
			-- 지금 적용 중인 데미지 스킨(블리자드 중이면 얼음 스킨)을 발사체에 새겨준다 - 수동 표시에 쓰인다.
			projComp.DamageSkinRUID = self:GetHitDamageSkinId()
			projComp:Fire(dirX, dirY)
		end

		self:SpawnShadowEchoArrowProjectile("firearrowprojectile", "script.FireArrowProjectile", arrowRuid, Vector3(myPos.x, myPos.y + 0.35, myPos.z), dirX, dirY, combatPower)
	end

	@ExecSpace("Multicast")
	method void PlayFireArrowCastEffect(Entity attacker, string effectRuid, number dirX, number dirY)
		-- 사용자 몸 쪽에서 1회 재생되는 시전 이펙트 + 사운드.
		-- 순수 좌우 방향(dirY==0)은 회전 대신 FlipX로 반전한다 - 180도 회전을 쓰면 이펙트 원점이 발밑까지
		-- 밀려 내려가는 문제가 있어서(사용자 확인 - 왼쪽은 정상, 오른쪽만 밀림), 회전 없이 좌우만 미러링한다.
		-- 위/아래/대각선 방향은 회전이 필요하므로 그대로 두되, 방향별로 사용자가 실제 화면으로 확인해 지적한
		-- 어긋난 위치를 방향별 로컬 오프셋으로 보정한다(위=좌측+상단으로, 아래=우측으로, 우측아래=우측으로, 우측위=상단으로 더).
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		local angleDeg = 0
		local flipX = false
		local offsetX = 0
		local offsetY = 0
		if dirY == 0 then
			flipX = dirX > 0
		elseif dirX == 0 and dirY > 0 then
			-- 위
			angleDeg = math.deg(math.atan(dirY, dirX)) + 180
			offsetX = -0.15
			offsetY = 0.2
		elseif dirX == 0 and dirY < 0 then
			-- 아래
			angleDeg = math.deg(math.atan(dirY, dirX)) + 180
			offsetX = 0.15
		elseif dirX > 0 and dirY > 0 then
			-- 우측위
			angleDeg = math.deg(math.atan(dirY, dirX)) + 180
			offsetY = 0.3
		elseif dirX > 0 and dirY < 0 then
			-- 우측아래
			angleDeg = math.deg(math.atan(dirY, dirX)) + 180
			offsetX = 0.15
		else
			-- 좌측위/좌측아래 (아직 별도 피드백 없음 - 기존 기본 보정 유지)
			angleDeg = math.deg(math.atan(dirY, dirX)) + 180
			if dirY > 0 then
				offsetY = 0.2
			end
		end
		local castOptions = { ["FlipX"] = flipX }
		local serial = _EffectService:PlayEffectAttached(effectRuid, attacker, Vector3(offsetX, offsetY, 0), angleDeg, Vector3(1, 1, 1), false, castOptions)
		-- 쉐도우 파트너: 같은 시전 이펙트를 x축 뒤쪽에서 투명도 70%로 복제 재생(그림자 몫 - 데미지 없음)
		local echoSerial = self:EchoShadowSkillEffectAttached(effectRuid, attacker, Vector3(offsetX, offsetY, 0), angleDeg, Vector3(1, 1, 1), castOptions, dirX)
		_SoundService:PlaySound("6f972ab4e14841398281f3fc2a8f376e", 1.0)
		_TimerService:SetTimerOnce(function()
			_EffectService:RemoveEffect(serial)
			if echoSerial ~= 0 then
				_EffectService:RemoveEffect(echoSerial)
			end
		end, 1.0)
	end

	@ExecSpace("ServerOnly")
	method void AttackIronArrow(number combatPower, number atkMultiplier, number rawDirX, number rawDirY)
		-- (기능 추가) "다른 스킬을 쓰면 숨고르기 모션은 중지" 요청 - 이 스킬을 새로 시전하는 시점에 이전 숨고르기가 재생 중이었다면 즉시 정리한다.
		self:StopBreather()
		-- 아이언에로우: 파이어에로우와 완전히 동일한 구조(8방향 발사·기모으는 딜레이·이동봉인)를 그대로
		-- 재사용하되, 전용 이펙트/사운드를 쓰고 레벨에 따른 분기는 없다(고정 1종). 파이어에로우와 서로
		-- 간섭하지 않도록 모든 _T 필드는 별도로 둔다.
		local currentState = self.Entity.StateComponent.CurrentStateName
		if currentState == "DEAD" or currentState == "CLIMB" or currentState == "LADDER" then
			return
		end

		local dirX, dirY = rawDirX, rawDirY
		local mag = math.sqrt(dirX * dirX + dirY * dirY)
		if mag > 0.0001 then
			dirX = dirX / mag
			dirY = dirY / mag
		else
			local playerCtrl = self.Entity.PlayerControllerComponent
			dirX = (isvalid(playerCtrl) and playerCtrl.LookDirectionX >= 0) and 1 or -1
			dirY = 0
		end
		self._T.pendingIronArrowDirX = dirX

		local castRuid = "dcac510901fe451282ad7b93abc3032d"
		local arrowRuid = "1e06841cc18a47c9975303520f3429d6"

		-- 기모으는 딜레이 동안 이동이 되지 않도록 컨트롤러를 잠근다 (파이어에로우와 동일한 첫-시전-캡처 +
		-- 토큰 가드 패턴 - 홀드 지속발동 중에도 안전).
		local playerCtrl = self.Entity.PlayerControllerComponent
		if not self._T.isIronArrowMovementLocked then
			self._T.pendingIronArrowWasControllerEnabled = isvalid(playerCtrl) and playerCtrl.Enable
			self._T.isIronArrowMovementLocked = true
		end
		if isvalid(playerCtrl) then
			playerCtrl.Enable = false
		end
		if isvalid(self.Entity.MovementComponent) then
			self.Entity.MovementComponent:Stop()
		end
		self._T.ironArrowMoveLockToken = (self._T.ironArrowMoveLockToken or 0) + 1
		local myMoveLockToken = self._T.ironArrowMoveLockToken

		-- 순수 상하 방향(dirX==0)은 캐릭터가 원래 보던 좌우 방향을 그대로 유지한다.
		local horizDirX
		if dirX ~= 0 then
			horizDirX = (dirX > 0) and 1 or -1
		else
			horizDirX = (isvalid(playerCtrl) and playerCtrl.LookDirectionX >= 0) and 1 or -1
		end

		self:PlayIronArrowCastEffect(self.Entity, castRuid, dirX, dirY)
		self:PlayIronArrowMotion(self.Entity, "shoot1", horizDirX, atkMultiplier)
		-- 화살이 실제로 발사되기까지의 기모으는 딜레이: 사용자 지정값 0.7로 직접 설정.
		_TimerService:SetTimerOnce(function()
			self:SpawnIronArrowProjectile(arrowRuid, combatPower, dirX, dirY)
		end, 0.7 * atkMultiplier)
		-- 이동 잠금은 모션 재생 시간이 아니라 스킬 재사용 대기시간(SkillManager의 0.75*atkMultiplier 쿨다운)과
		-- 동일하게 끝까지 유지한다.
		_TimerService:SetTimerOnce(function()
			self:RestoreIronArrowControl(myMoveLockToken)
		end, 0.75 * atkMultiplier)
	end

	@ExecSpace("Multicast")
	method void PlayIronArrowMotion(Entity attacker, string motionName, number dirX, number atkMultiplier)
		-- 아이언에로우 전용 활 쏘는 모션 재생. 파이어에로우와 동일한 방식 - 별도 플래그로 서로 간섭하지 않는다.
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		local avatarRenderer = attacker.AvatarRendererComponent
		if not isvalid(avatarRenderer) then return end
		local body = avatarRenderer:GetBodyEntity()
		if not isvalid(body) then return end

		avatarRenderer.ShowDefaultWeaponEffects = false

		local playerCtrl = attacker.PlayerControllerComponent
		if isvalid(attacker.MovementComponent) then
			attacker.MovementComponent:Stop()
		end
		if isvalid(playerCtrl) then
			playerCtrl.LookDirectionX = dirX
		end
		self._T.isIronArrowDirectionLocked = true
		self._T.lockedIronArrowDirX = dirX
		self._T.lockedIronArrowMotionName = motionName
		self._T.isIronArrowMotionPlaying = true
		self._T.ironArrowLockToken = (self._T.ironArrowLockToken or 0) + 1
		local myIronArrowLockToken = self._T.ironArrowLockToken

		local mult = math.max(atkMultiplier or 1.0, 0.001)
		local playRate = 1.0 / mult
		self._T.lockedIronArrowPlayRate = playRate

		local motionEvent = ActionStateChangedEvent(motionName, motionName, playRate, SpriteAnimClipPlayType.Onetime)
		body:SendEvent(motionEvent)
		log("[IronArrow] PlayIronArrowMotion sent: " .. tostring(motionName) .. " playRate=" .. tostring(playRate))

		-- 모션 재생 자체(포즈 유지)는 화살이 발사되는 시점(0.7*mult, 기모으는 딜레이와 동일하게 맞춤)에 끝나지만,
		-- 이동 잠금(방향 고정)은 스킬 재사용 대기시간 전체(0.75*mult, SkillManager 쿨다운과 동일)까지 유지한다.
		_TimerService:SetTimerOnce(function()
			if isvalid(avatarRenderer) then
				avatarRenderer.ShowDefaultWeaponEffects = true
			end
			self._T.isIronArrowMotionPlaying = false
		end, 0.7 * mult)

		_TimerService:SetTimerOnce(function()
			if self._T.ironArrowLockToken ~= myIronArrowLockToken then return end
			self._T.isIronArrowDirectionLocked = false
			local sc = self.Entity.StateComponent
			if isvalid(sc) and sc.CurrentStateName ~= "DEAD" then
				sc:ChangeState("IDLE")
				sc:ChangeState("MOVE")
				sc:ChangeState("IDLE")
			end
		end, 0.75 * mult)
	end

	@ExecSpace("Server")
	method void RestoreIronArrowControl(integer moveLockToken)
		-- 기모으는 딜레이가 끝나 화살이 발사된 직후 컨트롤러를 되돌린다. 홀드 지속발동으로 더 최근 시전이
		-- 이미 다시 잠가둔 상태라면(토큰 불일치) 여기서 섣불리 풀지 않는다.
		if self._T.ironArrowMoveLockToken ~= moveLockToken then return end
		self._T.isIronArrowMovementLocked = false
		local playerCtrl = self.Entity.PlayerControllerComponent
		if isvalid(playerCtrl) and self._T.pendingIronArrowWasControllerEnabled then
			playerCtrl.Enable = true
		end
		-- (기능 추가) "다른 스킬들을 사용하고 난 다음도 모두 숨고르기 모션을 3번 하도록 해달라"는 요청 -
		-- 컨트롤이 복구된 이 시점에 공용 숨고르기(PlayBreather)를 시작한다.
		self:PlayBreather(self.Entity, self._T.pendingIronArrowDirX or 1)
	end

	@ExecSpace("ServerOnly")
	method void SpawnIronArrowProjectile(string arrowRuid, number combatPower, number dirX, number dirY)
		local map = self.Entity.CurrentMap
		if not isvalid(map) then return end
		self._T.ironArrowCount = (self._T.ironArrowCount or 0) + 1
		local name = "ironarrow_" .. tostring(self.Entity.Name) .. "_" .. tostring(self._T.ironArrowCount)
		-- 발쪽(원점)이 아니라 몸통 중심 높이에서 날아가도록 y를 올린다 (파이어에로우와 동일한 body-center 기준값 0.35).
		local myPos = self.Entity.TransformComponent.WorldPosition
		local proj = _SpawnService:SpawnByModelId("ironarrowprojectile", name, Vector3(myPos.x, myPos.y + 0.35, myPos.z), map)
		if not isvalid(proj) then
			log_warning("[PlayerAttack] IronArrow 발사체 스폰 실패")
			return
		end

		local sprite = proj.SpriteRendererComponent
		if isvalid(sprite) then
			sprite.SpriteRUID = arrowRuid
		end

		---@type IronArrowProjectile
		local projComp = proj:GetComponent("script.IronArrowProjectile")
		if isvalid(projComp) then
			projComp.CombatPower = combatPower
			projComp.CritRate = self._T.currentCritRatePercent or 50
			-- 쉐도우 파트너 활성 여부를 원본 화살에 새겨둔다 - 히트 시 원본+보너스(타수 2배) 합산과 2줄 표시,
			-- 히트 이펙트 시간차 2배 재생에 쓰인다.
			projComp.ShadowEchoOn = self._T.shadowPartnerActive == true
			-- 지금 적용 중인 데미지 스킨(블리자드 중이면 얼음 스킨)을 발사체에 새겨준다 - 수동 표시에 쓰인다.
			projComp.DamageSkinRUID = self:GetHitDamageSkinId()
			projComp:Fire(dirX, dirY)
		end

		self:SpawnShadowEchoArrowProjectile("ironarrowprojectile", "script.IronArrowProjectile", arrowRuid, Vector3(myPos.x, myPos.y + 0.35, myPos.z), dirX, dirY, combatPower)
	end

	@ExecSpace("Multicast")
	method void PlayIronArrowCastEffect(Entity attacker, string effectRuid, number dirX, number dirY)
		-- 사용자 몸 쪽에서 1회 재생되는 시전 이펙트 + 사운드. 파이어에로우와 동일한 방향별 오프셋/회전
		-- 보정 로직을 그대로 재사용한다(사용자가 이미 화면으로 확인해 맞춰둔 값).
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		local angleDeg = 0
		local flipX = false
		local offsetX = 0
		local offsetY = 0
		if dirY == 0 then
			-- 좌/우: 이전값(0.15)과 직전값(0.0)의 중간 - 0.075.
			flipX = dirX > 0
			offsetY = 0.075
		elseif dirX == 0 and dirY > 0 then
			-- 위(대각선 아님): 왼쪽을 보고 쏠 때는 더 왼쪽으로(-0.3, 기존 유지), 오른쪽을 보고 쏠 때는
			-- 몸에서 너무 멀어졌다는 피드백으로 좌측으로 옮김(0.3 -> -0.15, 원래의 좌측 기본값 수준으로).
			angleDeg = math.deg(math.atan(dirY, dirX)) + 180
			local playerCtrl = attacker.PlayerControllerComponent
			local facingLeft = isvalid(playerCtrl) and playerCtrl.LookDirectionX < 0
			offsetX = facingLeft and -0.3 or -0.15
			offsetY = 0.2
		elseif dirX == 0 and dirY < 0 then
			-- 아래(대각선 아님): 오른쪽을 보고 쏠 때는 더 오른쪽으로(0.3, 기존 유지), 왼쪽을 보고 쏠 때는
			-- 몸에서 너무 멀어졌다는 피드백으로 우측으로 옮김(-0.3 -> 0.15, 원래의 우측 기본값 수준으로).
			angleDeg = math.deg(math.atan(dirY, dirX)) + 180
			local playerCtrl = attacker.PlayerControllerComponent
			local facingRight = isvalid(playerCtrl) and playerCtrl.LookDirectionX >= 0
			offsetX = facingRight and 0.3 or 0.15
		elseif dirX > 0 and dirY > 0 then
			-- 우측위: 방금 올라간 정도(0.5->0.65, +0.15)만큼 한번 더 올림 - 0.65 -> 0.8.
			angleDeg = math.deg(math.atan(dirY, dirX)) + 180
			offsetX = 0.3
			offsetY = 0.8
		elseif dirX > 0 and dirY < 0 then
			-- 우측아래: 조금만 더 올림 - offsetY 0.1->0.2.
			angleDeg = math.deg(math.atan(dirY, dirX)) + 180
			offsetX = 0.45
			offsetY = 0.2
		elseif dirX < 0 and dirY > 0 then
			-- 좌측위: 우측위와 높이를 맞추는 기준(0.5) - 좌측 당김은 그대로 유지.
			angleDeg = math.deg(math.atan(dirY, dirX)) + 180
			offsetX = -0.7
			offsetY = 0.5
		else
			-- 좌측아래: 살짝 왼쪽으로 더 - offsetX -0.15 추가(offsetY -0.2 유지).
			angleDeg = math.deg(math.atan(dirY, dirX)) + 180
			offsetX = -0.15
			offsetY = -0.2
		end
		local castOptions = { ["FlipX"] = flipX }
		local serial = _EffectService:PlayEffectAttached(effectRuid, attacker, Vector3(offsetX, offsetY, 0), angleDeg, Vector3(1, 1, 1), false, castOptions)
		-- 쉐도우 파트너: 같은 시전 이펙트를 x축 뒤쪽에서 투명도 70%로 복제 재생(그림자 몫 - 데미지 없음)
		local echoSerial = self:EchoShadowSkillEffectAttached(effectRuid, attacker, Vector3(offsetX, offsetY, 0), angleDeg, Vector3(1, 1, 1), castOptions, dirX)
		_SoundService:PlaySound("7d5ef2c392a34251990a9dc8b51deb12", 1.0)
		_TimerService:SetTimerOnce(function()
			_EffectService:RemoveEffect(serial)
			if echoSerial ~= 0 then
				_EffectService:RemoveEffect(echoSerial)
			end
		end, 1.0)
	end

	@ExecSpace("ServerOnly")
	method void AttackArrowBlow(number combatPower, number atkMultiplier, boolean enhanced)
		-- 에로우 블로우(1차): 전방으로 화살 한 발을 쏴서 적 "한 명"에게 전투력의 150%~200% 피해를 준다.
		-- 아이언 에로우의 구조(활 쏘는 모션·시전 딜레이·이동봉인)를 그대로 재사용하되, 8방향 조준은
		-- 없고(원작처럼 바라보는 방향 전방 고정) 몸쪽 시전 이펙트도 없다(해당 리소스가 없음).
		-- 다른 화살 스킬들과 서로 간섭하지 않도록 모든 _T 필드는 별도로 둔다.
		-- (기능 유지) 다른 스킬을 쓰면 숨고르기 모션은 중지한다.
		self:StopBreather()
		local currentState = self.Entity.StateComponent.CurrentStateName
		if currentState == "DEAD" or currentState == "CLIMB" or currentState == "LADDER" then
			return
		end

		local playerCtrl = self.Entity.PlayerControllerComponent
		local dirX = (isvalid(playerCtrl) and playerCtrl.LookDirectionX >= 0) and 1 or -1
		self._T.pendingArrowBlowDirX = dirX

		-- 시전 딜레이 동안 이동이 되지 않도록 컨트롤러를 잠근다(아이언에로우와 동일한 첫-시전-캡처 +
		-- 토큰 가드 패턴 - 홀드 지속발동 중에도 잠금이 고착되지 않는다).
		if not self._T.isArrowBlowMovementLocked then
			self._T.pendingArrowBlowWasControllerEnabled = isvalid(playerCtrl) and playerCtrl.Enable
			self._T.isArrowBlowMovementLocked = true
		end
		if isvalid(playerCtrl) then
			playerCtrl.Enable = false
		end
		if isvalid(self.Entity.MovementComponent) then
			self.Entity.MovementComponent:Stop()
		end
		self._T.arrowBlowMoveLockToken = (self._T.arrowBlowMoveLockToken or 0) + 1
		local myMoveLockToken = self._T.arrowBlowMoveLockToken

		self:PlayArrowBlowMotion(self.Entity, "shoot1", dirX, atkMultiplier)
		-- 1차 스킬이라 기모으는 동작 없이 빠르게 발사한다(아이언에로우의 0.7보다 훨씬 짧은 0.2).
		_TimerService:SetTimerOnce(function()
			-- 조준은 실제로 화살이 나가는 이 시점에 계산한다(시전 중 대상이 움직여도 따라간다).
			local aim = self:ComputeArrowAimDirection(dirX, self.ArrowAimXReach, self.ArrowAimYHalfHeight)
			self:SpawnArrowBlowProjectile(combatPower, aim.x, aim.y, enhanced)
		end, 0.2 * atkMultiplier)
		-- 이동 잠금은 스킬 재사용 대기시간(SkillManager의 0.75*atkMultiplier 쿨다운)과 동일하게 유지한다.
		_TimerService:SetTimerOnce(function()
			self:RestoreArrowBlowControl(myMoveLockToken)
		end, 0.75 * atkMultiplier)
	end

	@ExecSpace("Multicast")
	method void PlayArrowBlowMotion(Entity attacker, string motionName, number dirX, number atkMultiplier)
		-- 에로우 블로우 전용 활 쏘는 모션 재생. 아이언에로우와 동일한 방식 - 별도 플래그로 서로 간섭하지 않는다.
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		local avatarRenderer = attacker.AvatarRendererComponent
		if not isvalid(avatarRenderer) then return end
		local body = avatarRenderer:GetBodyEntity()
		if not isvalid(body) then return end

		avatarRenderer.ShowDefaultWeaponEffects = false

		local playerCtrl = attacker.PlayerControllerComponent
		if isvalid(attacker.MovementComponent) then
			attacker.MovementComponent:Stop()
		end
		if isvalid(playerCtrl) then
			playerCtrl.LookDirectionX = dirX
		end
		self._T.isArrowBlowDirectionLocked = true
		self._T.lockedArrowBlowDirX = dirX
		self._T.lockedArrowBlowMotionName = motionName
		self._T.isArrowBlowMotionPlaying = true
		self._T.arrowBlowLockToken = (self._T.arrowBlowLockToken or 0) + 1
		local myArrowBlowLockToken = self._T.arrowBlowLockToken

		local mult = math.max(atkMultiplier or 1.0, 0.001)
		local playRate = 1.0 / mult
		self._T.lockedArrowBlowPlayRate = playRate

		local motionEvent = ActionStateChangedEvent(motionName, motionName, playRate, SpriteAnimClipPlayType.Onetime)
		body:SendEvent(motionEvent)
		log("[ArrowBlow] PlayArrowBlowMotion sent: " .. tostring(motionName) .. " playRate=" .. tostring(playRate))

		-- 모션 재생 자체(포즈 유지)는 화살이 발사되는 시점(0.2*mult)에 끝나지만, 이동 잠금(방향 고정)은
		-- 스킬 재사용 대기시간 전체(0.75*mult)까지 유지한다.
		_TimerService:SetTimerOnce(function()
			if isvalid(avatarRenderer) then
				avatarRenderer.ShowDefaultWeaponEffects = true
			end
			self._T.isArrowBlowMotionPlaying = false
		end, 0.2 * mult)

		_TimerService:SetTimerOnce(function()
			if self._T.arrowBlowLockToken ~= myArrowBlowLockToken then return end
			self._T.isArrowBlowDirectionLocked = false
			local sc = self.Entity.StateComponent
			if isvalid(sc) and sc.CurrentStateName ~= "DEAD" then
				sc:ChangeState("IDLE")
				sc:ChangeState("MOVE")
				sc:ChangeState("IDLE")
			end
		end, 0.75 * mult)
	end

	@ExecSpace("Server")
	method void RestoreArrowBlowControl(integer moveLockToken)
		-- 시전이 끝나 컨트롤러를 되돌린다. 홀드 지속발동으로 더 최근 시전이 이미 다시 잠가둔 상태라면
		-- (토큰 불일치) 여기서 섣불리 풀지 않는다.
		if self._T.arrowBlowMoveLockToken ~= moveLockToken then return end
		self._T.isArrowBlowMovementLocked = false
		local playerCtrl = self.Entity.PlayerControllerComponent
		if isvalid(playerCtrl) and self._T.pendingArrowBlowWasControllerEnabled then
			playerCtrl.Enable = true
		end
		-- 다른 스킬들과 동일하게 컨트롤 복구 시점에 공용 숨고르기 모션을 시작한다.
		self:PlayBreather(self.Entity, self._T.pendingArrowBlowDirX or 1)
	end

	@ExecSpace("ServerOnly")
	method void SpawnArrowBlowProjectile(number combatPower, number dirX, number dirY, boolean enhanced)
		-- 에로우 블로우 화살 한 발을 맵에 스폰하고 조준 방향(dirX, dirY)으로 발사한다.
		-- enhanced면 화살에 강화 플래그를 새겨 첫 명중 지점에서 폭발(이펙트 3개 + 최대 5명 시간차 타격)한다.
		local map = self.Entity.CurrentMap
		if not isvalid(map) then return end
		self._T.arrowBlowCount = (self._T.arrowBlowCount or 0) + 1
		local name = "arrowblow_" .. tostring(self.Entity.Name) .. "_" .. tostring(self._T.arrowBlowCount)
		-- 발쪽(원점)이 아니라 몸통 중심 높이에서 날아가도록 y를 올린다(다른 화살 스킬과 동일한 0.35).
		local myPos = self.Entity.TransformComponent.WorldPosition
		local proj = _SpawnService:SpawnByModelId("arrowblowprojectile", name, Vector3(myPos.x, myPos.y + 0.35, myPos.z), map)
		if not isvalid(proj) then
			log_warning("[PlayerAttack] ArrowBlow 발사체 스폰 실패")
			return
		end

		---@type ArrowBlowProjectile
		local projComp = proj:GetComponent("script.ArrowBlowProjectile")
		if isvalid(projComp) then
			projComp.CombatPower = combatPower
			projComp.CritRate = self._T.currentCritRatePercent or 50
			-- 지금 적용 중인 데미지 스킨(블리자드 중이면 얼음 스킨)을 발사체에 새겨준다 - 수동 표시에 쓰인다.
			projComp.DamageSkinRUID = self:GetHitDamageSkinId()
			projComp.Enhanced = enhanced
			projComp:Fire(dirX, dirY)
		end
		log("[ArrowBlow] 화살 발사 dir=(" .. string.format("%.2f", dirX) .. "," .. string.format("%.2f", dirY) .. ") combatPower=" .. tostring(combatPower) .. " enhanced=" .. tostring(enhanced))
	end

	@ExecSpace("ServerOnly")
	method void AttackDoubleShot(number combatPower, number atkMultiplier, integer jobIdx)
		-- 더블샷(1차): 전방으로 화살 두 발을 동시에 쏜다. 두 발은 같은 x·같은 y에서 출발해 날아갈수록
		-- 위아래로 미세하게 벌어지고, 각각 적 한 명씩을 맞혀 럭키세븐처럼 데미지 숫자가 2줄로 뜬다.
		-- 화살 그림은 직업별로 다르다 - 신궁(jobIdx 7)은 ball2, 보우마스터(8) 및 그 외는 ball1.
		-- 에로우 블로우와 동일한 구조(활 쏘는 모션·시전 딜레이·이동봉인)를 쓰되 전용 _T 필드를 둔다.
		-- (기능 유지) 다른 스킬을 쓰면 숨고르기 모션은 중지한다.
		self:StopBreather()
		local currentState = self.Entity.StateComponent.CurrentStateName
		if currentState == "DEAD" or currentState == "CLIMB" or currentState == "LADDER" then
			return
		end

		local playerCtrl = self.Entity.PlayerControllerComponent
		local dirX = (isvalid(playerCtrl) and playerCtrl.LookDirectionX >= 0) and 1 or -1
		self._T.pendingDoubleShotDirX = dirX

		-- 시전 딜레이 동안 이동이 되지 않도록 컨트롤러를 잠근다(첫-시전-캡처 + 토큰 가드 패턴 -
		-- 홀드 지속발동 중에도 잠금이 고착되지 않는다).
		if not self._T.isDoubleShotMovementLocked then
			self._T.pendingDoubleShotWasControllerEnabled = isvalid(playerCtrl) and playerCtrl.Enable
			self._T.isDoubleShotMovementLocked = true
		end
		if isvalid(playerCtrl) then
			playerCtrl.Enable = false
		end
		if isvalid(self.Entity.MovementComponent) then
			self.Entity.MovementComponent:Stop()
		end
		self._T.doubleShotMoveLockToken = (self._T.doubleShotMoveLockToken or 0) + 1
		local myMoveLockToken = self._T.doubleShotMoveLockToken

		-- 신궁은 ball2(37x7 굵은 금색 화살), 그 외(보우마스터 포함)는 ball1(29x3 가는 주황 화살).
		local ballRuid = (jobIdx == 7) and "c43f61a98b8f41fd8a7d5f8769034db8" or "f1a8e518ae624dbcbe9c007af3429c2d"

		self:PlayDoubleShotMotion(self.Entity, "shoot1", dirX, atkMultiplier)
		_TimerService:SetTimerOnce(function()
			-- 조준은 실제로 화살이 나가는 이 시점에 계산한다(시전 중 대상이 움직여도 따라간다).
			-- 두 발은 완전히 같은 방향/좌표에서 동시에 발사된다(HitIndex/SpreadDir만 다르다).
			local aim = self:ComputeArrowAimDirection(dirX, self.ArrowAimXReach, self.ArrowAimYHalfHeight)
			self:SpawnDoubleShotProjectile(ballRuid, combatPower, aim.x, aim.y, 1, 1)
			self:SpawnDoubleShotProjectile(ballRuid, combatPower, aim.x, aim.y, 2, -1)
		end, 0.2 * atkMultiplier)
		-- 이동 잠금은 스킬 재사용 대기시간(SkillManager의 0.75*atkMultiplier 쿨다운)과 동일하게 유지한다.
		_TimerService:SetTimerOnce(function()
			self:RestoreDoubleShotControl(myMoveLockToken)
		end, 0.75 * atkMultiplier)
	end

	@ExecSpace("Multicast")
	method void PlayDoubleShotMotion(Entity attacker, string motionName, number dirX, number atkMultiplier)
		-- 더블샷 전용 활 쏘는 모션 재생. 다른 화살 스킬과 동일한 방식 - 별도 플래그로 서로 간섭하지 않는다.
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		local avatarRenderer = attacker.AvatarRendererComponent
		if not isvalid(avatarRenderer) then return end
		local body = avatarRenderer:GetBodyEntity()
		if not isvalid(body) then return end

		avatarRenderer.ShowDefaultWeaponEffects = false

		local playerCtrl = attacker.PlayerControllerComponent
		if isvalid(attacker.MovementComponent) then
			attacker.MovementComponent:Stop()
		end
		if isvalid(playerCtrl) then
			playerCtrl.LookDirectionX = dirX
		end
		self._T.isDoubleShotDirectionLocked = true
		self._T.lockedDoubleShotDirX = dirX
		self._T.lockedDoubleShotMotionName = motionName
		self._T.isDoubleShotMotionPlaying = true
		self._T.doubleShotLockToken = (self._T.doubleShotLockToken or 0) + 1
		local myDoubleShotLockToken = self._T.doubleShotLockToken

		local mult = math.max(atkMultiplier or 1.0, 0.001)
		local playRate = 1.0 / mult
		self._T.lockedDoubleShotPlayRate = playRate

		local motionEvent = ActionStateChangedEvent(motionName, motionName, playRate, SpriteAnimClipPlayType.Onetime)
		body:SendEvent(motionEvent)
		log("[DoubleShot] PlayDoubleShotMotion sent: " .. tostring(motionName) .. " playRate=" .. tostring(playRate))

		_TimerService:SetTimerOnce(function()
			if isvalid(avatarRenderer) then
				avatarRenderer.ShowDefaultWeaponEffects = true
			end
			self._T.isDoubleShotMotionPlaying = false
		end, 0.2 * mult)

		_TimerService:SetTimerOnce(function()
			if self._T.doubleShotLockToken ~= myDoubleShotLockToken then return end
			self._T.isDoubleShotDirectionLocked = false
			local sc = self.Entity.StateComponent
			if isvalid(sc) and sc.CurrentStateName ~= "DEAD" then
				sc:ChangeState("IDLE")
				sc:ChangeState("MOVE")
				sc:ChangeState("IDLE")
			end
		end, 0.75 * mult)
	end

	@ExecSpace("Server")
	method void RestoreDoubleShotControl(integer moveLockToken)
		-- 시전이 끝나 컨트롤러를 되돌린다. 홀드 지속발동으로 더 최근 시전이 이미 다시 잠가둔 상태라면
		-- (토큰 불일치) 여기서 섣불리 풀지 않는다.
		if self._T.doubleShotMoveLockToken ~= moveLockToken then return end
		self._T.isDoubleShotMovementLocked = false
		local playerCtrl = self.Entity.PlayerControllerComponent
		if isvalid(playerCtrl) and self._T.pendingDoubleShotWasControllerEnabled then
			playerCtrl.Enable = true
		end
		-- 다른 스킬들과 동일하게 컨트롤이 복구된 시점에 공용 숨고르기 모션을 시작한다.
		self:PlayBreather(self.Entity, self._T.pendingDoubleShotDirX or 1)
	end

	@ExecSpace("ServerOnly")
	method void SpawnDoubleShotProjectile(string ballRuid, number combatPower, number dirX, number dirY, integer hitIndex, number spreadDir)
		-- 더블샷 화살 한 발을 맵에 스폰하고 전방으로 발사한다. 두 발은 완전히 같은 좌표에서 출발하고
		-- (spreadDir이 서로 반대라) 날아가면서 위아래로 벌어진다.
		local map = self.Entity.CurrentMap
		if not isvalid(map) then return end
		self._T.doubleShotCount = (self._T.doubleShotCount or 0) + 1
		local name = "doubleshot_" .. tostring(self.Entity.Name) .. "_" .. tostring(self._T.doubleShotCount)
		-- 발쪽(원점)이 아니라 몸통 중심 높이에서 날아가도록 y를 올린다(다른 화살 스킬과 동일한 0.35).
		local myPos = self.Entity.TransformComponent.WorldPosition
		local proj = _SpawnService:SpawnByModelId("doubleshotprojectile", name, Vector3(myPos.x, myPos.y + 0.35, myPos.z), map)
		if not isvalid(proj) then
			log_warning("[PlayerAttack] DoubleShot 발사체 스폰 실패")
			return
		end

		local sprite = proj.SpriteRendererComponent
		if isvalid(sprite) then
			sprite.SpriteRUID = ballRuid
		end

		---@type DoubleShotProjectile
		local projComp = proj:GetComponent("script.DoubleShotProjectile")
		if isvalid(projComp) then
			projComp.CombatPower = combatPower
			projComp.CritRate = self._T.currentCritRatePercent or 50
			projComp.HitIndex = hitIndex
			projComp.SpreadDir = spreadDir
			-- 지금 적용 중인 데미지 스킨(블리자드 중이면 얼음 스킨)을 발사체에 새겨준다 - 수동 표시에 쓰인다.
			projComp.DamageSkinRUID = self:GetHitDamageSkinId()
			projComp:Fire(dirX, dirY)
		end
		log("[DoubleShot] 화살 발사 hitIndex=" .. tostring(hitIndex) .. " spreadDir=" .. tostring(spreadDir) .. " dir=(" .. string.format("%.2f", dirX) .. "," .. string.format("%.2f", dirY) .. ") combatPower=" .. tostring(combatPower))
	end

	@ExecSpace("ServerOnly")
	method void AttackAvenger(number combatPower, number atkMultiplier, number rawDirX, number rawDirY)
		-- (기능 추가) "다른 스킬을 쓰면 숨고르기 모션은 중지" 요청 - 이 스킬을 새로 시전하는 시점에 이전 숨고르기가 재생 중이었다면 즉시 정리한다.
		self:StopBreather()
		-- 어벤져: 파이어에로우/아이언에로우와 동일한 구조(8방향 발사·기모으는 딜레이·이동봉인)를 재사용한다.
		-- 전투력의 500% 고정 데미지로 최대 10명을 관통하고, 사거리는 파이어에로우의 2/3(AvengerProjectile.MaxLifetime로 조절).
		-- 몸쪽 이펙트(공식 어벤져 리소스팩 skill/800033.img/skill/80003327의 "effect")가 끝난 뒤 투사체(같은 팩의 "ball/0",
		-- RUID 0477b2c75e4b4fbcaf795e03bd8da11a)를 발사한다.
		local currentState = self.Entity.StateComponent.CurrentStateName
		if currentState == "DEAD" or currentState == "CLIMB" or currentState == "LADDER" then
			return
		end

		local dirX, dirY = rawDirX, rawDirY
		local mag = math.sqrt(dirX * dirX + dirY * dirY)
		if mag > 0.0001 then
			dirX = dirX / mag
			dirY = dirY / mag
		else
			local playerCtrl = self.Entity.PlayerControllerComponent
			dirX = (isvalid(playerCtrl) and playerCtrl.LookDirectionX >= 0) and 1 or -1
			dirY = 0
		end
		self._T.pendingAvengerDirX = dirX

		local castRuid = "954896b2b40a4d8085586ea0ec2f0e19"
		local ballRuid = "0477b2c75e4b4fbcaf795e03bd8da11a"

		-- 기모으는 딜레이 동안 이동이 되지 않도록 컨트롤러를 잠근다 (파이어에로우/아이언에로우와 동일한
		-- 첫-시전-캡처 + 토큰 가드 패턴 - 홀드 지속발동 중에도 안전).
		local playerCtrl = self.Entity.PlayerControllerComponent
		if not self._T.isAvengerMovementLocked then
			self._T.pendingAvengerWasControllerEnabled = isvalid(playerCtrl) and playerCtrl.Enable
			self._T.isAvengerMovementLocked = true
		end
		if isvalid(playerCtrl) then
			playerCtrl.Enable = false
		end
		if isvalid(self.Entity.MovementComponent) then
			self.Entity.MovementComponent:Stop()
		end
		self._T.avengerMoveLockToken = (self._T.avengerMoveLockToken or 0) + 1
		local myMoveLockToken = self._T.avengerMoveLockToken

		-- 순수 상하 방향(dirX==0)은 캐릭터가 원래 보던 좌우 방향을 그대로 유지한다.
		local horizDirX
		if dirX ~= 0 then
			horizDirX = (dirX > 0) and 1 or -1
		else
			horizDirX = (isvalid(playerCtrl) and playerCtrl.LookDirectionX >= 0) and 1 or -1
		end

		-- 몸쪽 이펙트(14프레임 차지 모션) 재생 + 럭키세븐과 동일한 모션(swingO1/O2/O3 순환). 이펙트가
		-- 끝나는 시점(0.6*mult)에서 0.2*mult 더 기다린 뒤 투사체를 발사한다("이펙트가 끝나고 0.2초 뒤
		-- 투사체가 날아가야 한다"는 요청).
		self:PlayAvengerCastEffect(self.Entity, castRuid, horizDirX)
		local swing = self:GetAvengerSwing()
		-- (기능 수정) "방향키를 누르면서 스킬을 써도 모션이 안 끊기게 해달라"는 요청 - 스킬 시전과 같은
		-- 프레임에 모션을 보내면 이동 입력으로 인한 상태변경 이벤트와 경합해 스윙 모션이 씹힐 수 있다.
		-- 0.15초 늦춰서 보내면(사용자 권장값) 그 사이 이동 관련 상태변경이 먼저 정리되어 안전하다.
		_TimerService:SetTimerOnce(function()
			self:PlayAvengerMotion(self.Entity, swing.name, horizDirX, atkMultiplier)
		end, 0.15)
		local fireDelay = (0.6 + 0.2) * atkMultiplier
		_TimerService:SetTimerOnce(function()
			self:SpawnAvengerProjectile(ballRuid, combatPower, dirX, dirY)
		end, fireDelay)
		-- 이동 잠금은 모션 재생 시간이 아니라 스킬 재사용 대기시간(SkillManager의 0.85*atkMultiplier 쿨다운)과
		-- 동일하게 끝까지 유지한다 - 투사체 발사 시점(fireDelay=0.8*mult)보다 늦어야 하므로 0.75가 아닌 0.85로 맞춘다.
		_TimerService:SetTimerOnce(function()
			self:RestoreAvengerControl(myMoveLockToken)
		end, 0.85 * atkMultiplier)
	end

	method table GetAvengerSwing()
		-- (기능 수정) "모션을 럭키세븐하고 같아야 한다"는 요청 - 럭키세븐의 GetLuckySevenSwing과
		-- 동일한 후보군(swingO1/O2/O3, 한손무기 계열)을 매 시전마다 순차 순환시킨다. 인덱스는 럭키세븐과
		-- 섞이지 않도록 어벤져 전용 필드(avengerSwingIndex)로 별도 관리한다.
		local candidates = {
			{ name = "swingO1" },
			{ name = "swingO2" },
			{ name = "swingO3" },
		}
		self._T.avengerSwingIndex = (self._T.avengerSwingIndex or 0) % #candidates + 1
		return candidates[self._T.avengerSwingIndex]
	end

	@ExecSpace("Multicast")
	method void PlayAvengerMotion(Entity attacker, string motionName, number dirX, number atkMultiplier)
		-- 어벤져 전용 모션 재생. 파이어에로우/아이언에로우와 동일한 방식 - 별도 플래그로 서로 간섭하지 않는다.
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		local avatarRenderer = attacker.AvatarRendererComponent
		if not isvalid(avatarRenderer) then return end
		local body = avatarRenderer:GetBodyEntity()
		if not isvalid(body) then return end

		avatarRenderer.ShowDefaultWeaponEffects = false

		local playerCtrl = attacker.PlayerControllerComponent
		if isvalid(attacker.MovementComponent) then
			attacker.MovementComponent:Stop()
		end
		if isvalid(playerCtrl) then
			playerCtrl.LookDirectionX = dirX
		end
		self._T.isAvengerDirectionLocked = true
		self._T.lockedAvengerDirX = dirX
		self._T.lockedAvengerMotionName = motionName
		self._T.isAvengerMotionPlaying = true
		self._T.avengerLockToken = (self._T.avengerLockToken or 0) + 1
		local myAvengerLockToken = self._T.avengerLockToken

		local mult = math.max(atkMultiplier or 1.0, 0.001)
		-- (기능 수정) "방향키를 누르면서 쓰다 보니 모션이 자주 끊긴다 - 캐릭터 모션을 1.3배 오래 걸리게
		-- 해달라"는 요청 - playRate를 1.3으로 나눠 재생 시간을 1.3배 늘린다.
		local playRate = 1.0 / mult / 1.3
		self._T.lockedAvengerPlayRate = playRate

		local motionEvent = ActionStateChangedEvent(motionName, motionName, playRate, SpriteAnimClipPlayType.Onetime)
		body:SendEvent(motionEvent)
		log("[Avenger] PlayAvengerMotion sent: " .. tostring(motionName) .. " playRate=" .. tostring(playRate))

		-- 모션 재생 자체(포즈 유지)는 투사체가 발사되는 시점((0.6+0.2)*mult, 기모으는 딜레이와 동일하게
		-- 맞춤)에 끝나지만, 이동 잠금(방향 고정)은 스킬 재사용 대기시간 전체(0.85*mult, SkillManager
		-- 쿨다운과 동일)까지 유지한다.
		_TimerService:SetTimerOnce(function()
			if isvalid(avatarRenderer) then
				avatarRenderer.ShowDefaultWeaponEffects = true
			end
			self._T.isAvengerMotionPlaying = false
		end, (0.6 + 0.2) * mult)

		_TimerService:SetTimerOnce(function()
			if self._T.avengerLockToken ~= myAvengerLockToken then return end
			self._T.isAvengerDirectionLocked = false
			local sc = self.Entity.StateComponent
			if isvalid(sc) and sc.CurrentStateName ~= "DEAD" then
				sc:ChangeState("IDLE")
				sc:ChangeState("MOVE")
				sc:ChangeState("IDLE")
			end
		end, 0.85 * mult)
	end

	@ExecSpace("Server")
	method void RestoreAvengerControl(integer moveLockToken)
		-- 기모으는 딜레이가 끝나 투사체가 발사된 직후 컨트롤러를 되돌린다. 홀드 지속발동으로 더 최근 시전이
		-- 이미 다시 잠가둔 상태라면(토큰 불일치) 여기서 섣불리 풀지 않는다.
		if self._T.avengerMoveLockToken ~= moveLockToken then return end
		self._T.isAvengerMovementLocked = false
		local playerCtrl = self.Entity.PlayerControllerComponent
		if isvalid(playerCtrl) and self._T.pendingAvengerWasControllerEnabled then
			playerCtrl.Enable = true
		end
		-- (기능 추가) "다른 스킬들을 사용하고 난 다음도 모두 숨고르기 모션을 3번 하도록 해달라"는 요청 -
		-- 컨트롤이 복구된 이 시점에 공용 숨고르기(PlayBreather)를 시작한다.
		self:PlayBreather(self.Entity, self._T.pendingAvengerDirX or 1)
	end

	@ExecSpace("ServerOnly")
	method void SpawnAvengerProjectile(string ballRuid, number combatPower, number dirX, number dirY)
		local map = self.Entity.CurrentMap
		if not isvalid(map) then return end
		self._T.avengerCount = (self._T.avengerCount or 0) + 1
		local name = "avenger_" .. tostring(self.Entity.Name) .. "_" .. tostring(self._T.avengerCount)
		-- 발쪽(원점)이 아니라 몸통 중심 높이에서 날아가도록 y를 올린다 (다른 화살류 스킬과 동일한 body-center 기준값 0.35).
		-- (기능 수정) "투사체의 y값을 원상복귀해달라"는 요청 - 낮추는 대신 이펙트(954896b2...) 쪽만 내린다.
		local myPos = self.Entity.TransformComponent.WorldPosition
		local proj = _SpawnService:SpawnByModelId("avengerprojectile", name, Vector3(myPos.x, myPos.y + 0.35, myPos.z), map)
		if not isvalid(proj) then
			log_warning("[PlayerAttack] Avenger 투사체 스폰 실패")
			return
		end

		local sprite = proj.SpriteRendererComponent
		if isvalid(sprite) then
			sprite.SpriteRUID = ballRuid
		end

		---@type AvengerProjectile
		local projComp = proj:GetComponent("script.AvengerProjectile")
		if isvalid(projComp) then
			projComp.CombatPower = combatPower
			projComp.CritRate = self._T.currentCritRatePercent or 50
			-- 쉐도우 파트너 활성 여부를 원본 투사체에 새겨둔다 - 히트 시 원본+보너스(타수 2배) 합산과 2줄 표시에 쓰인다.
			projComp.ShadowEchoOn = self._T.shadowPartnerActive == true
			-- 지금 적용 중인 데미지 스킨(블리자드 중이면 얼음 스킨)을 발사체에 새겨준다 - 수동 표시에 쓰인다.
			projComp.DamageSkinRUID = self:GetHitDamageSkinId()
			projComp:Fire(dirX, dirY)
		end

		self:SpawnShadowEchoArrowProjectile("avengerprojectile", "script.AvengerProjectile", ballRuid, Vector3(myPos.x, myPos.y + 0.35, myPos.z), dirX, dirY, combatPower)
	end

	@ExecSpace("Multicast")
	method void PlayAvengerCastEffect(Entity attacker, string effectRuid, number dirX)
		-- 사용자 몸 쪽에서 1회 재생되는 시전(차지) 이펙트 + 사운드. (기능 수정) "954896b2...의 값을
		-- 내려야 한다"는 요청 - 기존 0.15보다 더 내려 0.0(몸통 중심)으로 맞춘다. 회전/방향별 오프셋
		-- 없이 항상 같은 고정 위치에서 좌우 반전만 적용한다.
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		-- (기능 수정) "954896b2...를 1.3배 빨리 진행해달라"는 요청 - PlayRate 옵션으로 이펙트 재생 속도를 올린다.
		local castOptions = { ["FlipX"] = dirX > 0, ["PlayRate"] = 1.3 }
		local serial = _EffectService:PlayEffectAttached(effectRuid, attacker, Vector3(0, 0.0, 0), 0, Vector3(1, 1, 1), false, castOptions)
		-- 쉐도우 파트너: 같은 시전 이펙트를 x축 뒤쪽에서 투명도 70%로 복제 재생(그림자 몫 - 데미지 없음)
		local echoSerial = self:EchoShadowSkillEffectAttached(effectRuid, attacker, Vector3(0, 0.0, 0), 0, Vector3(1, 1, 1), castOptions, dirX)
		-- (기능 추가) "사용시 사운드입니다" 요청 - 스킬 사용 시점에 1회 재생.
		_SoundService:PlaySound("28d565bf11b242f8b55b05c1fe252b69", 1.0)
		_TimerService:SetTimerOnce(function()
			_EffectService:RemoveEffect(serial)
			if echoSerial ~= 0 then
				_EffectService:RemoveEffect(echoSerial)
			end
		end, 1.0)
	end

	-- 어썰터 전용 판정 범위(전방위) 안의 살아있는 script.Monster 중 가장 가까운 하나를 찾는다.
	-- 범위는 드래곤 로어(가로 15.0, 세로 7.5)의 1/5(가로 3.0, 세로 1.5) - 사용자 요청.
	-- (기능 수정) "사거리를 전방으로만 하고 3배 늘려달라"는 요청 - 기존 전방위 판정(가로 3.0/세로 1.5)을
	-- 캐릭터가 바라보는 방향(dirX) 전방으로만 판정하도록 바꾸고 3배(가로 9.0/세로 4.5)로 늘린다.
	method Entity FindAssaulterTarget(Vector2 fromPos, number dirX)
		local map = self.Entity.CurrentMap
		if not isvalid(map) then return nil end
		local monsterComps = map:GetChildComponentsByTypeName("script.Monster", true)
		local nearest = nil
		local nearestDist = 999999
		-- (기능 수정) "위아래 사거리를 2.0으로 해달라"는 요청 - 세로 판정을 2.0으로 늘린다(가로는 그대로).
		local xReach = 9.0
		local yHalfHeight = 2.0
		for _, comp in ipairs(monsterComps) do
			---@type Monster
			local mc = comp
			if isvalid(mc) and isvalid(mc.Entity) and not mc.IsDead then
				local pos = mc.Entity.TransformComponent.WorldPosition
				local dx = pos.x - fromPos.x
				local dy = pos.y - fromPos.y
				if dx * dirX >= 0 and math.abs(dx) <= xReach and math.abs(dy) <= yHalfHeight then
					local dist = math.sqrt(dx * dx + dy * dy)
					if dist < nearestDist then
						nearestDist = dist
						nearest = mc.Entity
					end
				end
			end
		end
		return nearest
	end

	@ExecSpace("ServerOnly")
	method void AttackAssaulter(number combatPower)
		-- 어썰터: 캐릭터가 사라졌다가 0.25초 뒤 가장 가까운 적을 통과한 뒤쪽(진행 방향으로 더 나아간 자리)에
		-- 나타나며 그 적과 주변 적들(최대 6명)을 찌른다. 사라지는 자리에 78ea5621...(대상이 왼쪽=그대로/오른쪽=반전),
		-- 나타나는 자리에서 손을 바닥에 짚는 착지 모션(prone) + 맞은 대상들 위치마다 흑백톤 히트 이펙트(5fd114...)를 재생한다.
		self:StopBreather()
		local currentState = self.Entity.StateComponent.CurrentStateName
		if currentState == "DEAD" or currentState == "CLIMB" or currentState == "LADDER" then
			return
		end
		if self._T.isAssaulting then
			log("PlayerAttack: AttackAssaulter 요청 차단됨(이미 진행 중)")
			return
		end

		local worldPos = self.Entity.TransformComponent.WorldPosition
		local originPos = Vector2(worldPos.x, worldPos.y)
		local playerCtrl0 = self.Entity.PlayerControllerComponent
		local facingDirX = (isvalid(playerCtrl0) and playerCtrl0.LookDirectionX >= 0) and 1 or -1
		local target = self:FindAssaulterTarget(originPos, facingDirX)
		local userId = self.Entity.PlayerComponent.UserId
		if target == nil then
			log("PlayerAttack: AttackAssaulter 실패 - 사거리 내 대상 없음")
			-- (기능 추가) "범위 내 타겟이 없으면 사용이 되지 않아야 한다"는 요청 - 클라이언트에 실패를
			-- 알려 쿨타임이 소모되지 않도록 한다.
			self:NotifyAssaulterResult(false, userId)
			return
		end
		self:NotifyAssaulterResult(true, userId)

		self._T.isAssaulting = true
		self._T.pendingAssaulterCombatPower = combatPower
		-- 시전 세대 번호 - 연속 시전 시 이전 시전의 컨트롤 복구 타이머(0.5초)가 새 시전 도중에
		-- 끼어들어 컨트롤을 되살리지 않도록 구분하는 용도.
		self._T.assaulterCastSerial = (self._T.assaulterCastSerial or 0) + 1

		local targetPos = target.TransformComponent.WorldPosition
		local dirX = (targetPos.x >= originPos.x) and 1 or -1
		self._T.pendingAssaulterTarget = target
		self._T.pendingAssaulterDirX = dirX

		local playerCtrl = self.Entity.PlayerControllerComponent
		-- (버그 방지) 연속 시전(체인) 중에는 직전 시전이 이미 컨트롤을 꺼둔 상태(Enable=false)라
		-- 그대로 캡처하면 마지막 복구 때 컨트롤이 영영 안 살아난다 - 체인의 첫 시전에서 캡처한
		-- 원래 값을 유지한다.
		if not self._T.assaulterControlSuppressed then
			self._T.pendingAssaulterWasControllerEnabled = isvalid(playerCtrl) and playerCtrl.Enable
			self._T.assaulterControlSuppressed = true
		end
		if isvalid(playerCtrl) then
			playerCtrl.Enable = false
		end
		if isvalid(self.Entity.MovementComponent) then
			self.Entity.MovementComponent:Stop()
		end

		self:PlayAssaulterVanishEffect(self.Entity, Vector3(originPos.x, originPos.y, 0), dirX)

		-- (기능 수정) "0.5초 뒤 나타나면서 데미지를 주던 것을 0.25초로 바꿔달라"는 요청.
		_TimerService:SetTimerOnce(function()
			self:ReappearAssaulter()
		end, 0.25)
	end

	@ExecSpace("Client")
	method void NotifyAssaulterResult(boolean success)
		-- 어썰터 발동 성공/실패를 시전한 클라이언트에게만 알려, 실패 시(사거리 내 대상 없음) 스택/쿨타임
		-- UI가 소모되지 않도록 SkillManager에 전달한다.
		_SkillManager:OnAssaulterResult(success)
	end

	@ExecSpace("Client")
	method void NotifyAssaulterChainReady()
		-- 착지(순간이동 완료) 시점을 시전한 클라이언트에게만 알린다 - 어썰터만은 착지 즉시 딜레이 없이
		-- 연속 시전할 수 있게 하기 위한 신호 (SkillManager.OnAssaulterChainReady에서 잠금 해제).
		_SkillManager:OnAssaulterChainReady()
	end

	@ExecSpace("Multicast")
	method void PlayAssaulterVanishEffect(Entity attacker, Vector3 originPos, number dirX)
		-- 사라지는 연출: 아바타를 투명화하고, 원래 있던 자리에 78ea5621...을 1회 재생한다.
		-- 대상이 왼쪽에 있으면(dirX<0) 그대로, 오른쪽에 있으면(dirX>0) 좌우 반전.
		-- (기능 수정) "시작이펙트는 이동 후에도 캐릭터를 따라오지 말고 이동한 그 자리에 남아야 한다"는
		-- 요청 - 캐릭터에 부착(PlayEffectAttached)하면 순간이동할 때 이펙트도 같이 딸려가버리므로,
		-- 캐릭터가 사라지기 직전의 월드 좌표에 고정 재생(PlayEffect)한다.
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		-- (기능 추가) "스킬 사용 즉시 사운드"를 넣어달라는 요청 - 도착 사운드와 별개로, 시전 시작 시점에
		-- 1회만 재생한다(쉐도우 파트너 에코는 없음 - 다른 즉시발동 캐스트 사운드들과 동일한 패턴).
		_SoundService:PlaySound("3cc6e9d3ad6b41fbbe2a6ab17b364b94", 1.0)
		local avatarRenderer = attacker.AvatarRendererComponent
		if isvalid(avatarRenderer) then
			avatarRenderer:SetAlpha(0, nil)
		end
		local options = { ["FlipX"] = dirX > 0 }
		local serial = _EffectService:PlayEffect("78ea5621bb574c8d8d7f84848262014d", attacker, originPos, 0, Vector3(1, 1, 1), false, options)
		-- 쉐도우 파트너: 사라지는 이펙트도 x축 뒤쪽에서 투명도 70%로 복제 재생(그림자 몫) - 이것도 고정 좌표 버전을 쓴다.
		local echoSerial = self:EchoShadowSkillEffect("78ea5621bb574c8d8d7f84848262014d", originPos, 0, Vector3(1, 1, 1), options, dirX)
		_TimerService:SetTimerOnce(function()
			_EffectService:RemoveEffect(serial)
			if echoSerial ~= 0 then
				_EffectService:RemoveEffect(echoSerial)
			end
		end, 1.0)
	end

	@ExecSpace("Server")
	method void ReappearAssaulter()
		-- 0.25초 뒤 실제로 대상 뒤(진행 방향으로 더 나아간 자리)에 순간이동해 나타난다.
		local target = self._T.pendingAssaulterTarget
		local dirX = self._T.pendingAssaulterDirX or 1

		if not isvalid(target) then
			-- 대기하는 사이 대상이 죽거나 사라졌다면: 원래 자리에서 그냥 다시 나타난다.
			self:PlayAssaulterReappearEffects(self.Entity)
			self:RestoreAssaulterControl()
			self:NotifyAssaulterChainReady(self.Entity.PlayerComponent.UserId)
			return
		end

		local rb = self.Entity.RigidbodyComponent
		local map = self.Entity.CurrentMap
		if isvalid(rb) and isvalid(map) then
			local fh = map.FootholdComponent
			-- (기능 수정) "몬스터 뒤로 이동한 뒤 너무 가깝다 - 조금 더 이동시켜달라"는 요청 - 0.6 → 1.0.
			local targetPos = target.TransformComponent.WorldPosition
			local BEHIND_OFFSET = 1.0
			local landX = targetPos.x + dirX * BEHIND_OFFSET
			local landY = targetPos.y
			if isvalid(fh) then
				local nearFh = self:FindNearbyFootholdAtX(fh, landX, targetPos.y, 1.2)
				if nearFh ~= nil then
					landY = nearFh:GetYByX(landX) + 0.05
				end
			end
			if isvalid(self.Entity.MovementComponent) then
				self.Entity.MovementComponent:Stop()
			end
			rb:SetWorldPosition(Vector2(landX, landY))
		end

		local playerCtrl = self.Entity.PlayerControllerComponent
		if isvalid(playerCtrl) then
			-- (기능 수정) "이동 후 보는 방향을 바꾸지 말고 그대로 보게 해달라"는 요청 - 기존에는 착지 후
			-- 대상 쪽(-dirX)으로 돌아봤지만, 이제 이동(진행) 방향(dirX)을 그대로 유지한다.
			playerCtrl.LookDirectionX = dirX
		end

		self:PlayAssaulterReappearEffects(self.Entity)

		-- (기능 추가) "대상 주변 적들도 최대 6명까지 데미지를 입히면서 히트이펙트를 달아달라"는 요청 -
		-- 썬더볼트와 동일한 패턴(위치 기반 탐색 후 동시 타격)으로, 착지한 대상의 위치를 중심으로 근처
		-- 적을 가까운 순으로 최대 6명까지 찾는다(주 대상 자신도 거리 0으로 포함됨).
		local targetPos = target.TransformComponent.WorldPosition
		local splashTargets = self:FindAssaulterSplashTargets(Vector2(targetPos.x, targetPos.y), 6)
		self:DealAssaulterHits(splashTargets)

		-- (기능 변경) 착지 즉시 어썰터만은 딜레이 없이 연속 시전할 수 있게 한다 (요청사항) -
		-- isAssaulting을 여기서 바로 풀고 시전한 클라이언트에 착지를 알린다(OnAssaulterChainReady).
		-- 이동/다른 스킬용 컨트롤 복구는 기존대로 0.5초 뒤 진행하되, 그 사이 새 어썰터 시전이
		-- 시작됐다면(세대 번호 불일치) 복구를 건너뛰어 새 시전을 방해하지 않는다.
		self._T.isAssaulting = false
		self:NotifyAssaulterChainReady(self.Entity.PlayerComponent.UserId)
		local mySerial = self._T.assaulterCastSerial
		_TimerService:SetTimerOnce(function()
			if self._T.assaulterCastSerial == mySerial then
				self:RestoreAssaulterControl()
			end
		end, 0.5)
	end

	-- 어썰터 착지 지점 주변의 살아있는 script.Monster를 가까운 순으로 최대 maxCount명까지 반환한다
	-- (썬더볼트의 FindThunderboltTargets와 동일한 구조 - 방향 무관, 위치 기반 박스 탐색).
	method table FindAssaulterSplashTargets(Vector2 fromPos, integer maxCount)
		local map = self.Entity.CurrentMap
		if not isvalid(map) then return {} end
		local monsterComps = map:GetChildComponentsByTypeName("script.Monster", true)
		local candidates = {}
		for _, comp in ipairs(monsterComps) do
			---@type Monster
			local mc = comp
			if isvalid(mc) and isvalid(mc.Entity) and not mc.IsDead then
				local pos = mc.Entity.TransformComponent.WorldPosition
				local dx = pos.x - fromPos.x
				local dy = pos.y - fromPos.y
				if math.abs(dx) <= 2.0 and math.abs(dy) <= 1.5 then
					table.insert(candidates, { entity = mc.Entity, dist = math.sqrt(dx * dx + dy * dy) })
				end
			end
		end
		table.sort(candidates, function(a, b) return a.dist < b.dist end)
		local result = {}
		for i = 1, math.min(#candidates, maxCount) do
			table.insert(result, candidates[i].entity)
		end
		return result
	end

	@ExecSpace("Multicast")
	method void PlayAssaulterReappearEffects(Entity attacker)
		-- 나타나는 연출: 아바타를 다시 보이게 하고, swingO1 모션의 마지막 프레임(사진 속 자세 - 찌르듯
		-- 내지르는 동작의 끝 포즈)만 2초간 고정해서 보여준 뒤 원래 자세(stand1)로 복귀한다 + 도착 사운드
		-- (bbb8c45c...)를 재생한다. 맞은 대상들 각각의 히트 이펙트는 PlayAssaulterHitEffect에서 대상별로
		-- 따로 재생한다(요청: "대상 주변 적들도 최대 6명까지 데미지+히트이펙트").
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		-- 연속 시전(체인) 시 이전 시전의 stand1 복귀 타이머가 새 시전의 끝 포즈를 중간에 덮어쓰지
		-- 않도록 세대 번호로 구분한다.
		self._T.assaulterMotionSerial = (self._T.assaulterMotionSerial or 0) + 1
		local motionSerial = self._T.assaulterMotionSerial
		_SoundService:PlaySound("bbb8c45c0d21491a97deb363a9d95e0c", 1.0)
		local avatarRenderer = attacker.AvatarRendererComponent
		if isvalid(avatarRenderer) then
			avatarRenderer:SetAlpha(1, nil)
			-- (버그 수정) "이동 후 착지 모션이 없다" - 순간이동 직후 같은 프레임에 모션을 보내면 텔레포트로
			-- 인한 위치 갱신(및 그로 인한 일시적 FALL 상태 전환)이 곧바로 이 one-shot 모션을 덮어써버리는
			-- 것으로 보인다. 위치가 안정된 뒤 보내도록 짧게 지연한다(0.1초).
			_TimerService:SetTimerOnce(function()
				if not isvalid(attacker) then return end
				local body = avatarRenderer:GetBodyEntity()
				if isvalid(body) then
					-- StartFrameIndex/EndFrameIndex에 총 프레임 수를 초과하는 큰 값을 넣으면 엔진이 실제
					-- 마지막 프레임 값으로 자동 보정한다(공식 문서 명시) - 두 값을 동일하게 최대치로 주면
					-- swingO1 애니메이션의 "끝 프레임 한 장"만 정지된 상태로 보여줄 수 있다.
					local motionEvent = ActionStateChangedEvent("swingO1", "swingO1", 1.0, SpriteAnimClipPlayType.Onetime, 2147483647, 2147483647)
					body:SendEvent(motionEvent)
				end
			end, 0.1)
			-- (기능 수정) "끝 모션의 길이를 1초 늘려달라"는 요청 - 1초 → 2초 고정 후 stand1로 복귀한다.
			_TimerService:SetTimerOnce(function()
				if not isvalid(attacker) then return end
				if self._T.assaulterMotionSerial ~= motionSerial then return end
				local body = avatarRenderer:GetBodyEntity()
				if isvalid(body) then
					local resetEvent = ActionStateChangedEvent("stand1", "stand1", 1.0, SpriteAnimClipPlayType.Loop)
					body:SendEvent(resetEvent)
				end
			end, 2.1)
		end
	end

	@ExecSpace("Multicast")
	method void PlayAssaulterHitEffect(Entity target)
		-- 맞은 대상 한 명의 자리에 흑백톤(어둡게 틴트한) 히트 이펙트(5fd114...)를 재생한다 - 주 대상/주변
		-- 적 모두 동일하게 대상마다 따로 호출된다.
		if not self:IsClient() then return end
		if not isvalid(target) then return end
		-- 검은색/회색 느낌으로 어둡게 틴트.
		local hitOptions = { ["Color"] = Color(0.2, 0.2, 0.2, 1.0) }
		-- (기능 수정) "y값을 조금 위로 올려달라"는 요청 - 0 -> 0.3.
		local serial = _EffectService:PlayEffectAttached("5fd114c93ac7453e9b54e228f2c62064", target, Vector3(0, 0.3, 0), 0, Vector3(1, 1, 1), false, hitOptions)
		-- 쉐도우 파트너: 같은 히트 이펙트를 시간차를 두고 그 자리에 한 번 더(70% 투명도) 재생.
		self:EchoShadowHitEffect("5fd114c93ac7453e9b54e228f2c62064", target, Vector3(0, 0.3, 0), 0, Vector3(1, 1, 1), hitOptions)
		_TimerService:SetTimerOnce(function()
			_EffectService:RemoveEffect(serial)
		end, 1.0)
	end

	@ExecSpace("ServerOnly")
	method void DealAssaulterHits(table targets)
		-- 예약된 대상 전원(주 대상 + 주변 최대 6명)에게 같은 프레임 안에서 동시에 타격 판정과 이펙트를
		-- 발생시킨다 (썬더볼트의 DealThunderboltHits와 동일한 구조).
		if not isvalid(self.Entity) then return end
		local hitCount = 0
		for _, target in ipairs(targets) do
			if isvalid(target) then
				-- 이번 Attack() 호출은 이 대상 하나만 통과하도록 지정 (몬스터 밀집 지역에서 이웃까지
				-- 겹쳐 중복 피해가 들어가는 것을 방지 - IsAttackTarget의 assaulterCurrentTarget 체크 참고).
				self._T.assaulterCurrentTarget = target
				local pos = target.TransformComponent.WorldPosition
				local shape = CircleShape(Vector2(pos.x, pos.y), 0.6)
				local hitComps = self:AttackShadowSafe(shape, "skill.assaulter", target)
				local actuallyHit = false
				for _, hc in ipairs(hitComps) do
					if isvalid(hc) and isvalid(hc.Entity) and hc.Entity == target then
						actuallyHit = true
						break
					end
				end
				-- (기능 추가) "코마처럼 몬스터를 3초간 행동불능 상태로 만들고 b0bd80f44c...를 스턴 동안 띄워달라"는 요청 -
				-- 주 대상뿐 아니라 이번에 맞은 주변 적 전원에게 동일하게 적용한다.
				if actuallyHit then
					self:PlayAssaulterHitEffect(target)
					self:PlayAssaulterStunEffect(target)
					self:ApplyAssaulterStun(target)
					hitCount = hitCount + 1
				end
			end
		end
		log("PlayerAttack: AttackAssaulter " .. tostring(#targets) .. "명 동시 타격, 실제 명중 " .. tostring(hitCount) .. "명")
	end

	@ExecSpace("ServerOnly")
	method void ApplyAssaulterStun(Entity target)
		-- 코마의 ApplyComaStun과 동일한 방식 - 몬스터 AI 추적/이동을 3초간 완전히 꺼서 행동불능으로 만든다.
		if not isvalid(target) then return end
		local aiChase = target.AIChaseComponent
		local wasAIEnabled = isvalid(aiChase) and aiChase.Enable
		if isvalid(aiChase) then
			aiChase.Enable = false
		end
		local movement = target.MovementComponent
		local wasMovementEnabled = isvalid(movement) and movement.Enable
		if isvalid(movement) then
			movement:Stop()
			movement.Enable = false
		end
		_TimerService:SetTimerOnce(function()
			if isvalid(target) and isvalid(aiChase) and wasAIEnabled then
				aiChase.Enable = true
			end
			if isvalid(target) and isvalid(movement) and wasMovementEnabled then
				movement.Enable = true
			end
		end, 3.0)
	end

	@ExecSpace("Multicast")
	method void PlayAssaulterStunEffect(Entity target)
		-- 코마의 PlayComaStunEffect와 동일한 방식 - 대상 머리 위에 3초간 스턴 표시 이펙트(b0bd80f4...)를 띄운다.
		if not self:IsClient() then return end
		if not isvalid(target) then return end
		local headY = 0.5
		local hit = target.HitComponent
		if isvalid(hit) then
			headY = hit.ColliderOffset.y + hit.BoxSize.y / 2
		end
		local serial = _EffectService:PlayEffectAttached("b0bd80f44c1543438ddf8c2c31a0a7ce", target, Vector3(0, headY, 0), 0, Vector3(1, 1, 1), true, {})
		_TimerService:SetTimerOnce(function()
			_EffectService:RemoveEffect(serial)
		end, 3.0)
	end

	@ExecSpace("Server")
	method void RestoreAssaulterControl()
		-- 착지 모션까지 끝난 뒤 컨트롤을 복구한다. 체인(연속 시전)의 마지막 복구 시점에만 호출되며,
		-- 다음 시전이 원래 컨트롤 값을 새로 캡처할 수 있도록 억제 플래그도 함께 푼다.
		self._T.isAssaulting = false
		self._T.assaulterControlSuppressed = false
		local playerCtrl = self.Entity.PlayerControllerComponent
		if isvalid(playerCtrl) and self._T.pendingAssaulterWasControllerEnabled then
			playerCtrl.Enable = true
		end
	end

	@ExecSpace("ServerOnly")
	method void AttackSpearBurst(number combatPower, number atkMultiplier, boolean enhanced)
		-- (기능 추가) "다른 스킬을 쓰면 숨고르기 모션은 중지" 요청 - 이 스킬을 새로 시전하는 시점에 이전 숨고르기가 재생 중이었다면 즉시 정리한다.
		self:StopBreather()
		-- 스피어 버스터: 타격감을 위해 "3번 찌르는" 스킬로 재설계한다(더블스탭과 동일하게 대상
		-- 하나당 실제 판정을 3회 진행) - 찌르기 자세 모션(시전 즉시) + 찌르는 이펙트 3종(852883a5→
		-- 3c2ee6e6→521bf9f6) + 고정해둔 대상 전원에 대한 실제 데미지 판정(DealSpearBurstStabWave,
		-- 데미지 표시 3줄 + 피격 이펙트 84c06a06 + 몬스터 피격음)은 스킬 사용 damageStartDelay=0.7s
		-- 뒤 + 0.1s/0.2s*mult에 진행되고, 찌르는 이펙트 3종은 그와 별개로 스킬 사용 즉시
		-- (effectStartDelay=0.0s) + 0.1s/0.2s*mult에 진행된다(요청: "852883a5 등 3종 찌르기 이펙트를
		-- 스킬 사용 즉시 보여주는 걸로 우선"). → 3타 판정 이후 여유를 두고 컨트롤 복구.
		-- 모든 리소스는 왼쪽을 보는 기준으로 제작돼, 오른쪽을 보고 있으면(dirX>0) 좌우 반전(FlipX) +
		-- 위치 반전이 필요하다.
		local currentState = self.Entity.StateComponent.CurrentStateName
		if currentState == "DEAD" or currentState == "CLIMB" or currentState == "LADDER" then
			return
		end
		if self._T.isSpearBursting then
			log("PlayerAttack: AttackSpearBurst 요청 차단됨(이미 진행 중)")
			return
		end
		self._T.isSpearBursting = true
		self._T.pendingSpearBurstCombatPower = combatPower
		-- (4차 패시브) 어드밴스드 스피어 버스터 보유 여부. 이펙트 색(검정/하양/빨강 조화)에 쓰인다.
		-- 데미지 1.5배는 SkillManager가 combatPower를 미리 1.5배로 올려 넘기므로 여기선 색상용으로만 보관.
		self._T.spearBurstEnhanced = (enhanced == true)

		local mult = math.max(atkMultiplier or 1.0, 0.001)
		local playerCtrl = self.Entity.PlayerControllerComponent
		local dirX = isvalid(playerCtrl) and playerCtrl.LookDirectionX or 1
		self._T.pendingSpearBurstDirX = dirX
		self._T.pendingSpearBurstWasControllerEnabled = isvalid(playerCtrl) and playerCtrl.Enable
		if isvalid(playerCtrl) then
			playerCtrl.Enable = false
		end
		if isvalid(self.Entity.MovementComponent) then
			self.Entity.MovementComponent:Stop()
		end

		-- 대상을 시전 시작 시점에 한 번만 찾아 고정한다(더블스탭/럭키세븐과 동일한 방식) - 드래곤머리가
		-- 발사되는 1.1초 시점까지 몬스터가 다른 공격으로 죽어 후보에서 빠지는 것을 방지한다.
		-- (기능 추가) "전방 2.5·상하 1.2로 해달라"는 요청으로 스피어 버스터 전용 탐색 범위를 직접 지정한다.
		-- 슬래쉬블래스트 쪽 호출부는 기존 값(2.0/1.0)을 그대로 유지하므로 이 변경은 스피어 버스터에만 적용된다.
		local worldPos = self.Entity.TransformComponent.WorldPosition
		self._T.spearBurstLockedTargets = self:FindSlashBlastTargets(Vector2(worldPos.x, worldPos.y), dirX, 3, 2.5, 1.2)

		-- 날개 이펙트는 진짜 라이브 트윈이 가능한 전용 엔티티(SpearBurstFadingEffect)로 재생한다
		-- (PlayEffectAttached 재생-재생 반복 방식은 깜빡임을 완전히 없앨 수 없어 실측 확인됨).
		-- 캐릭터의 자식 엔티티로 스폰해(로컬 오프셋 좌표) 캐릭터가 움직여도 같이 따라오게 한다 -
		-- 이전에는 맵의 자식으로 스폰 시점 월드좌표에 고정돼, 캐릭터가 움직이면 이펙트만 그 자리에 남는
		-- 문제가 있었다. X는 등 쪽으로 살짝만 떨어지도록 바라보는 방향 반대쪽으로 오프셋(-0.2*dirX, 기존
		-- -0.4에서 캐릭터 쪽으로 더 붙임)을 주고, Y는 등/어깨보다 살짝 낮게(0.05) 내렸다. 존재 시간(hold+tween)은
		-- 기존 0.3+0.3(총 0.6초)에서 1.5배인 0.45+0.45(총 0.9초)로 늘렸다.
		-- (4차 패시브) 강화 시 날개도 전용 아트로 교체. 과거엔 원본 파랑→검정 재색본(d536d11c)이었으나
		-- 사용자가 새로 그린 "스피어버스터 강화" 전용 날개 아트(160x192, 중심피벗)로 대체한다.
		local wingRuid = (enhanced == true) and "8da209f377f249f292e1d0c50c928683" or "c7051cc242c54208a7c22df2b4bcc28e"
		-- (버그 수정) 날개 위치는 강화 여부에 따라 분리한다. 두 아트는 알파(실루엣)가 픽셀 단위로
		-- 완전히 동일한데(실측: 원본 프레임 48fefc50과 강화본 008.png의 알파 diff=0) 피벗이 달라서
		-- 같은 좌표에 두면 화면에서 어긋난다 - 원본 클립은 WZ 피벗(x=56, y=-3 / 160x192)이고 강화
		-- 아트는 asset 업로드 기본값인 중심피벗이다.
		-- (실측) 같은 로컬좌표(0,3)에 나란히 스폰해 화면 픽셀을 비교한 결과, 강화본이 원본보다
		-- 화면 기준 왼쪽 35px · 아래 139px에 그려졌다(맵 스케일 138.3px/월드유닛 → 월드 0.253 / 1.005).
		-- 아래 wingEnhOffsetX/Y가 정확히 그 차이를 되돌려 강화 날개가 원본 날개와 완전히 겹치게 한다.
		-- FlipX(dirX>0)일 때는 피벗 기준으로 좌우가 뒤집히므로 X 보정 부호도 dirX로 뒤집는다.
		-- (기능 추가) "원본 파란 날개가 캐릭터 머리 위로 떠 있다 - 유저 위치까지 내려달라"는 피드백:
		-- 원본 날개는 이미지 하단이 캐릭터 발밑(원점) 기준 +0.17, 상단이 +1.95라 몸통이 아니라 머리
		-- 위쪽에 떠 있었다. 기준 y를 0.05 → -0.65로 0.7만큼 내려 날개 이미지 중앙(높이 1.79)이
		-- 캐릭터 몸통 중앙(≈+0.36)에 오도록 맞췄고, 이어서 "조금 더 위로"(+0.25) → "0.5 더 위로"(+0.5)
		-- → "0.4로" → "0.1로" → 최종 "0으로" 피드백을 거쳐 0으로 정착했다(날개 하단이 발밑 +0.12,
		-- 상단 +1.90, 중앙 ≈+1.01). 강화 날개도 같은 기준에서 위 보정만 더한다.
		local wingBaseY = 0.0
		local wingEnhOffsetX = (enhanced == true) and (-0.253 * dirX) or 0
		local wingY = (enhanced == true) and (wingBaseY + 1.005) or wingBaseY
		-- (기능 추가) "날개를 캐릭터쪽으로 dx를 조금 붙여달라"는 피드백으로 등 쪽 오프셋을 0.2 → 0.1로
		-- 절반만큼 더 캐릭터에 붙였다(0.4 → 0.2에 이은 두 번째 조정). 강화 날개의 wingEnhOffsetX는
		-- 두 아트의 피벗 차이를 되돌리는 보정값이라 여기서 건드리지 않는다 - 이 기준 오프셋만 옮기면
		-- 원본/강화 날개가 계속 같은 위치에 겹친 채로 함께 이동한다.
		-- 아래 쉐도우 파트너 복제본도 같은 기준값을 써야 하므로 변수로 뽑아둔다.
		local wingBaseX = -0.1 * dirX
		self:SpawnSpearBurstFadingEffect(
			wingRuid, Vector2(wingBaseX + wingEnhOffsetX, wingY), dirX > 0,
			1.0, 1.0, 1.0, 0.0, 0.45, 0.45, -1, false, "", 0, 0, 0, 0
		)
		-- (버그 수정) "쉐도우 파트너가 스피어버스터의 날개 이펙트는 따라하지 않는다" - 이 날개 이펙트는
		-- 다른 스킬 이펙트들과 달리 EchoShadowSkillEffectAttached(찌르기 이펙트 3종 등이 쓰는 공용
		-- 그림자 복제 경로)를 거치지 않고 SpawnSpearBurstFadingEffect라는 전용 라이브 트윈 엔티티로
		-- 직접 재생되고 있어, 그림자 몫 복제 호출 자체가 빠져 있었다. 다른 그림자 복제 이펙트와 동일한
		-- 관례(x축 뒤쪽으로 추가 오프셋 -0.45*dirX, 투명도 70%)를 그대로 적용해 별도로 한 번 더 재생한다.
		if self._T.shadowPartnerActive then
			self:SpawnSpearBurstFadingEffect(
				wingRuid, Vector2(wingBaseX - 0.45 * dirX + wingEnhOffsetX, wingY), dirX > 0,
				1.0, 1.0, 0.7, 0.0, 0.45, 0.45, -1, false, "", 0, 0, 0, 0
			)
		end
		-- 몸쪽 마법진 이펙트(176da561...)도 전용 엔티티(SpawnSpearBurstFadingEffect)로 재생해 투명도 50%→0%로
		-- 서서히 사라지면서 살짝 커지는 라이브 트윈을 재현한다 - PlayEffectAttached로 한 번 바꿨었지만
		-- 그러면 이 트윈 자체가 불가능해서(정적 1회 재생만 지원) 되돌렸다.
		-- (실측 이력) orderInLayer -1~-20은 캐릭터보다 뒤로 가지 않고, -30은 세션에 따라 보였다 안 보였다
		-- 하는 불안정한 값, -40 이하는 지형보다도 뒤로 밀려 항상 안 보였다 - 그래서 한 번은 -20(캐릭터
		-- 기준으로는 딱히 뒤도 아니지만 항상 보이는 안전값)으로 고정했었다. 이번 피드백은 "다른 이펙트(날개,
		-- 찌르는 이펙트 3종)와 겹칠 때 마법진이 앞에 보여야 한다"는 것으로, 그 이펙트들은 PlayEffectAttached
		-- 기본값(OrderInLayer 0 근방)을 쓰므로 마법진을 그보다 높은 양수로 올려 확실히 앞에 오도록 한다.
		-- (버그 수정) "마법진이 2번 재생된다"는 진짜 원인을 찾았다 - 애니메이션클립(176da561...)의
		-- RUID를 SpriteRUID에 그대로 넣으면 world용 SpriteRendererComponent엔 재생 방식(Loop/Onetime)을
		-- 제어하는 프로퍼티 자체가 없어(UI용과 달리) 엔진이 프레임을 계속 반복 재생했다. 대신 그 클립의
		-- 개별 프레임 스프라이트(마법진=d757a7ca..., 용머리=7d52e3968f...)를 직접 교체하는 방식으로
		-- 바꿔 반복 없이 정확히 한 번만 전환되게 한다.
		-- (기능 추가) 투명도 85%, 크기 75%→160%, 전체 속도 1.5배(0.6초, 각 구간 0.3초)로 조정.
		-- (버그 수정) "확대될 때 중앙에서 퍼지지 않고 한쪽에서 잡아당기듯 커진다" - 두 스프라이트의
		-- Pivot이 이미지 중앙이 아니라 좌하단 쪽으로 치우쳐 있어서였다(msw-search 실측: 마법진 pivot
		-- nx=0.6724,ny=0.1638, 116x116 → 중심오프셋(-0.20,0.39); 용머리 pivot nx=0.625,ny=0.1917,
		-- 168x120 → 중심오프셋(-0.21,0.37)). SpawnSpearBurstFadingEffect의 pivotOffset 인자로 넘겨
		-- 매 프레임 그만큼 반대로 위치를 보정해 이미지 중심이 고정된 채 커지도록 한다.
		-- (기능 추가) "좀 더 몸쪽 캐릭터 쪽으로 이동" - localOffset을 (0,0)에서 (0,0.25)로 올려 몸통
		-- 높이 쪽으로 옮겼다(추가 피드백으로 0.15→0.25로 한 번 더 올림). 투명도는 85%→60%로 낮췄고,
		-- 2번째 구간(용머리)이 95%만큼 커진 시점부터 투명도를 0%로 서서히 낮추는 처리는
		-- SpearBurstFadingEffect.mlua의 UpdateSplitGrowth에서 담당한다(StartAlpha=0.6 기준으로 페이드).
		-- (기능 추가) "버튼을 누르고 0.15초 뒤에 재생돼야 한다"는 피드백으로 스폰 자체를 0.15초 지연시켰다
		-- (날개 이펙트(c7051cc2)는 그대로 즉시 재생 - 이 마법진 이펙트만 지연).
		-- (되돌림) "캐릭터보다 앞은 Z-order(OrderInLayer)가 아니라 X축 이동으로 해야 한다"는 피드백으로
		-- OrderInLayer는 10으로 되돌리고(찌르기 3종의 OrderInLayer도 11로 함께 되돌림), 대신 localOffset.x를
		-- 캐릭터가 바라보는 방향(dirX)으로 0.2만큼 옮겨 앞쪽으로 이동시켰다.
		-- (기능 추가) "이펙트 속도를 50% 더 늘려달라(더 빠르게 커지고 더 빠르게 사라지도록)"는 피드백으로
		-- 전체 길이를 0.8→0.8/1.5초(≈0.533초)로 줄였다(1.5배 빠름).
		-- (기능 추가) "최대치를 10% 더 늘려달라"는 피드백으로 EndScale을 1.6→1.76(1.6*1.1)로 올렸다.
		-- (기능 추가) "Y축을 더 올려달라"는 피드백으로 localOffset.y를 0.25→0.35로 올렸다.
		-- (기능 추가) "커지는 속도를 5% 늦춰달라"는 피드백으로 전체 길이를 0.533→0.533*1.05(≈0.56초)로
		-- 늘렸다(5% 느리게).
		-- (기능 추가) "발동 시작 시간을 0.2초 더 미뤄달라"는 피드백으로 스폰 지연을 0.15→0.35초로 늘렸다.
		-- (4차 패시브) 어드밴스드 스피어 버스터 보유 시 마법진/용머리를 전용 아트로 교체한다.
		-- 과거엔 원본 파랑 클립을 "파랑→검정" 재색한 5a8f784/e831f448이었으나, 사용자가 새로 그린
		-- "스피어버스터 강화" 전용 아트(마법진 116x116, 용머리 168x120)로 대체한다.
		-- ⚠ pivot 주의: 원본 파랑 클립(d757a7ca/7d52e396)은 좌하단 치우친 pivot이라 split-growth가 중심에서
		-- 커지도록 pivotOffset(-0.20,0.39)/(-0.21,0.37) 보정이 필요했지만, 새 전용 아트는 asset 업로드 기본값인
		-- 중심피벗이라 보정이 필요 없다(0,0). enhanced 여부로 pivotOffset을 분기한다.
		local circleRuid = (enhanced == true) and "5b1685eba9af484cbcde8015ca7398f6" or "d757a7ca9e3b417fb2d0d5b725baa12c"
		local headRuid = (enhanced == true) and "3e2d1d048bb74bec8b9bd8966cde41ad" or "7d52e3968f954e2dabc8f5a050adcd40"
		local circlePivotX = (enhanced == true) and 0 or -0.20
		local circlePivotY = (enhanced == true) and 0 or 0.39
		local headPivotX = (enhanced == true) and 0 or -0.21
		local headPivotY = (enhanced == true) and 0 or 0.37
		_TimerService:SetTimerOnce(function()
			self:SpawnSpearBurstFadingEffect(
				circleRuid, Vector2(0.2 * dirX, 0.35), dirX > 0,
				0.75, 1.76, 0.6, 0.6, 0.0, 0.8 / 1.5 * 1.05, 10, true, headRuid,
				circlePivotX, circlePivotY, headPivotX, headPivotY
			)
		end, 0.35)
		-- 찌르는 이펙트 3종은 852883a5 → 3c2ee6e6 → 521bf9f6 순서대로 재생돼야 한다는 피드백으로,
		-- 동시 재생이 아니라 짧은 간격을 두고 순서대로 트리거한다. 타격감을 위해 "3번 찌르는 스킬"답게
		-- 데미지 판정과 무관하게 이 3번의 찌르기 각각에 공격 사운드를 재생한다(기존에는 시전 시점에
		-- 한 번만 재생돼 3번 찌르는 느낌이 안 산다는 피드백) - 사운드 호출은 각 PlaySpearBurst*Effect
		-- 메서드 안으로 옮겼다.
		-- (기능 추가) 이 3번의 찌르기 이펙트와 같은 타이밍에 실제 데미지 판정(DealSpearBurstStabWave)도
		-- 함께 진행해, 대상 몬스터의 데미지 표시 3줄 + 피격 이펙트 + 피격음이 이 3번의 순간에 맞춰
		-- 나도록 한다(요청: "3줄로 스킬 한번에 3대 때리는 느낌").
		-- (버그 수정) 이펙트 클립 자체(852883a5/3c2ee6e6/521bf9f6)의 0번 프레임이 msw-search 리소스
		-- 조회로 확인한 결과 4x4 사실상 투명 프레임이라, 이펙트 호출과 정확히 같은 프레임에 데미지를
		-- 넣으면 화면상 이펙트가 아직 안 보이는 상태에서 데미지가 먼저 들어간 것처럼 보였다(실측 확인).
		-- 이펙트 재생 자체(StartFrameIndex)는 원래대로 되돌리고, 대신 데미지 판정 쪽을 이펙트 호출
		-- 시점보다 이 투명 프레임 길이만큼(effectVisualDelay) 뒤로 미뤄 실제로 이펙트가 보이는 시점에
		-- 데미지가 들어가도록 한다.
		-- (기능 추가) 이펙트 시점과 데미지(히트) 시점을 하나의 hitStartDelay로 합쳐서 순차 조정해왔는데
		-- (0.8→0.4→0.1), "히트 속도는 0.7초 뒤로 하고 찌르기 3종 이펙트 시점은 그보다 0.5초 앞당겨
		-- 달라"는 피드백으로 다시 둘을 분리했다 - damageStartDelay(히트)=0.7, effectStartDelay(이펙트
		-- 3종)=damageStartDelay-0.5=0.2로 고정했었다.
		-- (기능 추가) "852883a5/3c2ee6e6/521bf9f6 이펙트 시점이 느리다 - 스킬버튼 누른 시점에서
		-- 0.2초 뒤로 해달라"는 피드백을 받았다. 계산상으로는 이미 0.2(damageStartDelay-0.5)였지만,
		-- damageStartDelay 파생값이 아니라 요청받은 절대값 그대로 명시적 리터럴로 고정해 앞으로
		-- damageStartDelay(히트 속도)만 따로 바뀌어도 이펙트 시점이 의도치 않게 함께 밀리지 않도록
		-- 한다.
		-- (되돌림) "852883a5/3c2ee6e6/521bf9f6 사이 간격을 늘리면 안 되고 다시 줄여야 한다"는
		-- 피드백으로 이펙트 3종 사이 간격을 0.2*mult/0.4*mult에서 다시 원래의 0.1*mult/0.2*mult로
		-- 되돌린다.
		-- (기능 추가) "852883a5와 c7051cc242c54208a7c22df2b4bcc28e(날개 이펙트, 시전 즉시 재생)
		-- 사이 간격을 절반으로 줄여달라"는 요청으로 한때 0.2 → 0.1로 줄였었으나, "그 간격은 다시
		-- 0.2초여야 한다"는 피드백으로 0.2로 되돌렸었다.
		-- (버그 수정) OrderInLayer로 마법진에 가려지는 문제로 착각했었으나, "852883a5는 날개 이펙트와
		-- 위치 자체가 달라 가려질 수 없다 - Z-order 문제가 아니라 보여지는 시점(딜레이) 자체가
		-- 문제다. 찌르기 이펙트 3종을 스킬 사용 즉시 보이는 것으로 우선 해보자"는 피드백으로
		-- effectStartDelay를 0(시전 즉시)으로 바꿨었다.
		-- (기능 추가) StartFrameIndex 수정으로 "852883a5 시작 시점이 스킬 사용 즉시로 바뀌었다"고
		-- 확인받은 뒤, "이 시작 시점에서 0.5초 후에 뜨는 것으로 바꿔달라"는 피드백으로
		-- effectStartDelay를 0 → 0.5로 조정한다.
		-- (기능 추가) "데미지가 들어가는 시점을 0.2초 앞당겨달라"는 피드백으로 damageStartDelay를
		-- 0.7→0.5로 줄였다(effectStartDelay는 그대로 0.5 유지 - 이제 데미지와 이펙트 시작이 같은
		-- 시점이 된다). SkillManager.mlua의 재사용 대기시간도 damageStartDelay와 반드시 동일해야
		-- 하므로 0.7→0.5로 함께 맞췄다.
		-- (버그 수정) "공격속도를 올려도 실제 공격 횟수(DPS)가 거의 안 오른다 - 파워스트라이크는
		-- 공속을 올리면 확실히 공격 횟수가 늘어난다"는 피드백. 원인은 damageStartDelay/effectStartDelay가
		-- atkMult와 무관한 고정값(0.5초)이었던 것 - 공속을 올려 mult가 작아져도 이 0.5초 고정 구간은
		-- 줄지 않아 스킬 전체 주기(SkillManager 쿨다운의 하한선)가 거의 안 줄었다. 다른 스킬들처럼
		-- 전체 주기가 mult에 비례하도록 두 값 모두 mult를 곱해 스케일링한다(공속을 올렸을 때 파워스트라이크와
		-- 동일한 비율로 스킬 전체 주기가 짧아지도록).
		-- (기능 추가) "날개가 생기고 다음 공격까지의 시간을 단축해달라 - stabT1 frame2가 재생될 때여야
		-- 한다"는 피드백. 날개 이펙트(c7051cc2)는 시전 즉시(t=0) 뜨고, 5단 조합 모션의 3번째 포즈인
		-- stabT1 frame2는 2 * poseInterval 시점에 재생된다(PlaySpearBurstStabMotion 참고). 그래서
		-- 고정값 0.5*mult이었던 두 딜레이를 그 포즈 시점에 정확히 맞춘다(0.5 → 0.288*mult).
		-- ⚠ poseInterval(0.144*mult)은 PlaySpearBurstStabMotion과 반드시 같은 값이어야 한다.
		-- 이 변경으로 3타가 모두(0.288 / 0.438 / 0.588 * mult) 모션 콤보(~0.72*mult) 안에 들어온다.
		local poseInterval = 0.144 * mult
		local damageStartDelay = 2 * poseInterval
		local effectStartDelay = 2 * poseInterval
		-- (기능 추가) "3종 찌르기 이펙트 간 시간 간격을 1.5배 늘려달라"는 피드백으로 간격 상수를
		-- 0.1/0.2*mult → 0.15/0.3*mult로 1.5배 늘렸다. 데미지 판정(DealSpearBurstStabWave) 타이밍도
		-- 화면 이펙트와 항상 함께 맞아야 하므로("3줄 데미지가 실제 3연타 이펙트와 같은 순간에 뜬다")
		-- 동일하게 1.5배로 같이 늘렸다.
		local enh = self._T.spearBurstEnhanced == true
		_TimerService:SetTimerOnce(function()
			self:PlaySpearBurstCircleEffect(self.Entity, dirX, enh)
			if enh then self:SpawnAdvSpearStabEffect(dirX, 1) end
		end, effectStartDelay)
		_TimerService:SetTimerOnce(function()
			self:DealSpearBurstStabWave(1, dirX)
		end, damageStartDelay)
		_TimerService:SetTimerOnce(function()
			self:PlaySpearBurstBuildupEffect1(self.Entity, dirX, enh)
			if enh then self:SpawnAdvSpearStabEffect(dirX, 2) end
		end, effectStartDelay + 0.15 * mult)
		_TimerService:SetTimerOnce(function()
			self:DealSpearBurstStabWave(2, dirX)
		end, damageStartDelay + 0.15 * mult)
		_TimerService:SetTimerOnce(function()
			self:PlaySpearBurstBuildupEffect2(self.Entity, dirX, enh)
			if enh then self:SpawnAdvSpearStabEffect(dirX, 3) end
		end, effectStartDelay + 0.3 * mult)
		_TimerService:SetTimerOnce(function()
			self:DealSpearBurstStabWave(3, dirX)
		end, damageStartDelay + 0.3 * mult)

		-- (사용자 실측 확정) 찌르기 모션은 단일 액션이 아니라 5개의 포즈를 순서대로 갈아끼우는 조합
		-- 모션이다 - stabT1 0/1/2 프레임 → stabTF 1프레임 → stabT2 2프레임(GetSpearBurstPoses 참고).
		-- (기능 추가) "모션이 즉시 시작해야 한다"는 피드백으로, 기존에 딜레이(0.55*mult 등)를 두고
		-- 타이머로 예약하던 것을 제거하고 시전 즉시(0초) 동기 호출로 바꿨다.
		self:PlaySpearBurstStabMotion(self.Entity, dirX, mult)

		-- (버그 수정) "반대 방향키를 누르고 있으면 찌르는 모션인 채로 뒤로 돌게 된다"는 피드백의 원인 -
		-- 컨트롤 복구(playerCtrl.Enable=true) 시점이 damageStartDelay+0.3*mult 공식만으로 계산돼,
		-- PlaySpearBurstStabMotion의 3단계 콤보(beat1Hold=0.12*mult+beat2Hold=0.25*mult+beat3Hold=0.2*mult)가
		-- 아직 안 끝났는데도 먼저 풀려버리는 경우가 있었다. 두 시점 중 항상 더 늦은 쪽을 기준으로 삼도록
		-- math.max로 묶어, 모션이 실제로 다 끝난 뒤에만 컨트롤이 풀리게 한다(모션 콤보 상수는
		-- PlaySpearBurstStabMotion의 beat1Hold/beat2Hold/beat3Hold와 반드시 일치해야 한다 - DPS 스케일링을
		-- 위해 이제 세 값 모두 mult가 곱해진다).
		-- (버그 수정) "공속을 올려도 DPS가 파워스트라이크만큼 안 오른다"는 추가 피드백 - 안전 여유였던
		-- "+0.05"가 mult와 무관한 고정값이라 공속이 빨라질수록 전체 주기에서 차지하는 비중이 커져 DPS
		-- 스케일링을 계속 깎아먹고 있었다. 두 안전 여유 모두 mult에 비례하도록(0.05*mult) 바꿔, 최종
		-- 주기가 damageStartDelay/motionComboEnd와 마찬가지로 순수하게 0.85*mult 형태(파워스트라이크의
		-- 0.75*atkMult와 동일한 단일 비례식)가 되도록 한다.
		-- (기능 변경) 3박자 콤보(0.12+0.25+0.35)가 5단 조합 포즈(5 * poseInterval)로 바뀌었다. 전체
		-- 길이는 0.72*mult로 동일하다(PlaySpearBurstStabMotion의 poseInterval=0.144*mult).
		-- (기능 변경) damageStartDelay가 0.5*mult → 0.288*mult로 당겨지면서, 아래 math.max의 승자가
		-- damageStartDelay 쪽(0.638*mult)에서 모션 콤보 쪽(0.77*mult)으로 바뀌었다 - 즉 이제는
		-- "3타가 다 끝난 시점"이 아니라 "모션이 다 끝난 시점"이 컨트롤 복구를 결정한다. 전체 주기는
		-- 0.85*mult → 0.77*mult로 짧아진다(요청대로 다음 공격까지의 시간이 단축된다).
		local motionComboEnd = 5 * poseInterval
		local restoreDelay = math.max(damageStartDelay + 0.3 * mult + 0.05 * mult, motionComboEnd + 0.05 * mult)
		_TimerService:SetTimerOnce(function()
			self:RestoreSpearBurstControl()
		end, restoreDelay)
	end

	-- PlayEffectAttached 재생-재생 반복으로 알파/스케일 페이드를 흉내내면 깜빡임을 완전히 없앨 수
	-- 없다는 것이 실측 확인됐다(엔진에 재생 중인 이펙트의 실시간 트윈 API가 없음). 대신 전용 엔티티
	-- (RootDesk/MyDesk/Models/Effects/SpearBurstFadingEffect.model, script.SpearBurstFadingEffect)를
	-- 스폰해 그 엔티티 자신의 SpriteRendererComponent.Color/TransformComponent.Scale을 매 프레임
	-- 직접 갱신하는 진짜 라이브 트윈으로 대체한다 - 깜빡임 없이 부드럽게 페이드/스케일된다.
	-- 캐릭터와의 앞/뒤 순서는 orderInLayer로 결정한다. (실측 확인) 같은 SortingLayer(Default)에서
	-- Position.z만 다르게 줘서는 이 전용 엔티티가 캐릭터(아바타 바디)보다 확실히 뒤로 가지 않았다 -
	-- OrderInLayer는 Z보다 우선순위가 높은 정렬 기준이라, 캐릭터 기준값(0)보다 1 작은/큰 값을 명시적으로
	-- 줘야 확실하게 뒤/앞이 결정된다. -100/100처럼 극단값을 주면 캐릭터가 아니라 맵의 다른 레이어(배경/지형)
	-- 까지 밀려날 위험이 있어, 캐릭터 기준 ±1의 작은 값만 사용한다.
	-- localOffset: 맵이 아니라 캐릭터 엔티티(self.Entity)의 자식으로 스폰해서 캐릭터 로컬 좌표로 해석된다 -
	-- 이전에는 맵의 자식으로 스폰 시점 월드좌표에 고정돼, 캐릭터가 움직이면 이펙트만 그 자리에 남는(따라오지
	-- 않는) 문제가 있었다. 자식으로 붙이면 부모(캐릭터) Transform을 따라 매 프레임 자동으로 같이 움직인다.
	@ExecSpace("ServerOnly")
	method void SpawnSpearBurstFadingEffect(string ruid, Vector2 localOffset, boolean flipX, number startScale, number endScale, number startAlpha, number endAlpha, number holdDuration, number tweenDuration, integer orderInLayer, boolean useSplitGrowth, string secondRuid, number pivotOffsetX, number pivotOffsetY, number secondPivotOffsetX, number secondPivotOffsetY)
		local fxEntity = _SpawnService:SpawnByModelId("spearburstfadingeffect", "SpearBurstFX", Vector3(localOffset.x, localOffset.y, 0), self.Entity)
		if not isvalid(fxEntity) then return end
		fxEntity:AddComponent("script.SpearBurstFadingEffect")
		local comp = fxEntity:GetComponent("script.SpearBurstFadingEffect")
		if isvalid(comp) then
			-- (4차 패시브) 강화 이펙트는 이제 Color 틴트가 아니라 "파랑→검정 재색된 스프라이트"를 직접 넣으므로
			-- 여기서 추가 틴트를 걸지 않는다(이중으로 어두워짐 방지). 색은 넘겨받은 ruid 자체가 이미 결정한다.
			comp.ClipRUID = ruid
			comp.IsFlipX = flipX
			comp.StartScale = startScale
			comp.EndScale = endScale
			comp.StartAlpha = startAlpha
			comp.EndAlpha = endAlpha
			comp.HoldDuration = holdDuration
			comp.TweenDuration = tweenDuration
			comp.OrderInLayerValue = orderInLayer
			comp.UseSplitGrowth = useSplitGrowth
			comp.SecondClipRUID = secondRuid
			comp.PivotOffsetX = pivotOffsetX
			comp.PivotOffsetY = pivotOffsetY
			comp.SecondPivotOffsetX = secondPivotOffsetX
			comp.SecondPivotOffsetY = secondPivotOffsetY
		end
		_TimerService:SetTimerOnce(function()
			if isvalid(fxEntity) then
				fxEntity:Destroy()
			end
		end, holdDuration + tweenDuration + 0.2)
	end

	@ExecSpace("ServerOnly")
	method void SpawnAdvSpearStabEffect(number dirX, integer variant)
		-- (4차 패시브) 재색(파랑→검정, 흰색 유지) 찌르기 용머리를 캐릭터 앞에 짧게 재생한다. 원본 파랑 클립
		-- (852883a5/3c2ee6e6/521bf9f6)은 애니메이션클립이라 새 클립 생성 불가(asset은 sprite만) → 각 클립의
		-- 프레임2를 재색한 sprite 3종으로 3타를 서로 다르게 재생한다(원본처럼 3개 머리로 보이도록).
		-- 위치: 원본 클립은 pivot을 부착점에 두고 렌더하는데, 이 스프라이트는 중심피벗이라 이미지 중심이
		-- (width/2-pivot_x, height/2-pivot_y)만큼 어긋난다 → 그 값을 localOffset으로 보정해 원본 위치와 맞춘다.
		-- 원본 클립 부착 오프셋(852883a5=0, 3c2ee6e6/521bf9f6=0.15*dir)도 합산했다.
		-- (스피어버스터 강화) 찌르기 3종 용머리를 사용자가 새로 그린 전용 아트로 교체한다.
		-- 새 아트는 원본 클립 프레임과 정확히 동일한 크기(164x80/156x88/152x72)로 그려졌고 중심피벗으로
		-- 업로드됐다. ox/oy(위치 보정)는 기존 재색본과 동일 크기·중심피벗이므로 그대로 시작값으로 두고,
		-- 실제 화면과 대조해 필요 시 미세조정한다.
		local ruid = "9229298b79a64868b7cee06dc198edec"   -- 찌르기1 (164x80)
		local ox, oy = 1.08, 0.28
		if variant == 2 then
			ruid = "38361a0c587544dc8b6074920475db82"       -- 찌르기2 (156x88)
			ox, oy = 1.19, 0.01
		elseif variant == 3 then
			ruid = "38922d3cb17f44bcaddf7d6269e5d6d2"       -- 찌르기3 (152x72)
			ox, oy = 1.17, 0.37
		end
		self:SpawnSpearBurstFadingEffect(
			ruid, Vector2(ox * dirX, oy), dirX > 0,
			1.0, 1.0, 1.0, 0.0, 0.12, 0.14, 11, false, "", 0, 0, 0, 0
		)
	end

	@ExecSpace("Multicast")
	method void PlaySpearBurstCircleEffect(Entity attacker, number dirX, boolean enhanced)
		-- 찌르는 이펙트 3종 중 첫 번째로, 스킬을 사용하는 시점에 몸쪽 높이에서 뜨는 마법진(발밑이
		-- 아니라 몸통 높이여야 한다는 피드백으로 Y 오프셋을 제거했다).
		-- (버그 수정) "날개/마법진 이펙트가 사라진 뒤에야 찌르기 이펙트가 보인다"는 피드백 원인을
		-- 찾았다 - 몸쪽 마법진(176da561...)의 OrderInLayer가 10으로, 이 찌르기 이펙트 3종의 기본값
		-- (미지정 시 0 근방)보다 높아 마법진이 다 사라지기 전까지 찌르기 이펙트를 가리고 있었다.
		-- 찌르기 이펙트가 effectStartDelay(0.2초) 시점에 마법진과 무관하게 항상 눈에 보이도록,
		-- 마법진(10)보다 높은 OrderInLayer(11)를 명시적으로 지정해 항상 앞에 그려지게 한다.
		-- (버그 수정) 그 뒤에도 "이펙트가 보이는 속도가 전혀 변하지 않는다"는 피드백이 계속돼
		-- effectStartDelay를 0.8→0.4→0.2→0.1→0까지 바꿔봐도 체감이 그대로였다 - 원인은 스케줄링
		-- 딜레이가 아니라 이펙트 클립 자체였다. msw-search로 852883a5/3c2ee6e6/521bf9f6 세 클립을
		-- 모두 재조회한 결과 셋 다 0번 프레임이 4x4 투명 placeholder이고 실제 형상은 1번 프레임부터
		-- 시작한다 - 호출 시점과 무관하게 클립이 항상 이 투명한 0번 프레임부터 재생을 시작해, 실제
		-- 형상이 보이기까지 클립 자체의 0번 프레임 재생 시간만큼 항상 고정 지연이 있었던 것이다(그래서
		-- effectStartDelay를 아무리 줄여도 체감이 변하지 않았다). StartFrameIndex=1을 지정해 투명한
		-- 0번 프레임을 건너뛰고 실제 형상이 있는 1번 프레임부터 바로 재생되도록 한다.
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		local flipX = dirX > 0
		-- (기능 추가) 마법진 이펙트의 OrderInLayer를 10→15로 올리면서, 이 찌르기 이펙트가 다시 가려지지
		-- (되돌림) 마법진이 X축 이동으로 앞에 오도록 바뀌어 OrderInLayer 경쟁이 더 이상 없으므로
		-- 원래 값(11)으로 되돌린다.
		-- (4차 패시브) 강화 시 원본 파랑 클립은 재생하지 않는다(재색 스프라이트를 AttackSpearBurst가 별도 스폰).
		if not enhanced then
			local opts1 = { ["FlipX"] = flipX, ["OrderInLayer"] = 11, ["StartFrameIndex"] = 1 }
			_EffectService:PlayEffectAttached("852883a5b27442e88ac5a23f5a218a58", attacker, Vector3(0, 0, 0), 0, Vector3(1, 1, 1), false, opts1)
			-- 쉐도우 파트너: 같은 찌르기 이펙트를 x축 뒤쪽에서 투명도 70%로 복제 재생(그림자 몫 - 데미지 없음)
			self:EchoShadowSkillEffectAttached("852883a5b27442e88ac5a23f5a218a58", attacker, Vector3(0, 0, 0), 0, Vector3(1, 1, 1), opts1, dirX)
		end
		self:PlaySpearBurstAttackSound(attacker)
	end

	method table GetSpearBurstPoses()
		-- (사용자 실측 확정) 스피어 버스터의 정확한 모션은 단일 액션 전체 재생이 아니라, 아래 5개의
		-- 포즈를 순서대로 갈아끼우는 조합 모션이다(새비지블로우 8단 조합과 동일한 방식).
		--   1~3번 → stabT1의 0 / 1 / 2 프레임
		--   4번    → stabTF의 1프레임(2번째)
		--   5번    → stabT2의 2프레임(3번째)
		-- 프레임 번호는 0-based(엔진의 StartFrameIndex와 동일 기준)이다.
		return {
			{ action = "stabT1", frame = 0 },
			{ action = "stabT1", frame = 1 },
			{ action = "stabT1", frame = 2 },
			{ action = "stabTF", frame = 1 },
			{ action = "stabT2", frame = 2 },
		}
	end

	method void ApplySpearBurstPose(string action, integer frameIdx)
		-- 지정한 액션의 frameIdx번 프레임 하나에 캐릭터를 사실상 정지시킨다.
		-- ApplySavageBlowPose에서 실측으로 확인된 두 함정을 그대로 회피한다:
		-- 1) StartFrameIndex == EndFrameIndex(구간 길이 0)면 엔진이 이벤트를 통째로 무시한다 →
		--    반드시 EndFrameIndex = StartFrameIndex + 1 로 구간을 준다.
		-- 2) Onetime 클립이 끝까지 재생되면 기본 stand 모션으로 되돌아간다 → PlayRate를 극단적으로
		--    낮춰(0.001) 그 프레임에서 멈춰 있게 하고, 다음 포즈는 타이머로 직접 갈아끼운다.
		if not self:IsClient() then return end
		local avatarRenderer = self.Entity.AvatarRendererComponent
		if not isvalid(avatarRenderer) then return end
		local body = avatarRenderer:GetBodyEntity()
		if not isvalid(body) then return end

		-- 상태 변경(IDLE 복귀 등)으로 포즈가 덮여쓰이면 HandleStateChangeEvent가 이 값으로 다시 적용한다.
		self._T.lockedSpearBurstAction = action
		self._T.lockedSpearBurstFrameIdx = frameIdx

		local motionEvent = ActionStateChangedEvent(action, action, 0.001, SpriteAnimClipPlayType.Onetime, frameIdx, frameIdx + 1)
		body:SendEvent(motionEvent)
		log("[SpearBurst] pose " .. tostring(action) .. " frame=" .. tostring(frameIdx))
	end

	@ExecSpace("Multicast")
	method void PlaySpearBurstStabMotion(Entity attacker, number dirX, number atkMultiplier)
		-- (기능 변경) 이전에는 단일 액션(stabT2)을 Onetime→ZigzagLoop→Onetime 3박자로 재생해 "마지막
		-- 모션 → 직전 모션 → 마지막 모션"을 흉내냈으나, 사용자가 원작의 정확한 모션을 실측 확정해줬다 -
		-- stabT1 0/1/2 프레임 → stabTF 1프레임 → stabT2 2프레임의 5프레임 조합이다. 그래서 재생 방식을
		-- 새비지블로우와 동일한 "포즈를 타이머로 하나씩 갈아끼우는" 조합 모션(GetSpearBurstPoses +
		-- ApplySpearBurstPose)으로 교체한다.
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		local avatarRenderer = attacker.AvatarRendererComponent
		if not isvalid(avatarRenderer) then return end
		local body = avatarRenderer:GetBodyEntity()
		if not isvalid(body) then return end

		avatarRenderer.ShowDefaultWeaponEffects = false

		local playerCtrl = attacker.PlayerControllerComponent
		if isvalid(attacker.MovementComponent) then
			attacker.MovementComponent:Stop()
		end
		if isvalid(playerCtrl) then
			playerCtrl.LookDirectionX = dirX
		end
		self._T.isSpearBurstDirectionLocked = true
		self._T.lockedSpearBurstDirX = dirX
		self._T.isSpearBurstMotionPlaying = true
		-- 재시전 시 이전 숨고르기가 남아있으면 새 콤보를 방해하지 않도록 즉시 정리한다.
		self._T.isBreatherPlaying = false

		local mult = math.max(atkMultiplier or 1.0, 0.001)

		-- 5개의 포즈를 같은 간격으로 하나씩 갈아끼운다. 기존 3박자 콤보의 전체 길이(0.12+0.25+0.35 =
		-- 0.72*배율)를 그대로 유지해 AttackSpearBurst의 restoreDelay 계산이 바뀌지 않도록 5등분했다
		-- (0.72/5 = 0.144). 공속을 올리면(mult가 작아지면) 콤보 전체가 비례해서 짧아진다 - 이 mult
		-- 비례는 DPS 스케일링을 위해 반드시 유지해야 한다.
		-- ⚠ 이 간격/포즈 개수는 AttackSpearBurst의 motionComboEnd와 반드시 일치해야 한다.
		local poseInterval = 0.144 * mult
		local poses = self:GetSpearBurstPoses()
		for i, p in ipairs(poses) do
			local pose = p
			local delay = (i - 1) * poseInterval
			if delay <= 0 then
				self:ApplySpearBurstPose(pose.action, pose.frame)
			else
				_TimerService:SetTimerOnce(function()
					self:ApplySpearBurstPose(pose.action, pose.frame)
				end, delay)
			end
		end

		-- 마지막 포즈가 화면에서 유지되는 시간까지 포함해(#poses * poseInterval) 방향/모션 잠금을 푼다.
		-- (기존 주석 유지) "모션보다 딜레이가 짧아 모션 중 방향전환이 된다"는 신고로 마지막 구간에는
		-- 여유가 필요하다 - 마지막 포즈도 다른 포즈와 동일하게 poseInterval만큼 유지된 뒤 풀린다.
		-- (주의) ShowDefaultWeaponEffects 복구는 기존과 동일하게 RestoreSpearBurstControl이 담당한다 -
		-- 여기서 먼저 켜면 컨트롤 복구 전 남은 구간에 기본 무기 이펙트가 잠깐 되살아난다.
		_TimerService:SetTimerOnce(function()
			self._T.isSpearBurstMotionPlaying = false
			self._T.isSpearBurstDirectionLocked = false
			self._T.lockedSpearBurstAction = nil
			log("[SpearBurst] 방향/모션 잠금 해제 t=" .. tostring(_UtilLogic.ElapsedSeconds))
		end, #poses * poseInterval)
	end

	@ExecSpace("Multicast")
	method void PlaySpearBurstBuildupEffect1(Entity attacker, number dirX, boolean enhanced)
		-- 찌르는 이펙트 3종 중 두 번째(852883a5 다음). 몸통 높이(Y=0)에서 재생된다.
		-- (버그 수정) PlaySpearBurstCircleEffect와 동일한 이유로 마법진(OrderInLayer=10)에 가리지
		-- 않도록 OrderInLayer=11을 명시한다. 3c2ee6e6도 0번 프레임이 4x4 투명이라 StartFrameIndex=1로
		-- 건너뛴다(PlaySpearBurstCircleEffect와 동일한 원인/조치).
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		local flipX = dirX > 0
		-- (기능 추가) "몸쪽으로 조금 땡겨달라"는 피드백으로 앞쪽 오프셋을 0.3→0.15로 줄였다. 마법진
		-- (되돌림) 마법진이 X축 이동으로 앞에 오도록 바뀌어 OrderInLayer는 원래 값(11)으로 되돌린다.
		if not enhanced then
			local opts2 = { ["FlipX"] = flipX, ["OrderInLayer"] = 11, ["StartFrameIndex"] = 1 }
			_EffectService:PlayEffectAttached("3c2ee6e636924e179cca843f819f9b30", attacker, Vector3(0.15 * dirX, 0, 0), 0, Vector3(1, 1, 1), false, opts2)
			-- 쉐도우 파트너: 같은 찌르기 이펙트를 x축 뒤쪽에서 투명도 70%로 복제 재생(그림자 몫 - 데미지 없음)
			self:EchoShadowSkillEffectAttached("3c2ee6e636924e179cca843f819f9b30", attacker, Vector3(0.15 * dirX, 0, 0), 0, Vector3(1, 1, 1), opts2, dirX)
		end
		self:PlaySpearBurstAttackSound(attacker)
	end

	@ExecSpace("Multicast")
	method void PlaySpearBurstBuildupEffect2(Entity attacker, number dirX, boolean enhanced)
		-- 찌르는 이펙트 3종 중 세 번째(마지막). 몸통 높이(Y=0)에서 재생된다.
		-- (버그 수정) PlaySpearBurstCircleEffect와 동일한 이유로 마법진(OrderInLayer=10)에 가리지
		-- 않도록 OrderInLayer=11을 명시한다. 521bf9f6도 0번 프레임이 4x4 투명이라 StartFrameIndex=1로
		-- 건너뛴다(PlaySpearBurstCircleEffect와 동일한 원인/조치).
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		local flipX = dirX > 0
		-- (기능 추가) "몸쪽으로 조금 땡겨달라"는 피드백으로 앞쪽 오프셋을 0.3→0.15로 줄였다. 마법진
		-- (되돌림) 마법진이 X축 이동으로 앞에 오도록 바뀌어 OrderInLayer는 원래 값(11)으로 되돌린다.
		if not enhanced then
			local opts3 = { ["FlipX"] = flipX, ["OrderInLayer"] = 11, ["StartFrameIndex"] = 1 }
			_EffectService:PlayEffectAttached("521bf9f60cb94a7fb9890ba2e0ede109", attacker, Vector3(0.15 * dirX, 0, 0), 0, Vector3(1, 1, 1), false, opts3)
			-- 쉐도우 파트너: 같은 찌르기 이펙트를 x축 뒤쪽에서 투명도 70%로 복제 재생(그림자 몫 - 데미지 없음)
			self:EchoShadowSkillEffectAttached("521bf9f60cb94a7fb9890ba2e0ede109", attacker, Vector3(0.15 * dirX, 0, 0), 0, Vector3(1, 1, 1), opts3, dirX)
		end
		self:PlaySpearBurstAttackSound(attacker)
	end

	-- (버그 수정) 이전에는 @ExecSpace("Multicast")였는데, 이 메서드를 서버가 직접 부르지 않고
	-- PlaySpearBurstCircleEffect/BuildupEffect1/2(이미 Multicast로 각 클라이언트에서 실행 중인 메서드) 안에서
	-- 호출하는 구조로 바뀌면서, 클라이언트 실행 컨텍스트 안에서 또 다른 Multicast 메서드를 호출하는 셈이 돼
	-- 실제로는 아무 데도 전달되지 않고 조용히 무시됐다(로그로 실측 확인 - 호출은 되지만 재생 로그가 전혀
	-- 안 찍힘). Multicast는 서버가 직접 호출해야 클라이언트들로 퍼진다 - 이미 클라이언트에서 실행 중인
	-- 호출부에서는 어노테이션 없는(호출한 쪽에서 그대로 실행되는) 일반 메서드여야 한다.
	method void PlaySpearBurstAttackSound(Entity attacker)
		-- 공격 사운드(fcac442d...). 공격속도에 따른 재생 속도 변경은 소리가 이상하게 들린다는
		-- 피드백으로 제거하고, 다른 스킬과 동일하게 고정 속도로 재생한다.
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		_SoundService:PlaySound("fcac442d953049d980da4b8d7bd766d8", 1.0)
		log("[SpearBurst] PlaySpearBurstAttackSound 재생됨 t=" .. tostring(_UtilLogic.ElapsedSeconds))
	end

	@ExecSpace("Server")
	method void RestoreSpearBurstControl()
		self._T.isSpearBursting = false
		local playerCtrl = self.Entity.PlayerControllerComponent
		if isvalid(playerCtrl) and self._T.pendingSpearBurstWasControllerEnabled then
			playerCtrl.Enable = true
		end
		if isvalid(self.Entity.AvatarRendererComponent) then
			self.Entity.AvatarRendererComponent.ShowDefaultWeaponEffects = true
		end

		local sc = self.Entity.StateComponent
		if isvalid(sc) and sc.CurrentStateName ~= "DEAD" then
			sc:ChangeState("IDLE")
			sc:ChangeState("MOVE")
			sc:ChangeState("IDLE")
		end

		-- (버그 수정) "idle 모션이 호출되는 순간 숨고르기로 전환되어야 하는데 안 된다"는 신고 - 처음엔 위
		-- 토글보다 먼저 PlayBreather(무장)를 호출해 HandleStateChangeEvent가 토글의 StateChangeEvent를 잡게
		-- 했는데, 실측 결과 이 서버 메서드 안에서 순서대로 보낸 Multicast RPC(PlayBreather)와 StateComponent
		-- 상태 동기화(위 ChangeState)가 서로 다른 네트워크 경로를 타 클라이언트 도착 순서가 보장되지 않았고,
		-- 실제로는 상태 동기화가 먼저 도착해 이벤트를 놓치고 5초 안전망 타이머로만 겨우 시작되는 문제가 있었다.
		-- 이 메서드는 서버가 위에서 토글을 "이미" 동기적으로 완료한 뒤이므로, 클라이언트의 이벤트를 기다릴
		-- 필요 없이 곧장 시작을 지시하는 전용 Multicast(PlayBreatherImmediate)를 쓴다 - 무장/이벤트 대기 없이
		-- 도착하는 즉시 재생한다.
		self:PlayBreatherImmediate(self.Entity, self._T.pendingSpearBurstDirX or 1)
	end

	@ExecSpace("Multicast")
	method void PlayBreatherImmediate(Entity attacker, number dirX)
		-- RestoreSpearBurstControl처럼 서버가 IDLE→MOVE→IDLE 토글을 이미 동기적으로 끝낸 뒤 호출하는 전용
		-- 경로. PlayBreather(무장 후 StateChangeEvent 대기)와 달리 곧장 재생을 시작한다 - 자세한 이유는
		-- RestoreSpearBurstControl의 주석 참고.
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		self._T.breatherToken = (self._T.breatherToken or 0) + 1
		local myToken = self._T.breatherToken
		self:StartBreatherNow(attacker, myToken)
	end

	@ExecSpace("Multicast")
	method void PlayBreather(Entity attacker, number dirX)
		-- (기능 추가) "가만히 있을 때 기본모션으로 돌아갔다가 다시 숨고르기로 가서 불안정해 보인다 -
		-- 기본모션으로 바뀌는 타이밍에 숨고르기를 넣어달라"는 요청 - 고정 시간을 기다리는 대신, 각
		-- 스킬의 모션 정리용 IDLE→MOVE→IDLE 토글이 실제로 "IDLE"(기본 모션)로 전환되는 순간을 감지해
		-- 그 즉시 숨고르기로 덮어쓴다(HandleStateChangeEvent 참고 - 기본 모션이 화면에 보일 틈이 없다).
		--
		-- (버그 수정) "idle 모션이 호출되는 순간 숨고르기로 전환돼야 하는데 안 된다"는 신고 - 예전에는
		-- 여기 도착 시점에 CurrentStateName이 이미 "IDLE"이면 곧장 시작했는데, 파워스트라이크류 스킬은
		-- ATTACK으로 상태 전환을 아예 하지 않고 raw 모션 이벤트만 보내기 때문에(PlayAttackMotion 참고)
		-- 스킬을 시전하는 내내 CurrentStateName이 계속 "IDLE"로 남아있다 - 즉 "이미 IDLE"이 "정말로 기본
		-- 모션으로 복귀하는 순간"을 의미하지 않았다. 그 결과 이 즉시-시작 경로가 실제 모션 정리 토글
		-- (0.8*mult초 뒤)보다 훨씬 먼저 숨고르기를 시작시켰고, 뒤늦게 진짜 토글이 발생하면서 그 토글이
		-- 만드는 진짜 StateChangeEvent(IDLE)가 방금 시작한 숨고르기 alert 애니메이션을 덮어써 기본 모션으로
		-- 되돌려버렸다(겉보기엔 "숨고르기가 시작 안 됨"). 이제는 무조건 "무장(armed)"만 하고, 실제 시작은
		-- HandleStateChangeEvent가 진짜 IDLE 전환 이벤트를 잡는 시점에서만 한다 - 모든 스킬이 결국 이 토글을
		-- 거치므로(클라이언트 쪽이든, 스피어 버스터처럼 서버 쪽이든) 항상 이벤트가 온다. 혹시 어느 스킬이
		-- 이 토글 없이 DEAD 등으로 빠지는 경우를 대비해서만 넉넉한 안전망 타이머를 둔다(공격속도 배율
		-- 최댓값 3.0 기준 최대 토글 지연 0.8*3.0=2.4초보다 충분히 긴 5초).
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end

		self._T.breatherToken = (self._T.breatherToken or 0) + 1
		local myToken = self._T.breatherToken
		self._T.isBreatherArmed = true
		self._T.breatherArmedAttacker = attacker

		_TimerService:SetTimerOnce(function()
			if self._T.breatherToken ~= myToken then return end
			if not self._T.isBreatherArmed then return end
			self._T.isBreatherArmed = false
			self:StartBreatherNow(attacker, myToken)
		end, 5.0)
	end

	method void StartBreatherNow(Entity attacker, integer myToken)
		-- PlayBreather가 IDLE 전환 감지(또는 안전망 타이머)로 판단한 시점에 실제로 alert 모션을 재생한다.
		-- (참고) 이 메서드는 @ExecSpace를 지정하지 않는다 - PlayBreather의 클라이언트 측 이벤트 핸들러/
		-- 타이머 콜백(이미 IsClient()를 통과한 상태) 안에서 호출되므로 그대로 같은 컨텍스트에서
		-- 실행돼야 한다. Multicast로 지정하면 그 안에서 재호출 시 실행되지 않는 문제가 실측 확인됐다.
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		local avatarRenderer = attacker.AvatarRendererComponent
		if not isvalid(avatarRenderer) then return end
		local body = avatarRenderer:GetBodyEntity()
		if not isvalid(body) then return end

		self._T.isBreatherPlaying = true

		local breatherEvent = ActionStateChangedEvent("alert", "alert", 1.0, SpriteAnimClipPlayType.Loop)
		body:SendEvent(breatherEvent)
		log("[Breather] 숨고르기 시작 (alert, 3초 또는 다른 행동 시까지)")

		_TimerService:SetTimerOnce(function()
			if self._T.breatherToken ~= myToken then return end
			if not self._T.isBreatherPlaying then return end
			self._T.isBreatherPlaying = false
			-- (버그 수정) "스피어 버스터 사용 후 숨고르기가 계속 지속된다"는 신고 - 원인은 여기서
			-- ChangeState("IDLE") 한 번만 불렀던 것. 컨트롤 복구 시점(RestoreSpearBurstControl 등)에서
			-- 이미 IDLE→MOVE→IDLE 토글을 거쳐 CurrentStateName이 이미 "IDLE"인 상태였기 때문에, 같은
			-- 상태로 다시 ChangeState("IDLE")를 부르면 실제 상태 전이가 없어 StateChangeEvent가 발생하지
			-- 않고, body에 직접 보낸 "alert" Loop 애니메이션을 덮어쓸 계기가 전혀 생기지 않아 화면에서
			-- 영원히 반복 재생되는 상태로 남았다. 이 파일의 다른 곳(PlayAttackMotion 등)에서 이미
			-- 검증된 것과 동일하게 IDLE→MOVE→IDLE 강제 토글로 반드시 새 StateChangeEvent를 일으켜야
			-- AvatarStateAnimationComponent가 기본 stand/walk 클립을 다시 내보내 alert를 확실히 덮어쓴다.
			local sc = attacker.StateComponent
			if isvalid(sc) and sc.CurrentStateName ~= "DEAD" then
				sc:ChangeState("IDLE")
				sc:ChangeState("MOVE")
				sc:ChangeState("IDLE")
			end
			log("[Breather] 숨고르기 자동 종료(3초 경과)")
		end, 3.0)
	end

	@ExecSpace("Multicast")
	method void StopBreather()
		-- (기능 추가) "움직이거나 다른 스킬을 쓰면 숨고르기 모션은 중지하여야 합니다"는 요청 - 각
		-- Attack* 스킬 진입 시점에 호출해 취소한다. IDLE 전환을 기다리는 중(isBreatherArmed)이든
		-- 재생 중(isBreatherPlaying)이든 상관없이 토큰을 무조건 올리고 두 플래그 모두 내려, 대기
		-- 중이던 시작(HandleStateChangeEvent의 IDLE 감지 / 0.3초 안전망 타이머)과 재생 중이던
		-- 자동종료 타이머를 모두 무력화한다.
		if not self:IsClient() then return end
		self._T.breatherToken = (self._T.breatherToken or 0) + 1
		self._T.isBreatherArmed = false
		if self._T.isBreatherPlaying then
			self._T.isBreatherPlaying = false
			log("[Breather] 숨고르기 중단(다른 스킬 사용)")
		end
	end

	-- 찌르는 이펙트 3종(852883a5/3c2ee6e6/521bf9f6)이 뜨는 매 순간(0.0s/0.1s/0.2s*mult)마다, 고정해둔
	-- 대상 전원(최대 3명)에게 한 번씩 실제 데미지 판정을 진행한다(hitIndex=1/2/3, "3번 찌르기").
	-- (실측 확인) 여러 대상이 같은 프레임에서 동시에 Attack()하면 히트 사운드가 하나로 합쳐지는
	-- 문제가 있었다(슬래쉬블래스트/스피어 버스터 멀티타깃 사례) - 대상마다 짧게(0.05초) 간격을 두고
	-- 순차 처리한다. 0.05초는 다음 찌르기 이펙트 타이밍(0.1초 간격)과 겹치지 않을 정도로 짧게 잡았다.
	@ExecSpace("ServerOnly")
	method void DealSpearBurstStabWave(integer hitIndex, number dirX)
		if not isvalid(self.Entity) then return end
		local targets = self._T.spearBurstLockedTargets or {}
		self:DealNextSpearBurstStabHit(targets, 1, hitIndex, dirX)
	end

	@ExecSpace("Server")
	method void DealNextSpearBurstStabHit(table targets, integer idx, integer hitIndex, number dirX)
		if idx > #targets then return end
		if not isvalid(self.Entity) then return end
		local target = targets[idx]
		if isvalid(target) then
			self:DealSpearBurstStabHit(target, dirX, hitIndex)
		end
		if idx < #targets then
			_TimerService:SetTimerOnce(function()
				self:DealNextSpearBurstStabHit(targets, idx + 1, hitIndex, dirX)
			end, 0.05)
		end
	end

	-- 대상 하나에게 스피어 버스터의 3연타 중 hitIndex번째 타격을 적중시킨다. 더블스탭과 동일하게
	-- Client 메서드(ShowSpearBurstStabDamageSkin)를 직접 호출하므로 ExecSpace도 더블스탭의
	-- DealDoubleStabHit과 동일하게 "Server"로 맞춘다.
	-- (버그 수정 이력 참고) 더블스탭에서, 같은 AttackComponent 인스턴스로 같은 대상에게 짧은 간격으로
	-- 반복 Attack()을 걸면 GetDisplayHitCount=0을 반환해도 엔진이 히트마다 자동 데미지 숫자를 하나씩
	-- 추가로 띄우는 문제가 실측 확인됐다 - 대상의 DamageSkinSpawnerComponent를 판정 직전 잠깐
	-- 떼었다가 붙이는 방식으로 해결했다. 스피어 버스터의 3연타도 동일한 반복-Attack() 패턴이라
	-- 같은 조치를 쓴다.
	@ExecSpace("Server")
	method void DealSpearBurstStabHit(Entity target, number dirX, integer hitIndex)
		if not isvalid(target) then return end
		self._T.spearBurstCurrentTarget = target
		---@type Monster
		local monsterComp = target:GetComponent("script.Monster")
		-- Attack() 호출 전에 미리 확인해둔다 - Monster.HandleHitEvent는 호출 시점에 이미 죽어있으면
		-- (IsDead) 자기 히트음을 건너뛰므로, 이 값을 "네이티브가 이미 히트음을 냈는지" 판단 기준으로 쓴다.
		local wasAlreadyDead = isvalid(monsterComp) and monsterComp.IsDead
		local pos = target.TransformComponent.WorldPosition
		local shape = BoxShape(Vector2(pos.x, pos.y), Vector2(1.0, 1.6), 0)
		local targetSkinSpawner = target:GetComponent("MOD.Core.DamageSkinSpawnerComponent")
		if isvalid(targetSkinSpawner) then target:RemoveComponent("MOD.Core.DamageSkinSpawnerComponent") end
		local hitComps = self:Attack(shape, "skill.spearburst", CollisionGroups.HitBox)
		if not isvalid(target:GetComponent("MOD.Core.DamageSkinSpawnerComponent")) then target:AddComponent("MOD.Core.DamageSkinSpawnerComponent") end
		local actuallyHit = false
		for _, hc in ipairs(hitComps) do
			if isvalid(hc) and isvalid(hc.Entity) and hc.Entity == target then
				actuallyHit = true
				break
			end
		end
		local damage = self._T.lastSpearBurstDamage or 0
		local spearBurstBaseCrit = self._T.lastSpearBurstIsCritical or false
		local bonus = self._T.shadowEchoBonus or 0
		local bonusCrit = self._T.shadowEchoBonusIsCritical or false
		if not actuallyHit then
			-- 더블스탭과 동일하게, 앞선 타격에 대상이 이미 죽어 판정 자체가 실패해도(콜라이더가 더
			-- 이상 걸리지 않음) 3줄이 항상 뜨도록 표시 전용 데미지를 동일 공식으로 새로 굴린다(실제
			-- Hp에는 영향 없음). CalcDamage의 skill.spearburst 분기와 반드시 같은 배율을 유지해야 한다.
			-- (버그 수정) 더블스탭/매직클로와 동일한 이유로, 이 경로도 크리티컬을 독립적으로 굴리고
			-- self._T.shadowEchoBonus의 stale 값 대신 쉐도우 파트너 보너스도 여기서 새로 굴린다.
			local critRate = (self._T.currentCritRatePercent or 50) / 100
			local critMult = (self._T.currentCritDamagePercent or 125) / 100
			local combatPower = self._T.pendingSpearBurstCombatPower or 0
			local mult = 0.1 + _UtilLogic:RandomDouble() * (0.2 - 0.1)
			-- 콤보 어택 버프 보너스도 실제 판정(CalcDamage)과 동일하게 표시 전용 값에 반영한다.
			damage = self:ApplyComboAttackBonus(math.floor(combatPower * mult))
			spearBurstBaseCrit = _UtilLogic:RandomDouble() < critRate
			if spearBurstBaseCrit then damage = math.floor(damage * critMult) end
			bonus = 0
			bonusCrit = false
			if self._T.shadowPartnerActive then
				bonus = math.floor(damage * (0.55 + _UtilLogic:RandomDouble() * 0.10))
				bonusCrit = _UtilLogic:RandomDouble() < critRate
				if bonusCrit then bonus = math.floor(bonus * critMult) end
			end
		end
		self:ShowSpearBurstStabDamageSkin(target, damage, hitIndex, bonus, spearBurstBaseCrit, bonusCrit)
		-- (기능 추가) "타격음이 2배로 많이 들리게 해달라" 요청 - 쉐도우 파트너 보너스가 있으면 아래의
		-- 중복 방지 로직과 별개로 항상 추가 1회를 더 재생한다.
		if bonus > 0 then
			self:PlayShadowEchoHitSound(target)
		end
		-- 타격 이펙트는 실제 판정 성공 여부와 무관하게 매번 재생한다(항상 3번 느껴지도록).
		-- (스피어버스터 강화) 강화 시에는 원본 클립(84c06a06)에 검붉은 틴트를 씌우던 방식 대신,
		-- 사용자가 새로 그린 폴더 아트(원본 히트 클립 프레임 0/1/2의 재작화본)를 프레임 순서대로
		-- 재생한다 - "히트 이펙트가 폴더 안에 들어있던 이펙트가 아니다"는 피드백.
		if self._T.spearBurstEnhanced == true then
			-- (요청) 강화 히트 이펙트의 투명도는 70%(1.0 → 0.85 → 0.6 → 0.7로 확정).
			self:SpawnAdvSpearHitFrames(target, dirX, 0.7, 0)
			if self._T.shadowPartnerActive then
				-- 쉐도우 파트너 몫: 0.25초 뒤 한 번 더. 원래 "본체 100% : 잔상 70%"의 비율이었으므로
				-- 본체 값에 같은 비율(0.7 x 0.7)을 곱해, 잔상이 본체보다 진해지는 역전을 막는다.
				self:SpawnAdvSpearHitFrames(target, dirX, 0.49, 0.25)
			end
		else
			self:PlaySpearBurstHitEffect(target, dirX, hitIndex, false)
		end
		-- (버그 수정) 실제로 명중했고(actuallyHit) 대상이 이번 타격 전까지 살아있었다면
		-- Monster.HandleHitEvent(Monster.mlua, 이 스킬과 무관하게 항상 동작)가 이미 자기 히트음을
		-- 재생했으므로 여기서 또 재생하면 같은 히트에 소리가 2번 겹친다(실측 확인). 대상이 이미
		-- 죽어있었거나(3연타 중 첫 타에 죽어 HandleHitEvent가 IsDead로 건너뜀) 판정 자체가 실패한
		-- 경우에만 이 스킬 전용으로 직접 재생해 3번의 히트음이 항상 나도록 보충한다.
		if isvalid(monsterComp) and (not actuallyHit or wasAlreadyDead) then
			monsterComp:PlayHitSound()
		end
		log("[SpearBurst] DealSpearBurstStabHit hitIndex=" .. tostring(hitIndex) .. " actuallyHit=" .. tostring(actuallyHit) .. " wasAlreadyDead=" .. tostring(wasAlreadyDead) .. " damage=" .. tostring(damage))
	end

	@ExecSpace("Client")
	method void ShowSpearBurstStabDamageSkin(Entity target, integer damage, integer hitIndex, integer bonus, boolean baseIsCritical, boolean bonusIsCritical)
		-- 다른 스킬과 동일한 기본 히트 데미지 스킨(RUID)을 사용한다. 3번의 찌르기가 위/중간/아래로
		-- 나뉘어 3줄로 쌓인 것처럼 보이도록 세로 오프셋을 준다(더블스탭의 ±0.2 2줄 배치와 동일한 방식).
		if not isvalid(target) then return end
		local offsetY = 0.0
		local bonusGap = 0.15
		if bonus > 0 then
			-- (기능 수정) 3줄->6줄로 늘어날 때 기존 간격(0.15)이 좁다는 피드백 - "1->2줄" 간격(0.3)과
			-- 동일한 단위로 6줄 전체를 -0.75/-0.45/-0.15/0.15/0.45/0.75로 재배치한다(버프가 없을 때의
			-- 3줄 배치는 그대로 유지).
			if hitIndex == 1 then
				offsetY = -0.75
			elseif hitIndex == 3 then
				offsetY = 0.45
			else
				offsetY = -0.15
			end
			bonusGap = 0.3
		else
			if hitIndex == 1 then
				offsetY = -0.3
			elseif hitIndex == 3 then
				offsetY = 0.3
			end
		end
		-- (버그 수정) 원본/보너스를 하나의 Play() 배열로 묶으면 3연타(3곳)가 각각 2줄씩이라 총 6줄이어야
		-- 하는데 실제로는 4줄처럼 겹쳐 보이는 문제가 있었다 - 배열로 묶인 두 값은 시간차(DelayPerAttack)로만
		-- 분리되고 같은 위치에서 뜨기 때문. 보너스를 별도의 Play() 호출로 분리해 offsetY를 bonusGap만큼
		-- 더 얹어서 서로 다른 위치에 뜨도록 한다.
		-- (버그 수정) "각자 크리티컬 여부를 독립적으로 판단해야 한다" - 하드코딩된 false 대신 CalcDamage가
		-- 이 타격(hitIndex)에 대해 독립적으로 굴린 결과를 그대로 전달한다.
		_DamageSkinService:Play(
			target, self:GetHitDamageSkinId(), 0,
			{ damage }, DamageSkinTweenType.Default, baseIsCritical,
			Vector2(0, offsetY), Vector2(1, 1), 1.0, 1.0, LitMode.Default
		)
		if bonus > 0 then
			_DamageSkinService:Play(
			    target, self:GetHitDamageSkinId(), 0,
			    { bonus }, DamageSkinTweenType.Default, bonusIsCritical,
			    Vector2(0, offsetY + bonusGap), Vector2(1, 1), 1.0, 1.0, LitMode.Default
			)
		end
		log("[SpearBurst] ShowSpearBurstStabDamageSkin hitIndex=" .. tostring(hitIndex) .. " damage=" .. tostring(damage) .. " offsetY=" .. tostring(offsetY) .. " baseCrit=" .. tostring(baseIsCritical) .. " bonusCrit=" .. tostring(bonusIsCritical))
	end

	@ExecSpace("Multicast")
	method void PlaySpearBurstHitEffect(Entity target, number dirX, integer hitIndex, boolean enhanced)
		-- 스피어 버스터에 맞은 몬스터 전용 히트 이펙트. 여러 명이 맞으면 대상마다 각각 재생되고,
		-- 3연타의 hitIndex마다(찌르는 이펙트 3종과 같은 타이밍) 매번 새로 재생된다.
		-- 오른쪽을 보고 공격할 때(dirX>0) 좌우 반전한다(캐릭터 쪽 이펙트와 동일한 관례).
		-- (실측 확인) PlayEffectAttached로 몬스터에 붙이면 각 몬스터 자신의 좌우 방향(스스로 걷는
		-- 방향)에 따라 반전 결과가 뒤섞여 "몇 개는 오른쪽, 몇 개는 왼쪽"으로 들쭉날쭉하게 나온다 -
		-- 몬스터에 붙이지 않고 그 순간의 월드 좌표에 독립적으로 재생해 이 간섭을 없앤다.
		-- (실측 확인) 알파를 낮춰가며 재생을 반복해 페이드를 흉내내면 클립이 매번 처음부터 다시
		-- 시작돼 "깜빡거림"으로 보인다 - 한 번만 재생하고 클립 자체의 자연스러운 소멸에 맡긴다.
		if not self:IsClient() then return end
		if not isvalid(target) then return end
		local pos = target.TransformComponent.WorldPosition
		local flipX = dirX > 0
		-- (요청) 어드밴스드 스피어 버스터 보유 시 히트 이펙트를 검붉은색으로. 원본(밝은 폭발)에 곱해
		-- 진한 검붉은 톤(어두운 빨강)이 되게 한다.
		-- (요청) 붉은색 비중을 줄이고 "검은색에 붉은색을 살짝 곁들인" 톤. R만 약간 남기고 전체를 어둡게.
		local hitOpts = { ["FlipX"] = flipX }
		if enhanced then hitOpts["Color"] = Color(0.3, 0.08, 0.08, 1.0) end
		_EffectService:PlayEffect("84c06a061ae74a10a96fd55947769868", target, Vector3(pos.x, pos.y, 0), 0, Vector3(1, 1, 1), false, hitOpts)
		-- 쉐도우 파트너: 같은 히트 이펙트를 0.25초 시간차를 두고 그 자리에 한 번 더(70% 투명도) 재생
		self:EchoShadowHitEffectAtPos("84c06a061ae74a10a96fd55947769868", Vector3(pos.x, pos.y, 0), 0, Vector3(1, 1, 1), hitOpts)
		log("[SpearBurst] PlaySpearBurstHitEffect hitIndex=" .. tostring(hitIndex) .. " t=" .. tostring(_UtilLogic.ElapsedSeconds))
	end

	@ExecSpace("ServerOnly")
	method void SpawnAdvSpearHitFrames(Entity target, number dirX, number alphaValue, number delaySeconds)
		-- (스피어버스터 강화) 히트 이펙트를 msw-dev-tools/resources/스피어버스터강화 폴더의 전용 아트로
		-- 재생한다. 원본 히트 클립(84c06a06)의 프레임 0/1/2를 그대로 재작화한 스프라이트 3장을 쓰며,
		-- 실측으로 원본 프레임과 알파(실루엣)가 픽셀 단위로 완전히 동일함을 확인했다
		-- (009=120x108/f0, 004=120x104/f1, 010=96x96/f2 - RUID.md에는 "미사용"으로 잘못 분류돼 있었다).
		-- asset 업로드는 sprite만 가능해 새 애니메이션클립을 만들 수 없으므로, 엔티티 하나의 ClipRUID를
		-- 순서대로 갈아끼워 클립처럼 재생한다(SpawnSlashBlastCastEffect와 동일한 프레임 교체 패턴).
		-- 원본의 4번째 프레임(68x88)은 재작화본이 없어 3프레임으로 끝낸다.
		-- delaySeconds > 0이면 그만큼 뒤에 재생한다(쉐도우 파트너 몫).
		-- (버그 수정) 이펙트를 몬스터의 자식으로 붙이면 몬스터가 오른쪽을 볼 때 부모의 Scale.x가
		-- 반전돼(몬스터 모델의 좌우 반전 관례) 자식인 이 이펙트까지 같이 뒤집힌다 - "히트 이펙트
		-- 방향이 몬스터가 보는 방향 기준으로 잡힌다"는 피드백의 원인. 원본 클립 재생부
		-- (PlaySpearBurstHitEffect)의 주석과 동일한 조치로, 몬스터에 붙이지 않고 그 순간의 월드
		-- 좌표에 맵의 자식으로 독립 스폰해 몬스터 방향의 간섭을 없애고 IsFlipX를 공격자(플레이어)의
		-- dirX로만 결정한다.
		if not isvalid(target) then return end
		local mapEntity = self.Entity.CurrentMap
		if not isvalid(mapEntity) then return end
		local targetPos = target.TransformComponent.WorldPosition
		local spawnX, spawnY = targetPos.x, targetPos.y + 0.4
		local frames = {
			"60930fee4e624d7f898debb4d0a92a3a",   -- f0 (120x108)
			"2b33049e548c43d7bbdd5f00dfd441de",   -- f1 (120x104)
			"51c423c9d2d841e993ae26fcfa986be4",   -- f2 (96x96)
		}
		local frameInterval = 0.07
		local playFrames = function()
			if not isvalid(mapEntity) then return end
			self._T.trailFxSeq = (self._T.trailFxSeq or 0) + 1
			local fx = _SpawnService:SpawnByModelId("spearburstfadingeffect", "SBAdvHitFx" .. tostring(self._T.trailFxSeq), Vector3(spawnX, spawnY, 0), mapEntity)
			if not isvalid(fx) then return end
			fx:AddComponent("script.SpearBurstFadingEffect")
			local comp = fx:GetComponent("script.SpearBurstFadingEffect")
			if isvalid(comp) then
				comp.IsFlipX = dirX > 0        -- 공격자(플레이어)가 보는 방향 기준 - 맞은 몬스터 방향과 무관
				comp.StartAlpha = alphaValue
				comp.EndAlpha = alphaValue     -- 페이드 없이 프레임 재생만(사라짐은 아래 Destroy가 담당)
				comp.HoldDuration = 1.0        -- 전체 수명보다 길게 잡아 트윈이 아예 시작되지 않게 한다
				comp.TweenDuration = 0.0
				comp.StartScale = 1.0
				comp.EndScale = 1.0
				comp.OrderInLayerValue = 5     -- 몬스터보다 앞에 그려지도록
				comp.ClipRUID = frames[1]      -- 마지막에 설정(클라 OnSyncProperty가 실제 적용을 트리거)
			end
			for i = 2, #frames do
				local frameRuid = frames[i]
				_TimerService:SetTimerOnce(function()
					if isvalid(comp) then comp.ClipRUID = frameRuid end
				end, (i - 1) * frameInterval)
			end
			_TimerService:SetTimerOnce(function()
				if isvalid(fx) then fx:Destroy() end
			end, #frames * frameInterval + 0.03)
			log("[SpearBurst] SpawnAdvSpearHitFrames 재생 alpha=" .. tostring(alphaValue) .. " t=" .. tostring(_UtilLogic.ElapsedSeconds))
		end
		if delaySeconds > 0 then
			_TimerService:SetTimerOnce(playFrames, delaySeconds)
		else
			playFrames()
		end
	end

	-- ─────────────────────────────────────────────────────────────────────
	-- 새비지블로우 (2차 스킬)
	--
	-- 사양(요청사항):
	--  · 전방의 적 1명을 6번 공격한다. 데미지는 6줄로 표시된다.
	--  · 데미지는 한 줄당 전투력의 220%~300% (CalcDamageBase의 skill.savageblow 분기).
	--  · 시전하면 캐릭터 앞에 1→8번 이미지가 순서대로 빠르게 뜨고, 이미지가 바뀔 때마다 히트 사운드가 난다
	--    (SavageBlowVisual.mlua가 클라이언트에서 담당).
	--  · 2·3·4·5·6·8번 이미지가 보이는 순간에 각각 1타씩, 총 6타의 데미지 판정이 들어간다.
	--  · 히트 이펙트는 3종 중 시전마다 1개를 랜덤으로 골라, 그 하나만 6번 몬스터에게서 터진다.
	--  · 3번째 타격에 몬스터가 죽더라도 6줄이 모두 떠야 한다 → 스피어 버스터와 동일하게, 판정이 실패하면
	--    (콜라이더가 더 이상 걸리지 않으면) 같은 공식으로 표시 전용 데미지를 새로 굴려 줄만 띄운다.
	-- ─────────────────────────────────────────────────────────────────────

	@ExecSpace("ServerOnly")
	method void AttackSavageBlow(number combatPower, number atkMultiplier)
		-- (다른 스킬과 동일) 새 스킬을 시전하는 시점에 이전 숨고르기가 재생 중이었다면 즉시 정리한다.
		self:StopBreather()
		local currentState = self.Entity.StateComponent.CurrentStateName
		if currentState == "DEAD" or currentState == "CLIMB" or currentState == "LADDER" then
			return
		end
		if self._T.isSavageBlowing then
			log("PlayerAttack: AttackSavageBlow 요청 차단됨(이미 진행 중)")
			return
		end
		self._T.isSavageBlowing = true

		local mult = math.max(0.1, math.min(atkMultiplier or 1.0, 3.0))
		self._T.pendingSavageBlowCombatPower = combatPower

		local playerCtrl = self.Entity.PlayerControllerComponent
		local worldPos = self.Entity.TransformComponent.WorldPosition
		local dirX = isvalid(playerCtrl) and playerCtrl.LookDirectionX or 1
		self._T.pendingSavageBlowDirX = dirX
		self._T.pendingSavageBlowWasControllerEnabled = isvalid(playerCtrl) and playerCtrl.Enable
		if isvalid(playerCtrl) then
			playerCtrl.Enable = false
		end
		if isvalid(self.Entity.MovementComponent) then
			self.Entity.MovementComponent:Stop()
		end

		-- 대상은 시전 시점에 한 번만 골라 고정한다(더블스탭/스피어버스터와 동일) - 6타가 진행되는 도중에
		-- 대상이 죽어도 나머지 타격의 데미지 줄이 계속 그 자리에 떠야 하므로, 매 타격마다 다시 찾지 않는다.
		self._T.savageBlowTarget = self:FindNearestMonsterInForwardBox(Vector2(worldPos.x, worldPos.y), dirX, 2.0, 1.0)

		-- 히트 이펙트는 3종 중 하나를 이번 시전에서 한 번만 골라, 6번 모두 같은 것으로 재생한다(요청사항 -
		-- "3개중 랜덤으로 하나를 골라 그 고른 하나의 이펙트만 6번 뜨고 사라짐").
		local hitEffects = {
			"5154d64ae24843a3bc29a878f13768ad",
			"45087e25ef5949f68af9fe40c5b3c0a9",
			"53a8a9f33fdb42819715399936e1a7fa",
		}
		local hitRuid = hitEffects[_UtilLogic:RandomIntegerRange(1, 3)]

		-- 프레임 간격/시작 딜레이. SavageBlowVisual.FrameInterval과 반드시 같은 값이어야 화면(이미지)과
		-- 판정(데미지)이 같은 순간에 일어난다.
		-- (기능 변경 이력)
		--  · "너무 빠르다 - 1/2로" 요청 → 프레임 간격/시작 딜레이를 2배(0.06→0.12 / 0.1→0.2)로 늘렸다.
		--  · 이번엔 "후딜이 더 줄어야 한다 - 모션이 더 빨라야 한다"는 피드백 → 프레임 간격 0.12 → 0.09,
		--    시작 딜레이 0.2 → 0.12로 당겼다(연출 전체 길이 1.16 → 0.84*배율).
		-- SavageBlowVisual.FrameInterval의 기본값도 같은 값(0.09)으로 맞춰야 한다.
		local frameInterval = 0.09 * mult
		local startDelay = 0.12 * mult

		-- 캐릭터 모션은 8장의 이펙트 프레임과 1:1로 맞춰 8개의 포즈를 순서대로 잡는다(요청받은 조합) -
		-- 그래서 프레임 타이밍(startDelay/frameInterval)이 정해진 뒤에 호출한다.
		self:PlaySavageBlowMotion(self.Entity, dirX, mult, startDelay, frameInterval)

		_TimerService:SetTimerOnce(function()
			self:SpawnSavageBlowVisual(dirX, frameInterval)
		end, startDelay)

		-- 6타 판정: 2·3·4·5·6·8번 이미지가 보이는 순간(= startDelay + (프레임번호-1) * 간격)에 각각 1타.
		local damageFrames = { 2, 3, 4, 5, 6, 8 }
		for i, frameIdx in ipairs(damageFrames) do
			local hitIndex = i
			local delay = startDelay + (frameIdx - 1) * frameInterval
			_TimerService:SetTimerOnce(function()
				self:DealSavageBlowHit(hitIndex, dirX, hitRuid)
			end, delay)
		end

		-- (기능 수정) "끝 딜레이를 더 줄여달라"는 추가 피드백 - 마지막 타격(8번 프레임 = 0.12 + 7*0.09 =
		-- 0.75*배율) 직후에 바로 컨트롤을 돌려준다(= 0.77*배율). 8번 이미지 자체는 전용 이펙트 엔티티가
		-- 자기 타이머로 끝까지 재생하므로, 컨트롤을 먼저 풀어도 연출이 잘리지 않는다.
		-- SkillManager의 재사용 대기시간(0.82*배율)도 여기에 맞춰 함께 줄였다.
		local restoreDelay = startDelay + 7 * frameInterval + 0.02 * mult
		_TimerService:SetTimerOnce(function()
			self:RestoreSavageBlowControl()
		end, restoreDelay)

		log("[SavageBlow] AttackSavageBlow dirX=" .. tostring(dirX) .. " combatPower=" .. tostring(combatPower) .. " hitRuid=" .. tostring(hitRuid) .. " targetFound=" .. tostring(isvalid(self._T.savageBlowTarget)))
	end

	method table GetSavageBlowPoses()
		-- (요청) 캐릭터 모션은 아래 포즈들을 순서대로 조합해서 만든다. 이펙트 프레임(1~8)과 앞에서부터
		-- 1:1로 짝지어, 이미지가 바뀌는 순간마다 포즈도 함께 바뀐다.
		--   1번 이미지 → stabO1 첫 모션
		--   2번        → swingOF 끝 모션
		--   3번        → proneStab 첫 모션
		--   4번        → swingOF 끝 모션
		--   5번        → swingO2 첫 모션
		--   6번        → stabO1 끝 모션
		--   7번        → alert 중간 모션
		-- (기능 변경) 마지막 8번(swingO1 첫 모션)은 빼달라는 요청으로 제거했다 - 8번 이펙트가 뜨는
		-- 동안에는 7번 포즈(alert 중간)가 그대로 유지된다.
		-- 각 액션의 실제 프레임 수는 플레이 중 프레임을 하나씩 넘겨보며 실측해서 확정했다:
		--   swingOF = 4프레임(0~3, 끝=3) / stabO1 = 2프레임(0~1, 끝=1) / alert = 3프레임(0~2, 중간=1)
		-- 그래서 "끝 모션"/"중간 모션"도 아래처럼 실제 프레임 번호로 직접 적는다.
		return {
			{ action = "stabO1",    frame = 0 },  -- 첫 모션
			{ action = "swingOF",   frame = 3 },  -- 끝 모션 (총 4프레임)
			{ action = "proneStab", frame = 0 },  -- 첫 모션
			{ action = "swingOF",   frame = 3 },  -- 끝 모션
			{ action = "swingO2",   frame = 0 },  -- 첫 모션
			{ action = "stabO1",    frame = 1 },  -- 끝 모션 (총 2프레임)
			{ action = "alert",     frame = 1 },  -- 중간 모션 (총 3프레임)
		}
	end

	@ExecSpace("Multicast")
	method void PlaySavageBlowMotion(Entity attacker, number dirX, number atkMultiplier, number startDelay, number frameInterval)
		-- 다른 스킬(더블스탭 등)은 액션 하나를 통째로 재생하지만, 새비지블로우는 8개의 포즈를 이펙트
		-- 프레임과 같은 타이밍에 하나씩 갈아끼우는 방식이다(요청받은 조합 모션).
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		local avatarRenderer = attacker.AvatarRendererComponent
		if not isvalid(avatarRenderer) then return end
		local body = avatarRenderer:GetBodyEntity()
		if not isvalid(body) then return end

		avatarRenderer.ShowDefaultWeaponEffects = false

		local playerCtrl = attacker.PlayerControllerComponent
		if isvalid(attacker.MovementComponent) then
			attacker.MovementComponent:Stop()
		end
		if isvalid(playerCtrl) then
			playerCtrl.LookDirectionX = dirX
		end
		self._T.isSavageBlowDirectionLocked = true
		self._T.lockedSavageBlowDirX = dirX
		self._T.isSavageBlowMotionPlaying = true
		-- 재시전 시 이전 숨고르기가 남아있으면 새 모션을 방해하지 않도록 즉시 정리한다.
		self._T.isBreatherPlaying = false

		local mult = math.max(atkMultiplier or 1.0, 0.001)

		-- 8개의 포즈를 이펙트 프레임과 동일한 시점(startDelay + (i-1)*frameInterval)에 하나씩 적용한다.
		local poses = self:GetSavageBlowPoses()
		for i, p in ipairs(poses) do
			local pose = p
			local delay = startDelay + (i - 1) * frameInterval
			_TimerService:SetTimerOnce(function()
				self:ApplySavageBlowPose(pose.action, pose.frame)
			end, delay)
		end

		_TimerService:SetTimerOnce(function()
			if isvalid(avatarRenderer) then
				avatarRenderer.ShowDefaultWeaponEffects = true
			end
			self._T.isSavageBlowMotionPlaying = false
		end, 0.78 * mult)

		-- (기능 변경) 키를 누르고 있으면 계속 재시전되므로(SkillManager의 홀드 반복 목록에 추가됨),
		-- 이 모션 해제 타이머가 다음 시전 도중에 터지면 새 포즈를 stand로 덮어써 버린다. 재사용
		-- 대기시간(0.82*배율)보다 앞에서 끝나야 한다 - 마지막 포즈(0.12 + 6*0.09 = 0.66*배율)와 마지막
		-- 타격(0.75*배율)이 모두 끝난 0.79*배율에 모션을 정리한다("끝 딜레이를 더 줄여달라"는 피드백).
		_TimerService:SetTimerOnce(function()
			self._T.isSavageBlowDirectionLocked = false
			self._T.lockedSavageBlowAction = nil
			local sc = self.Entity.StateComponent
			if isvalid(sc) and sc.CurrentStateName ~= "DEAD" then
				sc:ChangeState("IDLE")
				sc:ChangeState("MOVE")
				sc:ChangeState("IDLE")
			end
		end, 0.79 * mult)
	end

	method void ApplySavageBlowPose(string action, integer frameIdx)
		-- 지정한 액션의 frameIdx번 프레임 하나에 캐릭터를 사실상 정지시킨다.
		--
		-- (실측으로 확인한 두 가지 함정)
		-- 1) StartFrameIndex == EndFrameIndex(구간 길이 0)로 보내면 엔진이 이벤트를 통째로 무시한다
		--    (포즈가 전혀 바뀌지 않는다). 반드시 EndFrameIndex = StartFrameIndex + 1 로 구간을 줘야 한다.
		-- 2) PlayType=Onetime 클립이 끝까지 재생되고 나면 캐릭터가 기본 stand 모션으로 되돌아간다 -
		--    즉 "빠르게 감아서 마지막 프레임에 멈추기"는 통하지 않는다. 대신 PlayRate를 극단적으로 낮춰
		--    (0.001) 그 프레임에서 사실상 멈춰 있게 만든다. 다음 포즈는 우리가 타이머로 직접 갈아끼운다.
		if not self:IsClient() then return end
		local avatarRenderer = self.Entity.AvatarRendererComponent
		if not isvalid(avatarRenderer) then return end
		local body = avatarRenderer:GetBodyEntity()
		if not isvalid(body) then return end

		-- 상태 변경(IDLE 복귀 등)으로 포즈가 덮여쓰이면 HandleStateChangeEvent가 이 값으로 다시 적용한다.
		self._T.lockedSavageBlowAction = action
		self._T.lockedSavageBlowFrameIdx = frameIdx

		local motionEvent = ActionStateChangedEvent(action, action, 0.001, SpriteAnimClipPlayType.Onetime, frameIdx, frameIdx + 1)
		body:SendEvent(motionEvent)
		log("[SavageBlow] pose " .. tostring(action) .. " frame=" .. tostring(frameIdx))
	end

	@ExecSpace("ServerOnly")
	method void SpawnSavageBlowVisual(number dirX, number frameInterval)
		-- 캐릭터 앞(바라보는 방향)에 1~8번 이미지를 순서대로 재생하는 전용 엔티티를 캐릭터의 자식으로 스폰한다.
		-- 자식으로 붙여야 캐릭터가 움직여도 이펙트가 따라온다(SpearBurstFadingEffect와 동일한 이유).
		-- 이미지는 한자(流血殺 등)라 좌우 반전하면 글자가 뒤집혀 보이므로 FlipX는 쓰지 않고, 위치만 바라보는
		-- 방향으로 옮긴다.
		local fx = _SpawnService:SpawnByModelId("savageblowvisual", "SavageBlowFX", Vector3(0.55 * dirX, 0.45, 0), self.Entity)
		if not isvalid(fx) then
			log_warning("[SavageBlow] SpawnSavageBlowVisual: 스폰 실패 (savageblowvisual 모델 없음?)")
			return
		end
		fx:AddComponent("script.SavageBlowVisual")
		local comp = fx:GetComponent("script.SavageBlowVisual")
		if isvalid(comp) then
			comp.FrameInterval = frameInterval
			comp.OrderInLayerValue = 11
		end
		_TimerService:SetTimerOnce(function()
			if isvalid(fx) then
				fx:Destroy()
			end
		end, frameInterval * 8 + 0.4)
		log("[SavageBlow] SpawnSavageBlowVisual interval=" .. tostring(frameInterval))
	end

	@ExecSpace("Server")
	method void DealSavageBlowHit(integer hitIndex, number dirX, string hitRuid)
		-- 6타 중 hitIndex번째 타격. 스피어 버스터(DealSpearBurstStabHit)와 완전히 동일한 구조다:
		-- 같은 AttackComponent 인스턴스로 같은 대상을 짧은 간격으로 반복 타격하면 GetDisplayHitCount=0이어도
		-- 엔진이 자동 데미지 숫자를 추가로 띄우는 문제가 있어, 대상의 DamageSkinSpawnerComponent를 판정
		-- 직전에 잠깐 떼었다가 붙인다.
		if not isvalid(self.Entity) then return end
		local target = self._T.savageBlowTarget
		if not isvalid(target) then return end
		self._T.savageBlowCurrentTarget = target

		---@type Monster
		local monsterComp = target:GetComponent("script.Monster")
		-- Attack() 호출 전에 미리 확인한다 - Monster.HandleHitEvent는 이미 죽어있으면(IsDead) 자기 히트음을
		-- 건너뛰므로, "네이티브가 이 타격의 히트음을 이미 냈는지" 판단 기준으로 쓴다.
		local wasAlreadyDead = isvalid(monsterComp) and monsterComp.IsDead

		local pos = target.TransformComponent.WorldPosition
		local shape = BoxShape(Vector2(pos.x, pos.y), Vector2(1.0, 1.6), 0)
		local targetSkinSpawner = target:GetComponent("MOD.Core.DamageSkinSpawnerComponent")
		if isvalid(targetSkinSpawner) then target:RemoveComponent("MOD.Core.DamageSkinSpawnerComponent") end
		local hitComps = self:Attack(shape, "skill.savageblow", CollisionGroups.HitBox)
		if not isvalid(target:GetComponent("MOD.Core.DamageSkinSpawnerComponent")) then target:AddComponent("MOD.Core.DamageSkinSpawnerComponent") end

		local actuallyHit = false
		for _, hc in ipairs(hitComps) do
			if isvalid(hc) and isvalid(hc.Entity) and hc.Entity == target then
				actuallyHit = true
				break
			end
		end

		local damage = self._T.lastSavageBlowDamage or 0
		local baseCrit = self._T.lastSavageBlowIsCritical or false
		local bonus = self._T.shadowEchoBonus or 0
		local bonusCrit = self._T.shadowEchoBonusIsCritical or false

		if not actuallyHit then
			-- 앞선 타격에 대상이 이미 죽어 판정 자체가 실패해도(콜라이더가 더 이상 걸리지 않음) 6줄이 항상
			-- 뜨도록, CalcDamageBase의 skill.savageblow 분기와 동일한 공식(220%~300%)으로 표시 전용 데미지를
			-- 새로 굴린다(실제 Hp에는 영향 없음). 크리티컬/쉐도우 파트너 보너스도 stale 값 대신 여기서 새로 굴린다.
			local critRate = (self._T.currentCritRatePercent or 50) / 100
			local critMult = (self._T.currentCritDamagePercent or 125) / 100
			local combatPower = self._T.pendingSavageBlowCombatPower or 0
			local mult = 2.2 + _UtilLogic:RandomDouble() * (3.0 - 2.2)
			damage = self:ApplyComboAttackBonus(math.floor(combatPower * mult))
			baseCrit = _UtilLogic:RandomDouble() < critRate
			if baseCrit then damage = math.floor(damage * critMult) end
			bonus = 0
			bonusCrit = false
			if self._T.shadowPartnerActive then
				bonus = math.floor(damage * (0.55 + _UtilLogic:RandomDouble() * 0.10))
				bonusCrit = _UtilLogic:RandomDouble() < critRate
				if bonusCrit then bonus = math.floor(bonus * critMult) end
			end
		end

		self:ShowSavageBlowDamageSkin(target, damage, hitIndex, bonus, baseCrit, bonusCrit)
		if bonus > 0 then
			self:PlayShadowEchoHitSound(target)
		end

		-- 히트 이펙트는 실제 판정 성공 여부와 무관하게 매번 재생한다(대상이 죽어도 6번 모두 터져야 한다).
		self:SpawnSavageBlowHitEffect(target, hitRuid, dirX)

		-- 실제로 명중했고 대상이 이번 타격 전까지 살아있었다면 Monster.HandleHitEvent가 이미 히트음을 냈다 -
		-- 여기서 또 내면 같은 타격에 소리가 2번 겹친다(스피어 버스터에서 실측). 이미 죽어있었거나 판정이
		-- 실패한 경우에만 보충 재생한다.
		if isvalid(monsterComp) and (not actuallyHit or wasAlreadyDead) then
			monsterComp:PlayHitSound()
		end

		log("[SavageBlow] DealSavageBlowHit hitIndex=" .. tostring(hitIndex) .. " actuallyHit=" .. tostring(actuallyHit) .. " wasAlreadyDead=" .. tostring(wasAlreadyDead) .. " damage=" .. tostring(damage))
	end

	@ExecSpace("Client")
	method void ShowSavageBlowDamageSkin(Entity target, integer damage, integer hitIndex, integer bonus, boolean baseIsCritical, boolean bonusIsCritical)
		-- 6타를 세로로 6줄 쌓아 보여준다(스피어 버스터의 3줄 배치와 동일한 방식, 줄 수만 6개로 늘림).
		-- 줄 간격은 0.3 (요청: "6줄 간격은 좋다").
		-- (기능 수정 이력)
		--  · 첫 줄이 대상 중심보다 0.75 아래에서 시작해 "다른 스킬보다 너무 아래"라는 피드백 → 0.0으로 올림.
		--  · 이번엔 "약간 높다 - 조금 내려달라"는 피드백 → 시작점을 0.0 → -0.2로 살짝 내렸다.
		--    (6줄: -0.2 / 0.1 / 0.4 / 0.7 / 1.0 / 1.3)
		if not isvalid(target) then return end
		local offsetY = -0.2 + (hitIndex - 1) * 0.3
		local bonusGap = 0.15
		if bonus > 0 then
			-- 쉐도우 파트너 버프가 켜지면 한 타격당 2줄이라 총 12줄이 된다 - 기존 간격(0.4/보너스 0.2)으로는
			-- 12줄이 서로 붙어 보인다는 피드백으로 간격을 한 단계 더 넓혔다(0.5 / 보너스 0.25).
			-- (12줄: -0.2, 0.05 / 0.3, 0.55 / 0.8, 1.05 / 1.3, 1.55 / 1.8, 2.05 / 2.3, 2.55)
			offsetY = -0.2 + (hitIndex - 1) * 0.5
			bonusGap = 0.25
		end
		_DamageSkinService:Play(
			target, self:GetHitDamageSkinId(), 0,
			{ damage }, DamageSkinTweenType.Default, baseIsCritical,
			Vector2(0, offsetY), Vector2(1, 1), 1.0, 1.0, LitMode.Default
		)
		if bonus > 0 then
			_DamageSkinService:Play(
				target, self:GetHitDamageSkinId(), 0,
				{ bonus }, DamageSkinTweenType.Default, bonusIsCritical,
				Vector2(0, offsetY + bonusGap), Vector2(1, 1), 1.0, 1.0, LitMode.Default
			)
		end
		log("[SavageBlow] ShowSavageBlowDamageSkin hitIndex=" .. tostring(hitIndex) .. " damage=" .. tostring(damage) .. " offsetY=" .. tostring(offsetY) .. " crit=" .. tostring(baseIsCritical))
	end

	@ExecSpace("ServerOnly")
	method void SpawnSavageBlowHitEffect(Entity target, string ruid, number dirX)
		-- 몬스터 자리에서 터지는 히트 이펙트. 이 3종(hit1~3)은 애니메이션클립이 아니라 정지 스프라이트라
		-- _EffectService로 재생할 수 없어, 정지 스프라이트를 알파/스케일 트윈으로 띄웠다 사라지게 하는
		-- 기존 전용 엔티티(SpearBurstFadingEffect)를 그대로 재사용한다.
		-- 몬스터의 자식이 아니라 맵의 자식으로 그 순간의 월드 좌표에 스폰한다 - 3번째 타격에 몬스터가 죽어
		-- 엔티티가 비활성화(Enable=false)돼도 남은 타격의 이펙트가 정상적으로 보여야 하기 때문이다.
		if not isvalid(target) then return end
		local map = self.Entity.CurrentMap
		if not isvalid(map) then return end
		local pos = target.TransformComponent.WorldPosition
		local fx = _SpawnService:SpawnByModelId("spearburstfadingeffect", "SavageBlowHitFX", Vector3(pos.x, pos.y + 0.2, 0), map)
		if not isvalid(fx) then return end
		fx:AddComponent("script.SpearBurstFadingEffect")
		local comp = fx:GetComponent("script.SpearBurstFadingEffect")
		if isvalid(comp) then
			comp.ClipRUID = ruid
			comp.IsFlipX = dirX > 0
			comp.StartScale = 1.0
			comp.EndScale = 1.35
			comp.StartAlpha = 1.0
			comp.EndAlpha = 0.0
			comp.HoldDuration = 0.05
			comp.TweenDuration = 0.15
			comp.OrderInLayerValue = 12
			comp.UseSplitGrowth = false
			comp.SecondClipRUID = ""
			comp.PivotOffsetX = 0
			comp.PivotOffsetY = 0
			comp.SecondPivotOffsetX = 0
			comp.SecondPivotOffsetY = 0
		end
		_TimerService:SetTimerOnce(function()
			if isvalid(fx) then
				fx:Destroy()
			end
		end, 0.4)
	end

	@ExecSpace("Server")
	method void RestoreSavageBlowControl()
		self._T.isSavageBlowing = false
		local playerCtrl = self.Entity.PlayerControllerComponent
		if isvalid(playerCtrl) and self._T.pendingSavageBlowWasControllerEnabled then
			playerCtrl.Enable = true
		end
		-- 다른 스킬들과 동일하게 컨트롤이 복구된 시점에 공용 숨고르기 모션을 재생한다.
		self:PlayBreather(self.Entity, self._T.pendingSavageBlowDirX or 1)
	end


	method table FindRushTargets(Vector2 fromPos, number dirX, integer maxCount, number scanRange)
		-- 돌진 전용: 진행 방향 "앞"에 있는 적만 가까운 순으로 최대 maxCount명 고른다.
		-- 뒤쪽 적은 밀어낼 수 없으므로 애초에 제외한다(앞에 아무도 없으면 제자리 시전 판정에도 쓰인다).
		local map = self.Entity.CurrentMap
		if not isvalid(map) then return {} end
		local monsterComps = map:GetChildComponentsByTypeName("script.Monster", true)
		local candidates = {}
		for _, comp in ipairs(monsterComps) do
			---@type Monster
			local mc = comp
			if isvalid(mc) and isvalid(mc.Entity) and not mc.IsDead and mc.Entity.Enable then
				local pos = mc.Entity.TransformComponent.WorldPosition
				local dx = pos.x - fromPos.x
				local dy = pos.y - fromPos.y
				-- (버그 수정) 판정 범위가 고정 8칸이라 사거리(2.33칸)보다 훨씬 길어 멀리 있는 적까지
				-- 맞고 밀렸다. 실제로 밀고 지나갈 수 있는 구간(사거리 + 몸 앞 여유)으로 제한한다.
				if dx * dirX > 0 and math.abs(dx) <= scanRange and math.abs(dy) <= 1.5 then
					table.insert(candidates, { entity = mc.Entity, dist = math.abs(dx) })
				end
			end
		end
		table.sort(candidates, function(a, b) return a.dist < b.dist end)
		local result = {}
		for i = 1, math.min(#candidates, maxCount) do
			table.insert(result, candidates[i].entity)
		end
		return result
	end

	method number FindGroundEdgeX(FootholdComponent fh, Foothold startFh, number fromX, number dirX, number maxDistance)
		-- 지금 밟고 있는 발판에서 dirX 방향으로 "지면이 실제로 끊기는 지점"의 x를 돌려준다.
		-- 같은 지면이 여러 조각으로 나뉘어 있을 수 있어 NextFootholdId/PreviousFootholdId 체인을 따라간다
		-- (AttackTeleport의 검증된 로직과 동일한 방식). 벽(IsBlockVerticalLine)이 먼저 나오면 그 앞에서 끊는다.
		local desiredX = fromX + dirX * maxDistance
		if fh == nil or startFh == nil then return desiredX end

		local EDGE_MARGIN = 0.15
		local chainFh = startFh
		local farEdgeX = (dirX > 0) and math.max(startFh.StartPoint.x, startFh.EndPoint.x) or math.min(startFh.StartPoint.x, startFh.EndPoint.x)
		for _ = 1, 50 do
			if (dirX > 0 and farEdgeX >= desiredX) or (dirX < 0 and farEdgeX <= desiredX) then break end
			local nextId = (dirX > 0) and chainFh.NextFootholdId or chainFh.PreviousFootholdId
			if nextId == nil or nextId == 0 then break end
			local nextFh = fh:GetFoothold(nextId)
			if nextFh == nil then break end
			chainFh = nextFh
			farEdgeX = (dirX > 0) and math.max(nextFh.StartPoint.x, nextFh.EndPoint.x) or math.min(nextFh.StartPoint.x, nextFh.EndPoint.x)
		end
		local limitX = farEdgeX - dirX * EDGE_MARGIN
		if (dirX > 0 and limitX < desiredX) or (dirX < 0 and limitX > desiredX) then
			desiredX = limitX
		end
		return desiredX
	end

	@ExecSpace("ServerOnly")
	method void AttackRush(number combatPower, number atkMultiplier, string weaponClass)
		-- 돌진(4차): 전방의 적을 최대 10명까지 밀어내며 2.95초 동안 전진한다.
		-- (요청) 앞에 적이 없으면 돌진하지 않고 제자리에서 시전만 한다.
		-- 발판이 끊기는 지점에서는 플레이어도 몬스터도 더 나아가지 않는다.
		self:StopBreather()
		local currentState = self.Entity.StateComponent.CurrentStateName
		if currentState == "DEAD" or currentState == "CLIMB" or currentState == "LADDER" then return end
		if self._T.isRushing then
			log("PlayerAttack: AttackRush 요청 차단됨(이미 진행 중)")
			return
		end
		self._T.isRushing = true

		local playerCtrl = self.Entity.PlayerControllerComponent
		local dirX = playerCtrl.LookDirectionX
		local startPos = self.Entity.TransformComponent.WorldPosition
		local rb = self.Entity.RigidbodyComponent
		local map = self.Entity.CurrentMap
		local fh = isvalid(map) and map.FootholdComponent or nil

		-- (요청) 사거리 1/3로 축소: 7.0 -> 2.33. 몬스터 밀기 한계/판정 범위 계산에 쓴다
		-- (플레이어 본인의 정지 지점은 이동 주체인 클라이언트가 RunRushMove에서 따로 계산한다).
		local RUSH_MAX_DISTANCE = 2.33
		-- 플레이어 몸 앞 "제설판" 거리 - 밀린 몬스터가 최종적으로 서는 위치(플레이어 정지점 + 이 값).
		local RUSH_PUSH_FRONT = 1.0
		-- (요청) 이동 시간 0.25초 / 딜레이(컨트롤 복귀) 0.27초 / 모션 지속시간 0.4초.
		-- 모션은 딜레이보다 길게 유지해 딜레이가 끝날 때까지 자세가 바뀌지 않게 한다(요청).
		-- (요청) 공속이 오르면 모션이 빨라지고 딜레이도 그만큼 줄어야 한다 - 세 값에 모두 같은 배율을
		-- 곱해 "이동 종료 < 딜레이 종료 < 모션 종료" 순서를 그대로 유지한다(하나만 줄이면 딜레이가
		-- 이동보다 먼저 끝나 컨트롤러가 돌진 자세를 덮어쓴다). 돌진 거리(RUSH_MAX_DISTANCE)는 그대로라
		-- 공속이 오르면 같은 거리를 더 빨리 주파한다.
		local mult = math.max(0.1, math.min(atkMultiplier or 1.0, 3.0))
		local RUSH_MOVE_DURATION = 0.25 * mult
		local RUSH_DELAY = 0.27 * mult
		local RUSH_MOTION_DURATION = 0.4 * mult

		-- 밀어낼 대상(전방 최대 10명)
		-- 판정 범위 = 돌진 사거리 + 몸 앞 여유(밀어내는 폭). 사거리를 바꾸면 판정도 같이 따라온다.
		local targets = self:FindRushTargets(Vector2(startPos.x, startPos.y), dirX, 10, RUSH_MAX_DISTANCE + RUSH_PUSH_FRONT)

		self._T.pendingRushWasControllerEnabled = isvalid(playerCtrl) and playerCtrl.Enable
		if isvalid(playerCtrl) then playerCtrl.Enable = false end
		if isvalid(self.Entity.MovementComponent) then self.Entity.MovementComponent:Stop() end


		-- 모션: (요청) 창/두손검 = stabT1의 2번째 동작, 한손검 = stabO1의 2번째 동작.
		-- 프레임 인덱스는 0부터이므로 "2번째" = 1. 한 자세로 고정해 돌진 내내 유지한다.
		-- (요청/사진 확인) 창 = 양손무기 찌르기1(stabT1)의 **끝자세**(창을 앞으로 완전히 내뻗은 프레임).
		-- 두손검은 한손검과 같은 모션(stabO1 2번째 프레임)을 쓴다.
		-- 프레임 인덱스는 0부터. stabT1은 앞 프레임이 창을 뒤로 당긴 준비자세라 끝 프레임을 잡아야 한다.
		local motionName = "stabO1"
		local motionFrame = 1
		if weaponClass == "spear" then
			motionName = "stabT1"
			motionFrame = 2
		end
		self:PlayRushMotion(self.Entity, motionName, dirX, RUSH_MOTION_DURATION, motionFrame)
		self:PlayRushCastEffect(dirX)
		self:PlayRushUseSound(self.Entity)

		if #targets == 0 then
			-- 앞에 적 없음: 제자리 시전. 이동/타격 없이 모션만 끝나면 컨트롤을 돌려준다.
			log("PlayerAttack: AttackRush 제자리 시전(전방에 적 없음)")
			_TimerService:SetTimerOnce(function()
				self:RestoreRushControl()
			end, RUSH_DELAY)
			return
		end

		-- 이동 한계: 지면이 끊기는 지점까지만(위에서 선언한 RUSH_MAX_DISTANCE 사용).
		local startFh = isvalid(rb) and rb:GetCurrentFoothold() or nil
		local stopX = self:FindGroundEdgeX(fh, startFh, startPos.x, dirX, RUSH_MAX_DISTANCE)

		-- 몬스터별로 "플레이어와의 상대 간격"과 "그 몬스터 자신의 지면 끝"을 미리 잡아둔다.
		-- (요청) 몬스터는 상대 간격을 유지한 채 따라오는 게 아니라, 플레이어 앞의 "제설판"에 밀려
		-- 한 자리에 모여야 한다. 예) 몬스터가 x=1,2,3이고 돌진거리가 3이면 셋 다 최종 x=4.
		-- 그래서 개별 offsetX를 쓰지 않고, 매 틱 "플레이어 앞면(plowX)보다 뒤에 있으면 plowX로 끌어올린다".
		local pushInfos = {}
		for _, t in ipairs(targets) do
			if isvalid(t) then
				local tp = t.TransformComponent.WorldPosition
				local tRb = t.RigidbodyComponent
				local tFh = isvalid(tRb) and tRb:GetCurrentFoothold() or nil
				table.insert(pushInfos, {
					entity = t,
					limitX = self:FindGroundEdgeX(fh, tFh, tp.x, dirX, RUSH_MAX_DISTANCE + 2.0),
				})
			end
		end

		self._T.pendingRushCombatPower = combatPower
		self._T.rushDirX = dirX
		self._T.rushStopX = stopX
		self._T.rushPushInfos = pushInfos
		self._T.rushStartX = startPos.x
		self._T.rushElapsed = 0
		self._T.rushDuration = RUSH_MOVE_DURATION

		-- 데미지는 시전 1회분만(전투력 300~400%) 각 대상에게 준다 - 밀려나는 동안 중복 타격하지 않는다.
		self:DealRushHits(targets)

		-- (핵심) 플레이어 이동은 **클라이언트**가 매 틱 SetWorldPosition으로 처리한다.
		-- 실측 근거: 서버에서 플레이어를 움직이는 수단이 전부 막혀 있다 - rb.MoveVelocity 대입 무효,
		-- MovementComponent:MoveToDirection 무효(컨트롤러 ON/OFF 둘 다), rb.RealMoveVelocity는 서버에서
		-- 항상 0이라 속도 피드백 불가, AddForce는 관성이 누적돼 발판 끝을 뚫고 나가며 Stop()으로도 못 세운다.
		-- 반면 클라이언트에서 매 틱 SetWorldPosition하면 완전 등속으로 움직이고 되돌림도 없다(5초 후 위치 유지 확인).
		-- 플레이어 위치 권한이 클라이언트에 있어서 서버가 밀면 클라 예측이 되돌리는 것이 원인이었다.
		-- (몬스터는 서버 권한이라 서버 틱에서 SetWorldPosition으로 잘 밀린다 - 아래 RushTick.)
		-- 컨트롤러 복귀 시점을 딜레이(0.27)로 넘긴다 - 이동 종료(0.25)에 복귀시키면 딜레이가 끝나기도 전에
		-- 컨트롤러가 서기/걷기 애니메이션을 덮어써 돌진 자세가 풀린다(요청: 딜레이 도중 모션 유지).
		self:RunRushMove(dirX, RUSH_MOVE_DURATION, RUSH_DELAY, self.Entity.PlayerComponent.UserId)

		-- 서버 틱: 밀리는 몬스터만 담당(플레이어가 실제로 나아간 만큼 따라 옮긴다).
		self._T.rushTimerId = _TimerService:SetTimerRepeat(function()
			self:RushTick()
		end, 1 / 60)

		_TimerService:SetTimerOnce(function()
			self:EndRush()
		end, RUSH_DELAY)
		log("PlayerAttack: AttackRush 시작 targets=" .. tostring(#targets) .. " stopX=" .. tostring(stopX))
	end

	@ExecSpace("ServerOnly")
	method void RushTick()
		-- 돌진 이동 1틱. 플레이어를 목표 x까지 전진시키고, 밀리는 몬스터들을 같은 진행량만큼 끌고 간다.
		if not self._T.isRushing then return end
		if not isvalid(self.Entity) then return end
		local RUSH_PUSH_FRONT = 1.0
		local dirX = self._T.rushDirX or 1
		local curX = self.Entity.TransformComponent.WorldPosition.x

		-- 몬스터: 플레이어 앞면(plowX)에 닿은 놈만 그 앞으로 밀어낸다. 이미 plowX보다 앞에 있으면
		-- 건드리지 않는다 -> 뒤쪽 몬스터부터 차례로 걸려 결국 다 같은 자리(최종 plowX)에 모인다.
		local plowX = curX + dirX * RUSH_PUSH_FRONT
		for _, info in ipairs(self._T.rushPushInfos or {}) do
			local t = info.entity
			if isvalid(t) then
				local tRb = t.RigidbodyComponent
				if isvalid(tRb) then
					local tp = t.TransformComponent.WorldPosition
					local behindPlow = (dirX > 0 and tp.x < plowX) or (dirX < 0 and tp.x > plowX)
					if behindPlow then
						local wantX = plowX
						local limitX = info.limitX
						-- 자기 발판 끝을 넘어서는 밀리지 않는다(요청).
						if (dirX > 0 and wantX > limitX) or (dirX < 0 and wantX < limitX) then
							wantX = limitX
						end
						if (dirX > 0 and wantX > tp.x) or (dirX < 0 and wantX < tp.x) then
							tRb:SetWorldPosition(Vector2(wantX, tp.y))
						end
					end
				end
			end
		end
	end

	@ExecSpace("Client")
	method void RunRushMove(number dirX, number duration, number ctrlRestoreDelay)
		-- 돌진의 플레이어 이동. **반드시 클라이언트에서** 돈다 - 서버에서 플레이어를 움직이는 수단은
		-- 전부 무효/불안정하고(AttackRush 주석 참고), 클라이언트에서 매 틱 SetWorldPosition하면
		-- 완전 등속 + 되돌림 없음이 실측으로 확인됐다.
		if not isvalid(self.Entity) then return end
		local rb = self.Entity.RigidbodyComponent
		if not isvalid(rb) then return end
		local playerCtrl = self.Entity.PlayerControllerComponent
		local mv = self.Entity.MovementComponent

		-- 정지 지점(지면이 끊기는 곳)은 여기서 계산한다 - 이동 주체가 클라이언트이기 때문.
		-- (요청) 이동 시간 0.3초. 최대 사거리를 그 안에 주파하도록 속도를 역산한다.
		-- (요청) 사거리 1/3로 축소: 7.0 -> 2.33.
		local RUSH_MAX_DISTANCE = 2.33
		local RUSH_SPEED = RUSH_MAX_DISTANCE / duration
		local startPos = self.Entity.TransformComponent.WorldPosition
		local map = self.Entity.CurrentMap
		local fh = isvalid(map) and map.FootholdComponent or nil
		local startFh = rb:GetCurrentFoothold()
		local stopX = self:FindGroundEdgeX(fh, startFh, startPos.x, dirX, RUSH_MAX_DISTANCE)

		-- (버그 수정) 예전엔 여기서 "원래 켜져 있었나"를 읽어 그 값일 때만 복구했는데, 이제 PlayRushMotion이
		-- 이 시점보다 먼저 컨트롤러를 꺼버릴 수 있어(둘은 별도 RPC라 순서가 보장되지 않는다) 항상 false로
		-- 읽혀 영영 복구되지 않는다. 시전 자체가 DEAD/사다리 상태를 막고 들어오므로 무조건 복구한다.
		if isvalid(playerCtrl) then
			playerCtrl.Enable = false
			playerCtrl.LookDirectionX = dirX
		end

		local elapsed = 0
		if self._T.rushMoveTimerId ~= nil then
			_TimerService:ClearTimer(self._T.rushMoveTimerId)
		end
		self._T.rushMoveTimerId = _TimerService:SetTimerRepeat(function()
			if not isvalid(self.Entity) then return end
			elapsed = elapsed + 1 / 60
			local cur = self.Entity.TransformComponent.WorldPosition
			local wantX = startPos.x + dirX * RUSH_SPEED * elapsed
			-- 발판이 끊기는 지점을 넘어가지 않는다(요청) - 넘길 값은 여기서 잘라낸다.
			if (dirX > 0 and wantX > stopX) or (dirX < 0 and wantX < stopX) then
				wantX = stopX
			end
			rb:SetWorldPosition(Vector2(wantX, cur.y))
		end, 1 / 60)

		-- 이동만 먼저 끝낸다(컨트롤러는 아직 잠근 채로 둔다 - 자세 유지).
		_TimerService:SetTimerOnce(function()
			if self._T.rushMoveTimerId ~= nil then
				_TimerService:ClearTimer(self._T.rushMoveTimerId)
				self._T.rushMoveTimerId = nil
			end
			if isvalid(mv) then mv:Stop() end
			log("[Rush] RunRushMove 이동종료 stopX=" .. tostring(stopX))
		end, duration)

		-- 컨트롤러 복귀는 딜레이 시점에. 이때까지는 돌진 자세가 그대로 유지된다.
		_TimerService:SetTimerOnce(function()
			if isvalid(playerCtrl) then
				playerCtrl.Enable = true
			end
			log("[Rush] RunRushMove 컨트롤 복귀")
		end, ctrlRestoreDelay)
		log("[Rush] RunRushMove 시작 dirX=" .. tostring(dirX) .. " stopX=" .. tostring(stopX))
	end

	@ExecSpace("ServerOnly")
	method void EndRush()
		-- 돌진 종료: 이동 틱을 끄고 컨트롤을 돌려준다.
		if self._T.rushTimerId ~= nil then
			_TimerService:ClearTimer(self._T.rushTimerId)
			self._T.rushTimerId = nil
		end
		self._T.rushPushInfos = nil
		if isvalid(self.Entity.MovementComponent) then
			self.Entity.MovementComponent:Stop()
		end
		self:RestoreRushControl()
	end

	@ExecSpace("ServerOnly")
	method void RestoreRushControl()
		-- (버그 수정) RestoreBrandishControl과 동일한 이유로 무조건 복구한다 - 이미 컨트롤러가 꺼져 있는
		-- 동안 돌진이 시작하면 pendingRushWasControllerEnabled가 false로 찍혀 영영 복구되지 않았다.
		-- 클라이언트 쪽(RunRushMove)은 같은 원인으로 이미 무조건 복구로 고쳐져 있었는데 서버 쪽인
		-- 여기만 남아 있었다.
		self._T.isRushing = false
		local playerCtrl = self.Entity.PlayerControllerComponent
		if isvalid(playerCtrl) then
			playerCtrl.Enable = true
		end
		log("[Rush] RestoreRushControl 컨트롤 복구 wasCtrl=" .. tostring(self._T.pendingRushWasControllerEnabled))
	end

	@ExecSpace("ServerOnly")
	method void DealRushHits(table targets)
		-- 대상마다 개별 판정을 낸다. 실제 데미지 수치는 CalcDamageBase의 "skill.rush" 분기가 계산한다
		-- (다중 대상이라도 대상별 단일 포인터(rushCurrentTarget)로 걸러 이웃 겹침 타격을 막는다).
		for _, t in ipairs(targets) do
			if isvalid(t) then
				self._T.rushCurrentTarget = t
				local pos = t.TransformComponent.WorldPosition
				local shape = BoxShape(Vector2(pos.x, pos.y), Vector2(1.0, 1.6), 0)
				self:AttackShadowSafe(shape, "skill.rush", t)
			end
		end
	end

	@ExecSpace("ServerOnly")
	method void CastDoubleJump(number dirX)
		-- 더블 점프(1차): 이동 자체는 시전한 클라이언트가 처리하고(SkillManager.RunDoubleJumpMove),
		-- 여기서는 도약 지점에 남는 이펙트와 사용음만 담당한다. 두 RUID 모두 원본 팩
		-- skill/3300.img/skill/33001102(더블 점프)의 effect / _audio/Use 그대로다.
		self:PlayDoubleJumpSound(self.Entity)
		self:SpawnDoubleJumpEffect(dirX)
		log("[DoubleJump] CastDoubleJump dirX=" .. tostring(dirX))
	end

	@ExecSpace("Multicast")
	method void PlayDoubleJumpSound(Entity caster)
		-- 더블 점프 사용음. 주변 모든 클라이언트에서 재생한다(돌진 PlayRushUseSound와 동일한 패턴).
		if not self:IsClient() then return end
		if not isvalid(caster) then return end
		_SoundService:PlaySound("83efc24157d04c67b152d6782ce82b6b", 1.0)
	end

	@ExecSpace("ServerOnly")
	method void SpawnDoubleJumpEffect(number dirX)
		-- 도약한 "그 자리"에 남는 이펙트라 플레이어가 아니라 맵에 붙인다(플레이어에 붙이면 같이 날아가서
		-- 발자국처럼 보이지 않는다). 재생/페이드는 기존 SpearBurstFadingEffect를 그대로 재사용한다.
		local map = self.Entity.CurrentMap
		if not isvalid(map) then return end
		local pos = self.Entity.TransformComponent.WorldPosition
		self._T.doubleJumpFxSeq = (self._T.doubleJumpFxSeq or 0) + 1
		local fx = _SpawnService:SpawnByModelId("spearburstfadingeffect", "DoubleJumpFx" .. tostring(self._T.doubleJumpFxSeq), Vector3(pos.x, pos.y + 0.25, 0), map)
		if not isvalid(fx) then
			log_warning("[DoubleJump] 이펙트 스폰 실패")
			return
		end
		fx:AddComponent("script.SpearBurstFadingEffect")
		local comp = fx:GetComponent("script.SpearBurstFadingEffect")
		if isvalid(comp) then
			comp.IsFlipX = dirX > 0        -- (돌진과 동일) 원본 아트가 왼쪽 기준이라 오른쪽으로 갈 때 반전
			comp.StartAlpha = 1.0
			comp.EndAlpha = 0.0
			comp.HoldDuration = 0.2
			comp.TweenDuration = 0.25
			comp.StartScale = 1.0
			comp.EndScale = 1.0
			comp.OrderInLayerValue = 3
			comp.ClipRUID = "a2b497a1013f44e7b29ef8de081720f1"
		end
		_TimerService:SetTimerOnce(function()
			if isvalid(fx) then fx:Destroy() end
		end, 0.6)
		log("[DoubleJump] 이펙트 스폰 x=" .. string.format("%.2f", pos.x) .. " y=" .. string.format("%.2f", pos.y))
	end

	@ExecSpace("Multicast")
	method void PlayRushUseSound(Entity attacker)
		-- 돌진 사용음. 구버전 원본 팩(skill/111.img/skill/1111012)의 _audio/Use가 MSW 라이브러리에
		-- 그대로 살아있어 업로드 없이 참조한다(아트만 구버전이 없어 직접 조달했다).
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		_SoundService:PlaySound("d9522927411a4f8f9dc7e083ee891f7f", 1.0)
	end

	@ExecSpace("Multicast")
	method void PlayRushMotion(Entity attacker, string motionName, number dirX, number holdDuration, integer frameIndex)
		-- 지정한 한 프레임(frameIndex)만 잡아 돌진 내내 그 자세를 유지한다.
		-- PlayAttackMotionFramed와 같은 방식이되 시작/끝 프레임을 같게 줘서 정지 자세로 만든다.
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		local avatarRenderer = attacker.AvatarRendererComponent
		if not isvalid(avatarRenderer) then return end
		local body = avatarRenderer:GetBodyEntity()
		if not isvalid(body) then return end

		avatarRenderer.ShowDefaultWeaponEffects = false
		if isvalid(attacker.MovementComponent) then
			attacker.MovementComponent:Stop()
		end
		local playerCtrl = attacker.PlayerControllerComponent
		if isvalid(playerCtrl) then
			-- (버그 수정) 방향키를 누른 채 시전하면 돌진 자세가 안 보였다 - PlayerController가 걷기
			-- 애니메이션을 계속 내보내 아래 자세 이벤트를 덮어쓰기 때문. 컨트롤러를 끄는 건 클라의
			-- RunRushMove였는데 그건 별도 RPC라 이 모션보다 늦게 도착할 수 있었다. 자세를 보내기
			-- **직전에** 여기서 끊어, 시전~모션 사이에 다른 행동/애니메이션이 끼어들 틈을 없앤다.
			-- (조작 주체인 본인 클라이언트에서만 끈다 - Multicast라 남의 화면에서도 실행된다.)
			if _UserService.LocalPlayer == attacker then
				playerCtrl.Enable = false
			end
			playerCtrl.LookDirectionX = dirX
		end
		self._T.isRushMotionPlaying = true
		self._T.lockedRushDirX = dirX
		self._T.lockedRushMotionName = motionName
		self._T.lockedRushFrame = frameIndex

		body:SendEvent(ActionStateChangedEvent(motionName, motionName, 1.0, SpriteAnimClipPlayType.Onetime, frameIndex, frameIndex))
		log("[Rush] PlayRushMotion sent: " .. tostring(motionName) .. " frame=" .. tostring(frameIndex))

		_TimerService:SetTimerOnce(function()
			self._T.isRushMotionPlaying = false
			if isvalid(avatarRenderer) then
				avatarRenderer.ShowDefaultWeaponEffects = true
			end
			local sc = self.Entity.StateComponent
			if isvalid(sc) and sc.CurrentStateName ~= "DEAD" then
				sc:ChangeState("IDLE")
				sc:ChangeState("MOVE")
				sc:ChangeState("IDLE")
			end
		end, holdDuration)
	end

	@ExecSpace("ServerOnly")
	method void PlayRushCastEffect(number dirX)
		-- 돌진 이펙트: 구버전 원본에서 뽑아온 노란 빔 5프레임 + 흰 섬광 6프레임을 겹쳐 재생한다
		-- (원본 WZ의 effect / effect0 2겹 구조). MSW 라이브러리의 같은 스킬 effect는 현대 리메이크
		-- 아트라 쓰지 않는다. RUID 대응표: msw-dev-tools/resources/돌진/RUID.md
		local beam = {
			"c3dabaa7cf6543aaae6e12a8f7450755",
			"e329cbdd2402405f8a4ffa09dd73369f",
			"35e3a144e09c4f0db5ea3ddf9f8e6a21",
			"e01b24a0d0b14a919cce57e5a8e54c4c",
			"598fa2d4779049b9be5d9c4e62194d0c",
		}
		local white = {
			"5e115329cbbf43b481c144ae34190357",
			"4700271227d84b589e384262c3ace071",
			"560dc982d20745b391af3911ed148700",
			"ba976729a84a4003939e1d14c12b581d",
			"917b8bff6c5044f4a1bea90b7606609c",
			"639c7632196842e08b5a1a31a5f296f8",
		}
		-- (요청) 이펙트가 캐릭터보다 너무 앞에 떠 있어 몸에 겹치도록 당긴다.
		-- 스프라이트가 좌우 반전(IsFlipX)되면서 그림 덩어리가 오프셋 기준보다 앞쪽으로 쏠리기 때문에
		-- 음수 오프셋이 필요하다. 화면 비교(-1.4/-0.9/-0.4)로 -0.9에서 캐릭터가 빔 안에 들어오는 것을 확인.
		-- 흰 섬광은 스프라이트가 더 작아(195px vs 260px) 같은 비율로 -0.7.
		-- 전방 오프셋(음수일수록 뒤). 조정 이력: -1.5/-1.2/-1.05/-0.9/-0.3/0.45를 거쳐 -0.45로 확정(요청).
		-- 흰 섬광은 스프라이트가 작아(195px vs 260px) 같은 비율로 -0.35.
		self:SpawnRushFrameEffect(beam, dirX, -0.45, 0.35, 6)
		self:SpawnRushFrameEffect(white, dirX, -0.35, 0.45, 7)
	end

	@ExecSpace("ServerOnly")
	method void SpawnRushFrameEffect(table frames, number dirX, number offsetX, number offsetY, integer orderInLayer)
		-- 정지 스프라이트 여러 장을 순서대로 갈아끼워 애니메이션처럼 재생한다
		-- (SpawnSlashBlastCastEffect와 같은 패턴 - ClipRUID가 @Sync라 바뀔 때마다 클라가 재적용).
		local frameInterval = 0.1
		self._T.trailFxSeq = (self._T.trailFxSeq or 0) + 1
		local fx = _SpawnService:SpawnByModelId("spearburstfadingeffect", "RushFx" .. tostring(self._T.trailFxSeq), Vector3(offsetX * dirX, offsetY, 0), self.Entity)
		if not isvalid(fx) then return end
		fx:AddComponent("script.SpearBurstFadingEffect")
		local comp = fx:GetComponent("script.SpearBurstFadingEffect")
		if isvalid(comp) then
			comp.IsFlipX = dirX > 0        -- (실측 정정) 원본 이미지는 왼쪽 방향 - 오른쪽 볼 때 좌우 반전
			comp.StartAlpha = 1.0
			comp.EndAlpha = 1.0
			comp.HoldDuration = 5.0        -- 수명보다 길게 잡아 트윈이 시작되지 않게(프레임 교체만 사용)
			comp.TweenDuration = 0.0
			comp.StartScale = 1.0
			comp.EndScale = 1.0
			comp.OrderInLayerValue = orderInLayer
			comp.ClipRUID = frames[1]
		end
		for i = 2, #frames do
			local frameRuid = frames[i]
			_TimerService:SetTimerOnce(function()
				if isvalid(comp) then comp.ClipRUID = frameRuid end
			end, (i - 1) * frameInterval)
		end
		_TimerService:SetTimerOnce(function()
			if isvalid(fx) then fx:Destroy() end
		end, #frames * frameInterval + 0.05)
	end


	@ExecSpace("Multicast")
	method void DisableLocalControllerForBrandish(Entity attacker)
		-- 브랜디쉬 시전 순간, 조작 주체(로컬 플레이어) 클라이언트에서 PlayerController를 즉시 끊어
		-- 걷기(MOVE) 애니메이션이 첫 모션(swingT3)을 덮어쓰지 못하게 한다. 돌진 PlayRushMotion과 동일한 패턴.
		-- Multicast라 남의 화면에서도 실행되므로, 본인 클라에서만 끈다(남의 화면 모션은 상태/모션 이벤트로 구동됨).
		-- 복구는 서버 RestoreBrandishControl(Enable=true 동기화)가 담당한다.
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		if _UserService.LocalPlayer ~= attacker then return end
		local playerCtrl = attacker.PlayerControllerComponent
		if isvalid(playerCtrl) then playerCtrl.Enable = false end
		if isvalid(attacker.MovementComponent) then attacker.MovementComponent:Stop() end
	end

	@ExecSpace("ServerOnly")
	method void AttackBrandish(number combatPower, number atkMultiplier, string weaponClass, boolean enhanced)
		-- 브랜디쉬(4차): 검을 크게 휘둘러 전방의 적을 벤다. 한 번 시전에 총 3줄 -
		-- swingT3 마지막에 1줄, 이어지는 swingTF 마지막에 2줄이 들어간다(요청). 줄당 전투력의 400~700% 피해.
		-- 모션은 무기 분류와 무관하게 swingT3 -> swingTF 연속 재생(요청) - weaponClass는 쓰지 않는다.
		self:StopBreather()
		local currentState = self.Entity.StateComponent.CurrentStateName
		if currentState == "DEAD" or currentState == "CLIMB" or currentState == "LADDER" then return end
		if self._T.isBrandishing then
			log("PlayerAttack: AttackBrandish 요청 차단됨(이미 진행 중)")
			return
		end
		self._T.isBrandishing = true
		self._T.brandish2Queued = false   -- 이번 브랜디쉬의 콤보 예약 초기화(이전 시전의 잔여 예약 방지)
		self._T.brandishEnhanced = (enhanced == true)   -- 브랜디쉬 강화 버프 활성 여부(붉은 이펙트/색감)

		local mult = math.max(0.1, math.min(atkMultiplier or 1.0, 3.0))
		self._T.pendingBrandishCombatPower = combatPower
		local playerCtrl = self.Entity.PlayerControllerComponent
		local dirX = playerCtrl.LookDirectionX
		self._T.pendingBrandishDirX = dirX
		self._T.pendingBrandishWasCtrl = isvalid(playerCtrl) and playerCtrl.Enable
		if isvalid(playerCtrl) then playerCtrl.Enable = false end

		-- 시전 중 몸동작이 브랜디쉬 자세를 덮어쓰는 경로를 이번 시전 동안만 전부 막는다.
		-- (요청 ①) "맞으면 피격 모션 때문에 모션이 끊긴다" (요청 ②) "점프 브랜디쉬 중 착지하면 모션이 멈춘다"
		-- 원인은 같다 - 상태가 바뀌면 엔진(AvatarStateAnimationComponent)이 그 상태에 매핑된 몸동작을
		-- 자동으로 내려보내 진행 중인 raw 클립을 덮어쓴다. 매핑 자체를 빼두면(msw-avatar Strategy A)
		-- 상태만 조용히 바뀌고 몸에는 아무 클립도 안 내려가 브랜디쉬 자세가 그대로 이어진다.
		-- (버그 수정 - 이동 중 시전) 순서가 결정적이다. 아래 클라 컨트롤러 끄기 + 이동정지는 MOVE→IDLE
		-- 전환을 유발하는데, 그 순간 IDLE 매핑이 남아 있으면 엔진이 stand를 내려보내 첫 모션(swingT3)을
		-- 묻는다("idle 자세에서 시작하여 앞쪽 모션이 묻힌다"). 예전엔 이 억제가 ServerOnly라 @Sync가 클라에
		-- 도착하기 전에 전환이 일어나 stand가 새어나왔다. Multicast로 바꿔 클라에서도 즉시 매핑을 빼두고,
		-- 반드시 이동정지(MOVE→IDLE 유발)보다 **먼저** 호출한다. RestoreBrandishStateMotions(@Sync)에서 복구.
		self:SuppressBrandishStateMotions()
		self:SetBrandishMotionGuard(true)

		-- (버그 수정) 이동(방향키 홀드) 중 브랜디쉬를 쓰면 걷기 애니메이션이 첫 모션을 덮어쓰는 문제.
		-- 위 컨트롤러 끄기는 ServerOnly라 @Sync 도착 전까지 클라 PlayerController가 걷기(MOVE)를 계속
		-- 내보낸다. 돌진(PlayRushMotion)처럼 조작 주체 클라에서 즉시 컨트롤러를 끊는다(매핑은 이미 위에서
		-- 빼뒀으므로 이 정지가 유발하는 MOVE→IDLE에서 stand도 안 나온다). 복구는 서버 RestoreBrandishControl.
		self:DisableLocalControllerForBrandish(self.Entity)
		if isvalid(self.Entity.MovementComponent) then self.Entity.MovementComponent:Stop() end

		-- (요청) 모션 속도 2배 + 그만큼 못 움직이는 기간도 짧게. PlayAttackMotion은 재생속도를 1/배율로
		-- 잡으므로, 배율을 절반으로 넘기면 재생속도가 2배가 되고 아래 타이머들도 전부 같은 배율을 쓰므로
		-- 모션/판정/조작복구가 통째로 정확히 절반 시간에 끝난다(싱크 유지). 데미지 공식은 mult가 아니라
		-- pendingBrandishCombatPower를 쓰므로 이 변경에 영향받지 않는다.
		-- (요청) 그 2배에서 다시 20% 느리게 -> 재생속도 2.0배 -> 1.6배. 배율은 재생속도의 역수라
		-- 0.5 / 0.8 = 0.625를 곱한다.
		local motionMult = mult * 0.625
		-- (요청) 마지막 모션(swingTF)만 0.2초 더 길게. raw 클립 길이가 0.65*배율이므로, 배율에
		-- 0.2/0.65를 더하면 그 클립만 정확히 0.2초 길어진다(= 그만큼 더 천천히 재생된다).
		-- 아래 2타 판정/조작복구도 이 배율을 쓰므로 늘어난 길이에 그대로 따라붙는다.
		local finishMult = motionMult + 0.2 / 0.65
		-- swingTF 시작 시각(= swingT3 클립이 끝나는 시각). 아래 2타/조작복구의 기준점.
		local finishStart = 0.65 * motionMult
		-- (요청) 2타의 2줄 사이 텀 - 같은 틱에 몰아 넣으면 숫자가 한꺼번에 툭 튀어나와 뻣뻣하다.
		-- 이 스킬의 다른 시간값과 동일하게 공속 배율을 태운다(공속이 오르면 텀도 같이 좁아진다) -
		-- 고정값으로 두면 공속이 아주 빠를 때 둘째 줄이 조작 복구 뒤로 밀려난다.
		self._T.brandishFinishGap = 0.1 * mult

		-- 모션은 파워스트라이크와 같은 재생기(PlayAttackMotion)를 쓴다 - 상태 변경 시 자세를 다시
		-- 덧씌우는 기존 핸들러(HandleStateChangeEvent)가 그대로 적용돼 이동 중에도 모션이 살아남는다.
		-- raw 모션 한 클립의 길이는 0.65초 * 배율이다(PlayAttackMotion에 실측 문서화됨) - 두 모션을
		-- 그 길이만큼 띄워 연달아 재생하고, 각 타격을 클립이 끝나기 직전(0.55*배율, 약 85% 지점)에 맞춘다.
		self:PlayAttackMotion(self.Entity, "swingT3", dirX, motionMult)
		self:PlayBrandishCastEffect(self.Entity, dirX, self._T.brandishEnhanced == true)
		self:PlayBrandishUseSound(self.Entity)

		-- 1타: swingT3의 마지막 모션에서 1줄(요청).
		_TimerService:SetTimerOnce(function()
			self:DealBrandishFirstHits()
		end, 0.55 * motionMult)
		-- swingT3가 끝나는 시점에 swingTF를 이어서 재생한다(요청). 이 클립만 0.2초 긴 배율을 쓴다.
		_TimerService:SetTimerOnce(function()
			self:PlayAttackMotion(self.Entity, "swingTF", self._T.pendingBrandishDirX or 1, finishMult)
		end, finishStart)
		-- 2타: swingTF의 마지막 동작에서 2줄(요청). 1타에서 잡아둔 그 대상들만 때린다.
		-- 길어진 swingTF 클립의 같은 지점(85%)이라 판정도 그만큼 뒤로 밀린다.
		_TimerService:SetTimerOnce(function()
			self:DealBrandishFinishHits()
		end, finishStart + 0.55 * finishMult)

		-- 조작 복구(못 움직이는 기간의 끝) - swingTF 배율을 따라가므로 마지막 모션이 길어진 만큼 같이 밀린다.
		-- ⚠ SkillManager의 브랜디쉬 공용 쿨다운이 이 시각과 반드시 같아야 한다(어긋나면 홀드 연속 시전이
		-- "이미 진행 중"으로 차단되거나, 모션이 끝났는데도 다음 시전이 안 나간다) - 그 쪽 주석 참고.
		-- (브랜디쉬2 콤보) 브랜디쉬 진행 [절반~끝]에 브랜디쉬를 재입력하면 SkillManager가 QueueBrandish2로
		-- brandish2Queued를 켠다. 그 경우 여기서 조작을 복구하는 대신 AttackBrandish2(빠른 추가 2줄)로 이어
		-- 간다 - 시전 잠금(isBrandishing/매핑억제/가드)을 그대로 유지한 채 넘겨, 브랜디쉬2가 자기 끝에서 한
		-- 번만 RestoreBrandishControl한다. 예약이 없으면 평소대로 즉시 복구.
		_TimerService:SetTimerOnce(function()
			if self._T.brandish2Queued then
				self._T.brandish2Queued = false
				self:AttackBrandish2(self._T.pendingBrandish2CombatPower or 0, self._T.pendingBrandish2AtkMult or 1.0)
			else
				self:RestoreBrandishControl()
			end
		end, finishStart + 0.75 * finishMult)
		log("PlayerAttack: AttackBrandish 시전 dir=" .. tostring(dirX) .. " motionMult=" .. tostring(motionMult) .. " finishMult=" .. tostring(finishMult))
	end

	@ExecSpace("ServerOnly")
	method void DealBrandishFirstHits()
		-- 1타(swingT3 마지막) - 전방 박스 안의 적을 최대 6명까지 한 번에 타격한다(슬래시블러스트와 같은
		-- 탐색 방식). 여기서 찾은 대상 목록을 그대로 저장해 2타(swingTF 마지막)가 재탐색 없이 같은
		-- 대상만 때리게 한다("첫번째 공격과 2번째 공격은 같은 대상만 공격한다"는 요청) - 2타 때 다시
		-- 탐색하면 그 사이 다가온 다른 몬스터까지 맞는다.
		local worldPos = self.Entity.TransformComponent.WorldPosition
		local dirX = self._T.pendingBrandishDirX or 1
		local targets = self:FindSlashBlastTargets(Vector2(worldPos.x, worldPos.y), dirX, 6, 2.5, 1.0)
		self._T.brandishTargets = targets
		for _, t in ipairs(targets) do
			if isvalid(t) then
				self._T.brandishCurrentTarget = t
				local pos = t.TransformComponent.WorldPosition
				local shape = BoxShape(Vector2(pos.x, pos.y), Vector2(1.0, 1.6), 0)
				self:AttackShadowSafe(shape, "skill.brandish", t)
				self:PlayBrandishHitEffect(t)
			end
		end
		log("[Brandish] DealBrandishFirstHits targets=" .. tostring(#targets))
	end

	@ExecSpace("ServerOnly")
	method void DealBrandishFinishHits()
		-- 2타(swingTF 마지막) - 1타에서 저장해둔 대상만 순회하며 대상마다 2줄을 넣는다.
		-- (요청) 두 줄을 같은 틱에 몰아 넣으면 숫자 2개가 한꺼번에 툭 튀어나와 뻣뻣하다 - 둘째 줄만
		-- 짧은 텀(brandishFinishGap) 뒤에 넣어 아래 줄 -> 윗 줄로 이어져 뜨게 한다
		-- (ShowBrandishFinishDamageSkin이 hitIndex별로 offsetY를 0.0 / 0.3으로 쌓아 올린다).
		-- targets는 지역변수로 잡아 클로저에 담는다 - 아래에서 _T.brandishTargets를 비워도 둘째 줄이
		-- 같은 대상 목록을 그대로 쓴다(1타/2타가 같은 대상만 때린다는 요청 유지).
		local targets = self._T.brandishTargets
		if targets == nil then return end
		local gap = self._T.brandishFinishGap or 0.1
		for _, t in ipairs(targets) do
			if isvalid(t) then
				self:DealBrandishFinishHit(t, 1)
			end
		end
		_TimerService:SetTimerOnce(function()
			for _, t in ipairs(targets) do
				if isvalid(t) then
					self:DealBrandishFinishHit(t, 2)
				end
			end
		end, gap)
		self._T.brandishTargets = nil
	end

	@ExecSpace("ServerOnly")
	method void DealBrandishFinishHit(Entity target, integer hitIndex)
		-- 2타의 2줄 중 hitIndex번째. 새비지블로우(DealSavageBlowHit)와 완전히 동일한 구조다:
		--  · 같은 AttackComponent 인스턴스로 같은 대상을 짧은 간격으로 두 번 때리면 GetDisplayHitCount=0이어도
		--    엔진이 자동 데미지 숫자를 추가로 띄워, 판정 직전에 대상의 DamageSkinSpawnerComponent를 잠깐 뗀다.
		--  · 1타에 대상이 이미 죽어 판정 자체가 실패해도(콜라이더가 더 이상 걸리지 않음) 2줄이 항상 뜨도록
		--    표시 전용 데미지를 새로 굴린다("첫번째 공격으로 적이 죽었어도 데미지를 준다"는 요청).
		if not isvalid(target) then return end
		self._T.brandishCurrentTarget = target

		---@type Monster
		local monsterComp = target:GetComponent("script.Monster")
		-- Attack() 호출 전에 미리 확인한다 - Monster.HandleHitEvent는 이미 죽어있으면(IsDead) 자기 히트음을
		-- 건너뛰므로, "네이티브가 이 타격의 히트음을 이미 냈는지" 판단 기준으로 쓴다.
		local wasAlreadyDead = isvalid(monsterComp) and monsterComp.IsDead

		local pos = target.TransformComponent.WorldPosition
		local shape = BoxShape(Vector2(pos.x, pos.y), Vector2(1.0, 1.6), 0)
		local targetSkinSpawner = target:GetComponent("MOD.Core.DamageSkinSpawnerComponent")
		if isvalid(targetSkinSpawner) then target:RemoveComponent("MOD.Core.DamageSkinSpawnerComponent") end
		local hitComps = self:Attack(shape, "skill.brandish.finish", CollisionGroups.HitBox)
		if isvalid(target) and not isvalid(target:GetComponent("MOD.Core.DamageSkinSpawnerComponent")) then
			target:AddComponent("MOD.Core.DamageSkinSpawnerComponent")
		end

		local actuallyHit = false
		for _, hc in ipairs(hitComps) do
			if isvalid(hc) and isvalid(hc.Entity) and hc.Entity == target then
				actuallyHit = true
				break
			end
		end

		local damage = self._T.lastBrandishFinishDamage or 0
		local baseCrit = self._T.lastBrandishFinishIsCritical or false
		local bonus = self._T.shadowEchoBonus or 0
		local bonusCrit = self._T.shadowEchoBonusIsCritical or false

		if not actuallyHit then
			-- CalcDamageBase의 skill.brandish.finish 분기와 동일한 공식(400%~700%)으로 표시 전용 데미지를
			-- 새로 굴린다(실제 Hp에는 영향 없음). 크리티컬/쉐도우 파트너 보너스도 stale 값 대신 새로 굴린다.
			local critRate = (self._T.currentCritRatePercent or 50) / 100
			local critMult = (self._T.currentCritDamagePercent or 125) / 100
			local combatPower = self._T.pendingBrandishCombatPower or 0
			local mult = 4.0 + _UtilLogic:RandomDouble() * 3.0
			damage = self:ApplyComboAttackBonus(math.floor(combatPower * mult))
			baseCrit = _UtilLogic:RandomDouble() < critRate
			if baseCrit then damage = math.floor(damage * critMult) end
			bonus = 0
			bonusCrit = false
			if self._T.shadowPartnerActive then
				bonus = math.floor(damage * (0.55 + _UtilLogic:RandomDouble() * 0.10))
				bonusCrit = _UtilLogic:RandomDouble() < critRate
				if bonusCrit then bonus = math.floor(bonus * critMult) end
			end
		end

		self:ShowBrandishFinishDamageSkin(target, damage, hitIndex, bonus, baseCrit, bonusCrit)
		if bonus > 0 then
			self:PlayShadowEchoHitSound(target)
		end
		-- 히트 이펙트는 실제 판정 성공 여부와 무관하게 매번 재생한다(대상이 죽어도 2줄 모두 터져야 한다).
		self:PlayBrandishHitEffect(target)

		-- 실제로 명중했고 대상이 이번 타격 전까지 살아있었다면 Monster.HandleHitEvent가 이미 히트음을 냈다 -
		-- 여기서 또 내면 같은 타격에 소리가 2번 겹친다(스피어 버스터/새비지블로우에서 실측). 이미 죽어있었거나
		-- 판정이 실패한 경우에만 보충 재생한다("해당 몬스터의 타격소리를 들려준다"는 요청).
		if isvalid(monsterComp) and (not actuallyHit or wasAlreadyDead) then
			monsterComp:PlayHitSound()
		end

		log("[Brandish] DealBrandishFinishHit hitIndex=" .. tostring(hitIndex) .. " actuallyHit=" .. tostring(actuallyHit) .. " wasAlreadyDead=" .. tostring(wasAlreadyDead) .. " damage=" .. tostring(damage))
	end

	@ExecSpace("Client")
	method void ShowBrandishFinishDamageSkin(Entity target, integer damage, integer hitIndex, integer bonus, boolean baseIsCritical, boolean bonusIsCritical)
		-- 2타의 2줄을 세로로 쌓아 보여준다(새비지블로우의 6줄 배치와 동일한 방식, 줄 수만 2개).
		-- (2줄: 0.0 / 0.3, 쉐도우 파트너로 4줄이 되면 0.0, 0.25 / 0.5, 0.75)
		if not isvalid(target) then return end
		local offsetY = (hitIndex - 1) * 0.3
		local bonusGap = 0.15
		if bonus > 0 then
			offsetY = (hitIndex - 1) * 0.5
			bonusGap = 0.25
		end
		local skinRuid = self:GetHitDamageSkinId()
		_DamageSkinService:Play(
			target, skinRuid, 0,
			{ damage }, DamageSkinTweenType.Default, baseIsCritical,
			Vector2(0, offsetY), Vector2(1, 1), 1.0, 1.0, LitMode.Default
		)
		if bonus > 0 then
			_DamageSkinService:Play(
				target, skinRuid, 0,
				{ bonus }, DamageSkinTweenType.Default, bonusIsCritical,
				Vector2(0, offsetY + bonusGap), Vector2(1, 1), 1.0, 1.0, LitMode.Default
			)
		end
		log("[Brandish] ShowBrandishFinishDamageSkin hitIndex=" .. tostring(hitIndex) .. " damage=" .. tostring(damage) .. " offsetY=" .. tostring(offsetY) .. " crit=" .. tostring(baseIsCritical))
	end

	@ExecSpace("ServerOnly")
	method void RestoreBrandishControl()
		-- (버그 수정) "점프하고 어느 순간 다음 모션이 안 나간다" - 예전엔 시전 시작 시점에 찍어둔
		-- "원래 컨트롤러가 켜져 있었나"(pendingBrandishWasCtrl)가 true일 때만 복구했는데, 이미 컨트롤러가
		-- 꺼져 있는 동안(다른 스킬의 잠금 구간, 홀드 연속 시전 중 이전 시전의 잔여 잠금 등) 브랜디쉬가
		-- 시작하면 그 값이 false로 찍힌다. 그런데 AttackBrandish는 그와 무관하게 컨트롤러를 끄므로,
		-- 복구 시점에 false를 보고 그냥 넘어가 컨트롤러가 영영 꺼진 채로 남는다 -> 이동도 안 되고
		-- 다음 스킬 모션도 안 나간다. RunRushMove가 같은 원인으로 이미 한 번 고쳐진 것과 동일한 버그다
		-- (그 쪽 주석 참고). 시전 자체가 DEAD/사다리 상태를 막고 들어오므로 무조건 복구한다.
		self._T.isBrandishing = false
		local playerCtrl = self.Entity.PlayerControllerComponent
		if isvalid(playerCtrl) then
			playerCtrl.Enable = true
		end
		-- 시전 중 빼뒀던 몸동작 매핑을 기본값 그대로 되돌린다(AttackBrandish 참고).
		self:RestoreBrandishStateMotions()
		self:SetBrandishMotionGuard(false)
		local sc = self.Entity.StateComponent
		log("[Brandish] RestoreBrandishControl 컨트롤 복구 wasCtrl=" .. tostring(self._T.pendingBrandishWasCtrl) .. " state=" .. tostring(isvalid(sc) and sc.CurrentStateName or "nil"))
	end

	@ExecSpace("Multicast")
	method void SuppressBrandishStateMotions()
		-- 브랜디쉬 시전 중 브랜디쉬 자세를 덮어쓸 수 있는 상태들의 몸동작 매핑을 전부 빼둔다.
		-- 대상 5종과 그 이유:
		--   IDLE - 착지(FALL -> IDLE)나 피격 복귀, 이동정지(MOVE -> IDLE) 때 stand가 내려와 모션을 끊는다
		--          ("점프 브랜디쉬 착지 시 모션 중지" / "이동 중 시전 시 idle에서 시작해 앞 모션이 묻힘"의 직접 원인).
		--   MOVE - 이동(방향키 홀드) 중 시전 시, 컨트롤러가 클라에서 꺼지기 직전까지 walk가 첫 모션을 덮어쓴다.
		--   FALL - 점프 브랜디쉬에서 상승(JUMP) -> 하강 전환 시 fall이 내려와 공중에서 끊긴다.
		--   JUMP - 시전 도중 점프 상태로 바뀌는 경우(기본 매핑이 fall).
		--   HIT  - 시전 중 피격(몸동작 대신 표정만 바꾸는 요청 - OnHitDuringSkill 참고).
		-- DEAD는 남겨둔다 - 시전 중 죽으면 사망 모션은 정상적으로 나와야 한다.
		-- (버그 수정) 예전엔 ServerOnly라 매핑 제거가 @Sync로 클라에 도착하기 전에 상태 전환이 일어나면
		-- stand/walk가 새어나와 첫 모션을 묻었다. Multicast로 바꿔 서버+모든 클라에서 즉시 제거한다.
		-- 서버도 함께 실행되므로 상태 권한 쪽 매핑도 동일하게 빠진다. 복구는 RestoreBrandishStateMotions(@Sync).
		local asac = self.Entity.AvatarStateAnimationComponent
		if not isvalid(asac) then return end
		asac:RemoveActionSheet("IDLE")
		asac:RemoveActionSheet("MOVE")
		asac:RemoveActionSheet("FALL")
		asac:RemoveActionSheet("JUMP")
		asac:RemoveActionSheet("HIT")
	end

	@ExecSpace("ServerOnly")
	method void RestoreBrandishStateMotions()
		-- SuppressBrandishStateMotions가 빼둔 5종을 StateToAvatarBodyActionSheet 기본값 그대로 되돌린다.
		-- 기본값은 런타임 실측(AvatarBodyActionStateName / PlayRate): IDLE=stand@1.0 / MOVE=walk@1.68 /
		-- FALL=fall@1.0 / JUMP=fall@1.0 / HIT=hit@1.0. ⚠ MOVE는 PlayRate가 1.0이 아니라 1.68이다 -
		-- 1.0으로 복구하면 시전 후 걷기 애니메이션이 느려진다.
		-- 시전 중 사망 등으로 빠져나가도 RestoreBrandishControl은 타이머로 항상 실행되므로 매핑이 빠진 채로
		-- 남지 않는다. ServerOnly + @Sync로 모든 클라에 복구가 전파된다.
		local asac = self.Entity.AvatarStateAnimationComponent
		if not isvalid(asac) then return end
		asac.StateToAvatarBodyActionSheet["IDLE"] = AvatarBodyActionElement("stand", 1.0)
		asac.StateToAvatarBodyActionSheet["MOVE"] = AvatarBodyActionElement("walk", 1.68)
		asac.StateToAvatarBodyActionSheet["FALL"] = AvatarBodyActionElement("fall", 1.0)
		asac.StateToAvatarBodyActionSheet["JUMP"] = AvatarBodyActionElement("fall", 1.0)
		asac.StateToAvatarBodyActionSheet["HIT"] = AvatarBodyActionElement("hit", 1.0)
	end

	@ExecSpace("Multicast")
	method void SetBrandishMotionGuard(boolean on)
		-- 브랜디쉬 시전 중 "상태 전환이 몸동작을 건드리지 못하게" 막는 클라이언트 플래그를 켜고 끈다.
		-- 상태 전환/모션 재적용을 판단하는 코드(HandleStateChangeEvent, PlayerHit.ClientWatchdogTick)가
		-- 전부 클라이언트에서 돌기 때문에, 서버 전용인 _T.isBrandishing으로는 판단할 수 없어 별도로 둔다.
		self._T.brandishMotionGuard = on
		if on then return end
		if not self:IsClient() then return end
		-- 시전이 끝나는 시점의 자세 정리 안전망.
		-- PlayAttackMotion이 모션 끝에 도는 정리 토글(IDLE->MOVE->IDLE)은 IDLE 매핑이 있어야 stand를
		-- 내려보내 브랜디쉬 자세를 지운다. 그런데 매핑 복구(@Sync, 서버)가 그 토글보다 늦게 도착하면
		-- 토글이 헛돌아 브랜디쉬 자세로 굳은 채 남는다(움직이기 전까지). 매핑 복구와 같은 호출에서
		-- 출발한 이 RPC 뒤에 여유를 두고 한 번 더 토글해 확실히 되돌린다.
		-- 상태 전이 권한은 본인 클라이언트에만 있다 - 남의 화면(Multicast라 모두 실행된다)에서 부르면
		-- [LEA-3022]로 실패한다(PlayerHit.ClientWatchdogTick과 같은 이유).
		if _UserService.LocalPlayer ~= self.Entity then return end
		_TimerService:SetTimerOnce(function()
			-- 그 사이 새 시전이 시작됐으면(홀드 연속 시전) 새 모션을 건드리면 안 되므로 건너뛴다.
			if self._T.brandishMotionGuard then return end
			local sc = self.Entity.StateComponent
			if not isvalid(sc) or sc.CurrentStateName == "DEAD" then return end
			sc:ChangeState("IDLE")
			sc:ChangeState("MOVE")
			sc:ChangeState("IDLE")
			log("[Brandish] 시전 종료 자세 정리 토글 완료")
		end, 0.1)
	end

	method boolean IsBrandishMotionGuardOn()
		-- PlayerHit의 클라이언트 워치독이 참조한다 - 다른 스크립트가 _T를 직접 읽지 않도록 메서드로 노출한다.
		return self._T.brandishMotionGuard == true
	end

	@ExecSpace("ServerOnly")
	method void OnHitDuringSkill()
		-- PlayerHit.OnHit(서버)이 피격 때마다 호출한다. 브랜디쉬 시전 중이면 피격 몸동작을 막아둔 상태라
		-- (AttackBrandish 참고) 그대로 두면 맞은 티가 전혀 안 난다 - 몸동작 대신 표정만 피격 표정으로
		-- 바꿔준다(요청). PlayEmotion은 표정 전용이라 진행 중인 몸 클립에 영향을 주지 않는다.
		if not self._T.isBrandishing then return end
		local avatarRenderer = self.Entity.AvatarRendererComponent
		if not isvalid(avatarRenderer) then return end
		-- PlayEmotion은 @ExecSpace("Client") - 서버에서 호출하면 엔진이 클라이언트로 전달한다.
		avatarRenderer:PlayEmotion(EmotionalType.Hit, 1.0)
		log("[Brandish] 시전 중 피격 - 몸동작 유지, 표정만 피격 표정으로 변경")
	end

	@ExecSpace("ServerOnly")
	method void QueueBrandish2(number combatPower, number atkMultiplier)
		-- (브랜디쉬2 콤보) 브랜디쉬 진행 [절반~끝]에 브랜디쉬를 재입력하면 SkillManager의 서버 RPC
		-- (RequestQueueBrandish2)가 호출한다. 진행 중일 때만 예약을 켜, 브랜디쉬 조작복구 시점에 AttackBrandish2로
		-- 이어지게 한다(AttackBrandish의 복구 타이머 참고). 진행 중이 아니면 무시.
		if not self._T.isBrandishing then return end
		self._T.brandish2Queued = true
		self._T.pendingBrandish2CombatPower = combatPower
		self._T.pendingBrandish2AtkMult = atkMultiplier
		log("[Brandish2] 예약됨 combatPower=" .. tostring(combatPower))
	end

	@ExecSpace("ServerOnly")
	method void AttackBrandish2(number combatPower, number atkMultiplier)
		-- 브랜디쉬2(브랜디쉬 콤보 마무리): 브랜디쉬 끝에 이어서 빠른 2줄 추가타를 넣는다.
		-- 모션 = swingOF 프레임 0~2 + swingTF 프레임 2~3(빠르게, 마지막 조금 길게). 시전이펙트 = da1c...,
		-- 히트이펙트 = 브랜디쉬와 동일(PlayBrandishHitEffect), 사운드 = 1488... . 데미지 = 브랜디쉬 마무리
		-- 2줄과 동일(skill.brandish.finish, 400~700%) - DealBrandishFinishHit을 그대로 재사용한다.
		-- 브랜디쉬 시전 잠금(isBrandishing/매핑억제/가드)을 이어받아 유지하다가, 이 스킬 끝에서 한 번만 복구.
		if not self._T.isBrandishing then
			self:RestoreBrandishControl()
			return
		end
		local mult = math.max(0.1, math.min(atkMultiplier or 1.0, 3.0))
		-- DealBrandishFinishHit의 표시데미지는 pendingBrandishCombatPower를 참조하므로 브랜디쉬2 값으로 갱신.
		self._T.pendingBrandishCombatPower = combatPower
		self._T.pendingBrandish2CombatPower = combatPower
		local dirX = self._T.pendingBrandishDirX or 1

		-- (요청) 브랜디쉬보다 빠르게. seg1=swingOF 0~2, seg2=swingTF 2~3(마지막 조금 길게). 시간값은 튜닝 대상.
		local segMult = mult * 0.5          -- 재생속도 2배(빠르게)
		local seg1Time = 0.14 * mult        -- swingOF(0~2) 표시 시간
		local seg2Time = 0.24 * mult        -- swingTF(2~3) 표시 시간(마지막 조금 길게)
		self:PlayBrandish2Motion(self.Entity, dirX, segMult, seg1Time)
		self:PlayBrandish2CastEffect(self.Entity, dirX)
		self:PlayBrandish2Sound(self.Entity)

		-- 빠른 2줄: swingTF 임팩트(seg1Time 부근)에 1줄, 짧은 텀 뒤 2줄.
		_TimerService:SetTimerOnce(function() self:DealBrandish2Hits(1) end, seg1Time)
		_TimerService:SetTimerOnce(function() self:DealBrandish2Hits(2) end, seg1Time + 0.06 * mult)

		-- 조작 복구: 브랜디쉬2 모션 끝(마지막 조금 길게 포함) 뒤 한 번만.
		_TimerService:SetTimerOnce(function()
			self:RestoreBrandishControl()
		end, seg1Time + seg2Time + 0.12 * mult)
		log("[Brandish2] 발동 dir=" .. tostring(dirX) .. " mult=" .. tostring(mult))
	end

	@ExecSpace("ServerOnly")
	method void DealBrandish2Hits(integer hitIndex)
		-- 브랜디쉬2의 2줄 중 hitIndex번째. 브랜디쉬 마무리(DealBrandishFinishHit)를 그대로 재사용해
		-- 같은 데미지(400~700%)/데미지스킨 세로쌓기/히트이펙트/히트음을 낸다. 대상은 매번 새로 탐색한다
		-- (브랜디쉬 종료 후라 이전 대상 목록이 비어 있음).
		local worldPos = self.Entity.TransformComponent.WorldPosition
		local dirX = self._T.pendingBrandishDirX or 1
		local targets = self:FindSlashBlastTargets(Vector2(worldPos.x, worldPos.y), dirX, 6, 2.5, 1.0)
		for _, t in ipairs(targets) do
			if isvalid(t) then
				self:DealBrandishFinishHit(t, hitIndex)
			end
		end
		log("[Brandish2] DealBrandish2Hits hitIndex=" .. tostring(hitIndex) .. " targets=" .. tostring(#targets))
	end

	@ExecSpace("Multicast")
	method void PlayBrandish2Motion(Entity attacker, number dirX, number mult, number seg1Time)
		-- 브랜디쉬2 모션: swingOF(0~2) 재생 후 seg1Time 뒤 swingTF(2~3)를 이어 재생한다. 브랜디쉬 시전 중이라
		-- 상태매핑이 억제되어 있어(SuppressBrandishStateMotions) raw 모션이 덮이지 않는다. 마지막 세그먼트는
		-- 재생속도를 약간 낮춰(=조금 길게) 보여준다(요청).
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		local avatarRenderer = attacker.AvatarRendererComponent
		if not isvalid(avatarRenderer) then return end
		local body = avatarRenderer:GetBodyEntity()
		if not isvalid(body) then return end
		avatarRenderer.ShowDefaultWeaponEffects = false
		if isvalid(attacker.MovementComponent) then attacker.MovementComponent:Stop() end
		local playerCtrl = attacker.PlayerControllerComponent
		if isvalid(playerCtrl) then playerCtrl.LookDirectionX = dirX end
		local playRate = 1.0 / math.max(mult, 0.001)
		-- seg1: swingOF 프레임 0~2(빠르게)
		body:SendEvent(ActionStateChangedEvent("swingOF", "swingOF", playRate, SpriteAnimClipPlayType.Onetime, 0, 2))
		-- seg2: swingTF 프레임 2~3(빠르게, 마지막 조금 길게 = playRate 약간 낮춤)
		_TimerService:SetTimerOnce(function()
			if not isvalid(body) then return end
			body:SendEvent(ActionStateChangedEvent("swingTF", "swingTF", playRate * 0.8, SpriteAnimClipPlayType.Onetime, 2, 3))
		end, seg1Time)
	end

	@ExecSpace("Multicast")
	method void PlayBrandish2CastEffect(Entity attacker, number dirX)
		-- 브랜디쉬2 시전 이펙트(요청 RUID). 브랜디쉬 시전이펙트와 동일하게 몸 중앙(x=0)에 부착 재생한다.
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		local options = { ["FlipX"] = dirX > 0, ["Alpha"] = 1.0, ["OrderInLayer"] = 5 }
		local serial = _EffectService:PlayEffectAttached("da1c1c482f114293930993049ac7b764", attacker, Vector3(0, 0.0, 0), 0, Vector3(1, 1, 1), false, options)
		_TimerService:SetTimerOnce(function()
			_EffectService:RemoveEffect(serial)
		end, 2.0)
	end

	@ExecSpace("Multicast")
	method void PlayBrandish2Sound(Entity attacker)
		-- 브랜디쉬2 사용음(요청 RUID).
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		_SoundService:PlaySound("1488e238bb474c9087cd563a892d5dcb", 1.0)
	end

	@ExecSpace("ServerOnly")
	method void SummonDarkDragon(number combatPower)
		-- 플레이어가 시전하는 서먼 다크드래곤: 수명 10분(600초).
		self:SummonDarkDragonLife(combatPower, 600)
	end

	method void SummonDarkDragonLife(number combatPower, number lifetime)
		-- 서먼 다크드래곤: 드래곤 소환수(DarkDragon 컴포넌트)를 플레이어의 자식으로 스폰한다.
		-- spearburstfadingeffect 모델(Sprite+Transform, 기본 RUID "")을 몸체로 재활용 - 별도 모델 불필요.
		-- 위치/애니는 DarkDragon 컴포넌트가 처리(클라 로컬 궤도 + 프레임 교체). 블랙드래곤 연쇄 소환도 이걸 재호출.
		-- lifetime: 드래곤 수명(초). 플레이어 시전=600, 드래곤 버프(서먼블랙드래곤)로 나온 것=90.
		self._T.pendingDarkDragonCombatPower = combatPower
		self._T.darkDragonSeq = (self._T.darkDragonSeq or 0) + 1
		local dragon = _SpawnService:SpawnByModelId("spearburstfadingeffect", "DarkDragon" .. tostring(self._T.darkDragonSeq), Vector3(0, 1.0, 0), self.Entity)
		if not isvalid(dragon) then
			log_warning("[DarkDragon] 소환 실패(spawn nil)")
			return
		end
		dragon:AddComponent("script.DarkDragon")
		---@type DarkDragon
		local comp = dragon:GetComponent("script.DarkDragon")
		if isvalid(comp) then
			comp.OwnerEntity = self.Entity
			comp.Lifetime = lifetime
		end
		log("[DarkDragon] 소환 완료 seq=" .. tostring(self._T.darkDragonSeq) .. " combatPower=" .. tostring(combatPower) .. " lifetime=" .. tostring(lifetime))
	end

	method number GetDarkDragonCombatPower()
		-- 드래곤(블랙드래곤 연쇄 소환/공격)이 참조하는 소환 시점 전투력.
		return self._T.pendingDarkDragonCombatPower or 0
	end

	@ExecSpace("ServerOnly")
	method void DealDarkDragonHit(Entity target)
		-- 드래곤 공격 1타: 단일 대상 포인터(darkDragonCurrentTarget)로 걸러 skill.darkdragon(200~300%) 판정.
		if not isvalid(target) then return end
		self._T.darkDragonCurrentTarget = target
		local pos = target.TransformComponent.WorldPosition
		local shape = BoxShape(Vector2(pos.x, pos.y), Vector2(1.0, 1.6), 0)
		self:AttackShadowSafe(shape, "skill.darkdragon", target)
	end

	@ExecSpace("Multicast")
	method void PlayBrandishUseSound(Entity attacker)
		-- 브랜디쉬 사용음. MSW 라이브러리의 구버전 원본 팩(skill/112.img/skill/1121008)에 그대로 살아있다.
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		_SoundService:PlaySound("6c06fe8ab27b469eb61f466ea7f7e182", 1.0)
	end

	@ExecSpace("Multicast")
	method void PlayBrandishCastEffect(Entity attacker, number dirX, boolean enhanced)
		-- 시전 이펙트(주황 아크 9프레임) - skill/800033.img/skill/80003319의 effect(요청).
		-- animationclip이라 EffectService로 바로 재생한다(스프라이트 프레임 교체 방식 불필요).
		-- (요청) 좌우를 반대로 뒤집고(FlipX 조건 반전) 높이를 0.4 내렸다(y 0.4 -> 0.0, 40픽셀).
		-- (요청) 이펙트를 몸쪽으로 - x 0.6 -> 0.3 -> -0.45 -> -0.2 -> 0. 이제 앞뒤 치우침 없이
		-- 캐릭터 몸 중앙에 붙는다(x가 0이라 dirX를 곱해도 그대로 0 - 방향과 무관하게 항상 중앙).
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		local options = { ["FlipX"] = dirX > 0, ["Alpha"] = 1.0, ["OrderInLayer"] = 5 }
		-- (브랜디쉬 강화 버프) 활성 시 이펙트를 진한 빨강으로 물들인다(요청). Color는 원본 픽셀에 곱해지므로
		-- 밝은 주황 아크에 (1.0, 0.13, 0.13)을 곱하면 초록/파랑 성분이 크게 줄어 진한 빨강이 된다(아이콘과 일관).
		if enhanced then options["Color"] = Color(1.0, 0.13, 0.13, 1.0) end
		local serial = _EffectService:PlayEffectAttached("1c29e2f0793a48eb8aa40f697b93963d", attacker, Vector3(0, 0.0, 0), 0, Vector3(1, 1, 1), false, options)
		-- (버그 수정) "8번째 9번째 프레임이 보이지 않아 부자연스럽다" - 이 클립은 정확히 9프레임인데
		-- (리소스 조회로 확인: index 0~8), 아래 정리용 타이머가 1.0초에 이펙트를 지워버려 재생이 끝나기
		-- 전에 잘려나갔다(메이플 스킬 이펙트는 프레임당 100~120ms라 9프레임이면 약 0.9~1.1초).
		-- 이 타이머는 클립이 끝나도 남는 경우를 대비한 안전망일 뿐이므로, 클립 길이보다 확실히 뒤인
		-- 2.0초로 미뤄 9프레임이 전부 나오게 한다(isLoop=false라 재생이 끝나면 더 진행되지 않는다).
		_TimerService:SetTimerOnce(function()
			_EffectService:RemoveEffect(serial)
		end, 2.0)
	end

	-- ── 드래곤 라이딩(3차) ────────────────────────────────────────────────
	-- 5분간 드래곤 소환수(RidingDragon)를 소환하고, 소환 중 재시전하면 그 드래곤에 탑승한다.
	-- 소환/탑승 판단과 쿨타임/버프 UI는 SkillManager(클라)가 담당하고, 여기서는 스폰/데미지/연출만 맡는다.

	@ExecSpace("ServerOnly")
	method void SummonRidingDragon(number combatPower)
		-- 드래곤 라이딩 소환: spearburstfadingeffect 모델(Sprite+Transform)을 플레이어의 자식으로
		-- 스폰한 뒤 script.RidingDragon을 붙인다(다크드래곤과 동일한 재활용 패턴 - 별도 모델 불필요).
		self._T.pendingRidingDragonCombatPower = combatPower
		-- 이미 소환된 드래곤이 남아 있으면 정리한다(중복 소환 방지).
		local old = self._T.ridingDragonEntity
		if isvalid(old) then old:Destroy() end
		self._T.ridingDragonSeq = (self._T.ridingDragonSeq or 0) + 1
		local dragon = _SpawnService:SpawnByModelId("spearburstfadingeffect", "RidingDragon" .. tostring(self._T.ridingDragonSeq), Vector3(0, 1.0, 0), self.Entity)
		if not isvalid(dragon) then
			log_warning("[RidingDragon] 소환 실패(spawn nil)")
			return
		end
		dragon:AddComponent("script.RidingDragon")
		---@type RidingDragon
		local comp = dragon:GetComponent("script.RidingDragon")
		if isvalid(comp) then
			comp.OwnerEntity = self.Entity
			comp.Lifetime = 300
		end
		self._T.ridingDragonEntity = dragon
		self._T.ridingDragonMounted = false
		self:PlayRidingDragonSummonEffect(self.Entity)
		log("[RidingDragon] 소환 완료 seq=" .. tostring(self._T.ridingDragonSeq) .. " combatPower=" .. tostring(combatPower))
	end

	@ExecSpace("ServerOnly")
	method void SetRidingDragonMount(boolean active)
		-- 탑승/하차 상태를 소환수에 전달한다(@Sync라 각 클라의 RidingDragon.OnUpdate가 즉시 반영).
		-- 탑승은 곧바로 Riding을 켜지 않고 "제자리 워프 연출"을 거친다(BeginMountWarp - 요청 연출).
		local dragon = self._T.ridingDragonEntity
		if not isvalid(dragon) then
			log_warning("[RidingDragon] 탑승 전환 실패 - 소환된 드래곤 없음")
			return
		end
		---@type RidingDragon
		local comp = dragon:GetComponent("script.RidingDragon")
		if isvalid(comp) then
			if active then
				comp:BeginMountWarp()
			else
				comp.Warping = false
				comp.Riding = false
			end
		end
		self._T.ridingDragonMounted = active
		-- (요청) 탑승 중에는 이동해도 걷기 모션으로 넘어가면 안 된다. 아바타 상태→바디모션 매핑 자체를
		-- 전부 sit으로 바꿔버리면(IDLE/MOVE/JUMP/FALL/CROUCH) 컨트롤러가 상태를 어떻게 바꾸든 sit이 나온다.
		-- StateToAvatarBodyActionSheet는 @Sync라 반드시 서버에서 고쳐야 모든 클라에 반영된다.
		self:SetRidingAvatarSheet(active)
		log("[RidingDragon] 탑승 상태 = " .. tostring(active))
	end

	@ExecSpace("ServerOnly")
	method void SetRidingAvatarSheet(boolean riding)
		-- 탑승 중에는 "하차할 때까지" 절대 sit이 풀리면 안 된다(요청). 그래서 DEAD를 뺀 모든 상태 키를
		-- sit으로 덮어쓴다 - 이동(MOVE)뿐 아니라 점프/낙하/웅크리기/사다리/로프/피격(HIT)/공격(ATTACK)까지
		-- 전부 포함해야, 날다가 몬스터에게 맞거나 Ctrl을 눌러도 자세가 안 풀린다.
		-- 복구는 하드코딩 기본값이 아니라 "탑승 직전 값을 그대로 백업했다가 되돌리는" 방식이라
		-- PlayRate(예: MOVE=1.68)나 프로젝트에서 커스터마이즈한 값이 있어도 정확히 원복된다.
		local asac = self.Entity.AvatarStateAnimationComponent
		if not isvalid(asac) then
			log_warning("[RidingDragon] AvatarStateAnimationComponent 없음 - sit 고정 불가")
			return
		end
		local sheet = asac.StateToAvatarBodyActionSheet
		local keys = { "IDLE", "MOVE", "JUMP", "FALL", "CROUCH", "CLIMB", "LADDER", "HIT", "ATTACK", "ATTACK_WAIT", "SIT" }
		if riding then
			-- 이미 백업이 있으면(중복 호출) 덮어쓰지 않는다 - sit으로 바뀐 값을 원본으로 저장해버리면 복구 불가.
			if self._T.ridingSheetBackup == nil then
				local backup = {}
				for _, k in ipairs(keys) do
					local e = sheet[k]
					if e ~= nil then
						backup[k] = { name = e.AvatarBodyActionStateName, rate = e.PlayRate }
					else
						backup[k] = false   -- 원래 없던 키 - 복구 시 제거한다
					end
				end
				self._T.ridingSheetBackup = backup
			end
			for _, k in ipairs(keys) do
				sheet[k] = AvatarBodyActionElement("sit", 1.0)
			end
		else
			local backup = self._T.ridingSheetBackup
			if backup ~= nil then
				for _, k in ipairs(keys) do
					local b = backup[k]
					if b == false then
						asac:RemoveActionSheet(k)
					elseif b ~= nil then
						sheet[k] = AvatarBodyActionElement(b.name, b.rate)
					end
				end
				self._T.ridingSheetBackup = nil
			end
		end
		log("[RidingDragon] 아바타 모션 시트 " .. (riding and "sit 고정(전 상태)" or "탑승 전 값으로 복구"))
	end

	@ExecSpace("ServerOnly")
	method void DealRidingDragonHit(Entity target)
		-- 드래곤 공격 1타: 단일 대상 포인터로 걸러 skill.ridingdragon(전투력 200~300%) 판정.
		if not isvalid(target) then return end
		self._T.ridingDragonCurrentTarget = target
		local pos = target.TransformComponent.WorldPosition
		local shape = BoxShape(Vector2(pos.x, pos.y), Vector2(1.0, 1.6), 0)
		self:AttackShadowSafe(shape, "skill.ridingdragon", target)
	end

	@ExecSpace("Multicast")
	method void PlayRidingDragonSummonEffect(Entity attacker)
		-- (요청) 소환 시 1회 재생하는 이펙트. y는 캐릭터 발끝 높이(-0.45) - 트랜스폼 원점이 몸 중앙이라
		-- 0으로 두면 배 높이에서 터진다(브랜디쉬 시전 이펙트 주석과 같은 기준).
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		local serial = _EffectService:PlayEffectAttached("7ae16a28558045e2903af41106d7ba47", attacker, Vector3(0, -0.45, 0), 0, Vector3(1.1, 1.1, 1), false, { ["OrderInLayer"] = 6 })
		_TimerService:SetTimerOnce(function()
			_EffectService:RemoveEffect(serial)
		end, 2.0)
	end

	@ExecSpace("Multicast")
	method void PlayRidingMountEffectAt(Entity attacker, number fxX, number fxY)
		-- (요청) 탑승할 때와 내릴 때 1회 재생하는 이펙트(같은 RUID를 공용으로 쓴다).
		-- 부착이 아니라 "전환 직전 캐릭터가 서 있던 월드 좌표"에 고정 재생한다 - 탑승하면 캐릭터가
		-- 0.45만큼 떠오르는데, 부착이면 이펙트도 같이 따라 올라가 버려서 "올라가기 전 자리에서 터지는"
		-- 연출이 안 된다. y는 캐릭터 몸 기준 -0.1(발끝 -0.45보다 조금 위 - 요청).
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		local serial = _EffectService:PlayEffect("97f1637cc68143cd979124499adcd75f", attacker, Vector3(fxX, fxY - 0.1, 0), 0, Vector3(1.1, 1.1, 1), false, { ["OrderInLayer"] = 6 })
		_TimerService:SetTimerOnce(function()
			_EffectService:RemoveEffect(serial)
		end, 2.5)
	end

	@ExecSpace("Multicast")
	method void PlayBrandishHitEffect(Entity target)
		-- 타격 이펙트(흰 폭발) - 같은 팩의 hit/0.
		if not self:IsClient() then return end
		if not isvalid(target) then return end
		local serial = _EffectService:PlayEffectAttached("ee451f0e79a944b7b5546636a674005a", target, Vector3(0, 0.4, 0), 0, Vector3(1, 1, 1), false, {})
		_TimerService:SetTimerOnce(function()
			_EffectService:RemoveEffect(serial)
		end, 1.0)
	end

end