		            end
		            local sc = self.Entity.StateComponent
		            if isvalid(sc) then
		                sc:ChangeState("IDLE")
		                log("[MagicClaw] HandleStateChangeEvent forced back to IDLE from " .. tostring(event.CurrentStateName))
		            end
		        end

		        -- 썬더볼트 전용 처리 (매직클로와 동일한 패턴이지만 별도의 플래그를 사용 - 서로 간섭하지 않는다)
		        if self._T.isThunderboltMotionPlaying then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedThunderboltDirX
		            end
		            local motionName = self._T.lockedThunderboltMotionName
		            if not motionName then return end
		            local avatarRenderer = self.Entity.AvatarRendererComponent
		            if not isvalid(avatarRenderer) then return end
		            local body = avatarRenderer:GetBodyEntity()
		            if not isvalid(body) then return end
		            local motionEvent = ActionStateChangedEvent(motionName, motionName, self._T.lockedThunderboltPlayRate or 1.0, SpriteAnimClipPlayType.Onetime)
		            body:SendEvent(motionEvent)
		            log("[Thunderbolt] HandleStateChangeEvent re-applied motion over " .. tostring(event.CurrentStateName) .. ": " .. tostring(motionName))
		            return
		        end
		        if self._T.isThunderboltDirectionLocked and event.CurrentStateName ~= "IDLE" then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedThunderboltDirX
		            end
		            local sc = self.Entity.StateComponent
		            if isvalid(sc) then
		                sc:ChangeState("IDLE")
		                log("[Thunderbolt] HandleStateChangeEvent forced back to IDLE from " .. tostring(event.CurrentStateName))
		            end
		        end

		        -- 힐 전용 처리 (다른 스킬과 동일한 패턴이지만 별도의 플래그를 사용 - 서로 간섭하지 않는다)
		        if self._T.isHealMotionPlaying then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedHealDirX
		            end
		            local motionName = self._T.lockedHealMotionName
		            if not motionName then return end
		            local avatarRenderer = self.Entity.AvatarRendererComponent
		            if not isvalid(avatarRenderer) then return end
		            local body = avatarRenderer:GetBodyEntity()
		            if not isvalid(body) then return end
		            local motionEvent = ActionStateChangedEvent(motionName, motionName, self._T.lockedHealPlayRate or 1.0, SpriteAnimClipPlayType.Onetime)
		            body:SendEvent(motionEvent)
		            log("[Heal] HandleStateChangeEvent re-applied motion over " .. tostring(event.CurrentStateName) .. ": " .. tostring(motionName))
		            return
		        end
		        if self._T.isHealDirectionLocked and event.CurrentStateName ~= "IDLE" then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedHealDirX
		            end
		            local sc = self.Entity.StateComponent
		            if isvalid(sc) then
		                sc:ChangeState("IDLE")
		                log("[Heal] HandleStateChangeEvent forced back to IDLE from " .. tostring(event.CurrentStateName))
		            end
		        end

		        -- 파이어에로우 전용 처리 (다른 스킬과 동일한 패턴이지만 별도의 플래그를 사용 - 서로 간섭하지 않는다)
		        if self._T.isFireArrowMotionPlaying then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedFireArrowDirX
		            end
		            local motionName = self._T.lockedFireArrowMotionName
		            if not motionName then return end
		            local avatarRenderer = self.Entity.AvatarRendererComponent
		            if not isvalid(avatarRenderer) then return end
		            local body = avatarRenderer:GetBodyEntity()
		            if not isvalid(body) then return end
		            local motionEvent = ActionStateChangedEvent(motionName, motionName, self._T.lockedFireArrowPlayRate or 1.0, SpriteAnimClipPlayType.Onetime)
		            body:SendEvent(motionEvent)
		            log("[FireArrow] HandleStateChangeEvent re-applied motion over " .. tostring(event.CurrentStateName) .. ": " .. tostring(motionName))
		            return
		        end
		        if self._T.isFireArrowDirectionLocked and event.CurrentStateName ~= "IDLE" then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedFireArrowDirX
		            end
		            local sc = self.Entity.StateComponent
		            if isvalid(sc) then
		                sc:ChangeState("IDLE")
		                log("[FireArrow] HandleStateChangeEvent forced back to IDLE from " .. tostring(event.CurrentStateName))
		            end
		        end

		        -- 아이언에로우 전용 처리 (파이어에로우와 동일한 패턴이지만 별도의 플래그를 사용 - 서로 간섭하지 않는다)
		        if self._T.isIronArrowMotionPlaying then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedIronArrowDirX
		            end
		            local motionName = self._T.lockedIronArrowMotionName
		            if not motionName then return end
		            local avatarRenderer = self.Entity.AvatarRendererComponent
		            if not isvalid(avatarRenderer) then return end
		            local body = avatarRenderer:GetBodyEntity()
		            if not isvalid(body) then return end
		            local motionEvent = ActionStateChangedEvent(motionName, motionName, self._T.lockedIronArrowPlayRate or 1.0, SpriteAnimClipPlayType.Onetime)
		            body:SendEvent(motionEvent)
		            log("[IronArrow] HandleStateChangeEvent re-applied motion over " .. tostring(event.CurrentStateName) .. ": " .. tostring(motionName))
		            return
		        end
		        if self._T.isIronArrowDirectionLocked and event.CurrentStateName ~= "IDLE" then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedIronArrowDirX
		            end
		            local sc = self.Entity.StateComponent
		            if isvalid(sc) then
		                sc:ChangeState("IDLE")
		                log("[IronArrow] HandleStateChangeEvent forced back to IDLE from " .. tostring(event.CurrentStateName))
		            end
		        end

		        -- 포이즌 미스트 전용 처리 (힐과 동일한 패턴이지만 별도의 플래그를 사용 - 서로 간섭하지 않는다)
		        if self._T.isPoisonMistMotionPlaying then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedPoisonMistDirX
		            end
		            local motionName = self._T.lockedPoisonMistMotionName
		            if not motionName then return end
		            local avatarRenderer = self.Entity.AvatarRendererComponent
		            if not isvalid(avatarRenderer) then return end
		            local body = avatarRenderer:GetBodyEntity()
		            if not isvalid(body) then return end
		            local motionEvent = ActionStateChangedEvent(motionName, motionName, self._T.lockedPoisonMistPlayRate or 1.0, SpriteAnimClipPlayType.Onetime)
		            body:SendEvent(motionEvent)
		            log("[PoisonMist] HandleStateChangeEvent re-applied motion over " .. tostring(event.CurrentStateName) .. ": " .. tostring(motionName))
		            return
		        end
		        if self._T.isPoisonMistDirectionLocked and event.CurrentStateName ~= "IDLE" then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedPoisonMistDirX
		            end
		            local sc = self.Entity.StateComponent
		            if isvalid(sc) then
