@Component
script PlayerAttack extends AttackComponent

	@ExecSpace("ServerOnly")
	method void OnBeginPlay()
		        -- Ready: player attack component initialized
		        self._T.shape = BoxShape(Vector2.zero, Vector2.one, 0)
		        log("PlayerAttack: OnBeginPlay")
	end

	@ExecSpace("ServerOnly")
	method void AttackNormal()
		        -- Calculate frontal box in the direction the player is looking
		        local playerCtrl = self.Entity.PlayerControllerComponent
		        local worldPos = self.Entity.TransformComponent.WorldPosition
		        local attackOffset = Vector2(
		            worldPos.x + 0.5 * playerCtrl.LookDirectionX,
		            worldPos.y + 0.5
		        )
		        -- 기본 공격(Control)은 단일 대상 공격이다 - 몬스터가 밀집한 구역에서 AttackFast의 박스 판정이
		        -- 여러 마리를 동시에 맞히는 문제가 있어, 판정 전에 가장 가까운 몬스터 하나만 골라
		        -- IsAttackTarget에서 그 대상만 통과시킨다 (파워스트라이크와 동일한 FindNearestMonster 재사용).
		        self._T.normalAttackTarget = self:FindNearestMonster(Vector2(worldPos.x, worldPos.y), 1.5)
		        self._T.shape = BoxShape(attackOffset, Vector2.one, 0)
		        self:AttackFast(self._T.shape, nil, CollisionGroups.HitBox)
		        log("PlayerAttack: AttackNormal at x=" .. tostring(attackOffset.x) .. " y=" .. tostring(attackOffset.y))
	end

	method boolean IsAttackTarget(Entity defender, string attackInfo)
		        -- Skip other players; only hit non-player entities (monsters)
		        if isvalid(defender.PlayerComponent) then
		            return false
		        end
		        -- 기본 공격(attackInfo가 nil)은 단일 대상 - 미리 골라둔 가장 가까운 대상만 통과시킨다
		        if attackInfo == nil then
		            if not isvalid(self._T.normalAttackTarget) or defender ~= self._T.normalAttackTarget then
		                return false
		            end
		        end
		        -- 파워스트라이크는 단일 대상 스킬 - 미리 골라둔 가장 가까운 대상만 통과시킨다
		        if attackInfo == "skill.powerstrike" then
		            if not isvalid(self._T.powerStrikeTarget) or defender ~= self._T.powerStrikeTarget then
		                return false
		            end
		        end
		        -- 슬래쉬블래스트는 0.2초 간격으로 한 명씩 순차 타격 - 이번 차례의 대상(slashBlastCurrentTarget)만 통과시킨다
		        if attackInfo == "skill.slashblast" then
		            if not isvalid(self._T.slashBlastCurrentTarget) or defender ~= self._T.slashBlastCurrentTarget then
		                return false
		            end
		        end
		        -- 파이널어택으로 발동된 파워스트라이크/슬래쉬블래스트 추가타 - 원본과 동일한 방식이지만 별도 대상 필드를 쓴다.
		        if attackInfo == "skill.powerstrike.final" then
		            if not isvalid(self._T.powerStrikeFinalTarget) or defender ~= self._T.powerStrikeFinalTarget then
		                return false
		            end
		        end
		        if attackInfo == "skill.slashblast.final" then
		            if not isvalid(self._T.slashBlastFinalCurrentTarget) or defender ~= self._T.slashBlastFinalCurrentTarget then
		                return false
		            end
		        end
		        -- 더블스탭은 단일 고정 대상(doubleStabTarget)만 통과시킨다
		        if attackInfo == "skill.doublestab" then
		            if not isvalid(self._T.doubleStabTarget) or defender ~= self._T.doubleStabTarget then
		                return false
		            end
		        end
		        -- 매직클로는 단일 고정 대상(magicClawTarget)만 통과시킨다
		        if attackInfo == "skill.magicclaw" then
		            if not isvalid(self._T.magicClawTarget) or defender ~= self._T.magicClawTarget then
		                return false
		            end
		        end
		        -- 썬더볼트는 앞뒤 주변 최대 6명을 동시에 타격하는 다중 대상 스킬이지만, 몬스터가 밀집한 지역에서는
		        -- 개별 판정 범위가 이웃 대상까지 겹칠 수 있다. "6명 목록 중 아무나"가 아니라 이번 Attack() 호출의
		        -- 대상(thunderboltCurrentTarget) 하나만 통과시켜야 한 번의 호출이 이웃까지 중복으로 맞히지 않는다
		        -- (슬래쉬블래스트의 slashBlastCurrentTarget과 동일한 패턴).
		        if attackInfo == "skill.thunderbolt" then
		            if not isvalid(self._T.thunderboltCurrentTarget) or defender ~= self._T.thunderboltCurrentTarget then
		                return false
		            end
		        end
		        -- 힐이 언데드 몬스터에게 데미지를 입힐 때도 썬더볼트와 동일한 이유로 "이번 호출 전용 단일 대상"만 통과시킨다.
		        if attackInfo == "skill.heal" then
		            if not isvalid(self._T.healCurrentUndeadTarget) or defender ~= self._T.healCurrentUndeadTarget then
		                return false
		            end
		        end
		        return __base:IsAttackTarget(defender, attackInfo)
	end

	method integer CalcDamage(Entity attacker, Entity defender, string attackInfo)
		        if attackInfo == "skill.powerstrike" then
		            local combatPower = self._T.pendingCombatPower or 0
		            local mult = 0.5 + math.random() * (3.0 - 1.0)
		            return math.floor(combatPower * mult)
		        elseif attackInfo == "skill.slashblast" then
		            -- 전투력의 30%~150% 사이 랜덤
		            local combatPower = self._T.pendingSlashCombatPower or 0
		            local mult = 0.5 + math.random() * (1.5 - 0.5)
		            return math.floor(combatPower * mult)
		        elseif attackInfo == "skill.powerstrike.final" then
		            -- 파이널어택: 파워스트라이크와 동일한 공식에 15%~30% 추가 데미지를 곱한다.
		            local combatPower = self._T.pendingFinalCombatPower or 0
		            local mult = 0.5 + math.random() * (3.0 - 1.0)
		            local bonus = 1.15 + math.random() * (1.30 - 1.15)
		            return math.floor(combatPower * mult * bonus)
		        elseif attackInfo == "skill.slashblast.final" then
		            -- 파이널어택: 슬래쉬블래스트와 동일한 공식에 15%~30% 추가 데미지를 곱한다.
		            local combatPower = self._T.pendingFinalSlashCombatPower or 0
		            local mult = 0.5 + math.random() * (1.5 - 0.5)
		            local bonus = 1.15 + math.random() * (1.30 - 1.15)
		            return math.floor(combatPower * mult * bonus)
		        elseif attackInfo == "skill.doublestab" then
		            -- 전투력의 100%~260% 사이 랜덤 (매 타격마다 새로 굴림). math.random() 대신
		            -- _UtilLogic:RandomDouble()을 쓰는 이유: idx=1/idx=2가 0.1~0.2초 간격으로 짧게
		            -- 잇따라 호출될 때 math.random()이 동일한 값을 두 번 반환하는 현상이 실측됨.
		            local combatPower = self._T.pendingDoubleStabCombatPower or 0
		            local mult = 1.0 + _UtilLogic:RandomDouble() * (2.6 - 1.0)
		            self._T.lastDoubleStabDamage = math.floor(combatPower * mult)
		            return self._T.lastDoubleStabDamage
		        elseif attackInfo == "skill.magicclaw" then
		            -- 전투력의 100%~150% 사이 랜덤 (럭키세븐과 동일 비율)
		            local combatPower = self._T.pendingMagicClawCombatPower or 0
		            local mult = 1.0 + _UtilLogic:RandomDouble() * (1.5 - 1.0)
		            self._T.lastMagicClawDamage = math.floor(combatPower * mult)
		            return self._T.lastMagicClawDamage
		        elseif attackInfo == "skill.thunderbolt" then
		            -- 전투력의 80%~130% 사이 랜덤 (최대 6명에게 동시 적용 - 대상마다 독립적으로 새로 굴림).
		            -- 더블스탭 사례처럼 같은 프레임 안에서 연달아 호출되므로 math.random() 대신 _UtilLogic:RandomDouble() 사용.
		            local combatPower = self._T.pendingThunderboltCombatPower or 0
		            local mult = 0.8 + _UtilLogic:RandomDouble() * (1.3 - 0.8)
		            return math.floor(combatPower * mult)
		        elseif attackInfo == "skill.heal" then
		            -- 힐이 언데드 몬스터에게 입히는 데미지 - 썬더볼트와 동일한 전투력 80%~130% 공식.
		            local combatPower = self._T.pendingHealCombatPower or 0
		            local mult = 0.8 + _UtilLogic:RandomDouble() * (1.3 - 0.8)
		            return math.floor(combatPower * mult)
		        end
		        return 50
	end

	method boolean CalcCritical(Entity attacker, Entity defender, string attackInfo)
		        -- 더블스탭/매직클로는 크리티컬 미적용 - 수동 2줄 데미지 스킨이 CalcDamage 반환값만 캐싱해
		        -- 보여주는데, 크리티컬이 뜨면 엔진이 실제 적용 데미지에 배율을 추가로 곱해 화면 표시와
		        -- 실제 적용량이 어긋나는 문제가 있었다.
		        if attackInfo == "skill.doublestab" or attackInfo == "skill.magicclaw" then
		            return false
		        end
		        return math.random() < 0.3
	end

	method float GetCriticalDamageRate()
		        return 2.0
	end

	method int32 GetDisplayHitCount(string attackInfo)
		        -- 더블스탭/매직클로는 ShowDoubleStabDamageSkin/ShowMagicClawDamageSkin에서 수동으로 2줄
		        -- 스택 표시하므로 이 두 attackInfo에 한해서만 엔진 자동 데미지 스킨 표시를 끈다.
		        -- 다른 스킬(파워스트라이크/슬래쉬블래스트/기본공격)은 부모 기본값(1)과 동일하게 유지한다.
		        if attackInfo == "skill.doublestab" or attackInfo == "skill.magicclaw" then
		            return 0
		        end
		        return 1
	end

	@ExecSpace("ServerOnly")
	method void AttackPowerStrike(number combatPower, number atkMultiplier, boolean isSpear)
		        -- 파워스트라이크 전용 발동: 기본공격과 동일한 전방 박스 판정을 쓰되, attackInfo로 태그해 CalcDamage에서 별도 공식을 적용한다
		        -- 사다리/로프에 매달린 상태(CLIMB/LADDER)나 사망한 상태(DEAD)에서는 스킬을 사용할 수 없다.
		        local currentState = self.Entity.StateComponent.CurrentStateName
		        if currentState == "DEAD" or currentState == "CLIMB" or currentState == "LADDER" then
		            return
		        end
		        -- 이미 파워스트라이크 모션이 진행 중이면(모션 딜레이 구간, 파이널어택 진행 중 포함) 재시전을 막는다.
		        if self._T.isPowerStriking then
		            log("PlayerAttack: AttackPowerStrike 요청 차단됨(이미 진행 중 - 파이널어택 포함)")
		            return
		        end
		        self._T.isPowerStriking = true
		        self._T.motionEndHandled = false
		
		        -- 공격속도 배율: 클라이언트(CharInfoManager)가 소비한 "공격 속도의 비약" 단계로 계산해 넘겨준 값.
		        -- combatPower와 같은 이유로 클라이언트에서 계산해 RPC로 전달한다(서버에는 인벤토리 상태가 없음).
		        -- 1보다 작을수록 빠름(모션/딜레이 단축). 비정상적으로 극단적인 값이 오는 경우를 대비해 안전 범위로 clamp한다.
		        local mult = math.max(0.1, math.min(atkMultiplier or 1.0, 3.0))
		        self._T.pendingAtkMultiplier = mult
		        self._T.pendingIsSpear = isSpear
		
		        self._T.pendingCombatPower = combatPower
		        local playerCtrl = self.Entity.PlayerControllerComponent
		        local worldPos = self.Entity.TransformComponent.WorldPosition
		        local dirX = playerCtrl.LookDirectionX
		        self._T.pendingDirX = dirX
		
		        -- 단일 대상 스킬: 판정 전에 가장 가까운 몬스터 하나만 골라 IsAttackTarget에서 그 대상만 통과시킨다
		        self._T.powerStrikeTarget = self:FindNearestMonster(Vector2(worldPos.x, worldPos.y), 2.0)
		
		        -- (주의) 기본 무기 스윙 이펙트(ShowDefaultWeaponEffects) 끄기/복구는 여기(서버)가 아니라
		        -- PlayAttackMotion(클라이언트, Multicast)에서 직접 처리한다. ShowDefaultWeaponEffects는 @Sync라
		        -- 서버에서 바꾸면 클라이언트에 반영되기까지 네트워크 지연이 있고, 모션을 재생하는 Multicast 호출과
		        -- 도착 순서가 보장되지 않아 첫 프레임에 기본 스윙 이펙트가 잠깐 섞여 보이는 문제가 있었다.
		
		        -- 모션 재생 동안은 이동/점프/기본공격/반대방향 전환 등 다른 행동을 할 수 없도록 컨트롤러를 먼저 잠근다.
		        -- 모션(PlayAttackMotion) 재생보다 반드시 먼저 잠가야 한다 - 이동 중에 캐릭터 모션을 재생하면
		        -- 이동 입력이 계속 걸어가기 애니메이션을 다시 밀어넣어 스윙 모션이 씹히는(끊기는) 문제가 있었다.
		        -- 다른 이유로 이미 꺼져있던 경우(예: 사망 처리 등)까지 되살리지 않도록 이전 값을 기억해뒀다가 그대로 복구한다.
		        self._T.pendingWasControllerEnabled = isvalid(playerCtrl) and playerCtrl.Enable
		        if isvalid(playerCtrl) then
		            playerCtrl.Enable = false
		        end
		        -- 이동 중 시전한 경우 관성/잔여 이동으로 모션이 어색하게 끊기지 않도록 서버 쪽에서도 즉시 이동을 멈춘다.
		        if isvalid(self.Entity.MovementComponent) then
		            self.Entity.MovementComponent:Stop()
		        end
		
		        -- 스킬 사용 사운드 재생
		        self:PlaySkillUseSound(self.Entity)
		        -- 스킬 시전 시작 이펙트 재생 (파워 스트라이크 리소스팩의 시전 전용 이펙트)
		        self:PlaySkillStartEffect(self.Entity, dirX)
		
		        -- 캐릭터 공격 모션 재생: 매 시전마다 하나를 골라(GetPowerStrikeSwing) 캐릭터 모션과 스윙 이펙트를 동일하게 맞춘다.
		        -- 두 번 호출해서 각각 다시 뽑으면 모션과 이펙트가 서로 다른 자세로 어긋날 수 있으므로, 한 번만 뽑아 저장해둔다.
		        local swing = self:GetPowerStrikeSwing()
		        self._T.pendingSwing = swing
		        self:PlayAttackMotion(self.Entity, swing.name, dirX, mult)
		
		        -- 타격 판정은 실제 애니메이션 종료 이벤트가 아니라 고정 딜레이(기본 0.25초)로 진행한다.
		        -- 애니메이션 종료 이벤트 기준으로 하면 이동 중 걷기 모션이 끊기거나 점프 착지 모션이 끼어들 때도
		        -- 같은 종료 이벤트가 발생해 파워스트라이크 모션이 끝나기도 전에 타격 판정이 발생하는 문제가 있었다.
		        -- 공격속도 배율(mult)만큼 딜레이를 단축/연장한다 (mult<1이면 더 빠르게 타격 판정).
		        _TimerService:SetTimerOnce(function()
		            self:NotifyMotionEnded()
		        end, 0.45 * mult)
		
		        -- 컨트롤러 잠금(이동 봉인)은 모션이 끝난 뒤에도 추가 딜레이만큼 더 유지한다 (기본 0.25초 + 0.4초 = 0.65초).
		        -- 이 전체 잠금 시간도 공격속도 배율만큼 단축된다.
		        _TimerService:SetTimerOnce(function()
		            self:RestoreControl()
		        end, 0.65 * mult)
	end

	@ExecSpace("Server")
	method void RestoreControl()
		        -- AttackPowerStrike에서 예약한 고정 딜레이(0.65초 = 모션 0.25초 + 추가 이동 봉인 0.4초) 뒤 호출된다.
		        -- 재시전 가능 상태로 되돌리고, 잠가뒀던 컨트롤러를 원래 값으로 복구한다.
		        self._T.isPowerStriking = false
		        local playerCtrl = self.Entity.PlayerControllerComponent
		        if isvalid(playerCtrl) and self._T.pendingWasControllerEnabled then
		            playerCtrl.Enable = true
		        end
		        -- 파이널어택(2차 패시브): 30% 확률로, 컨트롤이 "실제로" 돌아오는 이 시점에 바로 이어서(동기 호출)
		        -- 강화된 추가타를 한 번 더 실행한다. 이전에는 이 호출을 별도의 동일 딜레이 타이머로 나란히 예약했는데,
		        -- 그 타이머와 RestoreControl 타이머가 같은 프레임에 만료될 때 어느 쪽이 먼저 실행되는지가 타이머 큐
		        -- 순서에 의존해 보장되지 않았다 - RestoreControl이 파이널어택의 컨트롤 잠금보다 "나중에" 실행되면
		        -- 컨트롤이 즉시 풀려버려(이동/다른 스킬 등 다른 행동이 가능해짐) 파이널어택 모션 동안 다른 행동이
		        -- 가능한 버그가 있었다. 이 메서드 안에서 직접(동기적으로) 호출하면 항상 컨트롤 복구 다음에 실행되어
		        -- 순서가 보장된다.
		        self:TryTriggerFinalAttack("powerstrike", self._T.pendingCombatPower, self._T.pendingAtkMultiplier, self._T.pendingIsSpear)
	end

	@ExecSpace("ServerOnly")
	method void AttackSlashBlast(number combatPower, number atkMultiplier, boolean isSpear)
		        -- 슬래쉬블래스트 발동. 사다리/로프/사망 상태에서는 사용 불가 (파워스트라이크와 동일 가드).
		        local currentState = self.Entity.StateComponent.CurrentStateName
		        if currentState == "DEAD" or currentState == "CLIMB" or currentState == "LADDER" then
		            return
		        end
		        -- 이미 슬래쉬블래스트 모션/타격 시퀀스가 진행 중이면(파이널어택 진행 중 포함) 재시전을 막는다.
		        if self._T.isSlashBlasting then
		            log("PlayerAttack: AttackSlashBlast 요청 차단됨(이미 진행 중 - 파이널어택 포함)")
		            return
		        end
		        self._T.isSlashBlasting = true
		
		        -- 공격속도 배율: 파워스트라이크와 동일하게 클라이언트(CharInfoManager)가 계산해 넘겨준 값을 그대로 적용한다.
		        -- 1보다 작을수록 빠름(모션/딜레이/타격 간격 전부 단축). 안전 범위로 clamp.
		        local mult = math.max(0.1, math.min(atkMultiplier or 1.0, 3.0))
		        self._T.pendingSlashMult = mult
		        self._T.pendingSlashIsSpear = isSpear
		
		        self._T.pendingSlashCombatPower = combatPower
		        local playerCtrl = self.Entity.PlayerControllerComponent
		        local worldPos = self.Entity.TransformComponent.WorldPosition
		        local dirX = playerCtrl.LookDirectionX
		        self._T.pendingSlashDirX = dirX
		
		        -- 전방 판정 범위(파워스트라이크 최종 판정 박스와 동일한 가로 2칸·세로 1칸) 안의 적을
		        -- 가까운 순으로 최대 6명까지 미리 골라둔다. 실제 Attack 판정 없이 위치만으로 탐색한다.
		        local targets = self:FindSlashBlastTargets(Vector2(worldPos.x, worldPos.y), dirX, 6)
		
		        self._T.pendingSlashWasControllerEnabled = isvalid(playerCtrl) and playerCtrl.Enable
		        if isvalid(playerCtrl) then
		            playerCtrl.Enable = false
		        end
		        if isvalid(self.Entity.MovementComponent) then
		            self.Entity.MovementComponent:Stop()
		        end
		
		        -- 스킬 사용과 동시에 플레이어 몸쪽에서 발현되는 시작 이펙트
		        self:PlaySlashBlastStartEffect(self.Entity, dirX)
		
		        -- 캐릭터 모션은 파워스트라이크와 같은 후보군(GetPowerStrikeSwing)에서 하나를 골라 재생한다.
		        -- (모션 이름만 재사용 - 스윙 궤적 이펙트 RUID는 사용하지 않는다.)
		        local swing = self:GetPowerStrikeSwing()
		        self:PlaySlashBlastMotion(self.Entity, swing.name, dirX, mult)
		
		        -- 첫 타격은 파워스트라이크와 동일하게 0.45초 뒤 판정하고, 이후 0.1초 고정 간격(공격속도 영향 없음)으로 다음 대상을 이어서 타격한다.
		        -- 대상 목록(targets)은 클로저 인자로 직접 전달한다 - 재시전으로 새 시퀀스가 시작돼도 이전 시퀀스의
		        -- 남은 타격이 뒤섞이지 않도록(공유 상태 대신 각자 자기 목록을 들고 있게) 하기 위함이다.
		        _TimerService:SetTimerOnce(function()
		            self:DealNextSlashBlastHit(targets, 1, mult)
		        end, 0.45 * mult)
		
		        -- 컨트롤 잠금 해제 시점: 대상 수와 무관하게 파워스트라이크와 동일한 고정 여유분(0.65초 = 0.45 + 0.2)에
		        -- 공격속도 배율을 적용한다. 타격이 여러 명에게 퍼져나가는 것(0.1초 고정 간격)은 이 잠금 시간과 별개로 계속 진행된다 -
		        -- 즉 컨트롤은 먼저 돌아오고, 남은 타격은 백그라운드에서 계속 이어진다.
		        _TimerService:SetTimerOnce(function()
		            self:RestoreSlashBlastControl()
		        end, 0.65 * mult)
	end

	@ExecSpace("Server")
	method void RestoreSlashBlastControl()
		        -- AttackSlashBlast에서 예약한(대상 수에 따라 가변인) 딜레이 뒤 호출된다.
		        -- 재시전 가능 상태로 되돌리고, 잠가뒀던 컨트롤러를 원래 값으로 복구한다.
		        self._T.isSlashBlasting = false
		        local playerCtrl = self.Entity.PlayerControllerComponent
		        if isvalid(playerCtrl) and self._T.pendingSlashWasControllerEnabled then
		            playerCtrl.Enable = true
		        end
		        -- 파이널어택(2차 패시브): 30% 확률로, 컨트롤이 실제로 돌아오는 이 시점에 바로 이어서(동기 호출) 추가타를
		        -- 실행한다. 파워스트라이크와 동일한 이유(별도 동일-딜레이 타이머의 실행 순서 레이스 방지)로 이 메서드
		        -- 안에서 직접 호출한다.
		        self:TryTriggerFinalAttack("slashblast", self._T.pendingSlashCombatPower, self._T.pendingSlashMult, self._T.pendingSlashIsSpear)
	end

	@ExecSpace("Server")
	method void DealNextSlashBlastHit(table targets, integer idx, number atkMultiplier)
		        -- 0.1초 고정 간격(공격속도 영향 없음)으로 재귀 예약되며, 호출부(AttackSlashBlast)가 넘겨준 대상 목록을 앞에서부터 한 명씩 타격한다.
		        -- 목록/인덱스/배율을 클로저 인자로 직접 들고 있어서, 컨트롤 잠금(RestoreSlashBlastControl)이나
		        -- 재시전 여부와 무관하게 이 시퀀스만의 진행 상태로 계속 이어진다.
		        if idx > #targets then return end
		        if not isvalid(self.Entity) then return end
		
		        local target = targets[idx]
		        if isvalid(target) then
		            -- IsAttackTarget이 이번 차례의 대상만 통과시키도록 지정한 뒤 동일한 전방 판정 박스로 Attack한다.
		            self._T.slashBlastCurrentTarget = target
		            local dirX = self._T.pendingSlashDirX or 1
		            local curWorldPos = self.Entity.TransformComponent.WorldPosition
		            local attackOffset = Vector2(
		                curWorldPos.x + 1.0 * dirX,
		                curWorldPos.y
		            )
		            local shape = BoxShape(attackOffset, Vector2(2, 2), 0)
		            local hitComps = self:Attack(shape, "skill.slashblast", CollisionGroups.HitBox)
		            -- IsHitTarget 등으로 실제로는 빗나갔을 수 있으므로, Attack()이 반환한 실제 명중 목록에서
		            -- 이번 대상이 있는지 확인한 뒤에만 히트 이펙트/사운드를 재생한다.
		            local actuallyHit = false
		            for _, hc in ipairs(hitComps) do
		                if isvalid(hc) and isvalid(hc.Entity) and hc.Entity == target then
		                    actuallyHit = true
		                    break
		                end
		            end
		            if actuallyHit then
		                self:PlaySlashBlastHitEffect(target)
		            end
		            log("PlayerAttack: AttackSlashBlast hit " .. tostring(idx) .. "/" .. tostring(#targets) .. " actuallyHit=" .. tostring(actuallyHit))
		        end

		        if idx < #targets then
		            _TimerService:SetTimerOnce(function()
		                self:DealNextSlashBlastHit(targets, idx + 1, atkMultiplier)
		            end, 0.1)
		        end
	end

	@ExecSpace("ServerOnly")
	method void AttackLuckySeven(number combatPower, number atkMultiplier)
		        -- 럭키세븐 발동: 표창 2개를 0.4초/0.5초 뒤 하나의 고정 표적에게 순서대로 던진다.
		        -- 딜레이 구조·컨트롤 잠금은 파워스트라이크와 동일한 공격속도 배율(atkMultiplier)을 적용한다.
		        local currentState = self.Entity.StateComponent.CurrentStateName
		        if currentState == "DEAD" or currentState == "CLIMB" or currentState == "LADDER" then
		            return
		        end
		        if self._T.isLuckySeven then
		            return
		        end

		        self._T.isLuckySeven = true

		        local mult = math.max(0.1, math.min(atkMultiplier or 1.0, 3.0))
		        self._T.pendingLuckySevenCombatPower = combatPower

		        local playerCtrl = self.Entity.PlayerControllerComponent
		        local worldPos = self.Entity.TransformComponent.WorldPosition
		        local dirX = playerCtrl.LookDirectionX
		        self._T.pendingLuckySevenDirX = dirX

		        -- 단일 고정 표적: 전방(x축) 사거리를 기존 대비 4배(2.0 → 8.0)로 늘린 럭키세븐 전용 탐색을 사용한다.
		        self._T.luckySevenTarget = self:FindLuckySevenTarget(Vector2(worldPos.x, worldPos.y), dirX)
		        -- 캐스팅 시점의 대상 위치를 스냅샷 - 표창이 날아가는 도중 대상이 죽어서 사라져도
		        -- 마지막 위치까지는 도달시켜 데미지 숫자(2줄)가 항상 뜨도록 한다.
		        self._T.luckySevenTargetPos = nil
		        if isvalid(self._T.luckySevenTarget) then
		            self._T.luckySevenTargetPos = self._T.luckySevenTarget.TransformComponent.Position
		        end

		        self._T.pendingLuckySevenWasControllerEnabled = isvalid(playerCtrl) and playerCtrl.Enable
		        if isvalid(playerCtrl) then
		            playerCtrl.Enable = false
		        end
		        if isvalid(self.Entity.MovementComponent) then
		            self.Entity.MovementComponent:Stop()
		        end

		        self:PlayLuckySevenUseSound(self.Entity)
		        self:PlayLuckySevenStartEffect(self.Entity, dirX)

		        local swing = self:GetLuckySevenSwing()
		        self:PlayLuckySevenMotion(self.Entity, swing.name, dirX, mult)

		        -- 표창 발사: 사용 후 0.4초/0.5초 뒤(공격속도 배율 적용) 순서대로 발사
		        _TimerService:SetTimerOnce(function()
		            self:FireLuckySevenShuriken(1)
		        end, 0.4 * mult)
		        _TimerService:SetTimerOnce(function()
		            self:FireLuckySevenShuriken(2)
		        end, 0.5 * mult)

		        -- 컨트롤 잠금 해제: 파워스트라이크와 동일한 고정 여유분(0.65초 * 배율). 표창 비행/타격은 이 시점 이후에도 계속된다.
		        _TimerService:SetTimerOnce(function()
		            self:RestoreLuckySevenControl()
		        end, 0.65 * mult)
	end

	@ExecSpace("Server")
	method void RestoreLuckySevenControl()
		        self._T.isLuckySeven = false
		        local playerCtrl = self.Entity.PlayerControllerComponent
		        if isvalid(playerCtrl) and self._T.pendingLuckySevenWasControllerEnabled then
		            playerCtrl.Enable = true
		        end
	end

	@ExecSpace("Server")
	method void FireLuckySevenShuriken(integer idx)
		        -- 예약된 딜레이(0.4초/0.5초 * 배율) 뒤 호출되어 표창 1개를 스폰하고 고정 표적을 향해 발사한다.
		        -- 대상이 이미 죽어서 사라졌어도 캐스팅 시점에 저장해둔 마지막 위치(fallbackPos)가 있으면
		        -- 그쪽으로 발사해 데미지 숫자(2줄)가 항상 뜨도록 한다 - 완전히 처음부터 대상이 없었을 때만 스킵.
		        if not isvalid(self.Entity) then return end
		        local target = self._T.luckySevenTarget
		        local fallbackPos = self._T.luckySevenTargetPos
		        if not isvalid(target) and fallbackPos == nil then
		            log("[LuckySeven] 대상 없음 - 표창 스킵 idx=" .. tostring(idx))
		            return
		        end
		        local parent = self.Entity.CurrentMap
		        if not isvalid(parent) then return end

		        self._T.luckySevenProjCount = (self._T.luckySevenProjCount or 0) + 1
		        local name = "luckyseven_proj_" .. tostring(self._T.luckySevenProjCount)
		        local pos = self.Entity.TransformComponent.WorldPosition
		        local spawnPos = Vector3(pos.x, pos.y + 0.4, pos.z)
		        local proj = _SpawnService:SpawnByModelId("luckysevenprojectile", name, spawnPos, parent)
		        if not isvalid(proj) then
		            log_warning("[LuckySeven] 표창 스폰 실패 idx=" .. tostring(idx))
		            return
		        end

		        ---@type LuckySevenProjectile
		        local pc = proj:GetComponent("script.LuckySevenProjectile")
		        if pc == nil then return end
		        pc.CombatPower = self._T.pendingLuckySevenCombatPower or 0
		        pc.HitIndex = idx
		        pc:Fire(target, fallbackPos)
		        local targetLabel = isvalid(target) and target.Name or "(대상 소멸, 마지막 위치로 발사)"
		        log("[LuckySeven] 표창 발사 idx=" .. tostring(idx) .. " target=" .. tostring(targetLabel))
	end

	@ExecSpace("ServerOnly")
	method Entity FindLuckySevenTarget(Vector2 fromPos, number dirX)
		local map = self.Entity.CurrentMap
		if not isvalid(map) then return nil end
		local monsterComps = map:GetChildComponentsByTypeName("script.Monster", true)
		local nearest = nil
		local nearestDist = 8.0
		for _, comp in ipairs(monsterComps) do
			---@type Monster
			local mc = comp
			if isvalid(mc) and isvalid(mc.Entity) and not mc.IsDead then
				local pos = mc.Entity.TransformComponent.WorldPosition
				local dx = pos.x - fromPos.x
				local dy = pos.y - fromPos.y
				if dx * dirX >= 0 and math.abs(dx) <= 8.0 and math.abs(dy) <= 1.0 then
					local dist = math.abs(dx)
					if dist <= nearestDist then
						nearest = mc.Entity
						nearestDist = dist
					end
				end
			end
		end
		return nearest
	end

	method table GetLuckySevenSwing()
		-- 사용자가 실제 화면으로 확인해 확정: swingO1/O2/O3(한손무기 계열)이 아대 모션으로 맞다.
		-- 존재하는 순서대로 1~3번 번호를 매겨 매 시전마다 순차적으로(랜덤 아님) 순환 재생한다.
		local candidates = {
			{ name = "swingO1" },
			{ name = "swingO2" },
			{ name = "swingO3" },
		}
		self._T.luckySevenSwingIndex = (self._T.luckySevenSwingIndex or 0) % #candidates + 1
		return candidates[self._T.luckySevenSwingIndex]
	end

	@ExecSpace("Multicast")
	method void PlayLuckySevenStartEffect(Entity attacker, number dirX)
		        -- 스킬 사용과 동시에 캐릭터 앞에서 발현되는 시작 이펙트 (skill/400.img/skill/4001344의 "effect" 노드)
		        if not self:IsClient() then return end
		        if not isvalid(attacker) then return end
		        local startEffectRUID = "0ae88fa494e743158da6ddb81c0c55f2"
		        local startOptions = { ["FlipX"] = dirX > 0 }
		        -- 이펙트 자체 아트의 피벗이 바깥쪽으로 치우쳐 있어 몸에서 멀어 보이던 것을 몸통 높이로 당김
		        -- (0.3은 너무 높다는 피드백으로 0.12로 낮춤)
		        _EffectService:PlayEffectAttached(startEffectRUID, attacker, Vector3(0, 0.12, 0), 0, Vector3(1, 1, 1), false, startOptions)
		        log("[LuckySeven] 시작 이펙트 재생")
	end

	@ExecSpace("Multicast")
	method void PlayLuckySevenUseSound(Entity attacker)
		        -- 스킬 사용 즉시 재생되는 사운드 (같은 리소스팩의 "_audio/Use")
		        if not self:IsClient() then return end
		        if not isvalid(attacker) then return end
		        _SoundService:PlaySound("879c81c8fc274aea87dc673de48ab5d1", 1.0)
	end

	@ExecSpace("Multicast")
	method void PlayLuckySevenMotion(Entity attacker, string motionName, number dirX, number atkMultiplier)
		        -- 럭키세븐 전용 모션 재생. 파워스트라이크/슬래쉬블래스트와 동일한 후보군(GetPowerStrikeSwing)에서
		        -- 고른 모션을 그대로 재생한다 - 표창 투척 전용 모션이 엔진에 없어 기존 스윙 모션을 재사용하는 단순화.
		        if not self:IsClient() then return end
		        if not isvalid(attacker) then return end
		        local avatarRenderer = attacker.AvatarRendererComponent
		        if not isvalid(avatarRenderer) then return end
		        local body = avatarRenderer:GetBodyEntity()
		        if not isvalid(body) then return end

		        local playerCtrl = attacker.PlayerControllerComponent
		        if isvalid(attacker.MovementComponent) then
		            attacker.MovementComponent:Stop()
		        end
		        if isvalid(playerCtrl) then
		            playerCtrl.LookDirectionX = dirX
		        end
		        self._T.isLuckySevenDirectionLocked = true
		        self._T.lockedLuckySevenDirX = dirX
		        self._T.lockedLuckySevenMotionName = motionName
		        self._T.isLuckySevenMotionPlaying = true

		        local mult = math.max(atkMultiplier or 1.0, 0.001)
		        local playRate = 1.0 / mult
		        self._T.lockedLuckySevenPlayRate = playRate

		        local motionEvent = ActionStateChangedEvent(motionName, motionName, playRate, SpriteAnimClipPlayType.Onetime)
		        body:SendEvent(motionEvent)
		        log("[LuckySeven] PlayLuckySevenMotion sent: " .. tostring(motionName) .. " playRate=" .. tostring(playRate))

		        _TimerService:SetTimerOnce(function()
		            self._T.isLuckySevenMotionPlaying = false
		        end, 0.25 * mult)

		        _TimerService:SetTimerOnce(function()
		            self._T.isLuckySevenDirectionLocked = false
		            local sc = self.Entity.StateComponent
		            if isvalid(sc) and sc.CurrentStateName ~= "DEAD" then
		                sc:ChangeState("IDLE")
		                sc:ChangeState("MOVE")
		                sc:ChangeState("IDLE")
		            end
		        end, 0.80 * mult)
	end

	@ExecSpace("ServerOnly")
	method table FindSlashBlastTargets(Vector2 fromPos, number dirX, integer maxCount)
		        -- 슬래쉬블래스트 대상 선정: 전방 판정 범위(가로 2칸, 세로 1칸) 안의 살아있는 script.Monster를
		        -- 가까운 순으로 정렬해 최대 maxCount명까지 후보로 반환한다 (실제 Attack 판정 없이 위치만으로 탐색).
		        local map = self.Entity.CurrentMap
		        if not isvalid(map) then return {} end
		        local monsterComps = map:GetChildComponentsByTypeName("script.Monster", true)
		        local candidates = {}
		        for _, comp in ipairs(monsterComps) do
		            ---@type Monster
		            local mc = comp
		            if isvalid(mc) and isvalid(mc.Entity) and not mc.IsDead then
		                local pos = mc.Entity.TransformComponent.WorldPosition
		                local dx = pos.x - fromPos.x
		                local dy = pos.y - fromPos.y
		                if dx * dirX >= 0 and math.abs(dx) <= 2.0 and math.abs(dy) <= 1.0 then
		                    table.insert(candidates, { entity = mc.Entity, dist = math.abs(dx) })
		                end
		            end
		        end
		        table.sort(candidates, function(a, b) return a.dist < b.dist end)
		        local result = {}
		        for i = 1, math.min(#candidates, maxCount) do
		            table.insert(result, candidates[i].entity)
		        end
		        return result
	end

	@ExecSpace("Multicast")
	method void PlaySlashBlastStartEffect(Entity attacker, number dirX)
		        -- 스킬 사용과 동시에 플레이어 몸쪽에서 발현되는 시작 이펙트 (skill/1100.img/skill/11001003 리소스팩의 "effect" 노드)
		        if not self:IsClient() then return end
		        if not isvalid(attacker) then return end
		        local startEffectRUID = "44c1d14578e24c639e480f54b156a8a2"
		        local startOptions = { ["FlipX"] = dirX > 0 }
		        _EffectService:PlayEffectAttached(startEffectRUID, attacker, Vector3(0, 0, 0), 0, Vector3(1, 1, 1), false, startOptions)
		        log("[SlashBlast] 시작 이펙트 재생")
	end

	@ExecSpace("Multicast")
	method void PlaySlashBlastHitEffect(Entity target)
		        -- hit 시 몬스터 몸에서 3종류 중 하나가 랜덤으로 발현 (같은 리소스팩의 hit/0, hit/1, hit/2)
		        if not self:IsClient() then return end
		        if not isvalid(target) then return end
		        local hitEffects = {
		            "41e13add2ba746d9bbe624a31205a848",
		            "880e540095704e30af6a554d51b8a3b3",
		            "eed46092f65940a7a8e77a1bd8e2aa75",
		        }
		        local index = _UtilLogic:RandomIntegerRange(1, #hitEffects)
		        _EffectService:PlayEffectAttached(hitEffects[index], target, Vector3(0, 0, 0), 0, Vector3(1, 1, 1), false, {})
		        -- 슬래쉬블래스트로 몬스터가 데미지를 받는 순간마다(대상 무관) 지정된 사운드를 1회 재생한다.
		        _SoundService:PlaySound("0f213b255ab34a0e8ed258c89f3b62fe", 1.0)
	end

	@ExecSpace("Multicast")
	method void PlaySlashBlastMotion(Entity attacker, string motionName, number dirX, number atkMultiplier)
		        -- 슬래쉬블래스트 전용 모션 재생. 파워스트라이크와 같은 방식(ActionStateChangedEvent 직접 전송)으로 동작하되,
		        -- 기본 무기 스윙 이펙트(ShowDefaultWeaponEffects)는 끄지 않는다 - 별도의 스윙 궤적 이펙트가 없고
		        -- 기본 공격의 스윙 이펙트를 그대로 사용하기 때문이다 (파워스트라이크와의 유일한 차이점).
		        if not self:IsClient() then return end
		        if not isvalid(attacker) then return end
		        local avatarRenderer = attacker.AvatarRendererComponent
		        if not isvalid(avatarRenderer) then return end
		        local body = avatarRenderer:GetBodyEntity()
		        if not isvalid(body) then return end
		
		        local playerCtrl = attacker.PlayerControllerComponent
		        if isvalid(attacker.MovementComponent) then
		            attacker.MovementComponent:Stop()
		        end
		        if isvalid(playerCtrl) then
		            playerCtrl.LookDirectionX = dirX
		        end
		        self._T.isSlashDirectionLocked = true
		        self._T.lockedSlashDirX = dirX
		        self._T.lockedSlashMotionName = motionName
		        self._T.isSlashMotionPlaying = true
		
		        -- 파워스트라이크(PlayAttackMotion)와 동일하게, 공격속도 배율이 짧을수록(빠를수록) 모션 재생속도(PlayRate)를
		        -- 그만큼 올려서 화면 재생 시간이 아래 타이머들(0.25/0.80초 * mult)과 어긋나지 않게 맞춘다.
		        local mult = math.max(atkMultiplier or 1.0, 0.001)
		        local playRate = 1.0 / mult
		        self._T.lockedSlashPlayRate = playRate
		
		        local motionEvent = ActionStateChangedEvent(motionName, motionName, playRate, SpriteAnimClipPlayType.Onetime)
		        body:SendEvent(motionEvent)
		        log("[SlashBlast] PlaySlashBlastMotion sent: " .. tostring(motionName) .. " playRate=" .. tostring(playRate))
		
		        -- 서버 RestoreSlashBlastControl과 동일한 길이(0.65초*mult + 0.15초 여유)로 잠금을 해제한다.
		        -- 대상 수와 무관하다 - 타격이 여러 명에게 퍼져나가는 것은 이 잠금과 별개로 계속 진행된다.
		        _TimerService:SetTimerOnce(function()
		            self._T.isSlashMotionPlaying = false
		        end, 0.25 * mult)
		
		        _TimerService:SetTimerOnce(function()
		            self._T.isSlashDirectionLocked = false
		            local sc = self.Entity.StateComponent
		            if isvalid(sc) and sc.CurrentStateName ~= "DEAD" then
		                sc:ChangeState("IDLE")
		                sc:ChangeState("MOVE")
		                sc:ChangeState("IDLE")
		            end
		        end, 0.80 * mult)
	end

	@ExecSpace("Server")
	method void NotifyMotionEnded()
		        -- AttackPowerStrike에서 예약한 고정 딜레이(0.25초) 타이머로 호출된다. 타격 판정/이펙트 재생만 여기서 처리한다.
		        -- (컨트롤러 잠금 해제와 재시전 허용은 RestoreControl에서 별도의 더 긴 딜레이로 처리한다.)
		        if self._T.motionEndHandled then return end
		        self._T.motionEndHandled = true
		
		        if not isvalid(self.Entity) then return end
		        local dirX = self._T.pendingDirX or 1
		        local swing = self._T.pendingSwing or { ruid = "", name = "?" }
		        local curWorldPos = self.Entity.TransformComponent.WorldPosition
		        -- 공격범위 x축 전방으로 2배 확장 (기존 1칸 → 2칸). y축은 아래쪽으로 더 길게 - 기존 상단 경계(y+1.0)는 유지하고 하단을 y-1.0까지 확장한다.
		        local attackOffset = Vector2(
		            curWorldPos.x + 1.0 * dirX,
		            curWorldPos.y
		        )
		        self._T.shape = BoxShape(attackOffset, Vector2(2, 2), 0)
		        local hitComps = self:Attack(self._T.shape, "skill.powerstrike", CollisionGroups.HitBox)
		        local targets = {}
		        for _, hc in ipairs(hitComps) do
		            if isvalid(hc) and isvalid(hc.Entity) then
		                table.insert(targets, hc.Entity)
		            end
		        end
		
		        self:PlayPowerStrikeEffects(self.Entity, dirX, targets, swing.ruid, swing.name)
		        log("PlayerAttack: AttackPowerStrike dir=" .. tostring(dirX) .. " targets=" .. tostring(#targets))
	end

	method table GetPowerStrikeSwing()
		        -- 파워스트라이크 전용 모션/이펙트 후보 - 매 시전마다 하나를 무작위로 골라 캐릭터 모션과 스윙 이펙트를 함께 통일한다.
		        -- (엔진이 기본 공격의 실제 재생 모션을 구분해 알려줄 방법이 없어서, 대신 스킬 전용 모션을 직접 지정하는 방식으로 바꿨다.)
		        -- swingTF(한바퀴 돌면서 공격하는 모션)는 기본 스킬 모션이 아니라 파이널어택 전용 모션이라는 사용자 지적으로
		        -- 이 후보군에서 제외하고 GetFinalAttackMotion()으로 옮겼다.
		        local candidates = {
		            { name = "swingT1", ruid = "98d2124f4c2740758a7ed92fb5aa3af1" },
		            { name = "swingT2", ruid = "447033cc51594e20a25d15bfe2995d2e" },
		            { name = "swingT3", ruid = "64e8406faa78478dbaccde3db7f074d1" },
		            { name = "stabO1",  ruid = "4e050b0cdec3479bb3ea4130b6f5e8a4" },
		            { name = "stabO2",  ruid = "e59f666887f14d498fed28682990f192" },
		            { name = "stabOF",  ruid = "d0515d7c8aef446d98e553a7f7c02696" },
		        }
		        local index = _UtilLogic:RandomIntegerRange(1, #candidates)
		        return candidates[index]
	end

	method table GetFinalAttackMotion(boolean isSpear)
		        -- 파이널어택(2차 패시브) 전용 모션. 창 장착 시에는 점프 찌르기/내려찍기 2종을 순환하고
		        -- (실제 화면으로 아직 확인되지 않은 추정 모션명 - 다르면 알려주면 바로 교체 가능),
		        -- 그 외 무기는 기존 파워스트라이크 후보군에서 빼온 회전 공격 모션(swingTF)을 고정 사용한다.
		        if isSpear then
		            local candidates = {
		                { name = "swingP1", ruid = "" },
		                { name = "swingPF", ruid = "" },
		            }
		            self._T.finalAttackSpearIndex = (self._T.finalAttackSpearIndex or 0) % #candidates + 1
		            return candidates[self._T.finalAttackSpearIndex]
		        end
		        return { name = "swingTF", ruid = "e46fe5e970f84e3f8f75ea914b2e3bf7" }
	end

	@ExecSpace("ServerOnly")
	method void TryTriggerFinalAttack(string sourceSkill, number combatPower, number atkMultiplier, boolean isSpear)
		        -- 파워스트라이크/슬래쉬블래스트 시전 시 30% 확률로, 그 스킬의 컨트롤 잠금이 풀리는 시점(RestoreControl/
		        -- RestoreSlashBlastControl)에 곧바로(동기 호출로) 이어서 같은 스킬을 "현재 캐릭터 공격속도 + 4단계"에
		        -- 해당하는 속도로 한번 더 실행하고(전용 모션은 창/비창 구분), 데미지에 15%~30% 추가 배율을 얹는다
		        -- (CalcDamage의 ".final" 분기가 처리). 호출부(RestoreControl류)가 이미 딜레이가 다 지난 시점에서
		        -- 직접 호출하므로 여기서 별도 타이머로 다시 감쌀 필요가 없다 - 별도 타이머로 감싸면 RestoreControl
		        -- 타이머와 실행 순서가 보장되지 않아(같은 프레임에 만료되는 두 타이머의 큐 순서 의존) 컨트롤이
		        -- 먼저 풀렸다가 파이널어택이 나중에 다시 잠그는 순서가 뒤집힐 경우 그 사이에 다른 행동이 가능해지는
		        -- 레이스 컨디션이 있었다.
		        -- CharInfoManager.GetAttackSpeedMultiplier()의 공식(0.9^(단계-5), 1단계 오를 때마다 이전 대비 10%씩 단축·복리)과
		        -- 동일하게, 현재 배율(atkMultiplier)에 0.9^4를 곱해 "현재 단계+4단계"의 배율을 구한다.
		        if math.random() >= 0.3 then return end
		        local finalMult = atkMultiplier * (0.9 ^ 4)
		        local userId = self.Entity.PlayerComponent.UserId
		        -- 파이널어택은 서버가 자체적으로(클라이언트 입력 없이) 발동시키므로, 클라이언트의 스킬 공용 쿨다운은
		        -- 원본 스킬의 쿨다운(0.75*atkMultiplier)이 이미 끝났거나 거의 끝난 상태다 - 그대로 두면 파이널어택
		        -- 모션이 재생되는 동안에도 다른 스킬 키를 눌러 딜레이 없이 다른 스킬을 쏠 수 있는 문제가 있었다.
		        -- 여기서 클라이언트의 공용 쿨다운을 다시 걸어(원본 스킬과 동일한 0.75*배율 공식) 파이널어택 모션
		        -- 동안에도 다른 스킬을 쓸 수 없도록 막는다.
		        _SkillManager:LockSkillUse(0.75 * finalMult, userId)
		        if sourceSkill == "powerstrike" then
		            self:AttackPowerStrikeFinal(combatPower, finalMult, isSpear)
		        else
		            self:AttackSlashBlastFinal(combatPower, finalMult, isSpear)
		        end
	end

	@ExecSpace("ServerOnly")
	method void AttackPowerStrikeFinal(number combatPower, number atkMultiplier, boolean isSpear)
		        -- 파이널어택으로 발동되는 파워스트라이크 추가타. 원본 파워스트라이크와 동일한 단일 대상 판정 구조를
		        -- 쓰되, 대상/컨트롤 관련 상태는 전부 별도 필드로 분리해 원본 스킬과 서로 간섭하지 않게 한다.
		        -- 단, 재시전 게이트(isPowerStriking)만은 원본과 **공유**한다 - 홀드 입력 중 클라이언트의 공용
		        -- 쿨다운(skillOnCooldown) 재설정이 네트워크 지연으로 파이널어택 시작보다 늦게 도착하면, 그 사이
		        -- 홀드-반복이 새 파워스트라이크 요청을 보낼 수 있는데(서버 입장에선 정상 요청처럼 보임), 이 요청이
		        -- isPowerStriking을 공유하지 않으면 그대로 통과해 파이널어택과 겹쳐 별도로 스윙만 재생되고 대상은
		        -- 이미 죽었거나 다른 이유로 빗나가 "헛빵"이 나는 문제가 있었다. 공유 게이트로 막으면 서버가
		        -- 네트워크 지연과 무관하게 항상 이 요청을 거부한다.
		        local currentState = self.Entity.StateComponent.CurrentStateName
		        if currentState == "DEAD" or currentState == "CLIMB" or currentState == "LADDER" then
		            return
		        end
		        self._T.isPowerStriking = true

		        self._T.pendingFinalCombatPower = combatPower
		        local playerCtrl = self.Entity.PlayerControllerComponent
		        local worldPos = self.Entity.TransformComponent.WorldPosition
		        local dirX = playerCtrl.LookDirectionX
		        self._T.pendingFinalDirX = dirX
		        self._T.powerStrikeFinalTarget = self:FindNearestMonster(Vector2(worldPos.x, worldPos.y), 2.0)

		        self._T.pendingFinalWasControllerEnabled = isvalid(playerCtrl) and playerCtrl.Enable
		        if isvalid(playerCtrl) then
		            playerCtrl.Enable = false
		        end
		        if isvalid(self.Entity.MovementComponent) then
		            self.Entity.MovementComponent:Stop()
		        end

		        self:PlaySkillUseSound(self.Entity)
		        self:PlaySkillStartEffect(self.Entity, dirX)

		        local swing = self:GetFinalAttackMotion(isSpear)
		        self._T.pendingFinalSwing = swing
		        self:PlayAttackMotion(self.Entity, swing.name, dirX, atkMultiplier)

		        _TimerService:SetTimerOnce(function()
		            self:NotifyFinalMotionEnded()
		        end, 0.45 * atkMultiplier)

		        _TimerService:SetTimerOnce(function()
		            self:RestoreFinalControl()
		        end, 0.65 * atkMultiplier)
	end

	@ExecSpace("Server")
	method void RestoreFinalControl()
		        self._T.isPowerStriking = false
		        local playerCtrl = self.Entity.PlayerControllerComponent
		        if isvalid(playerCtrl) and self._T.pendingFinalWasControllerEnabled then
		            playerCtrl.Enable = true
		        end
	end

	method void NotifyFinalMotionEnded()
		        if not isvalid(self.Entity) then return end
		        local dirX = self._T.pendingFinalDirX or 1
		        local swing = self._T.pendingFinalSwing or { ruid = "", name = "?" }
		        local curWorldPos = self.Entity.TransformComponent.WorldPosition
		        local attackOffset = Vector2(
		            curWorldPos.x + 1.0 * dirX,
		            curWorldPos.y
		        )
		        local shape = BoxShape(attackOffset, Vector2(2, 2), 0)
		        local hitComps = self:Attack(shape, "skill.powerstrike.final", CollisionGroups.HitBox)
		        local targets = {}
		        for _, hc in ipairs(hitComps) do
		            if isvalid(hc) and isvalid(hc.Entity) then
		                table.insert(targets, hc.Entity)
		            end
		        end
		        self:PlayPowerStrikeEffects(self.Entity, dirX, targets, swing.ruid, swing.name)
		        for _, t in ipairs(targets) do
		            self:PlayFinalAttackHitEffect(t)
		        end
		        log("PlayerAttack: AttackPowerStrikeFinal dir=" .. tostring(dirX) .. " targets=" .. tostring(#targets))
	end

	@ExecSpace("ServerOnly")
	method void AttackSlashBlastFinal(number combatPower, number atkMultiplier, boolean isSpear)
		        -- 파이널어택으로 발동되는 슬래쉬블래스트 추가타. 원본과 동일한 다중 대상(최대 6명) 순차 타격 구조.
		        -- 재시전 게이트(isSlashBlasting)는 파워스트라이크와 동일한 이유로 원본과 공유한다 - 클라이언트
		        -- 공용 쿨다운 재설정(LockSkillUse)이 네트워크 지연으로 늦게 도착해 홀드-반복이 새 요청을 보내도
		        -- 서버가 이 공유 게이트로 항상 거부하게 하기 위함(안 그러면 별도로 스윙만 재생되고 대상은 이미
		        -- 죽었거나 빗나가 "헛빵"이 나는 문제가 있었다).
		        local currentState = self.Entity.StateComponent.CurrentStateName
		        if currentState == "DEAD" or currentState == "CLIMB" or currentState == "LADDER" then
		            return
		        end
		        self._T.isSlashBlasting = true

		        self._T.pendingFinalSlashCombatPower = combatPower
		        local playerCtrl = self.Entity.PlayerControllerComponent
		        local worldPos = self.Entity.TransformComponent.WorldPosition
		        local dirX = playerCtrl.LookDirectionX
		        self._T.pendingFinalSlashDirX = dirX

		        local targets = self:FindSlashBlastTargets(Vector2(worldPos.x, worldPos.y), dirX, 6)

		        self._T.pendingFinalSlashWasControllerEnabled = isvalid(playerCtrl) and playerCtrl.Enable
		        if isvalid(playerCtrl) then
		            playerCtrl.Enable = false
		        end
		        if isvalid(self.Entity.MovementComponent) then
		            self.Entity.MovementComponent:Stop()
		        end

		        self:PlaySlashBlastStartEffect(self.Entity, dirX)

		        local swing = self:GetFinalAttackMotion(isSpear)
		        self:PlaySlashBlastMotion(self.Entity, swing.name, dirX, atkMultiplier)

		        _TimerService:SetTimerOnce(function()
		            self:DealNextSlashBlastFinalHit(targets, 1, atkMultiplier)
		        end, 0.45 * atkMultiplier)

		        _TimerService:SetTimerOnce(function()
		            self:RestoreSlashBlastFinalControl()
		        end, 0.65 * atkMultiplier)
	end

	@ExecSpace("Server")
	method void RestoreSlashBlastFinalControl()
		        self._T.isSlashBlasting = false
		        local playerCtrl = self.Entity.PlayerControllerComponent
		        if isvalid(playerCtrl) and self._T.pendingFinalSlashWasControllerEnabled then
		            playerCtrl.Enable = true
		        end
	end

	@ExecSpace("Server")
	method void DealNextSlashBlastFinalHit(table targets, integer idx, number atkMultiplier)
		        if idx > #targets then return end
		        if not isvalid(self.Entity) then return end

		        local target = targets[idx]
		        if isvalid(target) then
		            self._T.slashBlastFinalCurrentTarget = target
		            local dirX = self._T.pendingFinalSlashDirX or 1
		            local curWorldPos = self.Entity.TransformComponent.WorldPosition
		            local attackOffset = Vector2(
		                curWorldPos.x + 1.0 * dirX,
		                curWorldPos.y
		            )
		            local shape = BoxShape(attackOffset, Vector2(2, 2), 0)
		            local hitComps = self:Attack(shape, "skill.slashblast.final", CollisionGroups.HitBox)
		            local actuallyHit = false
		            for _, hc in ipairs(hitComps) do
		                if isvalid(hc) and isvalid(hc.Entity) and hc.Entity == target then
		                    actuallyHit = true
		                    break
		                end
		            end
		            if actuallyHit then
		                self:PlaySlashBlastHitEffect(target)
		                self:PlayFinalAttackHitEffect(target)
		            end
		            log("PlayerAttack: AttackSlashBlastFinal hit " .. tostring(idx) .. "/" .. tostring(#targets) .. " actuallyHit=" .. tostring(actuallyHit))
		        end

		        if idx < #targets then
		            _TimerService:SetTimerOnce(function()
		                self:DealNextSlashBlastFinalHit(targets, idx + 1, atkMultiplier)
		            end, 0.1)
		        end
	end

	@ExecSpace("Multicast")
	method void PlayFinalAttackHitEffect(Entity target)
		        -- 파이널어택 추가타에 맞은 몬스터 머리 위에 재생되는 전용 이펙트.
		        if not self:IsClient() then return end
		        if not isvalid(target) then return end
		        local headY = 0.5
		        local hit = target.HitComponent
		        if isvalid(hit) then
		            headY = hit.ColliderOffset.y + hit.BoxSize.y / 2
		        end
		        local serial = _EffectService:PlayEffectAttached("c36e70d7b1d84845bf4067d069ba5e1a", target, Vector3(0, headY, 0), 0, Vector3(1, 1, 1), false, {})
		        _TimerService:SetTimerOnce(function()
		            _EffectService:RemoveEffect(serial)
		        end, 1.0)
	end

	@ExecSpace("Multicast")
	method void PlaySkillUseSound(Entity attacker)
		        -- 파워스트라이크 사용 시 사운드 재생. Multicast는 서버 자신도 함께 실행하므로 클라이언트에서만 실행되게 막는다.
		        if not self:IsClient() then return end
		        if not isvalid(attacker) then return end
		        local hitSoundRUID = "e0178f48602742c0bd8b295fdc27261c"
		        _SoundService:PlaySound(hitSoundRUID, 1.0)
	end

	@ExecSpace("Multicast")
	method void PlayAttackMotion(Entity attacker, string motionName, number dirX, number atkMultiplier)
		        -- 파워스트라이크 전용 세부 모션(swingT1~TF, stabO1~OF)을 아바타 몸체에 직접 재생한다.
		        -- StateComponent:ChangeState("ATTACK")을 거치면 StateToAvatarBodyActionSheet의 기본 "attack" 클립이
		        -- 함께 재생을 시도해 이 이벤트와 경합하면서(레이스) 모든 시전이 같은 기본 자세로 보이는 문제가 있었다.
		        -- (animation-state.md 7절 "State change races animation" 패턴) 그래서 ATTACK 상태 전환 없이
		        -- ActionStateChangedEvent만으로 모션을 직접 재생해 7종 모션이 항상 구분되도록 한다.
		        -- Multicast는 서버 자신도 함께 실행하므로 클라이언트에서만 실행되게 막는다 (GetBodyEntity는 ClientOnly라 서버에서는 항상 실패한다).
		        if not self:IsClient() then return end
		        if not isvalid(attacker) then return end
		        local avatarRenderer = attacker.AvatarRendererComponent
		        if not isvalid(avatarRenderer) then return end
		        local body = avatarRenderer:GetBodyEntity()
		        if not isvalid(body) then return end
		
		        -- 기본 무기 스윙 이펙트(ShowDefaultWeaponEffects)를 여기(클라이언트, 같은 Multicast 호출 안)에서 직접 끈다.
		        -- 서버에서 끄면 @Sync 전파 지연 때문에 모션 재생(아래 SendEvent)과 도착 순서가 보장되지 않아,
		        -- 파워스트라이크가 "attack" 계열 모션을 그대로 갖다 쓰면서 딸려오는 기본 스윙 이펙트가 한 프레임 섞여 보였다.
		        avatarRenderer.ShowDefaultWeaponEffects = false
		
		        -- 이동 중이던 잔여 이동을 클라이언트 화면에서도 즉시 멈추고(순서상 반드시 모션 전송보다 먼저),
		        -- 바라보는 방향을 지금 이 시점 값으로 고정한다. 모션 재생 중 반대 방향키를 눌러도 바라보는 방향이
		        -- 바뀌지 않도록 OnUpdate에서 매 프레임 이 방향으로 다시 고정한다(아래 OnUpdate 참고) -
		        -- PlayerControllerComponent.Enable = false만으로는 이동은 막히지만 방향 전환까지는 막히지 않는다.
		        local playerCtrl = attacker.PlayerControllerComponent
		        if isvalid(attacker.MovementComponent) then
		            attacker.MovementComponent:Stop()
		        end
		        if isvalid(playerCtrl) then
		            playerCtrl.LookDirectionX = dirX
		        end
		        self._T.isDirectionLocked = true
		        self._T.lockedDirX = dirX
		        self._T.lockedMotionName = motionName
		        self._T.isMotionPlaying = true
		        -- 홀드 지속발동 중 다음 시전이 쿨다운(0.75*mult)만큼 뒤에 시작될 수 있는데, 이 잠금 해제 타이머는
		        -- 그보다 늦은 0.80*mult 뒤에 실행된다. 즉 새 시전이 이미 방향을 다시 잠근 뒤에 이전 시전의 해제
		        -- 타이머가 뒤늦게 실행되며 새 시전의 잠금을 잘못 풀어버려, 그 틈에 이동키 입력으로 방향이 갑자기
		        -- 바뀌는 문제가 있었다. 시전마다 토큰을 발급해 "그 사이 더 최근 시전이 없었을 때만" 해제한다.
		        self._T.powerStrikeLockToken = (self._T.powerStrikeLockToken or 0) + 1
		        local myLockToken = self._T.powerStrikeLockToken
		
		        -- 공격속도 배율(atkMultiplier)이 짧을수록(=공격속도가 빠를수록) 모션 재생속도(PlayRate)를 그만큼 올려서
		        -- 실제 화면 재생 시간이 아래 타이머들(0.25/0.65초 * atkMultiplier)과 어긋나지 않게 맞춘다.
		        local mult = math.max(atkMultiplier or 1.0, 0.001)
		        local playRate = 1.0 / mult
		        self._T.lockedPlayRate = playRate
		
		        local motionEvent = ActionStateChangedEvent(motionName, motionName, playRate, SpriteAnimClipPlayType.Onetime)
		        body:SendEvent(motionEvent)
		        log("[PowerStrike] PlayAttackMotion sent: " .. tostring(motionName) .. " playRate=" .. tostring(playRate))
		
		        -- 기본 스윙 이펙트 복구 + 실제 모션 재생 구간 종료(_T.isMotionPlaying)는 서버 타격 판정과 같은 시간(기본 0.25초 * 배율)에 처리한다.
		        _TimerService:SetTimerOnce(function()
		            if isvalid(avatarRenderer) then
		                avatarRenderer.ShowDefaultWeaponEffects = true
		            end
		            self._T.isMotionPlaying = false
		        end, 0.25 * mult)
		
		        -- 방향 잠금은 서버의 컨트롤러 잠금과 같은 길이(기본 0.65초 * 배율) 뒤 해제한다.
		        _TimerService:SetTimerOnce(function()
		            if self._T.powerStrikeLockToken ~= myLockToken then return end
		            self._T.isDirectionLocked = false
		            -- 반대 방향키를 누르고 있는 상태로 이 시점을 맞으면, 아직 화면에 남아있는 스킬 모션(raw
		            -- ActionStateChangedEvent) 클립의 꼬리 프레임이 보이면서 캐릭터가 반대 방향으로 움직이기
		            -- 시작하는 문제가 있었다. 상태가 계속 IDLE으로만 유지되면(자연스러운 MOVE 전환이 한 번도
		            -- 없었던 경우) StateChangeEvent가 새로 발생하지 않아 위 스킬 모션 클립이 그대로 남아있기
		            -- 때문이다. 여기서 IDLE -> MOVE -> IDLE로 강제 토글해 StateChangeEvent를 한 번 더 일으켜,
		            -- AvatarStateAnimationComponent가 걷기/서기 클립을 다시 내보내 남은 스킬 모션을 확실히
		            -- 덮어쓰게 한다. 이동 봉인이 완전히 풀리기 직전에 실행되므로 실제 조작감에는 영향이 없다.
		            local sc = self.Entity.StateComponent
		            if isvalid(sc) and sc.CurrentStateName ~= "DEAD" then
		                sc:ChangeState("IDLE")
		                sc:ChangeState("MOVE")
		                sc:ChangeState("IDLE")
		                log("[PowerStrike] unlock refresh toggle done (was " .. tostring(sc.CurrentStateName) .. ")")
		            end
		        end, 0.80 * mult)
	end

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		        -- 텔레포트 등으로 캐릭터가 카메라의 SoftZone을 벗어나면 부드러운 추적 대신 즉시 이동(스냅)으로
		        -- 바뀌는 것으로 추정됨(사용자 관찰) - SoftZone만 3배로 넓혀 텔레포트 거리(3유닛)가 이 범위 안에
		        -- 들어오게 한다. DeadZone은 건드리지 않는다 - DeadZone은 "카메라가 캐릭터를 안 움직이고 잡아두는
		        -- 영역"이라 이것까지 키우면 평소 걷기 이동에서도 캐릭터가 화면 정중앙까지 오지 않고 넓어진
		        -- 데드존 안 어딘가에서 멈춰버리는 문제가 있었다(사용자 재확인, 2026-07-05). 로컬 플레이어에게만,
		        -- 한 번만 적용(다른 클라이언트가 보는 원격 플레이어의 카메라 컴포넌트는 건드리지 않음).
		        if not self._T.cameraZoneApplied then
		            self._T.cameraZoneApplied = true
		            if self.Entity == _UserService.LocalPlayer then
		                local cam = self.Entity.CameraComponent
		                if isvalid(cam) then
		                    local ZONE_MULTIPLIER = 3.0
		                    local sz = cam.SoftZone
		                    cam.SoftZone = Vector2(math.min(sz.x * ZONE_MULTIPLIER, 1.0), math.min(sz.y * ZONE_MULTIPLIER, 1.0))
		                    log("[PlayerAttack] Camera zone enlarged: DeadZone=(" .. tostring(cam.DeadZone.x) .. "," .. tostring(cam.DeadZone.y) .. ") SoftZone=(" .. tostring(cam.SoftZone.x) .. "," .. tostring(cam.SoftZone.y) .. ")")
		                end
		            end
		        end
		        -- 파워스트라이크 모션 재생 중(_T.isDirectionLocked)에는 매 프레임 바라보는 방향을 고정해서,
		        -- 반대 방향키 입력으로 캐릭터가 순간적으로 반대쪽을 보며 모션이 어색하게 끊기는 것을 막는다.
		        if self._T.isDirectionLocked then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedDirX
		            end
		        end
		        -- 럭키세븐 모션 재생 중에도 매 프레임 바라보는 방향을 고정한다 (파워스트라이크/슬래쉬블래스트와 별도 플래그)
		        if self._T.isLuckySevenDirectionLocked then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedLuckySevenDirX
		            end
		        end
		        -- 슬래쉬블래스트 모션 재생 중에도 동일하게 방향을 고정한다 (파워스트라이크와 별도 플래그)
		        if self._T.isSlashDirectionLocked then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedSlashDirX
		            end
		        end
		        -- 더블스탭 모션 재생 중에도 동일하게 방향을 고정한다 (다른 스킬과 별도 플래그)
		        if self._T.isDoubleStabDirectionLocked then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedDoubleStabDirX
		            end
		        end
		        -- 매직클로 모션 재생 중에도 동일하게 방향을 고정한다 (다른 스킬과 별도 플래그)
		        if self._T.isMagicClawDirectionLocked then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedMagicClawDirX
		            end
		        end
		        -- 썬더볼트 모션 재생 중에도 동일하게 방향을 고정한다 (다른 스킬과 별도 플래그)
		        if self._T.isThunderboltDirectionLocked then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedThunderboltDirX
		            end
		        end
		        -- 힐 모션 재생 중에도 동일하게 방향을 고정한다 (다른 스킬과 별도 플래그)
		        if self._T.isHealDirectionLocked then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedHealDirX
		            end
		        end
		        -- 파이어에로우 모션 재생 중에도 동일하게 방향을 고정한다 (다른 스킬과 별도 플래그)
		        if self._T.isFireArrowDirectionLocked then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedFireArrowDirX
		            end
		        end
		        -- 아이언에로우 모션 재생 중에도 동일하게 방향을 고정한다 (파이어에로우와 별도 플래그)
		        if self._T.isIronArrowDirectionLocked then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedIronArrowDirX
		            end
		        end
	end

	@ExecSpace("Multicast")
	method void PlaySkillStartEffect(Entity attacker, number dirX)
		        -- 스킬 시전 시작 이펙트 재생: 파워 스트라이크 리소스팩(skill/800033.img/skill/80003316)의 "effect" 노드.
		        -- Multicast는 서버 자신도 함께 실행하므로 클라이언트에서만 실행되게 막는다.
		        if not self:IsClient() then return end
		        if not isvalid(attacker) then return end
		        local startEffectRUID = "522793cef4ff4b79bdf73b9eda9386f8"
		        local startOptions = { ["FlipX"] = dirX > 0 }
		        _EffectService:PlayEffectAttached(startEffectRUID, attacker, Vector3(0, 0, 0), 0, Vector3(1, 1, 1), false, startOptions)
		        log("[PowerStrike] 시전 시작 이펙트 재생")
	end

	@ExecSpace("ServerOnly")
	method Entity FindNearestMonster(Vector2 fromPos, number maxRange)
		        -- 파워스트라이크 대상 선정: 사거리 내 script.Monster 컴포넌트가 있는 살아있는 엔티티 중 가장 가까운 하나
		        local map = self.Entity.CurrentMap
		        if not isvalid(map) then return nil end
		        local monsterComps = map:GetChildComponentsByTypeName("script.Monster", true)
		        local nearest = nil
		        local nearestDist = maxRange
		        for _, comp in ipairs(monsterComps) do
		            ---@type Monster
		            local mc = comp
		            if isvalid(mc) and isvalid(mc.Entity) and not mc.IsDead then
		                local pos = mc.Entity.TransformComponent.WorldPosition
		                local dx = pos.x - fromPos.x
		                local dy = pos.y - fromPos.y
		                local dist = math.sqrt(dx * dx + dy * dy)
		                if dist <= nearestDist then
		                    nearest = mc.Entity
		                    nearestDist = dist
		                end
		            end
		        end
		        return nearest
	end

	@ExecSpace("Multicast")
	method void PlayPowerStrikeEffects(Entity attacker, number dirX, table targets, string swingEffectRUID, string swingEffectName)
		        -- 스윙 궤적 이펙트 + 몬스터 뒤쪽 후방 이펙트 재생. 호출 시점 자체가 이미 NotifyMotionEnded(모션 종료) 시점이므로 즉시 재생한다.
		        -- swingEffectRUID/Name은 호출부(AttackPowerStrike)에서 GetPowerStrikeSwing()으로 한 번만 뽑아 전달한 값 -
		        -- 여기서 다시 뽑으면 캐릭터 모션(PlayAttackMotion)과 서로 다른 자세로 어긋날 수 있다.
		        -- Multicast는 서버 자신도 함께 실행하므로 클라이언트에서만 실행되게 막는다 - 안 그러면 서버 쪽 실행이 fallback RUID로 별도의 스윙 이펙트를 한 번 더 재생해 2개가 겹쳐 보인다.
		        if not self:IsClient() then return end
		        if not isvalid(attacker) then return end
		        local backEffectRUID  = "dad03b3a528348bf98295b01edd621a4"
		        local swingSoundRUID  = "d3205fdd08e34b68bc01292a997531ed"
		
		        log("[PowerStrike] 파워스트라이크 스윙 재생: " .. tostring(swingEffectName) .. " (RUID=" .. tostring(swingEffectRUID) .. ")")
		        -- 스킬 이펙트 투명도 80%
		        local swingOptions = { ["FlipX"] = dirX > 0, ["Alpha"] = 0.8 }
		        _EffectService:PlayEffectAttached(swingEffectRUID, attacker, Vector3(0.1 * dirX, 0, 0), 0, Vector3(1, 1, 1), false, swingOptions)
		
		        -- 스윙 사운드는 실제로 몬스터에 적중했을 때만 후방 이펙트와 함께 재생 (빗나가면 들리지 않아야 함)
		        for _, target in ipairs(targets) do
		            if isvalid(target) then
		                local flipBack   = dirX > 0
		                local backOffset = dirX > 0 and 0.4 or -0.4
		                local backOptions = { ["FlipX"] = flipBack }
		                _EffectService:PlayEffectAttached(backEffectRUID, target, Vector3(backOffset, 0, 0), 0, Vector3(1, 1, 1), false, backOptions)
		                _SoundService:PlaySound(swingSoundRUID, 1.0)
		            end
		        end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleStateChangeEvent(StateChangeEvent event)
		        -- 파워스트라이크 실제 모션 재생 구간(_T.isMotionPlaying, 0~0.25초)에 착지(FALL/JUMP -> IDLE) 등 다른 상태
		        -- 전환이 끼어들면 StateToAvatarBodyActionSheet의 기본 모션(stand/walk/fall 등)이 재생되어 스킬 모션이
		        -- 끊기는 문제가 있었다 - 이 구간에서만 방향을 다시 고정하고 스킬 모션을 즉시 다시 덮어씌운다.
		        --
		        -- 모션 재생이 끝난 뒤(0.25~0.65초, 추가 이동 봉인 구간)에는 모션을 다시 덮어씌우지 않는다. 이 구간에서도
		        -- 매번 재적용하면, 방향키를 눌러 MOVE 상태로 전환될 때마다 이미 끝난 스윙 모션이 처음부터 다시 재생되어
		        -- "방향을 바꾸면 모션이 한 번 더 재생된다"는 문제가 있었다. 대신 IDLE이 아닌 상태로 전환되려는 시도만
		        -- 즉시 IDLE로 되돌려서, 이동 봉인이 완전히 풀릴 때까지(RestoreControl) 겉보기에도 계속 서 있게 만든다.
		        if event.CurrentStateName == "DEAD" then return end
		        if self._T.isMotionPlaying then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedDirX
		            end
		            local motionName = self._T.lockedMotionName
		            if not motionName then return end
		            local avatarRenderer = self.Entity.AvatarRendererComponent
		            if not isvalid(avatarRenderer) then return end
		            local body = avatarRenderer:GetBodyEntity()
		            if not isvalid(body) then return end
		            local motionEvent = ActionStateChangedEvent(motionName, motionName, self._T.lockedPlayRate or 1.0, SpriteAnimClipPlayType.Onetime)
		            body:SendEvent(motionEvent)
		            log("[PowerStrike] HandleStateChangeEvent re-applied motion over " .. tostring(event.CurrentStateName) .. ": " .. tostring(motionName))
		            return
		        end
		        if self._T.isDirectionLocked and event.CurrentStateName ~= "IDLE" then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedDirX
		            end
		            local sc = self.Entity.StateComponent
		            if isvalid(sc) then
		                sc:ChangeState("IDLE")
		                log("[PowerStrike] HandleStateChangeEvent forced back to IDLE from " .. tostring(event.CurrentStateName))
		            end
		        end
		
		        -- 럭키세븐 전용 처리 (파워스트라이크/슬래쉬블래스트와 동일한 패턴이지만 별도의 플래그를 사용 - 서로 간섭하지 않는다)
		        if self._T.isLuckySevenMotionPlaying then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedLuckySevenDirX
		            end
		            local motionName = self._T.lockedLuckySevenMotionName
		            if not motionName then return end
		            local avatarRenderer = self.Entity.AvatarRendererComponent
		            if not isvalid(avatarRenderer) then return end
		            local body = avatarRenderer:GetBodyEntity()
		            if not isvalid(body) then return end
		            local motionEvent = ActionStateChangedEvent(motionName, motionName, self._T.lockedLuckySevenPlayRate or 1.0, SpriteAnimClipPlayType.Onetime)
		            body:SendEvent(motionEvent)
		            log("[LuckySeven] HandleStateChangeEvent re-applied motion over " .. tostring(event.CurrentStateName) .. ": " .. tostring(motionName))
		            return
		        end
		        if self._T.isLuckySevenDirectionLocked and event.CurrentStateName ~= "IDLE" then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedLuckySevenDirX
		            end
		            local sc = self.Entity.StateComponent
		            if isvalid(sc) then
		                sc:ChangeState("IDLE")
		                log("[LuckySeven] HandleStateChangeEvent forced back to IDLE from " .. tostring(event.CurrentStateName))
		            end
		        end

		        -- 슬래쉬블래스트 전용 처리 (파워스트라이크와 동일한 패턴이지만 별도의 플래그를 사용 - 서로 간섭하지 않는다)
		        if self._T.isSlashMotionPlaying then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedSlashDirX
		            end
		            local motionName = self._T.lockedSlashMotionName
		            if not motionName then return end
		            local avatarRenderer = self.Entity.AvatarRendererComponent
		            if not isvalid(avatarRenderer) then return end
		            local body = avatarRenderer:GetBodyEntity()
		            if not isvalid(body) then return end
		            local motionEvent = ActionStateChangedEvent(motionName, motionName, self._T.lockedSlashPlayRate or 1.0, SpriteAnimClipPlayType.Onetime)
		            body:SendEvent(motionEvent)
		            log("[SlashBlast] HandleStateChangeEvent re-applied motion over " .. tostring(event.CurrentStateName) .. ": " .. tostring(motionName))
		            return
		        end
		        if self._T.isSlashDirectionLocked and event.CurrentStateName ~= "IDLE" then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedSlashDirX
		            end
		            local sc = self.Entity.StateComponent
		            if isvalid(sc) then
		                sc:ChangeState("IDLE")
		                log("[SlashBlast] HandleStateChangeEvent forced back to IDLE from " .. tostring(event.CurrentStateName))
		            end
		        end

		        -- 더블스탭 전용 처리 (파워스트라이크와 동일한 패턴이지만 별도의 플래그를 사용 - 서로 간섭하지 않는다)
		        if self._T.isDoubleStabMotionPlaying then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedDoubleStabDirX
		            end
		            local motionName = self._T.lockedDoubleStabMotionName
		            if not motionName then return end
		            local avatarRenderer = self.Entity.AvatarRendererComponent
		            if not isvalid(avatarRenderer) then return end
		            local body = avatarRenderer:GetBodyEntity()
		            if not isvalid(body) then return end
		            local motionEvent = ActionStateChangedEvent(motionName, motionName, self._T.lockedDoubleStabPlayRate or 1.0, SpriteAnimClipPlayType.Onetime)
		            body:SendEvent(motionEvent)
		            log("[DoubleStab] HandleStateChangeEvent re-applied motion over " .. tostring(event.CurrentStateName) .. ": " .. tostring(motionName))
		            return
		        end
		        if self._T.isDoubleStabDirectionLocked and event.CurrentStateName ~= "IDLE" then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedDoubleStabDirX
		            end
		            local sc = self.Entity.StateComponent
		            if isvalid(sc) then
		                sc:ChangeState("IDLE")
		                log("[DoubleStab] HandleStateChangeEvent forced back to IDLE from " .. tostring(event.CurrentStateName))
		            end
		        end

		        -- 매직클로 전용 처리 (다른 스킬과 동일한 패턴이지만 별도의 플래그를 사용 - 서로 간섭하지 않는다)
		        if self._T.isMagicClawMotionPlaying then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedMagicClawDirX
		            end
		            local motionName = self._T.lockedMagicClawMotionName
		            if not motionName then return end
		            local avatarRenderer = self.Entity.AvatarRendererComponent
		            if not isvalid(avatarRenderer) then return end
		            local body = avatarRenderer:GetBodyEntity()
		            if not isvalid(body) then return end
		            local motionEvent = ActionStateChangedEvent(motionName, motionName, self._T.lockedMagicClawPlayRate or 1.0, SpriteAnimClipPlayType.Onetime)
		            body:SendEvent(motionEvent)
		            log("[MagicClaw] HandleStateChangeEvent re-applied motion over " .. tostring(event.CurrentStateName) .. ": " .. tostring(motionName))
		            return
		        end
		        if self._T.isMagicClawDirectionLocked and event.CurrentStateName ~= "IDLE" then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedMagicClawDirX
		            end
		            local sc = self.Entity.StateComponent
		            if isvalid(sc) then
		                sc:ChangeState("IDLE")
		                log("[MagicClaw] HandleStateChangeEvent forced back to IDLE from " .. tostring(event.CurrentStateName))
		            end
		        end

		        -- 썬더볼트 전용 처리 (매직클로와 동일한 패턴이지만 별도의 플래그를 사용 - 서로 간섭하지 않는다)
		        if self._T.isThunderboltMotionPlaying then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedThunderboltDirX
		            end
		            local motionName = self._T.lockedThunderboltMotionName
		            if not motionName then return end
		            local avatarRenderer = self.Entity.AvatarRendererComponent
		            if not isvalid(avatarRenderer) then return end
		            local body = avatarRenderer:GetBodyEntity()
		            if not isvalid(body) then return end
		            local motionEvent = ActionStateChangedEvent(motionName, motionName, self._T.lockedThunderboltPlayRate or 1.0, SpriteAnimClipPlayType.Onetime)
		            body:SendEvent(motionEvent)
		            log("[Thunderbolt] HandleStateChangeEvent re-applied motion over " .. tostring(event.CurrentStateName) .. ": " .. tostring(motionName))
		            return
		        end
		        if self._T.isThunderboltDirectionLocked and event.CurrentStateName ~= "IDLE" then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedThunderboltDirX
		            end
		            local sc = self.Entity.StateComponent
		            if isvalid(sc) then
		                sc:ChangeState("IDLE")
		                log("[Thunderbolt] HandleStateChangeEvent forced back to IDLE from " .. tostring(event.CurrentStateName))
		            end
		        end

		        -- 힐 전용 처리 (다른 스킬과 동일한 패턴이지만 별도의 플래그를 사용 - 서로 간섭하지 않는다)
		        if self._T.isHealMotionPlaying then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedHealDirX
		            end
		            local motionName = self._T.lockedHealMotionName
		            if not motionName then return end
		            local avatarRenderer = self.Entity.AvatarRendererComponent
		            if not isvalid(avatarRenderer) then return end
		            local body = avatarRenderer:GetBodyEntity()
		            if not isvalid(body) then return end
		            local motionEvent = ActionStateChangedEvent(motionName, motionName, self._T.lockedHealPlayRate or 1.0, SpriteAnimClipPlayType.Onetime)
		            body:SendEvent(motionEvent)
		            log("[Heal] HandleStateChangeEvent re-applied motion over " .. tostring(event.CurrentStateName) .. ": " .. tostring(motionName))
		            return
		        end
		        if self._T.isHealDirectionLocked and event.CurrentStateName ~= "IDLE" then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedHealDirX
		            end
		            local sc = self.Entity.StateComponent
		            if isvalid(sc) then
		                sc:ChangeState("IDLE")
		                log("[Heal] HandleStateChangeEvent forced back to IDLE from " .. tostring(event.CurrentStateName))
		            end
		        end

		        -- 파이어에로우 전용 처리 (다른 스킬과 동일한 패턴이지만 별도의 플래그를 사용 - 서로 간섭하지 않는다)
		        if self._T.isFireArrowMotionPlaying then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedFireArrowDirX
		            end
		            local motionName = self._T.lockedFireArrowMotionName
		            if not motionName then return end
		            local avatarRenderer = self.Entity.AvatarRendererComponent
		            if not isvalid(avatarRenderer) then return end
		            local body = avatarRenderer:GetBodyEntity()
		            if not isvalid(body) then return end
		            local motionEvent = ActionStateChangedEvent(motionName, motionName, self._T.lockedFireArrowPlayRate or 1.0, SpriteAnimClipPlayType.Onetime)
		            body:SendEvent(motionEvent)
		            log("[FireArrow] HandleStateChangeEvent re-applied motion over " .. tostring(event.CurrentStateName) .. ": " .. tostring(motionName))
		            return
		        end
		        if self._T.isFireArrowDirectionLocked and event.CurrentStateName ~= "IDLE" then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedFireArrowDirX
		            end
		            local sc = self.Entity.StateComponent
		            if isvalid(sc) then
		                sc:ChangeState("IDLE")
		                log("[FireArrow] HandleStateChangeEvent forced back to IDLE from " .. tostring(event.CurrentStateName))
		            end
		        end

		        -- 아이언에로우 전용 처리 (파이어에로우와 동일한 패턴이지만 별도의 플래그를 사용 - 서로 간섭하지 않는다)
		        if self._T.isIronArrowMotionPlaying then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedIronArrowDirX
		            end
		            local motionName = self._T.lockedIronArrowMotionName
		            if not motionName then return end
		            local avatarRenderer = self.Entity.AvatarRendererComponent
		            if not isvalid(avatarRenderer) then return end
		            local body = avatarRenderer:GetBodyEntity()
		            if not isvalid(body) then return end
		            local motionEvent = ActionStateChangedEvent(motionName, motionName, self._T.lockedIronArrowPlayRate or 1.0, SpriteAnimClipPlayType.Onetime)
		            body:SendEvent(motionEvent)
		            log("[IronArrow] HandleStateChangeEvent re-applied motion over " .. tostring(event.CurrentStateName) .. ": " .. tostring(motionName))
		            return
		        end
		        if self._T.isIronArrowDirectionLocked and event.CurrentStateName ~= "IDLE" then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedIronArrowDirX
		            end
		            local sc = self.Entity.StateComponent
		            if isvalid(sc) then
		                sc:ChangeState("IDLE")
		                log("[IronArrow] HandleStateChangeEvent forced back to IDLE from " .. tostring(event.CurrentStateName))
		            end
		        end
	end

	@ExecSpace("ServerOnly")
	@EventSender("Self")
	handler HandlePlayerActionEvent(PlayerActionEvent event)
		        -- Fire attack on "Attack" action
		        if event.ActionName == "Attack" then
		            self:AttackNormal()
		        end
	end

	@ExecSpace("ServerOnly")
	method void AttackDoubleStab(number combatPower, number atkMultiplier)
		        -- 더블스탭 발동: 파워스트라이크와 동일한 전방 박스 판정 구조를 재사용하되, 공격범위는 2/3로 좁히고
		        -- 럭키세븐처럼 같은 대상을 두 번 연속 찔러(2줄 스택 데미지 스킨) 단일 대상에게 타격한다.
		        -- 사다리/로프/사망 상태에서는 사용 불가 (다른 스킬과 동일 가드).
		        local currentState = self.Entity.StateComponent.CurrentStateName
		        if currentState == "DEAD" or currentState == "CLIMB" or currentState == "LADDER" then
		            return
		        end
		        if self._T.isDoubleStabbing then
		            return
		        end
		        self._T.isDoubleStabbing = true

		        local mult = math.max(0.1, math.min(atkMultiplier or 1.0, 3.0))
		        self._T.pendingDoubleStabCombatPower = combatPower

		        local playerCtrl = self.Entity.PlayerControllerComponent
		        local worldPos = self.Entity.TransformComponent.WorldPosition
		        local dirX = playerCtrl.LookDirectionX
		        self._T.pendingDoubleStabDirX = dirX

		        -- 단일 고정 표적: 방향(dirX)을 고려하는 전용 탐색(FindDoubleStabTarget)을 사용한다.
		        -- (파워스트라이크가 쓰는 FindNearestMonster는 방향을 보지 않아, 밀집 몬스터 구역에서 등 뒤의
		        -- 몬스터를 고르면 좁아진 전방 판정 박스가 빗나가는 문제가 있었다 - 럭키세븐과 동일한 방식으로 해결.)
		        self._T.doubleStabTarget = self:FindDoubleStabTarget(Vector2(worldPos.x, worldPos.y), dirX)

		        self._T.pendingDoubleStabWasControllerEnabled = isvalid(playerCtrl) and playerCtrl.Enable
		        if isvalid(playerCtrl) then
		            playerCtrl.Enable = false
		        end
		        if isvalid(self.Entity.MovementComponent) then
		            self.Entity.MovementComponent:Stop()
		        end

		        -- 스킬 사용 사운드 (더블 스탭 리소스팩 skill/400.img/skill/4001334의 "_audio/Use")
		        self:PlayDoubleStabUseSound(self.Entity)

		        -- 캐릭터 모션: 더블스탭은 단검으로 "찌르는" 모션이 맞아야 하므로, 알려진 찌르기(stab) 계열
		        -- 후보를 전부 모아 매 시전마다 순차 순환한다(GetDoubleStabStab) - 사용자가 실제 화면과
		        -- 로그(PlayDoubleStabMotion sent: <이름>)를 대조해 맞는 이름을 확인한다.
		        local swing = self:GetDoubleStabStab()
		        self:PlayDoubleStabMotion(self.Entity, swing.name, dirX, mult)

		        -- 1번째 찌르기는 파워스트라이크와 동일하게 0.45초 뒤, 2번째는 그 직후(0.15초 뒤, 공격속도 배율 적용)에 판정한다.
		        _TimerService:SetTimerOnce(function()
		            self:DealDoubleStabHit(1, mult)
		        end, 0.45 * mult)
		        _TimerService:SetTimerOnce(function()
		            self:DealDoubleStabHit(2, mult)
		        end, 0.60 * mult)

		        -- 컨트롤 잠금 해제: 파워스트라이크와 동일한 고정 여유분(0.65초 * 배율).
		        _TimerService:SetTimerOnce(function()
		            self:RestoreDoubleStabControl()
		        end, 0.65 * mult)
	end

	@ExecSpace("ServerOnly")
	method Entity FindDoubleStabTarget(Vector2 fromPos, number dirX)
		        -- 더블스탭 전용 대상 탐색: 럭키세븐(FindLuckySevenTarget)과 동일하게 바라보는 방향(dirX) 앞쪽에
		        -- 있는 몬스터만 후보로 삼는다. 파워스트라이크가 쓰는 FindNearestMonster는 방향과 무관하게 그냥
		        -- 가장 가까운 몬스터를 고르는데, 밀집 몬스터 구역에서 등 뒤의 몬스터를 고르면 좁아진(2/3) 전방
		        -- 판정 박스가 그 대상을 빗나가는 문제가 실제로 재현되어(테스트로 확인) 방향 필터가 필요했다.
		        local map = self.Entity.CurrentMap
		        if not isvalid(map) then return nil end
		        local monsterComps = map:GetChildComponentsByTypeName("script.Monster", true)
		        local boxSize = 2.0 * (2.0 / 3.0)
		        local nearest = nil
		        local nearestDist = boxSize
		        for _, comp in ipairs(monsterComps) do
		            ---@type Monster
		            local mc = comp
		            if isvalid(mc) and isvalid(mc.Entity) and not mc.IsDead then
		                local pos = mc.Entity.TransformComponent.WorldPosition
		                local dx = pos.x - fromPos.x
		                local dy = pos.y - fromPos.y
		                if dx * dirX >= 0 and math.abs(dx) <= boxSize and math.abs(dy) <= (boxSize / 2.0) then
		                    local dist = math.abs(dx)
		                    if dist <= nearestDist then
		                        nearest = mc.Entity
		                        nearestDist = dist
		                    end
		                end
		            end
		        end
		        return nearest
	end

	method table GetDoubleStabStab()
		        -- 더블스탭 전용 찌르기(stab) 모션 - 사용자가 실제 화면으로 재확인해 stabO1/stabO2 2개로 최종 확정.
		        -- 매 시전마다 이 둘 중 하나를 무작위로 골라 재생한다(파워스트라이크의 GetPowerStrikeSwing과 동일한 랜덤 방식).
		        local candidates = {
		            { name = "stabO1" },
		            { name = "stabO2" },
		        }
		        local index = _UtilLogic:RandomIntegerRange(1, #candidates)
		        return candidates[index]
	end

	@ExecSpace("Server")
	method void RestoreDoubleStabControl()
		        self._T.isDoubleStabbing = false
		        local playerCtrl = self.Entity.PlayerControllerComponent
		        if isvalid(playerCtrl) and self._T.pendingDoubleStabWasControllerEnabled then
		            playerCtrl.Enable = true
		        end
	end

	@ExecSpace("Server")
	method void DealDoubleStabHit(integer idx, number atkMultiplier)
		        -- 예약된 딜레이(0.45초/0.60초 * 배율) 뒤 호출되어 같은 단일 대상을 향해 전방 박스 판정을 1회 실행한다.
		        -- 대상이 1타에 이미 죽었더라도 2타 판정은 그대로 진행한다 - 럭키세븐과 동일하게, 1타가 오버킬이어도
		        -- 2줄 모두 표시되는 것이 의도된 동작이다(Monster.HandleHitEvent가 IsDead면 실제 Hp 적용만 막고,
		        -- 판정 자체는 DestroyDelay(0.6초) 전까지 유효해 정상적으로 명중 처리된다).
		        if not isvalid(self.Entity) then return end
		        local target = self._T.doubleStabTarget
		        if not isvalid(target) then return end

		        local dirX = self._T.pendingDoubleStabDirX or 1
		        local curWorldPos = self.Entity.TransformComponent.WorldPosition
		        -- 파워스트라이크 판정 박스(2x2, 오프셋 1.0*dirX)의 2/3 크기로 좁힌다. 오프셋도 박스 크기의 절반(=boxSize/2)으로
		        -- 동일한 비율을 유지해, 캐릭터 바로 앞에서 시작해 앞으로 boxSize만큼 뻗는 판정 형태를 그대로 보존한다.
		        local boxSize = 2.0 * (2.0 / 3.0)
		        local attackOffset = Vector2(
		            curWorldPos.x + (boxSize / 2.0) * dirX,
		            curWorldPos.y
		        )

		        -- PlayerAttack이 직접 판정한다 (전용 DoubleStabAttack 컴포넌트에 위임하던 방식은 제거됨 - 플레이어
		        -- 엔티티에 AttackComponent 상속 컴포넌트가 2개(PlayerAttack + DoubleStabAttack) 붙어 있으면
		        -- 엔진이 [LWA-3048] DuplicateComponent로 취급해 자동 데미지 스킨이 우리 수동 표시와 별개로
		        -- 추가 발동되어 "2줄이 2번(총 4줄)" 뜨는 문제가 실측됨. IsAttackTarget/CalcDamage/CalcCritical/
		        -- GetDisplayHitCount를 전부 attackInfo 분기로 PlayerAttack 하나에 합쳐서 이 충돌을 없앤다.)
		        local shape = BoxShape(attackOffset, Vector2(boxSize, boxSize), 0)
		        -- 대상의 DamageSkinSpawnerComponent를 판정 직전 잠깐 떼었다가 붙인다 - 이 컴포넌트가 붙어있는 채로
		        -- 같은 AttackComponent 인스턴스가 같은 대상에게 두 번 연속 Attack()을 걸면(더블스탭 1타/2타),
		        -- GetDisplayHitCount=0을 반환해도 엔진이 히트마다 자동 데미지 숫자를 하나씩 추가로 띄워
		        -- "2줄이 2번(총 4줄)" 뜨는 문제가 있었다(럭키세븐은 매 타격마다 별도 투사체 엔티티를 새로 스폰해
		        -- 이 문제가 없었음 - 동일 컴포넌트 인스턴스 재사용이 근본 원인으로 추정).
		        local targetSkinSpawner = target:GetComponent("MOD.Core.DamageSkinSpawnerComponent")
		        if isvalid(targetSkinSpawner) then target:RemoveComponent("MOD.Core.DamageSkinSpawnerComponent") end
		        local hitComps = self:Attack(shape, "skill.doublestab", CollisionGroups.HitBox)
		        if not isvalid(target:GetComponent("MOD.Core.DamageSkinSpawnerComponent")) then target:AddComponent("MOD.Core.DamageSkinSpawnerComponent") end
		        local actuallyHit = false
		        for _, hc in ipairs(hitComps) do
		            if isvalid(hc) and isvalid(hc.Entity) and hc.Entity == target then
		                actuallyHit = true
		                break
		            end
		        end
		        local damage = self._T.lastDoubleStabDamage or 0
		        if not actuallyHit then
		            -- 대상이 1타에 이미 죽어 판정 자체가 실패해도(코르프스가 더 이상 충돌 판정에 걸리지 않음),
		            -- 럭키세븐과 동일하게 표시용 데미지를 동일 공식으로 새로 굴려 2줄이 항상 뜨도록 한다
		            -- (실제 Hp에는 영향 없는 표시 전용 값 - 이미 죽은 대상이므로 실제 데미지 적용은 불필요).
		            local mult = 1.0 + _UtilLogic:RandomDouble() * (2.6 - 1.0)
		            damage = math.floor((self._T.pendingDoubleStabCombatPower or 0) * mult)
		        end
		        self:ShowDoubleStabDamageSkin(target, damage, idx)
		        self:PlayDoubleStabHitEffect(target, dirX)
		        log("PlayerAttack: AttackDoubleStab hit idx=" .. tostring(idx) .. " actuallyHit=" .. tostring(actuallyHit) .. " damage=" .. tostring(damage))
	end

	@ExecSpace("Multicast")
	method void PlayDoubleStabUseSound(Entity attacker)
		        -- 더블 스탭 리소스팩(skill/400.img/skill/4001334)의 "_audio/Use" 사운드.
		        -- Multicast는 서버 자신도 함께 실행하므로 클라이언트에서만 실행되게 막는다.
		        if not self:IsClient() then return end
		        if not isvalid(attacker) then return end
		        _SoundService:PlaySound("ca4f802052184c0ba47f6971fde80bd0", 1.0)
	end

	@ExecSpace("Client")
	method void ShowDoubleStabDamageSkin(Entity target, integer damage, integer hitIndex)
		        -- 다른 스킬과 동일한 기본 히트 데미지 스킨(RUID)을 사용해 룩앤필을 통일한다.
		        -- 럭키세븐과 동일한 간격(±0.2)으로 1번째/2번째 찌르기가 위아래로 나뉘어 2줄로 쌓인 것처럼 보이게 한다.
		        if not isvalid(target) then return end
		        local offsetY = -0.2
		        if hitIndex == 2 then offsetY = 0.2 end
		        _DamageSkinService:Play(
		            target, "3271c3e79bf04ecba9a107d55495970d", 0,
		            { damage }, DamageSkinTweenType.Default, false,
		            Vector2(0, offsetY), Vector2(1, 1), 1.0, 1.0, LitMode.Default
		        )
		        log("[DoubleStab] ShowDoubleStabDamageSkin hitIndex=" .. tostring(hitIndex) .. " damage=" .. tostring(damage) .. " offsetY=" .. tostring(offsetY))
	end

	@ExecSpace("Client")
	method void PlayDoubleStabHitEffect(Entity target, number dirX)
		        -- 몬스터 몸에서 나타나는 타격 이펙트 (더블 스탭 리소스팩의 CharLevel/20/hit/0)
		        if not isvalid(target) then return end
		        local flipBack = dirX > 0
		        local hitOptions = { ["FlipX"] = flipBack }
		        local serial = _EffectService:PlayEffectAttached("8de01c7022964b1b9d6cf96070073446", target, Vector3(0, 0, 0), 0, Vector3(1, 1, 1), false, hitOptions)
		        -- 몬스터에 어태치된 이펙트가 자연 종료 전에 몬스터가 죽고(Enable=false) 다시 리젠(Enable=true)되면
		        -- 재생이 멈췄다가 리젠 순간 다시 보이는 문제가 있었다 - 짧은 타이머로 명시적으로 제거해 방지한다.
		        _TimerService:SetTimerOnce(function()
		            _EffectService:RemoveEffect(serial)
		        end, 0.5)
	end

	@ExecSpace("Multicast")
	method void PlayDoubleStabMotion(Entity attacker, string motionName, number dirX, number atkMultiplier)
		        -- 더블스탭 전용 세부 모션 재생. 파워스트라이크(PlayAttackMotion)와 동일한 방식 - 별도 플래그로 서로 간섭하지 않는다.
		        if not self:IsClient() then return end
		        if not isvalid(attacker) then return end
		        local avatarRenderer = attacker.AvatarRendererComponent
		        if not isvalid(avatarRenderer) then return end
		        local body = avatarRenderer:GetBodyEntity()
		        if not isvalid(body) then return end

		        avatarRenderer.ShowDefaultWeaponEffects = false

		        local playerCtrl = attacker.PlayerControllerComponent
		        if isvalid(attacker.MovementComponent) then
		            attacker.MovementComponent:Stop()
		        end
		        if isvalid(playerCtrl) then
		            playerCtrl.LookDirectionX = dirX
		        end
		        self._T.isDoubleStabDirectionLocked = true
		        self._T.lockedDoubleStabDirX = dirX
		        self._T.lockedDoubleStabMotionName = motionName
		        self._T.isDoubleStabMotionPlaying = true

		        local mult = math.max(atkMultiplier or 1.0, 0.001)
		        local playRate = 1.0 / mult
		        self._T.lockedDoubleStabPlayRate = playRate

		        local motionEvent = ActionStateChangedEvent(motionName, motionName, playRate, SpriteAnimClipPlayType.Onetime)
		        body:SendEvent(motionEvent)
		        log("[DoubleStab] PlayDoubleStabMotion sent: " .. tostring(motionName) .. " playRate=" .. tostring(playRate))

		        _TimerService:SetTimerOnce(function()
		            if isvalid(avatarRenderer) then
		                avatarRenderer.ShowDefaultWeaponEffects = true
		            end
		            self._T.isDoubleStabMotionPlaying = false
		        end, 0.60 * mult)

		        _TimerService:SetTimerOnce(function()
		            self._T.isDoubleStabDirectionLocked = false
		            local sc = self.Entity.StateComponent
		            if isvalid(sc) and sc.CurrentStateName ~= "DEAD" then
		                sc:ChangeState("IDLE")
		                sc:ChangeState("MOVE")
		                sc:ChangeState("IDLE")
		            end
		        end, 0.80 * mult)
	end

	@ExecSpace("ServerOnly")
	method void AttackMagicClaw(number combatPower, number atkMultiplier)
		        -- 매직클로 발동: 럭키세븐과 같은 단일 대상·2타·2줄 스택 데미지 스킨이지만, 표창을 던지지 않고
		        -- 더블스탭처럼 그 자리에서 즉시 전방 판정으로 데미지를 준다(리소스/이펙트만 다름).
		        -- 사다리/로프/사망 상태에서는 사용 불가 (다른 스킬과 동일 가드).
		        local currentState = self.Entity.StateComponent.CurrentStateName
		        if currentState == "DEAD" or currentState == "CLIMB" or currentState == "LADDER" then
		            return
		        end
		        if self._T.isMagicClawing then
		            return
		        end
		        self._T.isMagicClawing = true

		        local mult = math.max(0.1, math.min(atkMultiplier or 1.0, 3.0))
		        self._T.pendingMagicClawCombatPower = combatPower

		        local playerCtrl = self.Entity.PlayerControllerComponent
		        local worldPos = self.Entity.TransformComponent.WorldPosition
		        local dirX = playerCtrl.LookDirectionX
		        self._T.pendingMagicClawDirX = dirX

		        -- 단일 고정 표적: 더블스탭과 동일한 방향 인식 탐색(파워스트라이크 판정 박스 크기 그대로 사용).
		        self._T.magicClawTarget = self:FindMagicClawTarget(Vector2(worldPos.x, worldPos.y), dirX)

		        self._T.pendingMagicClawWasControllerEnabled = isvalid(playerCtrl) and playerCtrl.Enable
		        if isvalid(playerCtrl) then
		            playerCtrl.Enable = false
		        end
		        if isvalid(self.Entity.MovementComponent) then
		            self.Entity.MovementComponent:Stop()
		        end

		        -- 스킬 사용 사운드 (즉시)
		        self:PlayMagicClawUseSound(self.Entity)
		        -- 스킬 시전 시작 이펙트 (사용자 몸에서 발현)
		        self:PlayMagicClawStartEffect(self.Entity, dirX)

		        local swing = self:GetMagicClawSwing()
		        self:PlayMagicClawMotion(self.Entity, swing.name, dirX, mult)

		        -- 1번째 할큄은 파워스트라이크와 동일하게 0.45초 뒤, 2번째는 0.1초 텀을 두고 0.55초 뒤에 판정한다.
		        _TimerService:SetTimerOnce(function()
		            self:DealMagicClawHit(1, mult)
		        end, 0.45 * mult)
		        _TimerService:SetTimerOnce(function()
		            self:DealMagicClawHit(2, mult)
		        end, 0.55 * mult)

		        -- 컨트롤 잠금 해제: 2번째 타격 직후(0.60초 * 배율).
		        _TimerService:SetTimerOnce(function()
		            self:RestoreMagicClawControl()
		        end, 0.60 * mult)
	end

	@ExecSpace("ServerOnly")
	method Entity FindMagicClawTarget(Vector2 fromPos, number dirX)
		        -- 매직클로 전용 대상 탐색: 더블스탭(FindDoubleStabTarget)과 동일한 방향 인식 방식.
		        -- 사거리는 파워스트라이크 기준 박스(2칸) 대비 x축(전방) 2.5배·y축(위아래) 1.5배로 늘렸다.
		        local map = self.Entity.CurrentMap
		        if not isvalid(map) then return nil end
		        local monsterComps = map:GetChildComponentsByTypeName("script.Monster", true)
		        local forwardSize = 2.0 * 2.5
		        local verticalSize = 2.0 * 1.5
		        local nearest = nil
		        local nearestDist = forwardSize
		        for _, comp in ipairs(monsterComps) do
		            ---@type Monster
		            local mc = comp
		            if isvalid(mc) and isvalid(mc.Entity) and not mc.IsDead then
		                local pos = mc.Entity.TransformComponent.WorldPosition
		                local dx = pos.x - fromPos.x
		                local dy = pos.y - fromPos.y
		                if dx * dirX >= 0 and math.abs(dx) <= forwardSize and math.abs(dy) <= (verticalSize / 2.0) then
		                    local dist = math.abs(dx)
		                    if dist <= nearestDist then
		                        nearest = mc.Entity
		                        nearestDist = dist
		                    end
		                end
		            end
		        end
		        return nearest
	end

	method table GetMagicClawSwing()
		        -- 매직클로 전용 모션 - 우선 럭키세븐과 동일한 swingO1/O2/O3(한손무기 계열, "아대"로 확인됐던 것과
		        -- 동일 계열)을 순차 순환시켜 사용자가 화면으로 확인 후 확정할 수 있게 한다.
		        local candidates = {
		            { name = "swingO1" },
		            { name = "swingO2" },
		            { name = "swingO3" },
		        }
		        self._T.magicClawSwingIndex = (self._T.magicClawSwingIndex or 0) % #candidates + 1
		        return candidates[self._T.magicClawSwingIndex]
	end

	@ExecSpace("Server")
	method void RestoreMagicClawControl()
		        self._T.isMagicClawing = false
		        local playerCtrl = self.Entity.PlayerControllerComponent
		        if isvalid(playerCtrl) and self._T.pendingMagicClawWasControllerEnabled then
		            playerCtrl.Enable = true
		        end
	end

	@ExecSpace("Server")
	method void DealMagicClawHit(integer idx, number atkMultiplier)
		        -- 예약된 딜레이(0.45초/0.55초 * 배율) 뒤 호출되어 같은 단일 대상을 향해 전방 박스 판정을 1회 실행한다.
		        -- 더블스탭과 동일하게, 대상이 1타에 이미 죽었더라도 2타 판정은 그대로 진행해 럭키세븐과 같이
		        -- 1타가 오버킬이어도 2줄 모두 표시되도록 한다.
		        if not isvalid(self.Entity) then return end
		        local target = self._T.magicClawTarget
		        if not isvalid(target) then return end

		        local dirX = self._T.pendingMagicClawDirX or 1
		        local curWorldPos = self.Entity.TransformComponent.WorldPosition
		        -- FindMagicClawTarget과 동일한 사거리(x축 2.5배·y축 1.5배 확장)를 실제 판정 박스에도 적용한다.
		        local forwardSize = 2.0 * 2.5
		        local verticalSize = 2.0 * 1.5
		        local attackOffset = Vector2(
		            curWorldPos.x + (forwardSize / 2.0) * dirX,
		            curWorldPos.y
		        )

		        -- PlayerAttack이 직접 판정한다 (전용 MagicClawAttack 컴포넌트에 위임하던 방식은 제거됨 - 더블스탭과
		        -- 동일하게, 플레이어 엔티티에 AttackComponent 상속 컴포넌트가 2개 붙어 있으면 엔진이
		        -- [LWA-3048] DuplicateComponent로 취급해 자동 데미지 스킨이 추가로 발동되는 문제가 있었다.)
		        -- 대상의 DamageSkinSpawnerComponent도 판정 직전 잠깐 떼었다가 붙인다 - 더블스탭과 동일한 이유
		        -- (같은 AttackComponent 인스턴스로 같은 대상에게 두 번 연속 Attack()을 걸면 GetDisplayHitCount=0을
		        -- 반환해도 히트마다 자동 데미지 숫자가 추가로 뜨는 문제가 있었음 - 럭키세븐은 타격마다 별도
		        -- 투사체 엔티티를 새로 스폰해 이 문제가 없었던 것에서 착안).
		        local shape = BoxShape(attackOffset, Vector2(forwardSize, verticalSize), 0)
		        local targetSkinSpawner = target:GetComponent("MOD.Core.DamageSkinSpawnerComponent")
		        if isvalid(targetSkinSpawner) then target:RemoveComponent("MOD.Core.DamageSkinSpawnerComponent") end
		        local hitComps = self:Attack(shape, "skill.magicclaw", CollisionGroups.HitBox)
		        if not isvalid(target:GetComponent("MOD.Core.DamageSkinSpawnerComponent")) then target:AddComponent("MOD.Core.DamageSkinSpawnerComponent") end
		        local actuallyHit = false
		        for _, hc in ipairs(hitComps) do
		            if isvalid(hc) and isvalid(hc.Entity) and hc.Entity == target then
		                actuallyHit = true
		                break
		            end
		        end
		        local damage = self._T.lastMagicClawDamage or 0
		        if not actuallyHit then
		            -- 대상이 1타에 이미 죽어 판정 자체가 실패해도, 럭키세븐과 동일하게 표시용 데미지를
		            -- 동일 공식으로 새로 굴려 2줄이 항상 뜨도록 한다(실제 Hp에는 영향 없는 표시 전용 값).
		            local mult = 1.0 + _UtilLogic:RandomDouble() * (1.5 - 1.0)
		            damage = math.floor((self._T.pendingMagicClawCombatPower or 0) * mult)
		        end
		        self:ShowMagicClawDamageSkin(target, damage, idx)
		        self:PlayMagicClawHitEffect(target, dirX)
		        log("PlayerAttack: AttackMagicClaw hit idx=" .. tostring(idx) .. " actuallyHit=" .. tostring(actuallyHit) .. " damage=" .. tostring(damage))
	end

	@ExecSpace("Multicast")
	method void PlayMagicClawUseSound(Entity attacker)
		        -- 매직클로 리소스팩(skill/800032.img/skill/80003294)의 사용 사운드. 사용 즉시 재생.
		        if not self:IsClient() then return end
		        if not isvalid(attacker) then return end
		        _SoundService:PlaySound("96edfa618f6a4fe4a4620a5c56eb93b6", 1.0)
	end

	@ExecSpace("Multicast")
	method void PlayMagicClawStartEffect(Entity attacker, number dirX)
		        -- 스킬 사용과 동시에 캐릭터 몸에서 발현되는 시작 이펙트
		        if not self:IsClient() then return end
		        if not isvalid(attacker) then return end
		        local startOptions = { ["FlipX"] = dirX > 0 }
		        _EffectService:PlayEffectAttached("2a0d72e836fb4862aae83087035f3d2a", attacker, Vector3(0, 0, 0), 0, Vector3(1, 1, 1), false, startOptions)
	end

	@ExecSpace("Client")
	method void ShowMagicClawDamageSkin(Entity target, integer damage, integer hitIndex)
		        -- 다른 스킬과 동일한 기본 히트 데미지 스킨(RUID)을 사용해 룩앤필을 통일한다.
		        -- 럭키세븐/더블스탭과 동일한 간격(±0.2)으로 1번째/2번째 타격이 위아래로 나뉘어 2줄로 쌓인 것처럼 보이게 한다.
		        if not isvalid(target) then return end
		        local offsetY = -0.2
		        if hitIndex == 2 then offsetY = 0.2 end
		        _DamageSkinService:Play(
		            target, "3271c3e79bf04ecba9a107d55495970d", 0,
		            { damage }, DamageSkinTweenType.Default, false,
		            Vector2(0, offsetY), Vector2(1, 1), 1.0, 1.0, LitMode.Default
		        )
	end

	@ExecSpace("Client")
	method void PlayMagicClawHitEffect(Entity target, number dirX)
		        -- 맞는 몬스터 몸에서 나타나는 타격 이펙트 + 타격 사운드 (0.1초 텀을 두고 2번 재생됨 - 각 히트마다 1번씩)
		        if not isvalid(target) then return end
		        local flipBack = dirX > 0
		        local hitOptions = { ["FlipX"] = flipBack }
		        local serial = _EffectService:PlayEffectAttached("598d2d1859e84eaab18ae460a0a1e0a4", target, Vector3(0, 0, 0), 0, Vector3(1, 1, 1), false, hitOptions)
		        _SoundService:PlaySound("5f0c2e9b04ee4a3a9d493a863b8a1379", 1.0)
		        -- 몬스터에 어태치된 이펙트가 자연 종료 전에 몬스터가 죽고(Enable=false) 다시 리젠(Enable=true)되면
		        -- 재생이 멈췄다가 리젠 순간 다시 보이는 문제가 있었다 - 짧은 타이머로 명시적으로 제거해 방지한다.
		        _TimerService:SetTimerOnce(function()
		            _EffectService:RemoveEffect(serial)
		        end, 0.5)
	end

	@ExecSpace("Multicast")
	method void PlayMagicClawMotion(Entity attacker, string motionName, number dirX, number atkMultiplier)
		        -- 매직클로 전용 모션 재생. 다른 스킬과 동일한 방식 - 별도 플래그로 서로 간섭하지 않는다.
		        if not self:IsClient() then return end
		        if not isvalid(attacker) then return end
		        local avatarRenderer = attacker.AvatarRendererComponent
		        if not isvalid(avatarRenderer) then return end
		        local body = avatarRenderer:GetBodyEntity()
		        if not isvalid(body) then return end

		        avatarRenderer.ShowDefaultWeaponEffects = false

		        local playerCtrl = attacker.PlayerControllerComponent
		        if isvalid(attacker.MovementComponent) then
		            attacker.MovementComponent:Stop()
		        end
		        if isvalid(playerCtrl) then
		            playerCtrl.LookDirectionX = dirX
		        end
		        self._T.isMagicClawDirectionLocked = true
		        self._T.lockedMagicClawDirX = dirX
		        self._T.lockedMagicClawMotionName = motionName
		        self._T.isMagicClawMotionPlaying = true
		        -- 홀드 지속발동 중 다음 시전이 쿨다운(0.75*mult)만큼 뒤에 시작될 수 있는데, 이 잠금 해제 타이머는
		        -- 그보다 늦은 0.80*mult 뒤에 실행된다. 새 시전이 이미 방향을 다시 잠근 뒤에 이전 시전의 해제
		        -- 타이머가 뒤늦게 실행되며 새 시전의 잠금을 잘못 풀어버려, 그 틈에 방향이 갑자기 바뀌는 문제가
		        -- 있었다(파워스트라이크에서 동일하게 발견·수정한 것과 같은 원인). 시전마다 토큰을 발급해
		        -- "그 사이 더 최근 시전이 없었을 때만" 해제한다.
		        self._T.magicClawLockToken = (self._T.magicClawLockToken or 0) + 1
		        local myMagicClawLockToken = self._T.magicClawLockToken

		        local mult = math.max(atkMultiplier or 1.0, 0.001)
		        local playRate = 1.0 / mult
		        self._T.lockedMagicClawPlayRate = playRate

		        local motionEvent = ActionStateChangedEvent(motionName, motionName, playRate, SpriteAnimClipPlayType.Onetime)
		        body:SendEvent(motionEvent)
		        log("[MagicClaw] PlayMagicClawMotion sent: " .. tostring(motionName) .. " playRate=" .. tostring(playRate))

		        _TimerService:SetTimerOnce(function()
		            if isvalid(avatarRenderer) then
		                avatarRenderer.ShowDefaultWeaponEffects = true
		            end
		            self._T.isMagicClawMotionPlaying = false
		        end, 0.55 * mult)

		        _TimerService:SetTimerOnce(function()
		            if self._T.magicClawLockToken ~= myMagicClawLockToken then return end
		            self._T.isMagicClawDirectionLocked = false
		            local sc = self.Entity.StateComponent
		            if isvalid(sc) and sc.CurrentStateName ~= "DEAD" then
		                sc:ChangeState("IDLE")
		                sc:ChangeState("MOVE")
		                sc:ChangeState("IDLE")
		            end
		        end, 0.80 * mult)
	end

	@ExecSpace("ServerOnly")
	method void AttackTeleport(string direction)
		        -- 텔레포트: 즉시 순간이동 스킬 - 판정/데미지가 없고 모션 재생 딜레이도 없어 다른 스킬처럼 컨트롤러를 잠그지 않는다.
		        if not isvalid(self.Entity) then return end
		        local rb = self.Entity.RigidbodyComponent
		        if not isvalid(rb) then return end
		        local map = self.Entity.CurrentMap
		        if not isvalid(map) then return end
		        local fh = map.FootholdComponent
		        if not isvalid(fh) then return end

		        -- "짧은 거리를 순간이동한다"는 스킬 설명에 맞춰 다른 스킬 사거리(2.0~5.0)와 비슷한 수준으로 고정.
		        -- 기존 3.0 → 30% 감소로 2.1 → 사용자 요청으로 다시 10% 증가해 2.31로 조정.
		        local TELEPORT_DISTANCE = 2.31
		        -- 도착지점에 발판이 없을 때 위/아래로 이 거리 이내에 있는 발판을 대신 찾는다.
		        -- 기존 1.2에서 사용자 요청으로 절반(0.6)으로 축소 - 너무 높은/낮은 발판까지 끌어당겨지는 문제 완화.
		        local VERTICAL_TOLERANCE = 0.6
		        -- 발판 가장자리/벽에 딱 붙어 착지하지 않도록 살짝 여유를 둔다.
		        local EDGE_MARGIN = 0.15
		        -- 발판 표면에 살짝 파묻히지 않도록 위로 띄우는 높이 (다음 프레임에 중력이 바로 붙잡아준다).
		        local LAND_OFFSET = 0.05

		        local curPos3 = self.Entity.TransformComponent.WorldPosition
		        local curPos = Vector2(curPos3.x, curPos3.y)
		        local landing = nil

		        if direction == "up" or direction == "down" then
		            local dirY = (direction == "up") and 1 or -1
		            -- 현재 밟고 있는 발판 표면에서 그대로 위쪽으로 레이캐스트하면 자기 자신(현재 서있는 발판)을
		            -- 거리 0에서 다시 주워버리는 문제가 있다(한쪽면 충돌 판정) - 이동 방향으로 살짝 띄운 지점에서 시작한다.
		            local rayEpsilon = 0.05
		            local rayStart = Vector2(curPos.x, curPos.y + dirY * rayEpsilon)
		            -- 사거리 안에 발판이 여러 겹 있으면(예: 층층이 쌓인 발판) 가장 가까운 것이 아니라
		            -- 갈 수 있는 가장 먼 발판을 우선한다 - RaycastAll로 사거리 내 전부 찾아 거리가 최대인 것을 채택.
		            local hits = fh:RaycastAll(rayStart, Vector2(0, dirY), TELEPORT_DISTANCE - rayEpsilon)
		            local hit = nil
		            local farthestDist = -1
		            for _, h in ipairs(hits) do
		                local d = math.abs(h:GetYByX(curPos.x) - curPos.y)
		                if d > farthestDist then
		                    farthestDist = d
		                    hit = h
		                end
		            end
		            if hit ~= nil then
		                landing = Vector2(curPos.x, hit:GetYByX(curPos.x) + LAND_OFFSET)
		            end
		            -- 조건3: 거리 안에 발판이 없으면 사용 자체가 무효 - 사운드/이펙트도 재생하지 않는다.
		            if landing == nil then
		                log("[PlayerAttack] AttackTeleport 실패: " .. direction .. " 방향 " .. tostring(TELEPORT_DISTANCE) .. " 이내에 발판 없음")
		                return
		            end
		        else
		            local dirX = (direction == "left") and -1 or 1
		            local desiredX = curPos.x + dirX * TELEPORT_DISTANCE

		            -- 경로상에 진짜 벽(IsBlockVerticalLine=true)이 있으면 그 앞에서 멈추도록 목표 X를 앞당긴다.
		            -- 단순히 서로 다른 높이의 발판을 잇는 수직 연결선(절벽 가장자리, IsBlockVerticalLine=false)은
		            -- 실제로 이동을 막지 않으므로 벽으로 취급하지 않는다.
		            local wallHit = fh:Raycast(curPos, Vector2(dirX, 0), TELEPORT_DISTANCE)
		            if wallHit ~= nil and wallHit:IsVertical() and wallHit.IsBlockVerticalLine then
		                local wallX = wallHit:GetCenter().x
		                local clampedByWall = wallX - dirX * EDGE_MARGIN
		                if (dirX > 0 and clampedByWall < desiredX) or (dirX < 0 and clampedByWall > desiredX) then
		                    desiredX = clampedByWall
		                end
		            end

		            -- 조건1: 도착지점에 발판이 없으면 위아래 근접 발판을 찾는다.
		            local nearFh = self:FindNearbyFootholdAtX(fh, desiredX, curPos.y, VERTICAL_TOLERANCE)
		            if nearFh ~= nil then
		                landing = Vector2(desiredX, nearFh:GetYByX(desiredX) + LAND_OFFSET)
		            else
		                -- 조건2: 지금 서있는 발판이 목표 거리보다 먼저 끝나면 끝나는 지점까지만 이동한다.
		                local curFh = rb:GetCurrentFoothold()
		                if curFh ~= nil then
		                    -- 같은 지면이 여러 조각(발판 ID)으로 나뉘어 있을 수 있으므로, 지금 밟은 조각의
		                    -- StartPoint/EndPoint만 보지 않고 이동 방향으로 NextFootholdId/PreviousFootholdId
		                    -- 체인을 바라가며 실제로 지면이 끊기는 진짜 가장자리를 찾는다.
		                    local chainFh = curFh
		                    local farEdgeX = (dirX > 0) and math.max(curFh.StartPoint.x, curFh.EndPoint.x) or math.min(curFh.StartPoint.x, curFh.EndPoint.x)
		                    for _ = 1, 50 do
		                        if (dirX > 0 and farEdgeX >= desiredX) or (dirX < 0 and farEdgeX <= desiredX) then break end
		                        local nextId = (dirX > 0) and chainFh.NextFootholdId or chainFh.PreviousFootholdId
		                        if nextId == nil or nextId == 0 then break end
		                        local nextFh = fh:GetFoothold(nextId)
		                        if nextFh == nil then break end
		                        chainFh = nextFh
		                        farEdgeX = (dirX > 0) and math.max(nextFh.StartPoint.x, nextFh.EndPoint.x) or math.min(nextFh.StartPoint.x, nextFh.EndPoint.x)
		                    end
		                    local clampedX = farEdgeX - dirX * EDGE_MARGIN
		                    local reachesFullDistance = (dirX > 0 and clampedX >= desiredX) or (dirX < 0 and clampedX <= desiredX)
		                    if not reachesFullDistance then
		                        -- 축소된 지점에서도 위아래 발판을 다시 확인한다 (조건2의 "그 지점에서도 위아래 발판 구분" 요구사항).
		                        local nearFh2 = self:FindNearbyFootholdAtX(fh, clampedX, curPos.y, VERTICAL_TOLERANCE)
		                        if nearFh2 ~= nil then
		                            landing = Vector2(clampedX, nearFh2:GetYByX(clampedX) + LAND_OFFSET)
		                        else
		                            landing = Vector2(clampedX, curFh:GetYByX(clampedX) + LAND_OFFSET)
		                        end
		                    end
		                end
		            end

		            if landing == nil then
		                log("[PlayerAttack] AttackTeleport 실패: " .. direction .. " 방향에 착지 가능한 발판 없음")
		                return
		            end
		        end

		        if isvalid(self.Entity.MovementComponent) then
		            self.Entity.MovementComponent:Stop()
		        end
		        -- 실측 결과: SetWorldPosition을 짧은 시간 동안 여러 프레임에 걸쳐 나눠 호출하는 "대시" 방식을 시도했으나,
		        -- 몇 틱 뒤 위치가 원래 자리로 되돌아가는 현상이 재현됨(엔진의 물리/동기화 쪽에서 반복적인 위치
		        -- 갱신을 되돌리는 것으로 추정 - 정확한 내부 매커니즘은 불명). 한 번만 호출하는 방식은 이 세션
		        -- 내내 안정적으로 확인되었으므로, 검증된 단일 호출 방식을 유지한다.
		        rb:SetWorldPosition(landing)
		        self:PlayTeleportEffects(self.Entity, curPos)
		        log("[PlayerAttack] AttackTeleport 성공! direction=" .. direction .. " from=(" .. tostring(curPos.x) .. "," .. tostring(curPos.y) .. ") to=(" .. tostring(landing.x) .. "," .. tostring(landing.y) .. ")")
	end

	method Foothold FindNearbyFootholdAtX(FootholdComponent fh, number x, number y, number tolerance)
		        -- 지정한 x좌표에서 위/아래로 tolerance 거리 이내에 있는 가장 가까운 발판을 찾는다 (없으면 nil).
		        -- 이 지점이 마침 어떤 발판과 정확히 겹쳐 거리 0으로 찾아지는 것은 정상(그 발판 위에 착지)이므로,
		        -- AttackTeleport의 위/아래 이동 분기와 달리 여기서는 시작점을 띄우지 않는다.
		        local upHit = fh:Raycast(Vector2(x, y), Vector2(0, 1), tolerance)
		        local downHit = fh:Raycast(Vector2(x, y), Vector2(0, -1), tolerance)
		        if upHit ~= nil and downHit ~= nil then
		            local upDist = math.abs(upHit:GetYByX(x) - y)
		            local downDist = math.abs(downHit:GetYByX(x) - y)
		            if upDist <= downDist then return upHit end
		            return downHit
		        elseif upHit ~= nil then
		            return upHit
		        elseif downHit ~= nil then
		            return downHit
		        end
		        return nil
	end

	@ExecSpace("Multicast")
	method void PlayTeleportEffects(Entity attacker, Vector2 originPos)
		        -- 텔레포트 사용 사운드 + 이동 전 위치에 잠깐 나타나는 잔상 이펙트. Multicast는 서버도 함께 실행하므로 클라이언트에서만 실행되게 막는다.
		        if not self:IsClient() then return end
		        if not isvalid(attacker) then return end
		        _SoundService:PlaySound("4c1eb6001e9c47eda239cc58443b79cd", 1.0)
		        local serial = _EffectService:PlayEffect("b34e818d784f4a3891c2d50e48ca559d", attacker, Vector3(originPos.x, originPos.y, 0), 0, Vector3(1, 1, 1), false, {})
		        _TimerService:SetTimerOnce(function()
		            _EffectService:RemoveEffect(serial)
		        end, 0.1)
		        -- 텔레포트 전용 카메라 제어(Damping 임시 조정)는 사용자 요청으로 제거함 - 기본 카메라 동작만 남긴다.
	end

	@ExecSpace("ServerOnly")
	method void AttackThunderbolt(number combatPower, number atkMultiplier)
		-- 썬더볼트 발동: 방향(앞/뒤) 무관하게 캐릭터 주변의 몬스터 최대 6명을 동시에 타격한다.
		-- 사다리/로프/사망 상태에서는 사용 불가 (다른 스킬과 동일 가드).
		local currentState = self.Entity.StateComponent.CurrentStateName
		if currentState == "DEAD" or currentState == "CLIMB" or currentState == "LADDER" then
			return
		end
		if self._T.isThunderbolting then
			return
		end
		self._T.isThunderbolting = true

		local mult = math.max(0.1, math.min(atkMultiplier or 1.0, 3.0))
		self._T.pendingThunderboltCombatPower = combatPower

		local playerCtrl = self.Entity.PlayerControllerComponent
		local worldPos = self.Entity.TransformComponent.WorldPosition
		local dirX = playerCtrl.LookDirectionX

		-- 방향과 무관하게 앞뒤 모두에서 가까운 순으로 최대 6명을 미리 골라둔다 (실제 Attack 판정 없이 위치만으로 탐색).
		local targets = self:FindThunderboltTargets(Vector2(worldPos.x, worldPos.y), 6)
		self._T.thunderboltTargets = targets

		self._T.pendingThunderboltWasControllerEnabled = isvalid(playerCtrl) and playerCtrl.Enable
		if isvalid(playerCtrl) then
			playerCtrl.Enable = false
		end
		if isvalid(self.Entity.MovementComponent) then
			self.Entity.MovementComponent:Stop()
		end

		-- 스킬 사용 사운드 + 몸쪽 시전 이펙트 (즉시, 1회) + 캐릭터 모션(매직클로와 동일한 후보군/재생 방식)
		self:PlayThunderboltUseSound(self.Entity)
		self:PlayThunderboltStartEffect(self.Entity, dirX)
		local swing = self:GetThunderboltSwing()
		self:PlayThunderboltMotion(self.Entity, swing.name, dirX, mult)

		-- 딜레이 후 미리 골라둔 대상 전원에게 동시에 타격 판정 + 이펙트를 발생시킨다
		-- (슬래쉬블래스트처럼 대상마다 나눠서 순차 타격하는 것이 아니라, 같은 프레임 안에서 한꺼번에 처리).
		_TimerService:SetTimerOnce(function()
			self:DealThunderboltHits(targets)
		end, 0.4 * mult)

		-- 컨트롤 잠금 해제: 타격 판정 직후 여유(0.2초)를 두고, 배율을 적용한다.
		_TimerService:SetTimerOnce(function()
			self:RestoreThunderboltControl()
		end, 0.6 * mult)
	end

	@ExecSpace("ServerOnly")
	method table FindThunderboltTargets(Vector2 fromPos, integer maxCount)
		-- 썬더볼트 대상 선정: 다른 스킬과 달리 방향(dirX) 무관 - 앞뒤 판정 범위(가로 6칸, 세로 1칸) 안의
		-- 살아있는 script.Monster를 가까운 순으로 정렬해 최대 maxCount명까지 후보로 반환한다
		-- (실제 Attack 판정 없이 위치만으로 탐색). 좌우(가로) 범위는 기존 2.0에서 사용자 요청으로 1.5배인 3.0으로 확대.
		local map = self.Entity.CurrentMap
		if not isvalid(map) then return {} end
		local monsterComps = map:GetChildComponentsByTypeName("script.Monster", true)
		local candidates = {}
		for _, comp in ipairs(monsterComps) do
			---@type Monster
			local mc = comp
			if isvalid(mc) and isvalid(mc.Entity) and not mc.IsDead then
				local pos = mc.Entity.TransformComponent.WorldPosition
				local dx = pos.x - fromPos.x
				local dy = pos.y - fromPos.y
				if math.abs(dx) <= 3.0 and math.abs(dy) <= 1.0 then
					table.insert(candidates, { entity = mc.Entity, dist = math.abs(dx) })
				end
			end
		end
		table.sort(candidates, function(a, b) return a.dist < b.dist end)
		local result = {}
		for i = 1, math.min(#candidates, maxCount) do
			table.insert(result, candidates[i].entity)
		end
		return result
	end

	@ExecSpace("Server")
	method void RestoreThunderboltControl()
		self._T.isThunderbolting = false
		local playerCtrl = self.Entity.PlayerControllerComponent
		if isvalid(playerCtrl) and self._T.pendingThunderboltWasControllerEnabled then
			playerCtrl.Enable = true
		end
	end

	@ExecSpace("Server")
	method void DealThunderboltHits(table targets)
		-- 예약된 딜레이 뒤 호출되어, 미리 골라둔 대상 전원에게 같은 프레임 안에서 동시에 타격 판정과
		-- 이펙트를 발생시킨다 (슬래쉬블래스트처럼 대상마다 나눠서 순차 타격하지 않음).
		if not isvalid(self.Entity) then return end
		local hitIndex = 0
		for _, target in ipairs(targets) do
			if isvalid(target) then
				-- 이번 Attack() 호출은 이 대상 하나만 통과하도록 지정 (몬스터 밀집 지역에서 이웃까지
				-- 겹쳐 중복 피해가 들어가는 것을 방지 - IsAttackTarget의 thunderboltCurrentTarget 체크 참고).
				self._T.thunderboltCurrentTarget = target
				local targetPos = target.TransformComponent.WorldPosition
				local shape = CircleShape(Vector2(targetPos.x, targetPos.y), 0.6)
				local hitComps = self:Attack(shape, "skill.thunderbolt", CollisionGroups.HitBox)
				local actuallyHit = false
				for _, hc in ipairs(hitComps) do
					if isvalid(hc) and isvalid(hc.Entity) and hc.Entity == target then
						actuallyHit = true
						break
					end
				end
				if actuallyHit then
					-- 피격 이펙트/데미지는 동시에 처리하되, 타격음만 맞은 순서대로 0.04초 간격으로 재생한다
					-- (예: 6마리가 맞으면 0.04초 간격으로 6번 소리가 들림).
					self:PlayThunderboltHitEffect(target)
					local soundDelay = hitIndex * 0.04
					_TimerService:SetTimerOnce(function()
						self:PlayThunderboltHitSound()
					end, soundDelay)
					hitIndex = hitIndex + 1
				end
			end
		end
		log("PlayerAttack: AttackThunderbolt " .. tostring(#targets) .. "명 동시 타격, 실제 명중 " .. tostring(hitIndex) .. "명")
	end

	@ExecSpace("Multicast")
	method void PlayThunderboltUseSound(Entity attacker)
		-- 스킬 사용 즉시 재생되는 사운드. Multicast는 서버 자신도 함께 실행하므로 클라이언트에서만 실행되게 막는다.
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		_SoundService:PlaySound("3a8cf5d7d10f47f79f7bc9bdad81a746", 1.0)
	end

	@ExecSpace("Multicast")
	method void PlayThunderboltStartEffect(Entity attacker, number dirX)
		-- 스킬 사용과 동시에 캐릭터 몸에서 발현되는 시작 이펙트 (1회).
		-- 오프셋: 캐릭터 살짝 앞쪽 위에 있던 것을 사용자 요청으로 살짝 아래·몸쪽으로 이동 -
		-- x는 0.2*dirX(앞쪽으로 치우침) → 0.08*dirX(몸에 더 가깝게), y는 0.15 → 0.0으로 낮춤.
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		local startOptions = { ["FlipX"] = dirX > 0 }
		_EffectService:PlayEffectAttached("7b1fbc817b9a478e9f5c384dfc1a7176", attacker, Vector3(0.08 * dirX, 0.0, 0), 0, Vector3(1, 1, 1), false, startOptions)
	end

	method table GetThunderboltSwing()
		-- 매직클로와 동일한 모션 후보군(swingO1/O2/O3, 한손무기 계열)을 그대로 사용해 매 시전마다 순환 재생한다.
		local candidates = {
			{ name = "swingO1" },
			{ name = "swingO2" },
			{ name = "swingO3" },
		}
		self._T.thunderboltSwingIndex = (self._T.thunderboltSwingIndex or 0) % #candidates + 1
		return candidates[self._T.thunderboltSwingIndex]
	end

	@ExecSpace("Multicast")
	method void PlayThunderboltMotion(Entity attacker, string motionName, number dirX, number atkMultiplier)
		-- 썬더볼트 전용 모션 재생. 매직클로(PlayMagicClawMotion)와 완전히 동일한 방식 - 별도 플래그로 서로 간섭하지 않는다.
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		local avatarRenderer = attacker.AvatarRendererComponent
		if not isvalid(avatarRenderer) then return end
		local body = avatarRenderer:GetBodyEntity()
		if not isvalid(body) then return end

		avatarRenderer.ShowDefaultWeaponEffects = false

		local playerCtrl = attacker.PlayerControllerComponent
		if isvalid(attacker.MovementComponent) then
			attacker.MovementComponent:Stop()
		end
		if isvalid(playerCtrl) then
			playerCtrl.LookDirectionX = dirX
		end
		self._T.isThunderboltDirectionLocked = true
		self._T.lockedThunderboltDirX = dirX
		self._T.lockedThunderboltMotionName = motionName
		self._T.isThunderboltMotionPlaying = true

		local mult = math.max(atkMultiplier or 1.0, 0.001)
		local playRate = 1.0 / mult
		self._T.lockedThunderboltPlayRate = playRate

		local motionEvent = ActionStateChangedEvent(motionName, motionName, playRate, SpriteAnimClipPlayType.Onetime)
		body:SendEvent(motionEvent)
		log("[Thunderbolt] PlayThunderboltMotion sent: " .. tostring(motionName) .. " playRate=" .. tostring(playRate))

		_TimerService:SetTimerOnce(function()
			if isvalid(avatarRenderer) then
				avatarRenderer.ShowDefaultWeaponEffects = true
			end
			self._T.isThunderboltMotionPlaying = false
		end, 0.55 * mult)

		_TimerService:SetTimerOnce(function()
			self._T.isThunderboltDirectionLocked = false
			local sc = self.Entity.StateComponent
			if isvalid(sc) and sc.CurrentStateName ~= "DEAD" then
				sc:ChangeState("IDLE")
				sc:ChangeState("MOVE")
				sc:ChangeState("IDLE")
			end
		end, 0.80 * mult)
	end

	@ExecSpace("Multicast")
	method void PlayThunderboltHitEffect(Entity target)
		-- 타격받는 몬스터 머리 위에 나타나는 이펙트 (대상마다 1회, 전원 동시에 재생됨).
		-- 높이 오프셋은 기존 0.6에서 사용자 요청으로 조금 낮춰 0.3으로 조정.
		if not self:IsClient() then return end
		if not isvalid(target) then return end
		local serial = _EffectService:PlayEffectAttached("bb8d0c3c8b9940dfa5e4678bc642fa8d", target, Vector3(0, 0.3, 0), 0, Vector3(1, 1, 1), false, {})
		_TimerService:SetTimerOnce(function()
			_EffectService:RemoveEffect(serial)
		end, 1.0)
	end

	@ExecSpace("Multicast")
	method void PlayThunderboltHitSound()
		-- 몬스터 타격음. 맞은 몬스터 수만큼, 0.04초 간격으로 순서대로 재생된다
		-- (호출 시점 자체가 DealThunderboltHits에서 인덱스*0.04초 딜레이로 예약되어 있음).
		if not self:IsClient() then return end
		_SoundService:PlaySound("d3205fdd08e34b68bc01292a997531ed", 1.0)
	end

	@ExecSpace("ServerOnly")
	method void AttackHeal(number combatPower, number atkMultiplier)
		-- 힐 발동: 항상 자기 자신을 회복시키고, 주변(썬더볼트와 동일한 탐색 범위/최대 6명, 방향 무관)의
		-- 다른 플레이어는 함께 회복시키며, 그 범위 안의 언데드 몬스터(script.Monster.IsUndead=true)는 대신 피해를 입힌다.
		local currentState = self.Entity.StateComponent.CurrentStateName
		if currentState == "DEAD" or currentState == "CLIMB" or currentState == "LADDER" then
			return
		end
		if self._T.isHealing then
			return
		end
		self._T.isHealing = true

		local mult = math.max(0.1, math.min(atkMultiplier or 1.0, 3.0))
		self._T.pendingHealCombatPower = combatPower

		local playerCtrl = self.Entity.PlayerControllerComponent
		local worldPos = self.Entity.TransformComponent.WorldPosition
		local dirX = playerCtrl.LookDirectionX

		-- 자신을 제외한 범위 내 대상(다른 플레이어 + 언데드 몬스터)을 미리 골라둔다 (썬더볼트와 동일한 탐색 범위/최대 6명).
		local targets = self:FindHealTargets(Vector2(worldPos.x, worldPos.y), 6)
		self._T.healTargets = targets

		self._T.pendingHealWasControllerEnabled = isvalid(playerCtrl) and playerCtrl.Enable
		if isvalid(playerCtrl) then
			playerCtrl.Enable = false
		end
		if isvalid(self.Entity.MovementComponent) then
			self.Entity.MovementComponent:Stop()
		end

		-- 스킬 사용 사운드 + 몸쪽 시전 이펙트 (즉시, 1회) + 캐릭터 모션(버프/숨고르기 계열 후보 - 사용자가 화면으로 확인 후 확정 예정)
		self:PlayHealUseSound(self.Entity)
		self:PlayHealStartEffect(self.Entity)
		local motion = self:GetHealMotion()
		self:PlayHealMotion(self.Entity, motion.name, dirX, mult)

		-- 딜레이 후 자신을 무조건 회복시키고, 미리 골라둔 대상 전원에게 동시에 회복/피해를 적용한다.
		_TimerService:SetTimerOnce(function()
			self:DealHealEffects(targets)
		end, 0.4 * mult)

		-- 컨트롤 잠금 해제: 처리 직후 여유(0.2초)를 두고, 배율을 적용한다.
		_TimerService:SetTimerOnce(function()
			self:RestoreHealControl()
		end, 0.6 * mult)
	end

	@ExecSpace("ServerOnly")
	method table FindHealTargets(Vector2 fromPos, integer maxCount)
		-- 힐 대상 선정: 썬더볼트와 동일한 탐색 범위(방향 무관, 가로 6칸·세로 1칸)에서 자신을 제외한
		-- 다른 플레이어(회복 대상)와 언데드 몬스터(script.Monster.IsUndead=true, 피해 대상)를 함께 찾아
		-- 가까운 순으로 정렬해 최대 maxCount명까지 후보로 반환한다. 각 항목은 { entity, kind = "player"|"undead" }.
		local map = self.Entity.CurrentMap
		if not isvalid(map) then return {} end
		local candidates = {}

		local mapComp = map.MapComponent
		if isvalid(mapComp) then
			local users = _UserService:GetUsersByMapComponent(mapComp)
			if users ~= nil then
				for _, userEntity in ipairs(users) do
					if isvalid(userEntity) and userEntity ~= self.Entity then
						local pc = userEntity.PlayerComponent
						if isvalid(pc) and not pc:IsDead() then
							local pos = userEntity.TransformComponent.WorldPosition
							local dx = pos.x - fromPos.x
							local dy = pos.y - fromPos.y
							if math.abs(dx) <= 3.0 and math.abs(dy) <= 1.0 then
								table.insert(candidates, { entity = userEntity, dist = math.abs(dx), kind = "player" })
							end
						end
					end
				end
			end
		end

		local monsterComps = map:GetChildComponentsByTypeName("script.Monster", true)
		for _, comp in ipairs(monsterComps) do
			---@type Monster
			local mc = comp
			if isvalid(mc) and isvalid(mc.Entity) and not mc.IsDead and mc.IsUndead then
				local pos = mc.Entity.TransformComponent.WorldPosition
				local dx = pos.x - fromPos.x
				local dy = pos.y - fromPos.y
				if math.abs(dx) <= 3.0 and math.abs(dy) <= 1.0 then
					table.insert(candidates, { entity = mc.Entity, dist = math.abs(dx), kind = "undead" })
				end
			end
		end

		table.sort(candidates, function(a, b) return a.dist < b.dist end)
		local result = {}
		for i = 1, math.min(#candidates, maxCount) do
			table.insert(result, candidates[i])
		end
		return result
	end

	@ExecSpace("Server")
	method void RestoreHealControl()
		self._T.isHealing = false
		local playerCtrl = self.Entity.PlayerControllerComponent
		if isvalid(playerCtrl) and self._T.pendingHealWasControllerEnabled then
			playerCtrl.Enable = true
		end
	end

	@ExecSpace("Server")
	method void DealHealEffects(table targets)
		-- 예약된 딜레이 뒤 호출된다. 자신은 무조건 회복시키고(대상 목록과 무관), 목록의 각 대상은
		-- 종류(kind)에 따라 회복 또는 언데드 피해를 동시에 처리한다 (썬더볼트처럼 순차 딜레이 없음).
		if not isvalid(self.Entity) then return end

		self:ApplyHealToPlayer(self.Entity, self._T.pendingHealCombatPower or 0)

		for _, t in ipairs(targets) do
			if isvalid(t.entity) then
				if t.kind == "player" then
					self:ApplyHealToPlayer(t.entity, self._T.pendingHealCombatPower or 0)
				elseif t.kind == "undead" then
					-- 이번 Attack() 호출은 이 대상 하나만 통과하도록 지정 (썬더볼트와 동일한 교차 히트 방지 패턴).
					self._T.healCurrentUndeadTarget = t.entity
					local targetPos = t.entity.TransformComponent.WorldPosition
					local shape = CircleShape(Vector2(targetPos.x, targetPos.y), 0.6)
					local hitComps = self:Attack(shape, "skill.heal", CollisionGroups.HitBox)
					local actuallyHit = false
					for _, hc in ipairs(hitComps) do
						if isvalid(hc) and isvalid(hc.Entity) and hc.Entity == t.entity then
							actuallyHit = true
							break
						end
					end
					if actuallyHit then
						self:PlayHealUndeadHitSound()
						self:PlayHealUndeadHitEffect(t.entity)
					end
				end
			end
		end
		log("PlayerAttack: AttackHeal 처리 완료 대상=" .. tostring(#targets))
	end

	@ExecSpace("Server")
	method void ApplyHealToPlayer(Entity target, number combatPower)
		-- 전투력의 10%를 기준으로 ±50% 범위(즉 전투력의 5%~15%) 내에서 랜덤한 양만큼 HP를 회복시킨다
		-- (보유 중인 최대 HP를 넘지 않도록 클램프). 실제로 회복된 양만큼만 데미지스킨으로 숫자 표시 + 대상 머리 위 이펙트 재생.
		if not isvalid(target) then return end
		local pc = target.PlayerComponent
		if not isvalid(pc) then return end
		local baseHeal = combatPower * 0.10
		local mult = 0.5 + _UtilLogic:RandomDouble() * 1.0
		local healAmount = math.floor(baseHeal * mult)
		if healAmount <= 0 then return end
		local newHp = math.min(pc.Hp + healAmount, pc.MaxHp)
		local actualHealed = newHp - pc.Hp
		if actualHealed <= 0 then return end
		pc.Hp = newHp
		self:PlayHealTargetEffect(target)
		self:ShowHealDamageSkin(target, actualHealed)
	end

	@ExecSpace("Multicast")
	method void PlayHealUseSound(Entity attacker)
		-- 스킬 사용 즉시 재생되는 사운드. Multicast는 서버 자신도 함께 실행하므로 클라이언트에서만 실행되게 막는다.
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		_SoundService:PlaySound("a1a425ae3c1c49afa068ee212676c5dc", 1.0)
	end

	@ExecSpace("Multicast")
	method void PlayHealStartEffect(Entity attacker)
		-- 스킬 사용과 동시에 캐릭터 몸에서 발현되는 시작 이펙트 (1회).
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		_EffectService:PlayEffectAttached("26a8af1751324d2c9f14b1719a28d3c8", attacker, Vector3(0, 0, 0), 0, Vector3(1, 1, 1), false, {})
	end

	@ExecSpace("Multicast")
	method void PlayHealTargetEffect(Entity target)
		-- 힐을 받은 대상(자신 포함) 머리 위에 나타나는 이펙트 (1회).
		if not self:IsClient() then return end
		if not isvalid(target) then return end
		local serial = _EffectService:PlayEffectAttached("26a8af1751324d2c9f14b1719a28d3c8", target, Vector3(0, 0.6, 0), 0, Vector3(1, 1, 1), false, {})
		_TimerService:SetTimerOnce(function()
			_EffectService:RemoveEffect(serial)
		end, 1.0)
	end

	@ExecSpace("Multicast")
	method void PlayHealUndeadHitSound()
		-- 언데드 몬스터가 힐로 피해를 입을 때 재생되는 사운드.
		if not self:IsClient() then return end
		_SoundService:PlaySound("38052d3003a941759a340ae28611d4dd", 1.0)
	end

	@ExecSpace("Multicast")
	method void PlayHealUndeadHitEffect(Entity target)
		-- 언데드 몬스터가 힐로 피해를 입을 때만 머리 위에 나타나는 이펙트 (1회). 다른 공격에는 재생되지 않는다.
		if not self:IsClient() then return end
		if not isvalid(target) then return end
		local headY = 0.5
		local hit = target.HitComponent
		if isvalid(hit) then
			headY = hit.ColliderOffset.y + hit.BoxSize.y / 2
		end
		local serial = _EffectService:PlayEffectAttached("e81f0ba3f2b545d7895b98b1cf9be879", target, Vector3(0, headY, 0), 0, Vector3(1, 1, 1), false, {})
		_TimerService:SetTimerOnce(function()
			_EffectService:RemoveEffect(serial)
		end, 1.0)
	end

	@ExecSpace("Client")
	method void ShowHealDamageSkin(Entity target, integer healAmount)
		-- 회복된 양을 데미지처럼 숫자로 표시한다 (전용 데미지스킨 RUID 사용).
		if not isvalid(target) then return end
		_DamageSkinService:Play(
			target, "d58b67cf0f3a4eaf9fe1ad87c0ffac8a", 0,
			{ healAmount }, DamageSkinTweenType.Default, false,
			Vector2(0, 0), Vector2(1, 1), 1.0, 1.0, LitMode.Default
		)
	end

	method table GetHealMotion()
		-- 사용자가 실제 화면으로 비교한 뒤 "alert" 동작으로 최종 확정.
		return { name = "alert" }
	end

	@ExecSpace("Multicast")
	method void PlayHealMotion(Entity attacker, string motionName, number dirX, number atkMultiplier)
		-- 힐 전용 모션 재생. 썬더볼트/매직클로와 동일한 방식 - 별도 플래그로 서로 간섭하지 않는다.
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		local avatarRenderer = attacker.AvatarRendererComponent
		if not isvalid(avatarRenderer) then return end
		local body = avatarRenderer:GetBodyEntity()
		if not isvalid(body) then return end

		avatarRenderer.ShowDefaultWeaponEffects = false

		local playerCtrl = attacker.PlayerControllerComponent
		if isvalid(attacker.MovementComponent) then
			attacker.MovementComponent:Stop()
		end
		if isvalid(playerCtrl) then
			playerCtrl.LookDirectionX = dirX
		end
		self._T.isHealDirectionLocked = true
		self._T.lockedHealDirX = dirX
		self._T.lockedHealMotionName = motionName
		self._T.isHealMotionPlaying = true

		local mult = math.max(atkMultiplier or 1.0, 0.001)
		local playRate = 1.0 / mult
		self._T.lockedHealPlayRate = playRate

		local motionEvent = ActionStateChangedEvent(motionName, motionName, playRate, SpriteAnimClipPlayType.Onetime)
		body:SendEvent(motionEvent)
		log("[Heal] PlayHealMotion sent: " .. tostring(motionName) .. " playRate=" .. tostring(playRate))

		_TimerService:SetTimerOnce(function()
			if isvalid(avatarRenderer) then
				avatarRenderer.ShowDefaultWeaponEffects = true
			end
			self._T.isHealMotionPlaying = false
		end, 0.55 * mult)

		_TimerService:SetTimerOnce(function()
			self._T.isHealDirectionLocked = false
			local sc = self.Entity.StateComponent
			if isvalid(sc) and sc.CurrentStateName ~= "DEAD" then
				sc:ChangeState("IDLE")
				sc:ChangeState("MOVE")
				sc:ChangeState("IDLE")
			end
		end, 0.80 * mult)
	end

	@ExecSpace("ServerOnly")
	method void AttackHaste()
		-- 헤이스트: 이동속도 40%, 점프력 20% 증가(5분). 최초 사용 시 원본 값을 한 번만 캡처해두고
		-- 이후에는 항상 그 원본 값 기준으로 배율을 재계산하므로, 지속 중 다시 사용해도 중첩되지 않고
		-- 지속시간만 갱신된다(토큰 비교로 먼저 걸린 타이머의 원복을 무시).
		local currentState = self.Entity.StateComponent.CurrentStateName
		if currentState == "DEAD" then
			return
		end

		local movement = self.Entity.MovementComponent
		if not isvalid(movement) then
			return
		end

		if not self._T.hasteBaseCaptured then
			self._T.hasteBaseInputSpeed = movement.InputSpeed
			self._T.hasteBaseJumpForce = movement.JumpForce
			self._T.hasteBaseCaptured = true
		end

		movement.InputSpeed = self._T.hasteBaseInputSpeed * 1.4
		movement.JumpForce = self._T.hasteBaseJumpForce * 1.2

		self._T.hasteToken = (self._T.hasteToken or 0) + 1
		local myHasteToken = self._T.hasteToken
		local duration = 300

		self:PlayHasteCastEffect(self.Entity)

		local userId = self.Entity.PlayerComponent.UserId
		self:NotifyHasteStart(duration, userId)

		_TimerService:SetTimerOnce(function()
			if self._T.hasteToken ~= myHasteToken then return end
			if isvalid(movement) then
				movement.InputSpeed = self._T.hasteBaseInputSpeed
				movement.JumpForce = self._T.hasteBaseJumpForce
			end
		end, duration)
	end

	@ExecSpace("Multicast")
	method void PlayHasteCastEffect(Entity attacker)
		-- 헤이스트 시전 이펙트: 캐릭터 몸쪽에서 1회 재생.
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		local serial = _EffectService:PlayEffectAttached("410e6a09f8ec471f87bd8d55c34cc48d", attacker, Vector3(0, 0, 0), 0, Vector3(1, 1, 1), false, {})
		_TimerService:SetTimerOnce(function()
			_EffectService:RemoveEffect(serial)
		end, 1.5)
	end

	@ExecSpace("Client")
	method void NotifyHasteStart(number duration)
		-- 헤이스트 버프 타이머 UI 표시(본인 클라이언트에게만 - 호출부에서 UserId를 마지막 인자로 추가해 타겟팅).
		_HasteBuffUI:ShowBuff(duration)
	end

	@ExecSpace("ServerOnly")
	method void AttackFireArrow(number combatPower, number atkMultiplier, number rawDirX, number rawDirY, number level)
		-- 파이어에로우: 방향키(위/아래/대각선) 입력으로 각도를 바꿔 화살을 발사한다. 입력이 없으면 캐릭터가
		-- 바라보는 방향(전방)으로 발사. 레벨(50 기준)에 따라 몸쪽 이펙트와 화살 RUID가 달라진다.
		-- level은 SkillManager에서 combatPower와 동일하게 클라이언트에서 계산해 전달받는다 -
		-- _UIMyInfoManager.CharLevel은 서버에서 InitStats() 최초 1회 1로 고정된 뒤 갱신되지 않는 값이라 사용 불가.
		local currentState = self.Entity.StateComponent.CurrentStateName
		if currentState == "DEAD" or currentState == "CLIMB" or currentState == "LADDER" then
			return
		end

		local dirX, dirY = rawDirX, rawDirY
		local mag = math.sqrt(dirX * dirX + dirY * dirY)
		if mag > 0.0001 then
			dirX = dirX / mag
			dirY = dirY / mag
		else
			local playerCtrl = self.Entity.PlayerControllerComponent
			dirX = (isvalid(playerCtrl) and playerCtrl.LookDirectionX >= 0) and 1 or -1
			dirY = 0
		end

		local castRuid = (level >= 50) and "c04324310b7d43219ec0d0fa400c4a5b" or "f3d1726f78be40beae0b32960858f132"
		local arrowRuid = (level >= 50) and "17e6f8af37eb4be09b95304e7854c3db" or "bf1fda424a06413d9617789715d0470e"

		-- 기모으는 딜레이 동안 이동이 되지 않도록 컨트롤러를 잠근다 (매직클로/썬더볼트 등과 동일한 패턴).
		-- 홀드 지속발동(공격속도가 빨라지면 다음 시전이 이전 시전의 잠금 해제보다 먼저 겹쳐 들어올 수 있음) 중에도
		-- 안전하도록, "원래 활성화 상태였는지"는 잠금 체인의 첫 시전에서만 기록하고(이미 잠긴 상태에서 캡처하면
		-- false가 저장되어 영원히 안 풀리는 버그가 생김), 실제 복구도 토큰으로 가장 최근 시전에서만 실행되게 한다.
		local playerCtrl = self.Entity.PlayerControllerComponent
		if not self._T.isFireArrowMovementLocked then
			self._T.pendingFireArrowWasControllerEnabled = isvalid(playerCtrl) and playerCtrl.Enable
			self._T.isFireArrowMovementLocked = true
		end
		if isvalid(playerCtrl) then
			playerCtrl.Enable = false
		end
		if isvalid(self.Entity.MovementComponent) then
			self.Entity.MovementComponent:Stop()
		end
		self._T.fireArrowMoveLockToken = (self._T.fireArrowMoveLockToken or 0) + 1
		local myMoveLockToken = self._T.fireArrowMoveLockToken

		-- 순수 상하 방향(dirX==0)은 캐릭터가 원래 보던 좌우 방향을 그대로 유지한다.
		local horizDirX
		if dirX ~= 0 then
			horizDirX = (dirX > 0) and 1 or -1
		else
			horizDirX = (isvalid(playerCtrl) and playerCtrl.LookDirectionX >= 0) and 1 or -1
		end

		-- 기모으는 느낌: 활 쏘는 모션 + 시전 이펙트/사운드는 즉시 재생하고, 실제 화살 발사는 약간의 딜레이 후에 한다.
		self:PlayFireArrowCastEffect(self.Entity, castRuid, dirX, dirY)
		self:PlayFireArrowMotion(self.Entity, "shoot1", horizDirX, atkMultiplier)
		_TimerService:SetTimerOnce(function()
			self:SpawnFireArrowProjectile(arrowRuid, combatPower, dirX, dirY)
		end, 0.25 * atkMultiplier)
		-- 이동 잠금은 모션 재생 시간이 아니라 스킬 재사용 대기시간(SkillManager의 0.75*atkMultiplier 쿨다운)과
		-- 동일하게 끝까지 유지한다 - "스킬 딜레이 동안 계속 못 움직여야 한다"는 요구사항 반영.
		_TimerService:SetTimerOnce(function()
			self:RestoreFireArrowControl(myMoveLockToken)
		end, 0.75 * atkMultiplier)
	end

	@ExecSpace("Multicast")
	method void PlayFireArrowMotion(Entity attacker, string motionName, number dirX, number atkMultiplier)
		-- 파이어에로우 전용 활 쏘는 모션 재생. 다른 스킬과 동일한 방식 - 별도 플래그로 서로 간섭하지 않는다.
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		local avatarRenderer = attacker.AvatarRendererComponent
		if not isvalid(avatarRenderer) then return end
		local body = avatarRenderer:GetBodyEntity()
		if not isvalid(body) then return end

		avatarRenderer.ShowDefaultWeaponEffects = false

		local playerCtrl = attacker.PlayerControllerComponent
		if isvalid(attacker.MovementComponent) then
			attacker.MovementComponent:Stop()
		end
		if isvalid(playerCtrl) then
			playerCtrl.LookDirectionX = dirX
		end
		self._T.isFireArrowDirectionLocked = true
		self._T.lockedFireArrowDirX = dirX
		self._T.lockedFireArrowMotionName = motionName
		self._T.isFireArrowMotionPlaying = true
		self._T.fireArrowLockToken = (self._T.fireArrowLockToken or 0) + 1
		local myFireArrowLockToken = self._T.fireArrowLockToken

		local mult = math.max(atkMultiplier or 1.0, 0.001)
		local playRate = 1.0 / mult
		self._T.lockedFireArrowPlayRate = playRate

		local motionEvent = ActionStateChangedEvent(motionName, motionName, playRate, SpriteAnimClipPlayType.Onetime)
		body:SendEvent(motionEvent)
		log("[FireArrow] PlayFireArrowMotion sent: " .. tostring(motionName) .. " playRate=" .. tostring(playRate))

		-- 모션 재생 자체(포즈 유지)는 화살이 발사되는 시점(0.25*mult)에 끝나지만, 이동 잠금(방향 고정)은
		-- 스킬 재사용 대기시간 전체(0.75*mult, SkillManager 쿨다운과 동일)까지 유지한다.
		_TimerService:SetTimerOnce(function()
			if isvalid(avatarRenderer) then
				avatarRenderer.ShowDefaultWeaponEffects = true
			end
			self._T.isFireArrowMotionPlaying = false
		end, 0.25 * mult)

		_TimerService:SetTimerOnce(function()
			if self._T.fireArrowLockToken ~= myFireArrowLockToken then return end
			self._T.isFireArrowDirectionLocked = false
			local sc = self.Entity.StateComponent
			if isvalid(sc) and sc.CurrentStateName ~= "DEAD" then
				sc:ChangeState("IDLE")
				sc:ChangeState("MOVE")
				sc:ChangeState("IDLE")
			end
		end, 0.75 * mult)
	end

	@ExecSpace("Server")
	method void RestoreFireArrowControl(integer moveLockToken)
		-- 기모으는 딜레이가 끝나 화살이 발사된 직후 컨트롤러를 되돌린다. 홀드 지속발동으로 더 최근 시전이
		-- 이미 다시 잠가둔 상태라면(토큰 불일치) 여기서 섣불리 풀지 않는다 - 그 최근 시전의 복구 타이머가 처리한다.
		if self._T.fireArrowMoveLockToken ~= moveLockToken then return end
		self._T.isFireArrowMovementLocked = false
		local playerCtrl = self.Entity.PlayerControllerComponent
		if isvalid(playerCtrl) and self._T.pendingFireArrowWasControllerEnabled then
			playerCtrl.Enable = true
		end
	end

	@ExecSpace("ServerOnly")
	method void SpawnFireArrowProjectile(string arrowRuid, number combatPower, number dirX, number dirY)
		local map = self.Entity.CurrentMap
		if not isvalid(map) then return end
		self._T.fireArrowCount = (self._T.fireArrowCount or 0) + 1
		local name = "firearrow_" .. tostring(self.Entity.Name) .. "_" .. tostring(self._T.fireArrowCount)
		-- 발쪽(원점)이 아니라 몸통 중심 높이에서 날아가도록 y를 올린다 (다른 스킬들의 body-center 기준값 0.35 재사용)
		local myPos = self.Entity.TransformComponent.WorldPosition
		local proj = _SpawnService:SpawnByModelId("firearrowprojectile", name, Vector3(myPos.x, myPos.y + 0.35, myPos.z), map)
		if not isvalid(proj) then
			log_warning("[PlayerAttack] FireArrow 발사체 스폰 실패")
			return
		end

		local sprite = proj.SpriteRendererComponent
		if isvalid(sprite) then
			sprite.SpriteRUID = arrowRuid
		end

		---@type FireArrowProjectile
		local projComp = proj:GetComponent("script.FireArrowProjectile")
		if isvalid(projComp) then
			projComp.CombatPower = combatPower
			projComp:Fire(dirX, dirY)
		end
	end

	@ExecSpace("Multicast")
	method void PlayFireArrowCastEffect(Entity attacker, string effectRuid, number dirX, number dirY)
		-- 사용자 몸 쪽에서 1회 재생되는 시전 이펙트 + 사운드.
		-- 순수 좌우 방향(dirY==0)은 회전 대신 FlipX로 반전한다 - 180도 회전을 쓰면 이펙트 원점이 발밑까지
		-- 밀려 내려가는 문제가 있어서(사용자 확인 - 왼쪽은 정상, 오른쪽만 밀림), 회전 없이 좌우만 미러링한다.
		-- 위/아래/대각선 방향은 회전이 필요하므로 그대로 두되, 방향별로 사용자가 실제 화면으로 확인해 지적한
		-- 어긋난 위치를 방향별 로컬 오프셋으로 보정한다(위=좌측+상단으로, 아래=우측으로, 우측아래=우측으로, 우측위=상단으로 더).
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		local angleDeg = 0
		local flipX = false
		local offsetX = 0
		local offsetY = 0
		if dirY == 0 then
			flipX = dirX > 0
		elseif dirX == 0 and dirY > 0 then
			-- 위
			angleDeg = math.deg(math.atan(dirY, dirX)) + 180
			offsetX = -0.15
			offsetY = 0.2
		elseif dirX == 0 and dirY < 0 then
			-- 아래
			angleDeg = math.deg(math.atan(dirY, dirX)) + 180
			offsetX = 0.15
		elseif dirX > 0 and dirY > 0 then
			-- 우측위
			angleDeg = math.deg(math.atan(dirY, dirX)) + 180
			offsetY = 0.3
		elseif dirX > 0 and dirY < 0 then
			-- 우측아래
			angleDeg = math.deg(math.atan(dirY, dirX)) + 180
			offsetX = 0.15
		else
			-- 좌측위/좌측아래 (아직 별도 피드백 없음 - 기존 기본 보정 유지)
			angleDeg = math.deg(math.atan(dirY, dirX)) + 180
			if dirY > 0 then
				offsetY = 0.2
			end
		end
		local castOptions = { ["FlipX"] = flipX }
		local serial = _EffectService:PlayEffectAttached(effectRuid, attacker, Vector3(offsetX, offsetY, 0), angleDeg, Vector3(1, 1, 1), false, castOptions)
		_SoundService:PlaySound("6f972ab4e14841398281f3fc2a8f376e", 1.0)
		_TimerService:SetTimerOnce(function()
			_EffectService:RemoveEffect(serial)
		end, 1.0)
	end

	@ExecSpace("ServerOnly")
	method void AttackIronArrow(number combatPower, number atkMultiplier, number rawDirX, number rawDirY)
		-- 아이언에로우: 파이어에로우와 완전히 동일한 구조(8방향 발사·기모으는 딜레이·이동봉인)를 그대로
		-- 재사용하되, 전용 이펙트/사운드를 쓰고 레벨에 따른 분기는 없다(고정 1종). 파이어에로우와 서로
		-- 간섭하지 않도록 모든 _T 필드는 별도로 둔다.
		local currentState = self.Entity.StateComponent.CurrentStateName
		if currentState == "DEAD" or currentState == "CLIMB" or currentState == "LADDER" then
			return
		end

		local dirX, dirY = rawDirX, rawDirY
		local mag = math.sqrt(dirX * dirX + dirY * dirY)
		if mag > 0.0001 then
			dirX = dirX / mag
			dirY = dirY / mag
		else
			local playerCtrl = self.Entity.PlayerControllerComponent
			dirX = (isvalid(playerCtrl) and playerCtrl.LookDirectionX >= 0) and 1 or -1
			dirY = 0
		end

		local castRuid = "dcac510901fe451282ad7b93abc3032d"
		local arrowRuid = "1e06841cc18a47c9975303520f3429d6"

		-- 기모으는 딜레이 동안 이동이 되지 않도록 컨트롤러를 잠근다 (파이어에로우와 동일한 첫-시전-캡처 +
		-- 토큰 가드 패턴 - 홀드 지속발동 중에도 안전).
		local playerCtrl = self.Entity.PlayerControllerComponent
		if not self._T.isIronArrowMovementLocked then
			self._T.pendingIronArrowWasControllerEnabled = isvalid(playerCtrl) and playerCtrl.Enable
			self._T.isIronArrowMovementLocked = true
		end
		if isvalid(playerCtrl) then
			playerCtrl.Enable = false
		end
		if isvalid(self.Entity.MovementComponent) then
			self.Entity.MovementComponent:Stop()
		end
		self._T.ironArrowMoveLockToken = (self._T.ironArrowMoveLockToken or 0) + 1
		local myMoveLockToken = self._T.ironArrowMoveLockToken

		-- 순수 상하 방향(dirX==0)은 캐릭터가 원래 보던 좌우 방향을 그대로 유지한다.
		local horizDirX
		if dirX ~= 0 then
			horizDirX = (dirX > 0) and 1 or -1
		else
			horizDirX = (isvalid(playerCtrl) and playerCtrl.LookDirectionX >= 0) and 1 or -1
		end

		self:PlayIronArrowCastEffect(self.Entity, castRuid, dirX, dirY)
		self:PlayIronArrowMotion(self.Entity, "shoot1", horizDirX, atkMultiplier)
		-- 화살이 실제로 발사되기까지의 기모으는 딜레이: 사용자 지정값 0.7로 직접 설정.
		_TimerService:SetTimerOnce(function()
			self:SpawnIronArrowProjectile(arrowRuid, combatPower, dirX, dirY)
		end, 0.7 * atkMultiplier)
		-- 이동 잠금은 모션 재생 시간이 아니라 스킬 재사용 대기시간(SkillManager의 0.75*atkMultiplier 쿨다운)과
		-- 동일하게 끝까지 유지한다.
		_TimerService:SetTimerOnce(function()
			self:RestoreIronArrowControl(myMoveLockToken)
		end, 0.75 * atkMultiplier)
	end

	@ExecSpace("Multicast")
	method void PlayIronArrowMotion(Entity attacker, string motionName, number dirX, number atkMultiplier)
		-- 아이언에로우 전용 활 쏘는 모션 재생. 파이어에로우와 동일한 방식 - 별도 플래그로 서로 간섭하지 않는다.
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		local avatarRenderer = attacker.AvatarRendererComponent
		if not isvalid(avatarRenderer) then return end
		local body = avatarRenderer:GetBodyEntity()
		if not isvalid(body) then return end

		avatarRenderer.ShowDefaultWeaponEffects = false

		local playerCtrl = attacker.PlayerControllerComponent
		if isvalid(attacker.MovementComponent) then
			attacker.MovementComponent:Stop()
		end
		if isvalid(playerCtrl) then
			playerCtrl.LookDirectionX = dirX
		end
		self._T.isIronArrowDirectionLocked = true
		self._T.lockedIronArrowDirX = dirX
		self._T.lockedIronArrowMotionName = motionName
		self._T.isIronArrowMotionPlaying = true
		self._T.ironArrowLockToken = (self._T.ironArrowLockToken or 0) + 1
		local myIronArrowLockToken = self._T.ironArrowLockToken

		local mult = math.max(atkMultiplier or 1.0, 0.001)
		local playRate = 1.0 / mult
		self._T.lockedIronArrowPlayRate = playRate

		local motionEvent = ActionStateChangedEvent(motionName, motionName, playRate, SpriteAnimClipPlayType.Onetime)
		body:SendEvent(motionEvent)
		log("[IronArrow] PlayIronArrowMotion sent: " .. tostring(motionName) .. " playRate=" .. tostring(playRate))

		-- 모션 재생 자체(포즈 유지)는 화살이 발사되는 시점(0.7*mult, 기모으는 딜레이와 동일하게 맞춤)에 끝나지만,
		-- 이동 잠금(방향 고정)은 스킬 재사용 대기시간 전체(0.75*mult, SkillManager 쿨다운과 동일)까지 유지한다.
		_TimerService:SetTimerOnce(function()
			if isvalid(avatarRenderer) then
				avatarRenderer.ShowDefaultWeaponEffects = true
			end
			self._T.isIronArrowMotionPlaying = false
		end, 0.7 * mult)

		_TimerService:SetTimerOnce(function()
			if self._T.ironArrowLockToken ~= myIronArrowLockToken then return end
			self._T.isIronArrowDirectionLocked = false
			local sc = self.Entity.StateComponent
			if isvalid(sc) and sc.CurrentStateName ~= "DEAD" then
				sc:ChangeState("IDLE")
				sc:ChangeState("MOVE")
				sc:ChangeState("IDLE")
			end
		end, 0.75 * mult)
	end

	@ExecSpace("Server")
	method void RestoreIronArrowControl(integer moveLockToken)
		-- 기모으는 딜레이가 끝나 화살이 발사된 직후 컨트롤러를 되돌린다. 홀드 지속발동으로 더 최근 시전이
		-- 이미 다시 잠가둔 상태라면(토큰 불일치) 여기서 섣불리 풀지 않는다.
		if self._T.ironArrowMoveLockToken ~= moveLockToken then return end
		self._T.isIronArrowMovementLocked = false
		local playerCtrl = self.Entity.PlayerControllerComponent
		if isvalid(playerCtrl) and self._T.pendingIronArrowWasControllerEnabled then
			playerCtrl.Enable = true
		end
	end

	@ExecSpace("ServerOnly")
	method void SpawnIronArrowProjectile(string arrowRuid, number combatPower, number dirX, number dirY)
		local map = self.Entity.CurrentMap
		if not isvalid(map) then return end
		self._T.ironArrowCount = (self._T.ironArrowCount or 0) + 1
		local name = "ironarrow_" .. tostring(self.Entity.Name) .. "_" .. tostring(self._T.ironArrowCount)
		-- 발쪽(원점)이 아니라 몸통 중심 높이에서 날아가도록 y를 올린다 (파이어에로우와 동일한 body-center 기준값 0.35).
		local myPos = self.Entity.TransformComponent.WorldPosition
		local proj = _SpawnService:SpawnByModelId("ironarrowprojectile", name, Vector3(myPos.x, myPos.y + 0.35, myPos.z), map)
		if not isvalid(proj) then
			log_warning("[PlayerAttack] IronArrow 발사체 스폰 실패")
			return
		end

		local sprite = proj.SpriteRendererComponent
		if isvalid(sprite) then
			sprite.SpriteRUID = arrowRuid
		end

		---@type IronArrowProjectile
		local projComp = proj:GetComponent("script.IronArrowProjectile")
		if isvalid(projComp) then
			projComp.CombatPower = combatPower
			projComp:Fire(dirX, dirY)
		end
	end

	@ExecSpace("Multicast")
	method void PlayIronArrowCastEffect(Entity attacker, string effectRuid, number dirX, number dirY)
		-- 사용자 몸 쪽에서 1회 재생되는 시전 이펙트 + 사운드. 파이어에로우와 동일한 방향별 오프셋/회전
		-- 보정 로직을 그대로 재사용한다(사용자가 이미 화면으로 확인해 맞춰둔 값).
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		local angleDeg = 0
		local flipX = false
		local offsetX = 0
		local offsetY = 0
		if dirY == 0 then
			-- 좌/우: 이전값(0.15)과 직전값(0.0)의 중간 - 0.075.
			flipX = dirX > 0
			offsetY = 0.075
		elseif dirX == 0 and dirY > 0 then
			-- 위(대각선 아님): 왼쪽을 보고 쏠 때는 더 왼쪽으로(-0.3, 기존 유지), 오른쪽을 보고 쏠 때는
			-- 몸에서 너무 멀어졌다는 피드백으로 좌측으로 옮김(0.3 -> -0.15, 원래의 좌측 기본값 수준으로).
			angleDeg = math.deg(math.atan(dirY, dirX)) + 180
			local playerCtrl = attacker.PlayerControllerComponent
			local facingLeft = isvalid(playerCtrl) and playerCtrl.LookDirectionX < 0
			offsetX = facingLeft and -0.3 or -0.15
			offsetY = 0.2
		elseif dirX == 0 and dirY < 0 then
			-- 아래(대각선 아님): 오른쪽을 보고 쏠 때는 더 오른쪽으로(0.3, 기존 유지), 왼쪽을 보고 쏠 때는
			-- 몸에서 너무 멀어졌다는 피드백으로 우측으로 옮김(-0.3 -> 0.15, 원래의 우측 기본값 수준으로).
			angleDeg = math.deg(math.atan(dirY, dirX)) + 180
			local playerCtrl = attacker.PlayerControllerComponent
			local facingRight = isvalid(playerCtrl) and playerCtrl.LookDirectionX >= 0
			offsetX = facingRight and 0.3 or 0.15
		elseif dirX > 0 and dirY > 0 then
			-- 우측위: 방금 올라간 정도(0.5->0.65, +0.15)만큼 한번 더 올림 - 0.65 -> 0.8.
			angleDeg = math.deg(math.atan(dirY, dirX)) + 180
			offsetX = 0.3
			offsetY = 0.8
		elseif dirX > 0 and dirY < 0 then
			-- 우측아래: 조금만 더 올림 - offsetY 0.1->0.2.
			angleDeg = math.deg(math.atan(dirY, dirX)) + 180
			offsetX = 0.45
			offsetY = 0.2
		elseif dirX < 0 and dirY > 0 then
			-- 좌측위: 우측위와 높이를 맞추는 기준(0.5) - 좌측 당김은 그대로 유지.
			angleDeg = math.deg(math.atan(dirY, dirX)) + 180
			offsetX = -0.7
			offsetY = 0.5
		else
			-- 좌측아래: 살짝 왼쪽으로 더 - offsetX -0.15 추가(offsetY -0.2 유지).
			angleDeg = math.deg(math.atan(dirY, dirX)) + 180
			offsetX = -0.15
			offsetY = -0.2
		end
		local castOptions = { ["FlipX"] = flipX }
		local serial = _EffectService:PlayEffectAttached(effectRuid, attacker, Vector3(offsetX, offsetY, 0), angleDeg, Vector3(1, 1, 1), false, castOptions)
		_SoundService:PlaySound("7d5ef2c392a34251990a9dc8b51deb12", 1.0)
		_TimerService:SetTimerOnce(function()
			_EffectService:RemoveEffect(serial)
		end, 1.0)
	end

end