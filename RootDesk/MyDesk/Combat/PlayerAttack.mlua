		                log("[PoisonMist] HandleStateChangeEvent forced back to IDLE from " .. tostring(event.CurrentStateName))
		            end
		        end

		        -- 익스플로젼 전용 처리 (힐과 동일한 패턴이지만 별도의 플래그를 사용 - 서로 간섭하지 않는다)
		        if self._T.isExplosionMotionPlaying then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedExplosionDirX
		            end
		            local motionName = self._T.lockedExplosionMotionName
		            if not motionName then return end
		            local avatarRenderer = self.Entity.AvatarRendererComponent
		            if not isvalid(avatarRenderer) then return end
		            local body = avatarRenderer:GetBodyEntity()
		            if not isvalid(body) then return end
		            local motionEvent = ActionStateChangedEvent(motionName, motionName, self._T.lockedExplosionPlayRate or 1.0, SpriteAnimClipPlayType.Onetime)
		            body:SendEvent(motionEvent)
