@Component
script PlayerAttack extends AttackComponent

	-- 콤보 어택 버프로 쌓인 콤보 구슬 수(0~5). 서버가 갱신하고 모든 클라이언트에 동기화돼
	-- ComboOrb(구슬 엔티티)가 균등 간격 공전 계산에 읽어 쓴다. 구슬 1개당 데미지 +20%.
	@Sync property integer ComboOrbCount = 0

	-- 쉐도우 파트너 버프 활성 여부. 서버(AttackShadowPartner/만료 타이머)가 켜고 끄며 모든 클라이언트에
	-- 동기화된다 - 클라이언트에서 실행되는 이펙트 재생 메서드들이 이 값을 보고 그림자 몫의
	-- 스킬 이펙트(x축 뒤쪽, 투명도 70%)와 히트 이펙트(시간차 2배)를 복제 재생한다.
	@Sync property boolean ShadowPartnerOn = false

	-- 화살류 스킬(에로우 블로우 / 더블샷)의 자동 조준 범위. 캐릭터 앞쪽으로 이만큼 뻗은 사각형 안에
	-- 몬스터가 있으면 그 방향(위/아래 대각선)으로 쏜다. ComputeArrowAimDirection이 읽는다.
	property number ArrowAimXReach = 6.0

	-- 조준 사각형의 세로 반높이 - "캐릭터의 키(높이) 정도만큼 위아래"라는 요청에 맞춘 값.
	-- 런타임 실측: 플레이어 HitComponent.BoxSize = (0.5, 0.8) → 캐릭터 키 = 0.8 유닛.
	-- 화살이 출발하는 몸통 중심(발끝 기준 y+0.35)을 기준으로 위아래 각각 이만큼까지 탐색한다.
	property number ArrowAimYHalfHeight = 0.8

	@ExecSpace("ClientOnly")
	method void OnSyncProperty(string name, any value)
		-- (버그 수정) "스탯창의 데미지가 오르지 않는다 - 스탯창이 열려있어도 즉시 반영돼야 한다"는
		-- 피드백. 콤보 구슬 개수(ComboOrbCount)가 바뀔 때마다, 스탯창이 열려 있으면 즉시 다시 계산해
		-- 표시한다(창이 닫혀 있으면 다음에 열 때 어차피 새로 계산되므로 건너뛴다).
		if name ~= "ComboOrbCount" then return end
		local window = _EntityService:GetEntityByPath("/ui/DefaultGroup/CharInfoWindow")
		if isvalid(window) and window.Enable then
			_CharInfoManager:UpdateStats()
		end
	end

	@ExecSpace("ServerOnly")
	method void OnBeginPlay()
		        -- Ready: player attack component initialized
		        self._T.shape = BoxShape(Vector2.zero, Vector2.one, 0)
		        log("PlayerAttack: OnBeginPlay")
		        -- (버그 수정) "이동 불가 버그가 잦다"는 신고에 대한 자가복구 안전장치.
		        -- 모든 스킬은 시전 시 PlayerControllerComponent.Enable = false로 조작을 잠그고, 각자의 복구
		        -- 타이머(Restore*Control)에서 다시 켠다. 그런데 시전 도중 사망/맵이동/스킬 중첩 등으로 그
		        -- 복구가 유실되면 조작이 영구히 꺼진 채로 남아 "이동만 안 되고 스킬은 나가는" 상태가 된다.
		        -- 스킬 하나하나를 고치는 대신, 잠금이 비정상적으로 오래(4.5초) 유지되면 강제로 풀어준다.
		        -- (정상 스킬의 잠금 구간 중 가장 긴 것이 블리자드의 3초다 - 임계값을 그보다 넉넉히 잡아야
		        --  정상 시전을 자가복구가 먼저 풀어버리지 않는다.)
		        self._T.ctrlDisabledFor = 0
		        self._T.ctrlWatchdogId = _TimerService:SetTimerRepeat(function()
			            self:ControlWatchdogTick()
		        end, 0.25)
	end

	@ExecSpace("ServerOnly")
	method void ControlWatchdogTick()
		if not isvalid(self.Entity) then return end
		-- 사망 중에는 일부러 잠가둔 것이므로 건드리지 않는다(HandleDeadLockStateEvent).
		if self._T.isDeadLocked then
			self._T.ctrlDisabledFor = 0
			return
		end
		local playerCtrl = self.Entity.PlayerControllerComponent
		if not isvalid(playerCtrl) then return end
		if playerCtrl.Enable then
			self._T.ctrlDisabledFor = 0
			return
		end
		self._T.ctrlDisabledFor = (self._T.ctrlDisabledFor or 0) + 0.25
		if self._T.ctrlDisabledFor >= 4.5 then
			playerCtrl.Enable = true
			self._T.ctrlDisabledFor = 0
			log_warning("[PlayerAttack] 조작 잠금이 3초 이상 풀리지 않아 강제 복구 (스킬 복구 타이머 유실 추정) - 이동불가 버그 자가복구")
		end
	end

	-- (기능 추가) "캐릭터가 사망했을 때 부활 전까지 다른 행동을 못하게 해달라"는 요청.
	-- 사망(DEAD) 상태로 들어가면 조작(PlayerControllerComponent)을 꺼서 이동/점프/기본공격을 막고,
	-- 부활(DEAD -> IDLE)하는 순간 다시 켠다. 스킬 입력은 SkillManager.UseSkillInSlot의 사망 가드가 막는다.
	--
	-- 반복 타이머로 계속 눌러 끄는 이유: 사망 직전에 시전한 스킬의 컨트롤 복구 타이머
	-- (RestoreSavageBlowControl 등 스킬마다 존재)가 사망 도중에 터지면 조작을 다시 켜버린다.
	-- 그 타이머들을 스킬별로 전부 고치는 대신, 사망 중에는 매 프레임 가까이 다시 꺼서 확실히 봉인한다.
	@ExecSpace("ServerOnly")
	@EventSender("Self")
	handler HandleDeadLockStateEvent(StateChangeEvent event)
		if event.CurrentStateName == "DEAD" then
			if self._T.isDeadLocked then return end
			self._T.isDeadLocked = true
			self:ApplyDeadLock()
			self._T.deadLockTimerId = _TimerService:SetTimerRepeat(function()
				if not self._T.isDeadLocked then return end
				-- (버그 수정) 부활 이벤트(PrevStateName == "DEAD")를 놓치면 조작이 영구히 잠긴 채로 남는다 -
				-- 매 틱 실제 상태를 직접 확인해, DEAD가 아니면 스스로 봉인을 푼다(자가복구).
				local sc = self.Entity.StateComponent
				if isvalid(sc) and sc.CurrentStateName ~= "DEAD" then
					self:ReleaseDeadLock()
					log("[PlayerAttack] 부활 감지(상태 확인) - 행동 봉인 해제")
					return
				end
				self:ApplyDeadLock()
			end, 0.05)
			log("[PlayerAttack] 사망 - 부활 전까지 행동 봉인")
		elseif event.PrevStateName == "DEAD" then
			if not self._T.isDeadLocked then return end
			self:ReleaseDeadLock()
			log("[PlayerAttack] 부활 - 행동 봉인 해제")
		end
	end

	@ExecSpace("ServerOnly")
	method void ReleaseDeadLock()
		-- 사망 봉인을 풀고 조작을 되돌린다(부활 이벤트 경로와 상태 확인 경로 둘 다 여기로 모인다).
		self._T.isDeadLocked = false
		if self._T.deadLockTimerId then
			_TimerService:ClearTimer(self._T.deadLockTimerId)
			self._T.deadLockTimerId = nil
		end
		self._T.ctrlDisabledFor = 0
		local playerCtrl = self.Entity.PlayerControllerComponent
		if isvalid(playerCtrl) then
			playerCtrl.Enable = true
		end
	end

	@ExecSpace("ServerOnly")
	method void ApplyDeadLock()
		-- 사망 중 이동/조작을 계속 꺼둔다.
		if not isvalid(self.Entity) then return end
		local playerCtrl = self.Entity.PlayerControllerComponent
		if isvalid(playerCtrl) and playerCtrl.Enable then
			playerCtrl.Enable = false
		end
		local movement = self.Entity.MovementComponent
		if isvalid(movement) then
			movement:Stop()
		end
	end

	@ExecSpace("ServerOnly")
	method void AttackNormal()
		        -- Calculate frontal box in the direction the player is looking
		        local playerCtrl = self.Entity.PlayerControllerComponent
		        local worldPos = self.Entity.TransformComponent.WorldPosition
		        local attackOffset = Vector2(
		            worldPos.x + 0.5 * playerCtrl.LookDirectionX,
		            worldPos.y + 0.5
		        )
		        -- 기본 공격(Control)은 단일 대상 공격이다 - 몬스터가 밀집한 구역에서 AttackFast의 박스 판정이
		        -- 여러 마리를 동시에 맞히는 문제가 있어, 판정 전에 가장 가까운 몬스터 하나만 골라
		        -- IsAttackTarget에서 그 대상만 통과시킨다 (파워스트라이크와 동일한 FindNearestMonster 재사용).
		        self._T.normalAttackTarget = self:FindNearestMonster(Vector2(worldPos.x, worldPos.y), 1.5)
		        self._T.shape = BoxShape(attackOffset, Vector2.one, 0)
		        self:AttackFastShadowSafe(self._T.shape, nil, self._T.normalAttackTarget)
		        log("PlayerAttack: AttackNormal at x=" .. tostring(attackOffset.x) .. " y=" .. tostring(attackOffset.y))
	end

	method boolean IsAttackTarget(Entity defender, string attackInfo)
		        -- Skip other players; only hit non-player entities (monsters)
		        if isvalid(defender.PlayerComponent) then
		            return false
		        end
		        -- 차지 블로우 지속 피해(화상/장판)는 이번 호출에 지정한 대상 하나만 때린다
		        -- (포이즌 미스트와 동일 - 밀집 지역에서 판정 박스가 이웃까지 겹쳐 맞는 것을 막는다).
		        if attackInfo == "dot.chargeblow.burn" or attackInfo == "dot.chargeblow.shock" or attackInfo == "dot.chargeblow.curse" then
		            return isvalid(self._T.chargeBlowDotTarget) and defender == self._T.chargeBlowDotTarget
		        end
		        -- 기본 공격(attackInfo가 nil)은 단일 대상 - 미리 골라둔 가장 가까운 대상만 통과시킨다
		        if attackInfo == nil then
		            if not isvalid(self._T.normalAttackTarget) or defender ~= self._T.normalAttackTarget then
		                return false
		            end
		        end
		        -- 파워스트라이크는 단일 대상 스킬 - 미리 골라둔 가장 가까운 대상만 통과시킨다.
		        -- (요청) 단, 차지 블로우로 시전된 경우에는 최대 3명까지 동시에 때린다.
		        if attackInfo == "skill.powerstrike" then
		            if (self._T.chargeBlowMode or 0) > 0 then
		                if not self:AcceptChargeBlowMultiTarget(defender) then return false end
		            elseif not isvalid(self._T.powerStrikeTarget) or defender ~= self._T.powerStrikeTarget then
		                return false
		            end
		        end
		        -- 슬래쉬블래스트는 0.2초 간격으로 한 명씩 순차 타격 - 이번 차례의 대상(slashBlastCurrentTarget)만 통과시킨다
		        if attackInfo == "skill.slashblast" then
		            if not isvalid(self._T.slashBlastCurrentTarget) or defender ~= self._T.slashBlastCurrentTarget then
		                return false
		            end
		        end
		        -- 파이널어택으로 발동된 파워스트라이크/슬래쉬블래스트 추가타 - 원본과 동일한 방식이지만 별도 대상 필드를 쓴다.
		        if attackInfo == "skill.powerstrike.final" then
		            if (self._T.chargeBlowMode or 0) > 0 then
		                if not self:AcceptChargeBlowMultiTarget(defender) then return false end
		            elseif not isvalid(self._T.powerStrikeFinalTarget) or defender ~= self._T.powerStrikeFinalTarget then
		                return false
		            end
		        end
		        if attackInfo == "skill.slashblast.final" then
		            if not isvalid(self._T.slashBlastFinalCurrentTarget) or defender ~= self._T.slashBlastFinalCurrentTarget then
		                return false
		            end
		        end
		        -- 더블스탭은 단일 고정 대상(doubleStabTarget)만 통과시킨다
		        if attackInfo == "skill.doublestab" then
		            if not isvalid(self._T.doubleStabTarget) or defender ~= self._T.doubleStabTarget then
		                return false
		            end
		        end
		        -- 매직클로는 단일 고정 대상(magicClawTarget)만 통과시킨다
		        if attackInfo == "skill.magicclaw" then
		            if not isvalid(self._T.magicClawTarget) or defender ~= self._T.magicClawTarget then
		                return false
		            end
		        end
		        -- 썬더볼트는 앞뒤 주변 최대 6명을 동시에 타격하는 다중 대상 스킬이지만, 몬스터가 밀집한 지역에서는
		        -- 개별 판정 범위가 이웃 대상까지 겹칠 수 있다. "6명 목록 중 아무나"가 아니라 이번 Attack() 호출의
		        -- 대상(thunderboltCurrentTarget) 하나만 통과시켜야 한 번의 호출이 이웃까지 중복으로 맞히지 않는다
		        -- (슬래쉬블래스트의 slashBlastCurrentTarget과 동일한 패턴).
		        if attackInfo == "skill.thunderbolt" then
		            if not isvalid(self._T.thunderboltCurrentTarget) or defender ~= self._T.thunderboltCurrentTarget then
		                return false
		            end
		        end
		        -- 힐이 언데드 몬스터에게 데미지를 입힐 때도 썬더볼트와 동일한 이유로 "이번 호출 전용 단일 대상"만 통과시킨다.
		        if attackInfo == "skill.heal" then
		            if not isvalid(self._T.healCurrentUndeadTarget) or defender ~= self._T.healCurrentUndeadTarget then
		                return false
		            end
		        end
		        -- 익스플로젼(본체 폭발 + 독구름 파열 데미지 공용) - 이번 호출 전용 단일 대상만 통과시킨다.
		        if attackInfo == "skill.explosion" then
			            if not isvalid(self._T.explosionCurrentTarget) or defender ~= self._T.explosionCurrentTarget then
			                return false
			            end
		        end
		        -- 드래곤 로어 - 이번 호출 전용 단일 대상만 통과시킨다(익스플로젼과 동일한 패턴).
		        if attackInfo == "skill.dragonroar" then
			            if not isvalid(self._T.dragonRoarCurrentTarget) or defender ~= self._T.dragonRoarCurrentTarget then
			                return false
			            end
		        end
		        -- 브랜디쉬 - 이번 호출 전용 단일 대상만 통과시킨다(밀집 지역에서 이웃까지 겹쳐맞는 것 방지).
		        -- 마무리 2줄(skill.brandish.finish)도 같은 _T.brandishCurrentTarget을 쓴다 - 1타에서 잡아둔
		        -- 대상 목록을 그대로 순회하므로 "1타와 2타가 같은 대상만 때린다"는 요청이 여기서 보장된다.
		        if attackInfo == "skill.brandish" or attackInfo == "skill.brandish.finish" then
			            if not isvalid(self._T.brandishCurrentTarget) or defender ~= self._T.brandishCurrentTarget then
			                return false
			            end
		        end
		        -- 다크드래곤(소환수 공격) - 이번 호출 전용 단일 대상만 통과시킨다.
		        if attackInfo == "skill.darkdragon" then
			            if not isvalid(self._T.darkDragonCurrentTarget) or defender ~= self._T.darkDragonCurrentTarget then
				                return false
			            end
		        end
		        -- 드래곤 라이딩(소환수 공격) - 이번 호출 전용 단일 대상만 통과시킨다(다크드래곤과 동일한 패턴).
		        if attackInfo == "skill.ridingdragon" then
			            if not isvalid(self._T.ridingDragonCurrentTarget) or defender ~= self._T.ridingDragonCurrentTarget then
				                return false
			            end
		        end
		        -- 돌진 - 이번 호출 전용 단일 대상만 통과시킨다(밀집 지역에서 이웃까지 겹쳐맞는 것 방지).
		        if attackInfo == "skill.rush" then
			            if not isvalid(self._T.rushCurrentTarget) or defender ~= self._T.rushCurrentTarget then
			                return false
			            end
		        end
		        -- 스피어 버스터 - 이번 호출 전용 단일 대상만 통과시킨다(익스플로젼과 동일한 패턴).
		        if attackInfo == "skill.spearburst" then
			            if not isvalid(self._T.spearBurstCurrentTarget) or defender ~= self._T.spearBurstCurrentTarget then
			                return false
			            end
		        end
		        -- 패닉은 파워스트라이크와 동일한 단일 대상 스킬 - 미리 골라둔 가장 가까운 대상만 통과시킨다.
		        if attackInfo == "skill.panic" then
		            if not isvalid(self._T.panicTarget) or defender ~= self._T.panicTarget then
		                return false
		            end
		        end
		        -- 코마 - 드래곤로어와 동일한 패턴(이번 호출 전용 단일 대상만 통과, 최대 15명까지 순차 호출).
		        if attackInfo == "skill.coma" then
		            if not isvalid(self._T.comaCurrentTarget) or defender ~= self._T.comaCurrentTarget then
		                return false
		            end
		        end
		        -- 어썰터 - 텔레포트로 나타난 자리의 그 대상만 통과시킨다(익스플로젼과 동일한 패턴).
		        if attackInfo == "skill.assaulter" then
		            if not isvalid(self._T.assaulterCurrentTarget) or defender ~= self._T.assaulterCurrentTarget then
		                return false
		            end
		        end
		        -- 블리자드 - 시전자 주위 다중 대상이지만, 이번 호출 전용 단일 대상만 통과시킨다
		        -- (드래곤 로어와 동일한 패턴 - 밀집 지역에서 판정 박스가 이웃까지 겹쳐 맞히는 것을 막는다).
		        if attackInfo == "skill.blizzard" then
		            if not isvalid(self._T.blizzardCurrentTarget) or defender ~= self._T.blizzardCurrentTarget then
		                return false
		            end
		        end
		        -- 블리자드 기둥(발판 위에 뜬 팩 이펙트) - 이번 호출 전용 단일 대상만 통과시킨다.
		        if attackInfo == "skill.blizzard.pillar" then
		            if not isvalid(self._T.blizzardPillarCurrentTarget) or defender ~= self._T.blizzardPillarCurrentTarget then
		                return false
		            end
		        end
		        -- 블리자드 얼음조각(낙하 지점에 있던 몬스터) - 이번 호출 전용 단일 대상만 통과시킨다.
		        if attackInfo == "skill.blizzard.shard" then
		            if not isvalid(self._T.blizzardShardCurrentTarget) or defender ~= self._T.blizzardShardCurrentTarget then
		                return false
		            end
		        end
		        -- 패링 반격 - 주변 최대 6명 다중 대상이지만, 이번 호출 전용 단일 대상만 통과시킨다
		        -- (블리자드/드래곤로어와 동일한 패턴 - 밀집 지역에서 이웃까지 겹쳐 맞히는 것을 막는다).
		        if attackInfo == "skill.parry" then
		            if not isvalid(self._T.parryCurrentTarget) or defender ~= self._T.parryCurrentTarget then
		                return false
		            end
		        end
		        -- 새비지블로우 - 전방 1명만 6번 때리는 단일 대상 스킬. 시전 시점에 고정해둔 그 대상만 통과시킨다.
		        if attackInfo == "skill.savageblow" then
		            if not isvalid(self._T.savageBlowCurrentTarget) or defender ~= self._T.savageBlowCurrentTarget then
		                return false
		            end
		        end
		        return __base:IsAttackTarget(defender, attackInfo)
	end

	-- 캐릭터 정보창과 동일한 크리티컬 확률(%)을 서버로 동기화한다 - CalcCritical/CalcDamage는 서버에서만
	-- 실행되는데 장비 잠재능력은 클라이언트 전용 상태라(인벤토리와 동일한 이유) 직접 읽을 수 없다.
	-- SkillManager가 스킬을 사용할 때마다 CharInfoManager:CalcCritRate()의 최신값을 넘겨준다.
	@ExecSpace("Server")
	method void SyncCritRate(number ratePercent)
		self._T.currentCritRatePercent = ratePercent
	end

	-- 캐릭터 정보창과 동일한 크리티컬 데미지(%, 기본 125%)를 서버로 동기화한다 - SyncCritRate와 동일한
	-- 이유(장비 잠재능력은 클라이언트 전용 상태)로 SkillManager가 스킬을 사용할 때마다
	-- CharInfoManager:CalcCritDamage()의 최신값을 넘겨준다. CalcDamage/GetCriticalDamageRate의
	-- 크리티컬 배율이 이 값을 참조한다(기존 하드코딩된 200% 대신).
	@ExecSpace("Server")
	method void SyncCritDamage(number damagePercent)
		self._T.currentCritDamagePercent = damagePercent
		log("[PlayerAttack] SyncCritDamage 수신: " .. tostring(damagePercent) .. "%")
	end

	method integer CalcDamage(Entity attacker, Entity defender, string attackInfo)
		-- 실제 공식은 CalcDamageBase에 있고, 여기서는 콤보 어택 버프 보너스(구슬 1개당 +20%)만
		-- 모든 스킬/기본공격에 일괄 적용한다. 수동 데미지 표시용 캐시(lastDoubleStabDamage 등)는
		-- Base 안에서 보너스 미반영 값으로 먼저 채워지므로, 여기서 보너스 반영값으로 재갱신해
		-- 화면 표시와 실제 적용량을 일치시킨다.
		local dmg = self:ApplyComboAttackBonus(self:CalcDamageBase(attacker, defender, attackInfo))
		local isManualSkin = (attackInfo == "skill.doublestab" or attackInfo == "skill.magicclaw" or attackInfo == "skill.spearburst" or attackInfo == "skill.savageblow" or attackInfo == "skill.brandish.finish")
		local critRate = (self._T.currentCritRatePercent or 50) / 100
		-- 크리티컬 데미지 배율: 기본 125%(1.25배) + 장비 잠재능력의 "크리티컬 데미지" 옵션. SyncCritDamage로
		-- 동기화된 값을 쓴다(GetCriticalDamageRate와 동일 소스) - 이 아래의 수동 다중 표시 분기들은 엔진
		-- 자동배율을 거치지 않으므로 여기서 직접 곱해야 한다.
		local critMult = (self._T.currentCritDamagePercent or 125) / 100

		-- (버그 수정) 더블스탭/매직클로/스피어버스터(수동 다중 표시 스킬)는 각 타격(hitIndex)이 이미
		-- 별도의 진짜 Attack() 호출이므로, 이 히트 하나에 대해서만 독립적으로 크리티컬을 굴리고 배율을
		-- 직접 곱해 반환값(dmg)에 반영한다. CalcCritical은 이 attackInfo들에 대해 항상 false를 반환해
		-- (아래 참고) 엔진이 여기서 이미 곱한 배율 위에 또 곱하는 이중 적용을 막는다. 이전에는 이
		-- attackInfo들의 크리티컬 자체를 통째로 꺼두어 "원래 2/3줄 뜨던 스킬에 크리티컬이 전혀 안 뜬다"는
		-- 문제가 있었다.
		local baseIsCritical = false
		if isManualSkin then
			-- math.random() 대신 _UtilLogic:RandomDouble()을 쓴다 - 이 파일에 이미 문서화된 버그(짧은
			-- 간격으로 잇따라 호출되면 math.random()이 같은 가상난수 시퀀스를 그대로 반복 소비해 값이
			-- 편향되는 현상, 더블스탭/스피어버스터 등에서 실측)를 원본/보너스 크리티컬 굴림에도 동일하게 피한다.
			baseIsCritical = _UtilLogic:RandomDouble() < critRate
			if baseIsCritical then
				dmg = math.floor(dmg * critMult)
			end
		end
		if attackInfo == "skill.doublestab" then
			self._T.lastDoubleStabDamage = dmg
			self._T.lastDoubleStabIsCritical = baseIsCritical
		elseif attackInfo == "skill.magicclaw" then
			self._T.lastMagicClawDamage = dmg
			self._T.lastMagicClawIsCritical = baseIsCritical
		elseif attackInfo == "skill.spearburst" then
			self._T.lastSpearBurstDamage = dmg
			self._T.lastSpearBurstIsCritical = baseIsCritical
		elseif attackInfo == "skill.savageblow" then
			self._T.lastSavageBlowDamage = dmg
			self._T.lastSavageBlowIsCritical = baseIsCritical
		elseif attackInfo == "skill.brandish.finish" then
			self._T.lastBrandishFinishDamage = dmg
			self._T.lastBrandishFinishIsCritical = baseIsCritical
		end
		-- (기능 변경) 쉐도우 파트너 - "타수 2배"를 별도의 진짜 히트(재진입 Attack() 호출)로 처리하던
		-- 기존 방식은 (1) 죽는 순간의 히트에서 대상이 이미 죽어 [LEA-3002]로 실패하거나 그 경우 통째로
		-- 생략됐고, (2) 두 줄이 한 번에 묶여 뜨지 않고 서로 다른 타이밍에 각각 한 줄씩 떴다는 문제가
		-- 실측 확인됐다. 이제는 이번 한 번의 진짜 히트 안에서 "원본 데미지 + 원본의 55~65%"를 합산한
		-- 값을 그대로 총 데미지로 반환하고(대상이 그 즉시 죽어도 항상 함께 적용됨), 표시만 OnAttack에서
		-- 두 줄(원본/보너스)로 묶어 한 번에 띄운다(ShowShadowEchoDamageSkin 참고). 더블스탭/매직클로/
		-- 스피어버스터는 이미 자기 전용 수동 표시가 있으므로 그 쪽에서 직접 보너스를 추가한다(아래
		-- Show*DamageSkin 메서드들 참고) - 여기서는 원본 값만 그대로 캐싱해둔다.
		self._T.shadowEchoOriginal = nil
		self._T.shadowEchoBonus = nil
		-- (버그 수정) "쉐도우 파트너로 뜬 2줄이 항상 같이 크리가 뜨거나 같이 안 뜬다" - 원본/보너스가 하나의
		-- CalcCritical 결과(shadowEchoIsCritical)를 공유해서 생긴 문제. 원본은 위에서 이미 독립적으로 구한
		-- baseIsCritical을 쓰고, 보너스는 아래에서 별도로 새로 굴려 서로 완전히 독립되게 한다.
		self._T.shadowEchoOriginalIsCritical = baseIsCritical
		self._T.shadowEchoBonusIsCritical = false
		self._T.shadowEchoIsManualSkin = isManualSkin
		if self._T.shadowPartnerActive then
			if not isManualSkin then
				-- 수동 표시가 아닌 일반 스킬도 쉐도우 파트너 중에는 이 히트 안에서만 크리티컬을 직접
				-- 처리한다(엔진 자동표시가 꺼져 있으므로 - GetDisplayHitCount 참고). isManualSkin 분기와
				-- 동일하게 baseIsCritical을 독립적으로 새로 굴린다.
				baseIsCritical = _UtilLogic:RandomDouble() < critRate
				if baseIsCritical then
					dmg = math.floor(dmg * critMult)
				end
				self._T.shadowEchoOriginalIsCritical = baseIsCritical
			end
			local bonus = math.floor(dmg * (0.55 + _UtilLogic:RandomDouble() * 0.10))
			local bonusIsCritical = _UtilLogic:RandomDouble() < critRate
			if bonusIsCritical then
				bonus = math.floor(bonus * critMult)
			end
			self._T.shadowEchoOriginal = dmg
			self._T.shadowEchoBonus = bonus
			self._T.shadowEchoBonusIsCritical = bonusIsCritical
			dmg = dmg + bonus
		end
		-- (요청) 브랜디쉬 1타(skill.brandish)는 대상을 죽이지 않는다 - HP를 1만 남기고 2타(swingTF
		-- 마지막의 2줄)에서 죽게 한다. Monster.HandleHitEvent가 Hp - TotalDamage로 깎으므로, 여기서
		-- 반환값을 "지금 HP - 1"로 잘라두면 HitEvent 파이프라인은 그대로 태운 채(데미지 스킨/히트
		-- 이펙트/피격음 전부 정상) HP만 1로 남는다. Hp에 직접 대입하는 방식은 HitEvent를 우회해
		-- 그 연출들이 통째로 조용히 생략되므로 쓰지 않는다.
		-- 잘라내기는 반드시 이 위치(쉐도우 파트너 보너스까지 합산된 최종값)에서 해야 한다 - 위쪽에서
		-- 자르면 그 뒤에 보너스가 더해져 다시 치명타가 된다.
		-- 2타(skill.brandish.finish)는 이 분기를 타지 않으므로 그대로 죽일 수 있다.
		if attackInfo == "skill.brandish" and isvalid(defender) then
			---@type Monster
			local monsterComp = defender:GetComponent("script.Monster")
			if isvalid(monsterComp) and not monsterComp.IsDead and dmg >= monsterComp.Hp then
				local capped = monsterComp.Hp - 1
				if capped < 0 then capped = 0 end
				-- 쉐도우 파트너가 켜져 있으면 이 히트를 원본/보너스 2줄로 나눠 표시하는데
				-- (ShowShadowEchoDamageSkin), 잘라낸 총량에 맞춰 두 줄도 같은 비율로 다시 나눠
				-- 표시 합이 실제 적용량과 어긋나지 않게 한다.
				if self._T.shadowEchoOriginal ~= nil and dmg > 0 then
					local newBonus = math.floor(capped * (self._T.shadowEchoBonus or 0) / dmg)
					self._T.shadowEchoBonus = newBonus
					self._T.shadowEchoOriginal = capped - newBonus
				end
				log("[Brandish] 1타 마무리 방지: HP 1 남김 target=" .. tostring(defender.Name) .. " hp=" .. tostring(monsterComp.Hp) .. " dmg=" .. tostring(dmg) .. " -> " .. tostring(capped))
				dmg = capped
			end
		end
		return dmg
	end

	method integer CalcDamageBase(Entity attacker, Entity defender, string attackInfo)
		        if attackInfo == "skill.brandish" or attackInfo == "skill.brandish.finish" then
		            -- (요청) 브랜디쉬: 전투력의 400%~700%. swingT3 마지막의 1줄과 swingTF 마지막의 2줄이
		            -- 모두 같은 공식을 쓴다(줄당 400~700%, 한 시전에 총 3줄).
		            -- math.random() 대신 _UtilLogic:RandomDouble()을 쓴다 - 마무리 2줄은 같은 틱에 잇따라
		            -- 굴리므로 이 파일에 문서화된 math.random() 반복 소비 편향(더블스탭에서 실측)에 그대로 걸린다.
		            local combatPower = self._T.pendingBrandishCombatPower or 0
		            local mult = 4.0 + _UtilLogic:RandomDouble() * 3.0
		            return math.floor(combatPower * mult)
		        elseif attackInfo == "skill.darkdragon" then
		            -- (요청) 다크드래곤 소환수 공격: 전투력의 200%~300%
		            local combatPower = self._T.pendingDarkDragonCombatPower or 0
		            local mult = 2.0 + _UtilLogic:RandomDouble() * 1.0
		            return math.floor(combatPower * mult)
		        elseif attackInfo == "skill.ridingdragon" then
		            -- (요청) 드래곤 라이딩 소환수 공격: 전투력의 200%~300%(다크드래곤과 동일 규격)
		            local combatPower = self._T.pendingRidingDragonCombatPower or 0
		            local mult = 2.0 + _UtilLogic:RandomDouble() * 1.0
		            return math.floor(combatPower * mult)
		        elseif attackInfo == "skill.rush" then
		            -- (요청) 돌진: 전투력의 300%~400%
		            local combatPower = self._T.pendingRushCombatPower or 0
		            local mult = 3.0 + math.random() * 1.0
		            return math.floor(combatPower * mult)
		        elseif attackInfo == "dot.chargeblow.burn" then
		            -- 차지 블로우(디바인 스윙 강화) 화상: 3초마다 전투력의 50%(12초간 4회). 공격속도 영향 없음.
		            return math.floor((self._T.pendingChargeBlowBurnPower or 0) * 0.5)
		        elseif attackInfo == "dot.chargeblow.shock" then
		            -- 차지 블로우(디바인 저지먼트 강화) 잔류 장판: 0.4초마다 전투력의 500%, 총 3회.
		            return math.floor((self._T.pendingChargeBlowShockPower or 0) * 5.0)
		        elseif attackInfo == "dot.chargeblow.curse" then
		            -- 화상 저주(화상 중인 적을 얼음으로 타격): 3초마다 전투력의 100%, 20초간.
		            return math.floor((self._T.pendingChargeBlowShockPower or 0) * 1.0)
		        elseif attackInfo == "skill.powerstrike" then
		            local combatPower = self._T.pendingCombatPower or 0
		            local mult = 0.5 + math.random() * (3.0 - 1.0)
		            return math.floor(combatPower * mult * self:GetChargeBlowDamageFactor(defender))
		        elseif attackInfo == "skill.slashblast" then
		            -- 전투력의 30%~150% 사이 랜덤
		            local combatPower = self._T.pendingSlashCombatPower or 0
		            local mult = 0.5 + math.random() * (1.5 - 0.5)
		            return math.floor(combatPower * mult)
		        elseif attackInfo == "skill.powerstrike.final" then
		            -- 파이널어택: 파워스트라이크와 동일한 공식에 15%~30% 추가 데미지를 곱한다.
		            local combatPower = self._T.pendingFinalCombatPower or 0
		            local mult = 0.5 + math.random() * (3.0 - 1.0)
		            local bonus = 1.15 + math.random() * (1.30 - 1.15)
		            return math.floor(combatPower * mult * bonus * self:GetChargeBlowDamageFactor(defender))
		        elseif attackInfo == "skill.slashblast.final" then
		            -- 파이널어택: 슬래쉬블래스트와 동일한 공식에 15%~30% 추가 데미지를 곱한다.
		            local combatPower = self._T.pendingFinalSlashCombatPower or 0
		            local mult = 0.5 + math.random() * (1.5 - 0.5)
		            local bonus = 1.15 + math.random() * (1.30 - 1.15)
		            return math.floor(combatPower * mult * bonus)
		        elseif attackInfo == "skill.doublestab" then
		            -- 전투력의 100%~260% 사이 랜덤 (매 타격마다 새로 굴림). math.random() 대신
		            -- _UtilLogic:RandomDouble()을 쓰는 이유: idx=1/idx=2가 0.1~0.2초 간격으로 짧게
		            -- 잇따라 호출될 때 math.random()이 동일한 값을 두 번 반환하는 현상이 실측됨.
		            local combatPower = self._T.pendingDoubleStabCombatPower or 0
		            local mult = 1.0 + _UtilLogic:RandomDouble() * (2.6 - 1.0)
		            self._T.lastDoubleStabDamage = math.floor(combatPower * mult)
		            return self._T.lastDoubleStabDamage
		        elseif attackInfo == "skill.magicclaw" then
		            -- 전투력의 100%~150% 사이 랜덤 (럭키세븐과 동일 비율)
		            local combatPower = self._T.pendingMagicClawCombatPower or 0
		            local mult = 1.0 + _UtilLogic:RandomDouble() * (1.5 - 1.0)
		            self._T.lastMagicClawDamage = math.floor(combatPower * mult)
		            return self._T.lastMagicClawDamage
		        elseif attackInfo == "skill.thunderbolt" then
		            -- 전투력의 80%~130% 사이 랜덤 (최대 6명에게 동시 적용 - 대상마다 독립적으로 새로 굴림).
		            -- 더블스탭 사례처럼 같은 프레임 안에서 연달아 호출되므로 math.random() 대신 _UtilLogic:RandomDouble() 사용.
		            local combatPower = self._T.pendingThunderboltCombatPower or 0
		            local mult = 0.8 + _UtilLogic:RandomDouble() * (1.3 - 0.8)
		            return math.floor(combatPower * mult)
		        elseif attackInfo == "skill.heal" then
		            -- 힐이 언데드 몬스터에게 입히는 데미지 - 썬더볼트와 동일한 전투력 80%~130% 공식.
		            local combatPower = self._T.pendingHealCombatPower or 0
		            local mult = 0.8 + _UtilLogic:RandomDouble() * (1.3 - 0.8)
		            return math.floor(combatPower * mult)
		elseif attackInfo == "skill.explosion" then
		-- 전투력의 500%~700% 사이 랜덤 (본체 폭발/독구름 파열 데미지 공용 - 대상마다 독립적으로 새로 굴림)
		local combatPower = self._T.pendingExplosionCombatPower or 0
		local mult = 5.0 + _UtilLogic:RandomDouble() * (7.0 - 5.0)
		return math.floor(combatPower * mult)
		        elseif attackInfo == "skill.dragonroar" then
			            -- 전투력의 1000%~1300% 사이 랜덤 (대상마다 독립적으로 새로 굴림)
			            local combatPower = self._T.pendingDragonRoarCombatPower or 0
			            local mult = 10.0 + _UtilLogic:RandomDouble() * (13.0 - 10.0)
			            return math.floor(combatPower * mult)
		        elseif attackInfo == "skill.blizzard" then
			            -- 블리자드(4차): 전투력의 3500%~5000% 사이 랜덤 (대상마다 독립적으로 새로 굴린다 -
			            -- 시전자 주위 다중 대상이라 같은 프레임 안에서 연달아 호출되므로 math.random() 대신
			            -- 이 파일에 이미 문서화된 _UtilLogic:RandomDouble()을 쓴다).
			            local combatPower = self._T.pendingBlizzardCombatPower or 0
			            local mult = 35.0 + _UtilLogic:RandomDouble() * (50.0 - 35.0)
			            return math.floor(combatPower * mult)
		        elseif attackInfo == "skill.blizzard.pillar" then
			            -- 블리자드 기둥(발판 위에 뜬 팩 이펙트): 0.5초 뒤 그 자리의 몬스터에게 전투력의 700%~1000% 피해.
			            local combatPower = self._T.pendingBlizzardCombatPower or 0
			            local mult = 7.0 + _UtilLogic:RandomDouble() * (10.0 - 7.0)
			            return math.floor(combatPower * mult)
		        elseif attackInfo == "skill.blizzard.shard" then
			            -- 블리자드 얼음조각: 떨어진 자리에 있던 몬스터가 0.3초 뒤 받는 피해 - 전투력의 100%~150%.
			            local combatPower = self._T.pendingBlizzardCombatPower or 0
			            local mult = 1.0 + _UtilLogic:RandomDouble() * (1.5 - 1.0)
			            return math.floor(combatPower * mult)
		        elseif attackInfo == "skill.spearburst" then
			            -- (임시) 히트 사운드 테스트용으로 전투력의 10%~20%로 낮춤 - 몬스터가 한방에 죽지 않아야
			            -- 피격음/사망음을 구분해서 확인하기 쉽다는 요청. 원래 값(240%~390%)은 아래 주석으로 보존.
			            -- local mult = 2.4 + _UtilLogic:RandomDouble() * (3.9 - 2.4)
			            local combatPower = self._T.pendingSpearBurstCombatPower or 0
			            local mult = 0.1 + _UtilLogic:RandomDouble() * (0.2 - 0.1)
			            -- 3연타 표시(ShowSpearBurstStabDamageSkin)가 실제 판정 성공 여부와 무관하게 보여줄
			            -- 데미지 값을 캐싱해둔다(더블스탭과 동일한 방식) - 앞선 타격에 대상이 이미 죽어
			            -- 이후 타격의 충돌 판정 자체가 실패해도 표시용 데미지를 새로 굴려 항상 3줄이 뜨게 한다.
			            self._T.lastSpearBurstDamage = math.floor(combatPower * mult)
			            return self._T.lastSpearBurstDamage
		        elseif attackInfo == "skill.panic" then
			            -- 구슬 1개당 전투력의 1000%~1200% - 소모한 구슬 개수(pendingPanicOrbCount)만큼
			            -- 그대로 곱해진다 (예: 구슬 2개 소모 시 2000%~2400%). 콤보 어택 버프의 +20%/개
			            -- 보너스(ApplyComboAttackBonus)는 AttackPanic에서 판정 전에 구슬을 이미 전부
			            -- 비워두므로(ComboOrbCount=0) 중복 적용되지 않는다.
			            local combatPower = self._T.pendingPanicCombatPower or 0
			            local orbCount = self._T.pendingPanicOrbCount or 0
			            local perOrbMult = 10.0 + _UtilLogic:RandomDouble() * (12.0 - 10.0)
			            return math.floor(combatPower * orbCount * perOrbMult)
		        elseif attackInfo == "skill.coma" then
			            -- (기능 추가) "패닉 데미지 공식의 1/5로 해달라"는 요청 - 패닉(구슬 1개당 1000%~1200%)의
			            -- 1/5인 구슬 1개당 200%~240%. 코마는 다중 대상(최대 15명)이라 각 대상마다 독립적으로 새로 굴린다.
			            local combatPower = self._T.pendingComaCombatPower or 0
			            local orbCount = self._T.pendingComaOrbCount or 0
			            local perOrbMult = 2.0 + _UtilLogic:RandomDouble() * (2.4 - 2.0)
			            return math.floor(combatPower * orbCount * perOrbMult)
		        elseif attackInfo == "skill.assaulter" then
			            -- 어썰터: 대상 뒤로 순간이동해 찌르는 확정 히트 단일 대상 데미지. 전투력의 300%~450%
			            -- (사용자가 정확한 %를 지정하지 않아 다른 단일 대상 스킬들과 비슷한 수준으로 설정 - 조정 가능).
			            local combatPower = self._T.pendingAssaulterCombatPower or 0
			            local mult = 3.0 + _UtilLogic:RandomDouble() * (4.5 - 3.0)
			            return math.floor(combatPower * mult)
		        elseif attackInfo == "skill.parry" then
			            -- 패링 반격(1차): 전투력의 500%~700% (요청사항). 주변 최대 6명에게 동시에 들어가므로
			            -- 같은 프레임 안에서 연달아 호출된다 - 이 파일에 이미 문서화된 math.random() 반복 소비
			            -- 편향을 피하려고 _UtilLogic:RandomDouble()을 쓴다.
			            local combatPower = self._T.pendingParryCombatPower or 0
			            local mult = 5.0 + _UtilLogic:RandomDouble() * (7.0 - 5.0)
			            -- 마지막으로 굴린 값을 캐싱해둔다 - 반격 로그(AttackParryCounter)가 실제 적용된 피해량을
			            -- 그대로 남겨 검증할 수 있게 하기 위함(표시는 엔진 자동 데미지 스킨이 담당한다).
			            self._T.lastParryDamage = math.floor(combatPower * mult)
			            return self._T.lastParryDamage
		        elseif attackInfo == "skill.savageblow" then
			            -- 새비지블로우: 한 줄(1타)당 전투력의 220%~300% (요청사항). 6타이므로 총 1320%~1800%.
			            -- 6번의 타격이 짧은 간격으로 잇따라 호출되므로 math.random() 대신 _UtilLogic:RandomDouble()을
			            -- 쓴다(이 파일에 이미 문서화된 더블스탭/스피어버스터의 편향 이슈와 동일한 이유).
			            -- 6줄 표시(ShowSavageBlowDamageSkin)가 실제 판정 성공 여부와 무관하게 보여줄 값을 캐싱해둔다 -
			            -- 앞선 타격에 대상이 죽어 이후 타격의 충돌 판정이 실패해도 항상 6줄이 뜨게 하기 위함이다.
			            local combatPower = self._T.pendingSavageBlowCombatPower or 0
			            local mult = 2.2 + _UtilLogic:RandomDouble() * (3.0 - 2.2)
			            self._T.lastSavageBlowDamage = math.floor(combatPower * mult)
			            return self._T.lastSavageBlowDamage
		        end
		        return 50
	end

	method boolean CalcCritical(Entity attacker, Entity defender, string attackInfo)
		        -- 더블스탭/매직클로/스피어버스터(수동 다중 표시 스킬)와 쉐도우 파트너 활성 중인 모든 히트는
		        -- CalcDamage에서 각 줄(원본/보너스, 또는 각 타격)마다 독립적으로 크리티컬을 굴려 배율까지
		        -- 이미 반환값(dmg)에 직접 곱해뒀다 - 여기서 또 true를 반환하면 엔진이 그 위에 배율을 한 번
		        -- 더 곱해 실제 적용 데미지가 표시값의 2~4배로 이중 적용된다. 이 경우엔 항상 false를 반환해
		        -- 이중 적용을 막는다(크리티컬 자체를 끄는 것이 아니라, 반영 지점만 CalcDamage로 옮긴 것).
		        local isManualSkin = (attackInfo == "skill.doublestab" or attackInfo == "skill.magicclaw" or attackInfo == "skill.spearburst" or attackInfo == "skill.savageblow")
		        if isManualSkin or self._T.shadowPartnerActive then
		            return false
		        end
		        -- (기능 수정) "크리티컬 확률은 캐릭터 정보창의 크리티컬 확률을 참고해야 한다"는 요청 -
		        -- 하드코딩된 30% 대신 SyncCritRate로 동기화해둔 실제 스탯(기본 50% + 장비 잠재능력)을 쓴다.
		        -- 썬더볼트/코마처럼 여러 대상에게 같은 프레임 안에서 연달아 호출될 수 있어, math.random()
		        -- 대신 이 파일에서 이미 문서화된 대체제 _UtilLogic:RandomDouble()을 쓴다.
		        local critRate = (self._T.currentCritRatePercent or 50) / 100
		        return _UtilLogic:RandomDouble() < critRate
	end

	method float GetCriticalDamageRate()
		        -- (기능 수정) "크리티컬이 뜨면 캐릭터 정보창의 크리티컬 데미지 스탯(기본 125%)을 참고해야
		        -- 한다"는 요청 - 하드코딩된 200%(2.0배) 대신 SyncCritDamage로 동기화해둔 실제 스탯을 쓴다.
		        return (self._T.currentCritDamagePercent or 125) / 100
	end

	method string GetHitDamageSkinId()
		-- 지금 적용해야 할 "공격 데미지 스킨" RUID.
		-- (버그 수정) 다중 타격 스킬(더블스탭/매직클로/스피어버스터/새비지블로우/쉐도우파트너/투사체)들은
		-- 엔진 자동표시를 끄고 _DamageSkinService:Play로 직접 숫자를 띄우는데, 거기에 기본 스킨 RUID가
		-- 하드코딩돼 있어서 블리자드의 스킨 교체(DamageSkinSettingComponent.DamageSkinId)가 무시됐다
		-- ("단일 스킬은 되는데 2~3대 때리는 스킬은 스킨이 안 바뀐다"). 수동 표시도 전부 이 값을 읽는다.
		local skinComp = self.Entity:GetComponent("MOD.Core.DamageSkinSettingComponent")
		if isvalid(skinComp) and skinComp.DamageSkinId ~= nil and skinComp.DamageSkinId.DataId ~= "" then
			return skinComp.DamageSkinId.DataId
		end
		return "3271c3e79bf04ecba9a107d55495970d"
	end

	method int32 GetDisplayHitCount(string attackInfo)
		        -- 더블스탭/매직클로/스피어 버스터는 각각 전용 Show*DamageSkin에서 수동으로 다중 줄을
		        -- 표시하므로 이 attackInfo들에 한해서만 엔진 자동 데미지 스킨 표시를 끈다 - 끄지 않으면
		        -- 같은 AttackComponent 인스턴스로 같은 대상을 짧은 간격으로 반복 타격할 때 자동표시가
		        -- 우리 수동 표시와 별개로 중복으로 겹쳐 뜨는 문제가 있다(더블스탭에서 실측 확인). 스피어
		        -- 버스터는 "3번 찌르기" 타격감을 위해 대상 하나당 실제 판정을 3회 진행하도록 재설계돼
		        -- 이 목록에 추가한다. 다른 스킬(파워스트라이크/슬래쉬블래스트/기본공격)은 부모 기본값(1) 유지.
		        -- 새비지블로우도 동일하게 6타를 수동으로 6줄 표시(ShowSavageBlowDamageSkin)하므로 자동표시를 끈다.
		        -- 브랜디쉬 마무리(swingTF 마지막의 2줄)도 같은 대상을 연속 2번 때리므로 자동표시를 끄고
		        -- ShowBrandishFinishDamageSkin에서 2줄을 직접 띄운다. 1타(skill.brandish)는 대상당 판정이
		        -- 한 번뿐이라 부모 기본값(1) 그대로 엔진 자동표시로 1줄을 띄운다.
		        if attackInfo == "skill.doublestab" or attackInfo == "skill.magicclaw" or attackInfo == "skill.spearburst" or attackInfo == "skill.savageblow" or attackInfo == "skill.brandish.finish" then
		            return 0
		        end
		        -- (버그 수정) 쉐도우 파트너 활성 중에는 항상 엔진 자동 표시를 끈다. 이전에는
		        -- self._T.shadowEchoBonus(이번 CalcDamage가 방금 계산해둔 값)를 기준으로 판단했는데,
		        -- GetDisplayHitCount가 attackInfo 단위로 CalcDamage와 다른 시점에 평가될 수 있어
		        -- (실측: "1줄로 뜨던 스킬"이 첫 줄 2개+둘째 줄 1개, 총 3번 표시되는 문제로 재현됨) 직전
		        -- 히트의 잔여값에 의존하는 shadowEchoBonus 체크는 타이밍에 취약했다. 버프 활성 여부
		        -- (shadowPartnerActive)는 히트 도중 값이 바뀌지 않으므로 이걸로 직접 판단한다.
		        if self._T.shadowPartnerActive then
		            return 0
		        end
		        return 1
	end

	@ExecSpace("ServerOnly")
	method void AttackChargeBlow(number combatPower, number atkMultiplier, string weaponClass, integer chargeMode)
		        -- 차지 블로우(3차). 공격 자체는 파워스트라이크와 완전히 동일해야 하므로 별도 구현을 두지 않고
		        -- AttackPowerStrike를 그대로 태운다 - 모션/판정 박스/데미지 공식/파이널어택까지 전부 공유된다.
		        -- 다른 점은 검 궤적 이펙트뿐이라, 여기서는 "다음 파워스트라이크 1회에 실을 속성"만 예약한다
		        -- (AttackPowerStrike가 시전 성공 시 이 값을 self._T.chargeBlowMode로 확정한다).
		        --   1=디바인 스티그마 강화(얼음) 2=디바인 스윙 강화(불) 3=디바인 저지먼트 강화(전기) 4=디바인 차지(성)
		        --   0=속성 없음 → 파워스트라이크 기본 궤적 그대로.
		        self._T.nextChargeBlowMode = chargeMode
		        self:AttackPowerStrike(combatPower, atkMultiplier, weaponClass)
	end

	@ExecSpace("ServerOnly")
	method void AttackPowerStrike(number combatPower, number atkMultiplier, string weaponClass)
		        -- 차지 블로우가 예약해둔 속성(AttackChargeBlow)을 여기서 회수한다. 예약값은 1회용이라 즉시
		        -- 비우고, 아래 재시전 가드에 막히면 확정하지 않는다(막힌 요청이 진행 중인 차지 블로우의
		        -- 속성을 덮어쓰면 안 된다). 그냥 파워스트라이크로 들어오면 0 - 즉 기본 궤적으로 돌아간다.
		        local chargeMode = self._T.nextChargeBlowMode or 0
		        self._T.nextChargeBlowMode = 0
		        -- (기능 추가) "다른 스킬을 쓰면 숨고르기 모션은 중지" 요청 - 이 스킬을 새로 시전하는 시점에 이전 숨고르기가 재생 중이었다면 즉시 정리한다.
		        self:StopBreather()
		        -- 파워스트라이크 전용 발동: 기본공격과 동일한 전방 박스 판정을 쓰되, attackInfo로 태그해 CalcDamage에서 별도 공식을 적용한다
		        -- 사다리/로프에 매달린 상태(CLIMB/LADDER)나 사망한 상태(DEAD)에서는 스킬을 사용할 수 없다.
		        local currentState = self.Entity.StateComponent.CurrentStateName
		        if currentState == "DEAD" or currentState == "CLIMB" or currentState == "LADDER" then
		            return
		        end
		        -- 이미 파워스트라이크 모션이 진행 중이면(모션 딜레이 구간, 파이널어택 진행 중 포함) 재시전을 막는다.
		        if self._T.isPowerStriking then
		            log("PlayerAttack: AttackPowerStrike 요청 차단됨(이미 진행 중 - 파이널어택 포함)")
		            return
		        end
		        self._T.isPowerStriking = true
		        self._T.motionEndHandled = false
		        -- 여기까지 왔다는 건 시전이 실제로 시작됐다는 뜻 - 이번 시전에 실릴 속성을 확정한다.
		        -- 이 값은 파이널어택(TryTriggerFinalAttack → NotifyFinalMotionEnded)까지 그대로 유지돼
		        -- 추가타 궤적도 같은 속성으로 나가고, 다음 일반 파워스트라이크에서 0으로 되돌아간다.
		        self._T.chargeBlowMode = chargeMode
		
		        -- 공격속도 배율: 클라이언트(CharInfoManager)가 소비한 "공격 속도의 비약" 단계로 계산해 넘겨준 값.
		        -- combatPower와 같은 이유로 클라이언트에서 계산해 RPC로 전달한다(서버에는 인벤토리 상태가 없음).
		        -- 1보다 작을수록 빠름(모션/딜레이 단축). 비정상적으로 극단적인 값이 오는 경우를 대비해 안전 범위로 clamp한다.
		        local mult = math.max(0.1, math.min(atkMultiplier or 1.0, 3.0))
		        self._T.pendingAtkMultiplier = mult
		        self._T.pendingWeaponClass = weaponClass
		
		        self._T.pendingCombatPower = combatPower
		        local playerCtrl = self.Entity.PlayerControllerComponent
		        local dirX = playerCtrl.LookDirectionX
		        self._T.pendingDirX = dirX

		        -- (버그 수정) "히트박스가 네모가 아닌 것 같다 - 멀리 있는 적이 맞고 가까이 있는 적은 안 맞는다"는
		        -- 신고 - 원인은 대상 선정을 여기(시전 시점)에서 전방향(원형) FindNearestMonster로 미리 골라두고,
		        -- 실제 타격 판정(NotifyMotionEnded의 전방 사각 박스)에서는 그 미리 골라둔 대상 하나만 통과시켰던
		        -- 것. "전방향 중 가장 가까운 대상"과 "전방 사각형 박스 안의 대상"은 서로 다른 도형이라, 캐릭터
		        -- 등 뒤나 대각선에 있는 몬스터가 전방향 기준으로는 더 가까워 먼저 선택돼버리면, 정작 박스
		        -- 안(전방)에 있는 진짜 가까운 몬스터가 오히려 걸러지는 "네모가 아닌" 히트박스처럼 보였다.
		        -- 대상 선정을 실제 박스 판정 시점(NotifyMotionEnded)으로 옮기고, 그 박스와 동일한 모양(전방
		        -- 사각형)으로 다시 골라야 진짜 사각형 히트박스처럼 동작한다 - 아래 NotifyMotionEnded 참고.

		        -- (주의) 기본 무기 스윙 이펙트(ShowDefaultWeaponEffects) 끄기/복구는 여기(서버)가 아니라
		        -- PlayAttackMotion(클라이언트, Multicast)에서 직접 처리한다. ShowDefaultWeaponEffects는 @Sync라
		        -- 서버에서 바꾸면 클라이언트에 반영되기까지 네트워크 지연이 있고, 모션을 재생하는 Multicast 호출과
		        -- 도착 순서가 보장되지 않아 첫 프레임에 기본 스윙 이펙트가 잠깐 섞여 보이는 문제가 있었다.
		
		        -- 모션 재생 동안은 이동/점프/기본공격/반대방향 전환 등 다른 행동을 할 수 없도록 컨트롤러를 먼저 잠근다.
		        -- 모션(PlayAttackMotion) 재생보다 반드시 먼저 잠가야 한다 - 이동 중에 캐릭터 모션을 재생하면
		        -- 이동 입력이 계속 걸어가기 애니메이션을 다시 밀어넣어 스윙 모션이 씹히는(끊기는) 문제가 있었다.
		        -- 다른 이유로 이미 꺼져있던 경우(예: 사망 처리 등)까지 되살리지 않도록 이전 값을 기억해뒀다가 그대로 복구한다.
		        self._T.pendingWasControllerEnabled = isvalid(playerCtrl) and playerCtrl.Enable
		        if isvalid(playerCtrl) then
		            playerCtrl.Enable = false
		        end
		        -- 이동 중 시전한 경우 관성/잔여 이동으로 모션이 어색하게 끊기지 않도록 서버 쪽에서도 즉시 이동을 멈춘다.
		        if isvalid(self.Entity.MovementComponent) then
		            self.Entity.MovementComponent:Stop()
		        end
		
		        -- 스킬 사용 사운드 재생
		        self:PlaySkillUseSound(self.Entity)
		        -- 스킬 시전 시작 이펙트 재생 (파워 스트라이크 리소스팩의 시전 전용 이펙트)
		        -- (요청) 차지 블로우는 파워스트라이크의 이미지 이펙트를 가져오지 않는다 - 속성 궤적만 보여야
		        -- 하므로 파워스트라이크 팩 소유의 시전 시작 이펙트는 건너뛴다.
		        if chargeMode <= 0 then
		            self:PlaySkillStartEffect(self.Entity, dirX)
		        end
		
		        -- 캐릭터 공격 모션 재생: 매 시전마다 하나를 골라(GetPowerStrikeSwing) 캐릭터 모션과 스윙 이펙트를 동일하게 맞춘다.
		        -- 두 번 호출해서 각각 다시 뽑으면 모션과 이펙트가 서로 다른 자세로 어긋날 수 있으므로, 한 번만 뽑아 저장해둔다.
		        local swing = self:GetPowerStrikeSwing(weaponClass)
		        self._T.pendingSwing = swing
		        -- 모션 재생 직전에 차지 블로우 여부를 클라 쪽에 알린다(엔진 기본 검격 on/off 판단에 쓰인다).
		        self:SetChargeBlowVisualMode(chargeMode)
		        self:PlayAttackMotion(self.Entity, swing.name, dirX, mult)
		
		        -- 타격 판정은 실제 애니메이션 종료 이벤트가 아니라 고정 딜레이(기본 0.25초)로 진행한다.
		        -- 애니메이션 종료 이벤트 기준으로 하면 이동 중 걷기 모션이 끊기거나 점프 착지 모션이 끼어들 때도
		        -- 같은 종료 이벤트가 발생해 파워스트라이크 모션이 끝나기도 전에 타격 판정이 발생하는 문제가 있었다.
		        -- 공격속도 배율(mult)만큼 딜레이를 단축/연장한다 (mult<1이면 더 빠르게 타격 판정).
		        _TimerService:SetTimerOnce(function()
		            self:NotifyMotionEnded()
		        end, 0.45 * mult)
		
		        -- 컨트롤러 잠금(이동 봉인)은 모션이 끝난 뒤에도 추가 딜레이만큼 더 유지한다 (기본 0.25초 + 0.4초 = 0.65초).
		        -- 이 전체 잠금 시간도 공격속도 배율만큼 단축된다.
		        _TimerService:SetTimerOnce(function()
		            self:RestoreControl()
		        end, 0.65 * mult)
	end

	@ExecSpace("Server")
	method void RestoreControl()
		        -- AttackPowerStrike에서 예약한 고정 딜레이(0.65초 = 모션 0.25초 + 추가 이동 봉인 0.4초) 뒤 호출된다.
		        -- 재시전 가능 상태로 되돌리고, 잠가뒀던 컨트롤러를 원래 값으로 복구한다.
		        self._T.isPowerStriking = false
		        local playerCtrl = self.Entity.PlayerControllerComponent
		        if isvalid(playerCtrl) and self._T.pendingWasControllerEnabled then
		            playerCtrl.Enable = true
		        end
		        -- 파이널어택(2차 패시브): 60% 확률로, 컨트롤이 "실제로" 돌아오는 이 시점에 바로 이어서(동기 호출)
		        -- 강화된 추가타를 한 번 더 실행한다. 이전에는 이 호출을 별도의 동일 딜레이 타이머로 나란히 예약했는데,
		        -- 그 타이머와 RestoreControl 타이머가 같은 프레임에 만료될 때 어느 쪽이 먼저 실행되는지가 타이머 큐
		        -- 순서에 의존해 보장되지 않았다 - RestoreControl이 파이널어택의 컨트롤 잠금보다 "나중에" 실행되면
		        -- 컨트롤이 즉시 풀려버려(이동/다른 스킬 등 다른 행동이 가능해짐) 파이널어택 모션 동안 다른 행동이
		        -- 가능한 버그가 있었다. 이 메서드 안에서 직접(동기적으로) 호출하면 항상 컨트롤 복구 다음에 실행되어
		        -- 순서가 보장된다.
		        self:TryTriggerFinalAttack("powerstrike", self._T.pendingCombatPower, self._T.pendingAtkMultiplier, self._T.pendingWeaponClass or "twohand")
		        -- (기능 추가) "다른 스킬들을 사용하고 난 다음도 모두 숨고르기 모션을 3번 하도록 해달라"는 요청 -
		        -- 컨트롤이 복구된 이 시점에 공용 숨고르기(PlayBreather)를 시작한다.
		        -- (버그 수정) "파워스트라이크 사용 후 파이널어택이 발동하면 숨고르기 때문에 파이널어택
		        -- 모션을 볼 수 없다"는 신고 - TryTriggerFinalAttack이 방금 발동했다면(동기 호출이라 위 줄에서
		        -- 이미 isPowerStriking=true로 다시 잠긴 상태) 숨고르기를 시작하지 않는다. 발동하지 않았을
		        -- 때만(isPowerStriking이 여전히 false) 숨고르기를 시작한다.
		        if not self._T.isPowerStriking then
		            self:PlayBreather(self.Entity, self._T.pendingDirX or 1)
		        end
	end

	@ExecSpace("ServerOnly")
	method void AttackSlashBlast(number combatPower, number atkMultiplier, string weaponClass)
		        -- (기능 추가) "다른 스킬을 쓰면 숨고르기 모션은 중지" 요청 - 이 스킬을 새로 시전하는 시점에 이전 숨고르기가 재생 중이었다면 즉시 정리한다.
		        self:StopBreather()
		        -- 슬래쉬블래스트 발동. 사다리/로프/사망 상태에서는 사용 불가 (파워스트라이크와 동일 가드).
		        local currentState = self.Entity.StateComponent.CurrentStateName
		        if currentState == "DEAD" or currentState == "CLIMB" or currentState == "LADDER" then
		            return
		        end
		        -- 이미 슬래쉬블래스트 모션/타격 시퀀스가 진행 중이면(파이널어택 진행 중 포함) 재시전을 막는다.
		        if self._T.isSlashBlasting then
		            log("PlayerAttack: AttackSlashBlast 요청 차단됨(이미 진행 중 - 파이널어택 포함)")
		            return
		        end
		        self._T.isSlashBlasting = true
		
		        -- 공격속도 배율: 파워스트라이크와 동일하게 클라이언트(CharInfoManager)가 계산해 넘겨준 값을 그대로 적용한다.
		        -- 1보다 작을수록 빠름(모션/딜레이/타격 간격 전부 단축). 안전 범위로 clamp.
		        local mult = math.max(0.1, math.min(atkMultiplier or 1.0, 3.0))
		        self._T.pendingSlashMult = mult
		        self._T.pendingSlashWeaponClass = weaponClass
		
		        self._T.pendingSlashCombatPower = combatPower
		        local playerCtrl = self.Entity.PlayerControllerComponent
		        local worldPos = self.Entity.TransformComponent.WorldPosition
		        local dirX = playerCtrl.LookDirectionX
		        self._T.pendingSlashDirX = dirX
		
		        -- 전방 판정 범위(파워스트라이크 최종 판정 박스와 동일한 가로 2칸·세로 1칸) 안의 적을
		        -- 가까운 순으로 최대 6명까지 미리 골라둔다. 실제 Attack 판정 없이 위치만으로 탐색한다.
		        local targets = self:FindSlashBlastTargets(Vector2(worldPos.x, worldPos.y), dirX, 6, 2.0, 1.0)
		
		        self._T.pendingSlashWasControllerEnabled = isvalid(playerCtrl) and playerCtrl.Enable
		        if isvalid(playerCtrl) then
		            playerCtrl.Enable = false
		        end
		        if isvalid(self.Entity.MovementComponent) then
		            self.Entity.MovementComponent:Stop()
		        end
		
		        -- 스킬 사용과 동시에 플레이어 몸쪽에서 발현되는 시작 이펙트 + 전용 사용 사운드
		        -- (요청) 몸쪽 캐스트 이펙트: 원본 4프레임 스파클 애니메이션(SpawnSlashBlastCastEffect).
		        self:SpawnSlashBlastCastEffect(dirX)
		        self:PlaySlashBlastUseSound(self.Entity)
		
		        -- (요청) 슬래시블러스트 전용 모션/궤적: 창=stabT1/stabT2, 두손검=swingT2만. 궤적은 새로 구해온
		        -- 파랑 스프라이트를 SpawnSkillTrailSprite로 표시(isSprite). 한손검은 파워스트라이크와 동일
		        -- (swingO 계열 + 엔진 기본 검격, 궤적 없음).
		        local swing = self:GetSlashBlastSwing(weaponClass)
		        -- (기능 추가) "원본 동작이 찌르기였으면 파이널어택도 찌르기를 연속으로 하지 말아달라"는
		        -- 요청 - TryTriggerFinalAttack이 이 값을 읽어 GetFinalAttackMotion에 전달한다.
		        self._T.pendingSlashSwing = swing
		        -- (요청) "슬래시블러스트의 모든 동작을 파워스트라이크와 똑같이" - 모션 재생기도 PS의
		        -- PlayAttackMotion으로 통일한다. 기존 PlaySlashBlastMotion은 ①기본 무기 이펙트
		        -- (ShowDefaultWeaponEffects)를 안 꺼서 찌르기 모션 위에 기본 스윙 이펙트가 겹쳐 어색했고
		        -- ②시전 토큰 가드가 없어 본체 모션의 IDLE 강제 토글이 파이널 모션을 중간에 덮어썼다.
		        self:PlayAttackMotion(self.Entity, swing.name, dirX, mult)
		
		        -- 첫 타격은 파워스트라이크와 동일하게 0.45초 뒤 판정하고, 이후 0.1초 고정 간격(공격속도 영향 없음)으로 다음 대상을 이어서 타격한다.
		        -- 대상 목록(targets)은 클로저 인자로 직접 전달한다 - 재시전으로 새 시퀀스가 시작돼도 이전 시퀀스의
		        -- 남은 타격이 뒤섞이지 않도록(공유 상태 대신 각자 자기 목록을 들고 있게) 하기 위함이다.
		        _TimerService:SetTimerOnce(function()
		            -- 첫 타격 시점에 궤적도 함께 표시한다(파워스트라이크와 동일 타이밍) - 스프라이트/클립 모두 지원.
		            if swing.isSprite == true then
		                self:SpawnSkillTrailSprite(swing.ruid, dirX, swing.trailOffsetX or 0.75, swing.trailOffsetY or 0.35, swing.trailScale or 1.0)
		            else
		                self:PlaySwingTrailClip(self.Entity, swing.ruid, dirX)
		            end
		            self:DealNextSlashBlastHit(targets, 1, mult)
		        end, 0.45 * mult)
		
		        -- 컨트롤 잠금 해제 시점: 대상 수와 무관하게 파워스트라이크와 동일한 고정 여유분(0.65초 = 0.45 + 0.2)에
		        -- 공격속도 배율을 적용한다. 타격이 여러 명에게 퍼져나가는 것(0.1초 고정 간격)은 이 잠금 시간과 별개로 계속 진행된다 -
		        -- 즉 컨트롤은 먼저 돌아오고, 남은 타격은 백그라운드에서 계속 이어진다.
		        _TimerService:SetTimerOnce(function()
		            self:RestoreSlashBlastControl()
		        end, 0.65 * mult)
	end

	@ExecSpace("Server")
	method void RestoreSlashBlastControl()
		        -- AttackSlashBlast에서 예약한(대상 수에 따라 가변인) 딜레이 뒤 호출된다.
		        -- 재시전 가능 상태로 되돌리고, 잠가뒀던 컨트롤러를 원래 값으로 복구한다.
		        self._T.isSlashBlasting = false
		        local playerCtrl = self.Entity.PlayerControllerComponent
		        if isvalid(playerCtrl) and self._T.pendingSlashWasControllerEnabled then
		            playerCtrl.Enable = true
		        end
		        -- 파이널어택(2차 패시브): 60% 확률로, 컨트롤이 실제로 돌아오는 이 시점에 바로 이어서(동기 호출) 추가타를
		        -- 실행한다. 파워스트라이크와 동일한 이유(별도 동일-딜레이 타이머의 실행 순서 레이스 방지)로 이 메서드
		        -- 안에서 직접 호출한다.
		        self:TryTriggerFinalAttack("slashblast", self._T.pendingSlashCombatPower, self._T.pendingSlashMult, self._T.pendingSlashWeaponClass or "twohand")
		        -- (기능 추가) "다른 스킬들을 사용하고 난 다음도 모두 숨고르기 모션을 3번 하도록 해달라"는 요청 -
		        -- 컨트롤이 복구된 이 시점에 공용 숨고르기(PlayBreather)를 시작한다.
		        -- (버그 수정) 파워스트라이크와 동일한 이유로, 파이널어택이 방금 발동했다면(isSlashBlasting이
		        -- 다시 true로 잠긴 상태) 숨고르기를 시작하지 않는다.
		        if not self._T.isSlashBlasting then
		            self:PlayBreather(self.Entity, self._T.pendingSlashDirX or 1)
		        end
	end

	@ExecSpace("Server")
	method void DealNextSlashBlastHit(table targets, integer idx, number atkMultiplier)
		        -- 0.1초 고정 간격(공격속도 영향 없음)으로 재귀 예약되며, 호출부(AttackSlashBlast)가 넘겨준 대상 목록을 앞에서부터 한 명씩 타격한다.
		        -- 목록/인덱스/배율을 클로저 인자로 직접 들고 있어서, 컨트롤 잠금(RestoreSlashBlastControl)이나
		        -- 재시전 여부와 무관하게 이 시퀀스만의 진행 상태로 계속 이어진다.
		        if idx > #targets then return end
		        if not isvalid(self.Entity) then return end
		
		        local target = targets[idx]
		        if isvalid(target) then
		            -- IsAttackTarget이 이번 차례의 대상만 통과시키도록 지정한 뒤 동일한 전방 판정 박스로 Attack한다.
		            self._T.slashBlastCurrentTarget = target
		            local dirX = self._T.pendingSlashDirX or 1
		            local curWorldPos = self.Entity.TransformComponent.WorldPosition
		            local attackOffset = Vector2(
		                curWorldPos.x + 1.0 * dirX,
		                curWorldPos.y
		            )
		            local shape = BoxShape(attackOffset, Vector2(2, 2), 0)
		            local hitComps = self:AttackShadowSafe(shape, "skill.slashblast", target)
		            -- IsHitTarget 등으로 실제로는 빗나갔을 수 있으므로, Attack()이 반환한 실제 명중 목록에서
		            -- 이번 대상이 있는지 확인한 뒤에만 히트 이펙트/사운드를 재생한다.
		            local actuallyHit = false
		            for _, hc in ipairs(hitComps) do
		                if isvalid(hc) and isvalid(hc.Entity) and hc.Entity == target then
		                    actuallyHit = true
		                    break
		                end
		            end
		            if actuallyHit then
		                -- (요청) 히트 이펙트를 폴더에서 가져온 파랑 히트 스프라이트 3종 중 하나로 무작위 교체.
		                local hitRuids = {
		                    "b0fba4de0af64fe18d288b6d791329ea",
		                    "55f7cfa3c85d4d9a95c4e9b18b8d564d",
		                    "cb4d15eb5d56431f98ed45d3cb9e72a5",
		                }
		                self:SpawnHitSpriteOnTarget(target, hitRuids[_UtilLogic:RandomIntegerRange(1, #hitRuids)])
		            end
		            log("PlayerAttack: AttackSlashBlast hit " .. tostring(idx) .. "/" .. tostring(#targets) .. " actuallyHit=" .. tostring(actuallyHit))
		        end

		        if idx < #targets then
		            -- (요청) 데미지가 퍼져 나가는 속도 1.5배 - 순차 타격 간격 0.1초 → 0.1/1.5초.
		            _TimerService:SetTimerOnce(function()
		                self:DealNextSlashBlastHit(targets, idx + 1, atkMultiplier)
		            end, 0.1 / 1.5)
		        end
	end

	@ExecSpace("ServerOnly")
	method void AttackLuckySeven(number combatPower, number atkMultiplier)
		        -- (기능 추가) "다른 스킬을 쓰면 숨고르기 모션은 중지" 요청 - 이 스킬을 새로 시전하는 시점에 이전 숨고르기가 재생 중이었다면 즉시 정리한다.
		        self:StopBreather()
		        -- 럭키세븐 발동: 표창 2개를 0.4초/0.5초 뒤 하나의 고정 표적에게 순서대로 던진다.
		        -- 딜레이 구조·컨트롤 잠금은 파워스트라이크와 동일한 공격속도 배율(atkMultiplier)을 적용한다.
		        local currentState = self.Entity.StateComponent.CurrentStateName
		        if currentState == "DEAD" or currentState == "CLIMB" or currentState == "LADDER" then
		            return
		        end
		        if self._T.isLuckySeven then
		            return
		        end

		        self._T.isLuckySeven = true

		        local mult = math.max(0.1, math.min(atkMultiplier or 1.0, 3.0))
		        self._T.pendingLuckySevenCombatPower = combatPower

		        local playerCtrl = self.Entity.PlayerControllerComponent
		        local worldPos = self.Entity.TransformComponent.WorldPosition
		        local dirX = playerCtrl.LookDirectionX
		        self._T.pendingLuckySevenDirX = dirX

		        -- 단일 고정 표적: 전방(x축) 사거리를 기존 대비 4배(2.0 → 8.0)로 늘린 럭키세븐 전용 탐색을 사용한다.
		        self._T.luckySevenTarget = self:FindLuckySevenTarget(Vector2(worldPos.x, worldPos.y), dirX)
		        -- 캐스팅 시점의 대상 위치를 스냅샷 - 표창이 날아가는 도중 대상이 죽어서 사라져도
		        -- 마지막 위치까지는 도달시켜 데미지 숫자(2줄)가 항상 뜨도록 한다.
		        self._T.luckySevenTargetPos = nil
		        if isvalid(self._T.luckySevenTarget) then
		            self._T.luckySevenTargetPos = self._T.luckySevenTarget.TransformComponent.Position
		        end

		        self._T.pendingLuckySevenWasControllerEnabled = isvalid(playerCtrl) and playerCtrl.Enable
		        if isvalid(playerCtrl) then
		            playerCtrl.Enable = false
		        end
		        if isvalid(self.Entity.MovementComponent) then
		            self.Entity.MovementComponent:Stop()
		        end

		        self:PlayLuckySevenUseSound(self.Entity)
		        self:PlayLuckySevenStartEffect(self.Entity, dirX)

		        local swing = self:GetLuckySevenSwing()
		        self:PlayLuckySevenMotion(self.Entity, swing.name, dirX, mult)

		        -- 표창 발사: 사용 후 0.4초/0.5초 뒤(공격속도 배율 적용) 순서대로 발사
		        _TimerService:SetTimerOnce(function()
		            self:FireLuckySevenShuriken(1)
		        end, 0.4 * mult)
		        _TimerService:SetTimerOnce(function()
		            self:FireLuckySevenShuriken(2)
		        end, 0.5 * mult)

		        -- 컨트롤 잠금 해제: 파워스트라이크와 동일한 고정 여유분(0.65초 * 배율). 표창 비행/타격은 이 시점 이후에도 계속된다.
		        _TimerService:SetTimerOnce(function()
		            self:RestoreLuckySevenControl()
		        end, 0.65 * mult)
	end

	@ExecSpace("Server")
	method void RestoreLuckySevenControl()
		        self._T.isLuckySeven = false
		        local playerCtrl = self.Entity.PlayerControllerComponent
		        if isvalid(playerCtrl) and self._T.pendingLuckySevenWasControllerEnabled then
		            playerCtrl.Enable = true
		        end
		        -- (기능 추가) "다른 스킬들을 사용하고 난 다음도 모두 숨고르기 모션을 3번 하도록 해달라"는 요청 -
		        -- 컨트롤이 복구된 이 시점에 공용 숨고르기(PlayBreather)를 시작한다.
		        self:PlayBreather(self.Entity, self._T.pendingLuckySevenDirX or 1)
	end

	@ExecSpace("Server")
	method void FireLuckySevenShuriken(integer idx)
		        -- 예약된 딜레이(0.4초/0.5초 * 배율) 뒤 호출되어 표창 1개를 스폰하고 고정 표적을 향해 발사한다.
		        -- 대상이 이미 죽어서 사라졌어도 캐스팅 시점에 저장해둔 마지막 위치(fallbackPos)가 있으면
		        -- 그쪽으로 발사해 데미지 숫자(2줄)가 항상 뜨도록 한다 - 완전히 처음부터 대상이 없었을 때만 스킵.
		        if not isvalid(self.Entity) then return end
		        local target = self._T.luckySevenTarget
		        local fallbackPos = self._T.luckySevenTargetPos
		        if not isvalid(target) and fallbackPos == nil then
		            log("[LuckySeven] 대상 없음 - 표창 스킵 idx=" .. tostring(idx))
		            return
		        end
		        local parent = self.Entity.CurrentMap
		        if not isvalid(parent) then return end

		        self._T.luckySevenProjCount = (self._T.luckySevenProjCount or 0) + 1
		        local name = "luckyseven_proj_" .. tostring(self._T.luckySevenProjCount)
		        local pos = self.Entity.TransformComponent.WorldPosition
		        local spawnPos = Vector3(pos.x, pos.y + 0.4, pos.z)
		        local proj = _SpawnService:SpawnByModelId("luckysevenprojectile", name, spawnPos, parent)
		        if not isvalid(proj) then
		            log_warning("[LuckySeven] 표창 스폰 실패 idx=" .. tostring(idx))
		            return
		        end

		        ---@type LuckySevenProjectile
		        local pc = proj:GetComponent("script.LuckySevenProjectile")
		        if pc == nil then return end
		        pc.CombatPower = self._T.pendingLuckySevenCombatPower or 0
		        pc.CritRate = self._T.currentCritRatePercent or 50
		        pc.HitIndex = idx
		        -- 쉐도우 파트너 활성 여부를 원본 표창에 새겨둔다 - 히트 시 원본+보너스(타수 2배) 합산과
		        -- 데미지 숫자 2줄 표시, 그리고 히트 이펙트 시간차 2배 재생에 쓰인다.
		        pc.ShadowEchoOn = self._T.shadowPartnerActive == true
		        -- 지금 적용 중인 데미지 스킨(블리자드 중이면 얼음 스킨)을 표창에 새겨준다 - 수동 표시에 쓰인다.
		        pc.DamageSkinRUID = self:GetHitDamageSkinId()
		        pc:Fire(target, fallbackPos)
		        local targetLabel = isvalid(target) and target.Name or "(대상 소멸, 마지막 위치로 발사)"
		        log("[LuckySeven] 표창 발사 idx=" .. tostring(idx) .. " target=" .. tostring(targetLabel))

		        -- 쉐도우 파트너: 그림자 몫의 표창은 "시각 전용"이다(그림자 스킬 이펙트는 몬스터에게 직접적인
		        -- 데미지를 주지 않는다는 요청). 타수 2배는 원본 표창의 히트 하나에 원본+보너스를 합산하고
		        -- 2줄로 나눠 표시하는 방식(LuckySevenProjectileAttack.CalcDamage + ShowDamageSkin)으로
		        -- 처리하고, 이 표창은 x축 뒤쪽에서 투명도 70%로 원본을 따라 날아가는 연출만 담당한다.
		        if self._T.shadowPartnerActive then
		            self._T.shadowEchoProjCount = (self._T.shadowEchoProjCount or 0) + 1
		            local echoName = "shadowecho_lucky_" .. tostring(self._T.shadowEchoProjCount)
		            local echoDirX = self._T.pendingLuckySevenDirX or 1
		            local echoPos = Vector3(spawnPos.x - 0.45 * echoDirX, spawnPos.y, spawnPos.z)
		            local echoProj = _SpawnService:SpawnByModelId("luckysevenprojectile", echoName, echoPos, parent)
		            if isvalid(echoProj) then
		                ---@type LuckySevenProjectile
		                local echoComp = echoProj:GetComponent("script.LuckySevenProjectile")
		                if isvalid(echoComp) then
		                    echoComp.VisualOnly = true
		                    echoComp:Fire(target, fallbackPos)
		                end
		            end
		        end
	end

	@ExecSpace("ServerOnly")
	method Entity FindLuckySevenTarget(Vector2 fromPos, number dirX)
		local map = self.Entity.CurrentMap
		if not isvalid(map) then return nil end
		local monsterComps = map:GetChildComponentsByTypeName("script.Monster", true)
		local nearest = nil
		local nearestDist = 8.0
		for _, comp in ipairs(monsterComps) do
			---@type Monster
			local mc = comp
			if isvalid(mc) and isvalid(mc.Entity) and not mc.IsDead then
				local pos = mc.Entity.TransformComponent.WorldPosition
				local dx = pos.x - fromPos.x
				local dy = pos.y - fromPos.y
				if dx * dirX >= 0 and math.abs(dx) <= 8.0 and math.abs(dy) <= 1.0 then
					local dist = math.abs(dx)
					if dist <= nearestDist then
						nearest = mc.Entity
						nearestDist = dist
					end
				end
			end
		end
		return nearest
	end

	method table GetLuckySevenSwing()
		-- 사용자가 실제 화면으로 확인해 확정: swingO1/O2/O3(한손무기 계열)이 아대 모션으로 맞다.
		-- 존재하는 순서대로 1~3번 번호를 매겨 매 시전마다 순차적으로(랜덤 아님) 순환 재생한다.
		local candidates = {
			{ name = "swingO1" },
			{ name = "swingO2" },
			{ name = "swingO3" },
		}
		self._T.luckySevenSwingIndex = (self._T.luckySevenSwingIndex or 0) % #candidates + 1
		return candidates[self._T.luckySevenSwingIndex]
	end

	@ExecSpace("Multicast")
	method void PlayLuckySevenStartEffect(Entity attacker, number dirX)
		        -- 스킬 사용과 동시에 캐릭터 앞에서 발현되는 시작 이펙트 (skill/400.img/skill/4001344의 "effect" 노드)
		        if not self:IsClient() then return end
		        if not isvalid(attacker) then return end
		        local startEffectRUID = "0ae88fa494e743158da6ddb81c0c55f2"
		        local startOptions = { ["FlipX"] = dirX > 0 }
		        -- 이펙트 자체 아트의 피벗이 바깥쪽으로 치우쳐 있어 몸에서 멀어 보이던 것을 몸통 높이로 당김
		        -- (0.3은 너무 높다는 피드백으로 0.12로 낮춤)
		        _EffectService:PlayEffectAttached(startEffectRUID, attacker, Vector3(0, 0.12, 0), 0, Vector3(1, 1, 1), false, startOptions)
		        -- 쉐도우 파트너: 같은 시작 이펙트를 x축 뒤쪽에서 투명도 70%로 복제 재생(그림자 몫 - 데미지 없음)
		        self:EchoShadowSkillEffectAttached(startEffectRUID, attacker, Vector3(0, 0.12, 0), 0, Vector3(1, 1, 1), startOptions, dirX)
		        log("[LuckySeven] 시작 이펙트 재생")
	end

	@ExecSpace("Multicast")
	method void PlayLuckySevenUseSound(Entity attacker)
		        -- 스킬 사용 즉시 재생되는 사운드 (같은 리소스팩의 "_audio/Use")
		        if not self:IsClient() then return end
		        if not isvalid(attacker) then return end
		        _SoundService:PlaySound("879c81c8fc274aea87dc673de48ab5d1", 1.0)
	end

	@ExecSpace("Multicast")
	method void PlayLuckySevenMotion(Entity attacker, string motionName, number dirX, number atkMultiplier)
		        -- 럭키세븐 전용 모션 재생. 파워스트라이크/슬래쉬블래스트와 동일한 후보군(GetPowerStrikeSwing)에서
		        -- 고른 모션을 그대로 재생한다 - 표창 투척 전용 모션이 엔진에 없어 기존 스윙 모션을 재사용하는 단순화.
		        if not self:IsClient() then return end
		        if not isvalid(attacker) then return end
		        local avatarRenderer = attacker.AvatarRendererComponent
		        if not isvalid(avatarRenderer) then return end
		        local body = avatarRenderer:GetBodyEntity()
		        if not isvalid(body) then return end

		        local playerCtrl = attacker.PlayerControllerComponent
		        if isvalid(attacker.MovementComponent) then
		            attacker.MovementComponent:Stop()
		        end
		        if isvalid(playerCtrl) then
		            playerCtrl.LookDirectionX = dirX
		        end
		        self._T.isLuckySevenDirectionLocked = true
		        self._T.lockedLuckySevenDirX = dirX
		        self._T.lockedLuckySevenMotionName = motionName
		        self._T.isLuckySevenMotionPlaying = true

		        local mult = math.max(atkMultiplier or 1.0, 0.001)
		        local playRate = 1.0 / mult
		        self._T.lockedLuckySevenPlayRate = playRate

		        local motionEvent = ActionStateChangedEvent(motionName, motionName, playRate, SpriteAnimClipPlayType.Onetime)
		        body:SendEvent(motionEvent)
		        log("[LuckySeven] PlayLuckySevenMotion sent: " .. tostring(motionName) .. " playRate=" .. tostring(playRate))

		        _TimerService:SetTimerOnce(function()
		            self._T.isLuckySevenMotionPlaying = false
		        end, 0.25 * mult)

		        _TimerService:SetTimerOnce(function()
		            self._T.isLuckySevenDirectionLocked = false
		            local sc = self.Entity.StateComponent
		            if isvalid(sc) and sc.CurrentStateName ~= "DEAD" then
		                sc:ChangeState("IDLE")
		                sc:ChangeState("MOVE")
		                sc:ChangeState("IDLE")
		            end
		        end, 0.80 * mult)
	end

	@ExecSpace("ServerOnly")
	method table FindSlashBlastTargets(Vector2 fromPos, number dirX, integer maxCount, number forwardRange, number verticalRange)
		        -- 슬래쉬블래스트 대상 선정: 전방 판정 범위(가로 2칸, 세로 1칸) 안의 살아있는 script.Monster를
		        -- 가까운 순으로 정렬해 최대 maxCount명까지 후보로 반환한다 (실제 Attack 판정 없이 위치만으로 탐색).
		        -- 스피어 버스터도 이 탐색을 그대로 재사용하지만 사거리가 달라야 하므로, forwardRange/verticalRange를
		        -- 선택 인자로 받는다 - 생략(nil)하면 기존 슬래쉬블래스트 기본값(2.0/1.0)을 그대로 쓴다.
		        forwardRange = forwardRange or 2.0
		        verticalRange = verticalRange or 1.0
		        local map = self.Entity.CurrentMap
		        if not isvalid(map) then return {} end
		        local monsterComps = map:GetChildComponentsByTypeName("script.Monster", true)
		        local candidates = {}
		        for _, comp in ipairs(monsterComps) do
		            ---@type Monster
		            local mc = comp
		            if isvalid(mc) and isvalid(mc.Entity) and not mc.IsDead then
		                local pos = mc.Entity.TransformComponent.WorldPosition
		                local dx = pos.x - fromPos.x
		                local dy = pos.y - fromPos.y
		                if dx * dirX >= 0 and math.abs(dx) <= forwardRange and math.abs(dy) <= verticalRange then
		                    table.insert(candidates, { entity = mc.Entity, dist = math.abs(dx) })
		                end
		            end
		        end
		        table.sort(candidates, function(a, b) return a.dist < b.dist end)
		        local result = {}
		        for i = 1, math.min(#candidates, maxCount) do
		            table.insert(result, candidates[i].entity)
		        end
		        return result
	end

	@ExecSpace("Multicast")
	method void PlaySlashBlastStartEffect(Entity attacker, number dirX)
		        -- 스킬 사용과 동시에 플레이어 몸쪽에서 발현되는 시작 이펙트 (skill/1100.img/skill/11001003 리소스팩의 "effect" 노드)
		        if not self:IsClient() then return end
		        if not isvalid(attacker) then return end
		        local startEffectRUID = "44c1d14578e24c639e480f54b156a8a2"
		        local startOptions = { ["FlipX"] = dirX > 0 }
		        _EffectService:PlayEffectAttached(startEffectRUID, attacker, Vector3(0, 0, 0), 0, Vector3(1, 1, 1), false, startOptions)
		        -- 쉐도우 파트너: 같은 시작 이펙트를 x축 뒤쪽에서 투명도 70%로 복제 재생(그림자 몫 - 데미지 없음)
		        self:EchoShadowSkillEffectAttached(startEffectRUID, attacker, Vector3(0, 0, 0), 0, Vector3(1, 1, 1), startOptions, dirX)
		        log("[SlashBlast] 시작 이펙트 재생")
	end

	@ExecSpace("Multicast")
	method void PlaySlashBlastHitEffect(Entity target, boolean isFinal)
		        -- hit 시 몬스터 몸에서 3종류 중 하나가 랜덤으로 발현 (같은 리소스팩의 hit/0, hit/1, hit/2)
		        if not self:IsClient() then return end
		        if not isvalid(target) then return end
		        -- (기능 변경) "파이널어택이 뜰 때 원래 히트 이펙트를 대체해서 파이널어택 히트 이펙트만 떠야
		        -- 한다"는 요청 - isFinal이면 이 기본 히트 이펙트(3종 랜덤)를 재생하지 않는다. 호출부
		        -- (DealNextSlashBlastFinalHit)가 곧이어 PlayFinalAttackHitEffect로 전용 이펙트를 대신 띄운다.
		        if not isFinal then
		            local hitEffects = {
		                "41e13add2ba746d9bbe624a31205a848",
		                "880e540095704e30af6a554d51b8a3b3",
		                "eed46092f65940a7a8e77a1bd8e2aa75",
		            }
		            local index = _UtilLogic:RandomIntegerRange(1, #hitEffects)
		            _EffectService:PlayEffectAttached(hitEffects[index], target, Vector3(0, 0, 0), 0, Vector3(1, 1, 1), false, {})
		            -- 쉐도우 파트너: 같은 히트 이펙트를 0.25초 시간차를 두고 그 자리에 한 번 더(70% 투명도) 재생
		            self:EchoShadowHitEffect(hitEffects[index], target, Vector3(0, 0, 0), 0, Vector3(1, 1, 1), {})
		        end
		        -- 슬래쉬블래스트로 몬스터가 데미지를 받는 순간마다(대상 무관) 지정된 사운드를 1회 재생한다.
		        _SoundService:PlaySound("0f213b255ab34a0e8ed258c89f3b62fe", 1.0)
	end

	@ExecSpace("Multicast")
	method void PlaySlashBlastMotion(Entity attacker, string motionName, number dirX, number atkMultiplier)
		        -- 슬래쉬블래스트 전용 모션 재생. 파워스트라이크와 같은 방식(ActionStateChangedEvent 직접 전송)으로 동작하되,
		        -- 기본 무기 스윙 이펙트(ShowDefaultWeaponEffects)는 끄지 않는다 - 별도의 스윙 궤적 이펙트가 없고
		        -- 기본 공격의 스윙 이펙트를 그대로 사용하기 때문이다 (파워스트라이크와의 유일한 차이점).
		        if not self:IsClient() then return end
		        if not isvalid(attacker) then return end
		        local avatarRenderer = attacker.AvatarRendererComponent
		        if not isvalid(avatarRenderer) then return end
		        local body = avatarRenderer:GetBodyEntity()
		        if not isvalid(body) then return end
		
		        local playerCtrl = attacker.PlayerControllerComponent
		        if isvalid(attacker.MovementComponent) then
		            attacker.MovementComponent:Stop()
		        end
		        if isvalid(playerCtrl) then
		            playerCtrl.LookDirectionX = dirX
		        end
		        self._T.isSlashDirectionLocked = true
		        self._T.lockedSlashDirX = dirX
		        self._T.lockedSlashMotionName = motionName
		        self._T.isSlashMotionPlaying = true
		
		        -- 파워스트라이크(PlayAttackMotion)와 동일하게, 공격속도 배율이 짧을수록(빠를수록) 모션 재생속도(PlayRate)를
		        -- 그만큼 올려서 화면 재생 시간이 아래 타이머들(0.25/0.80초 * mult)과 어긋나지 않게 맞춘다.
		        local mult = math.max(atkMultiplier or 1.0, 0.001)
		        local playRate = 1.0 / mult
		        self._T.lockedSlashPlayRate = playRate
		
		        local motionEvent = ActionStateChangedEvent(motionName, motionName, playRate, SpriteAnimClipPlayType.Onetime)
		        body:SendEvent(motionEvent)
		        log("[SlashBlast] PlaySlashBlastMotion sent: " .. tostring(motionName) .. " playRate=" .. tostring(playRate))
		
		        -- 서버 RestoreSlashBlastControl과 동일한 길이(0.65초*mult + 0.15초 여유)로 잠금을 해제한다.
		        -- 대상 수와 무관하다 - 타격이 여러 명에게 퍼져나가는 것은 이 잠금과 별개로 계속 진행된다.
		        _TimerService:SetTimerOnce(function()
		            self._T.isSlashMotionPlaying = false
		        end, 0.25 * mult)
		
		        _TimerService:SetTimerOnce(function()
		            self._T.isSlashDirectionLocked = false
		            local sc = self.Entity.StateComponent
		            if isvalid(sc) and sc.CurrentStateName ~= "DEAD" then
		                sc:ChangeState("IDLE")
		                sc:ChangeState("MOVE")
		                sc:ChangeState("IDLE")
		            end
		        end, 0.80 * mult)
	end

	@ExecSpace("Server")
	method void NotifyMotionEnded()
		        -- AttackPowerStrike에서 예약한 고정 딜레이(0.25초) 타이머로 호출된다. 타격 판정/이펙트 재생만 여기서 처리한다.
		        -- (컨트롤러 잠금 해제와 재시전 허용은 RestoreControl에서 별도의 더 긴 딜레이로 처리한다.)
		        if self._T.motionEndHandled then return end
		        self._T.motionEndHandled = true
		
		        if not isvalid(self.Entity) then return end
		        local dirX = self._T.pendingDirX or 1
		        local swing = self._T.pendingSwing or { ruid = "", name = "?" }
		        local curWorldPos = self.Entity.TransformComponent.WorldPosition
		        -- 공격범위 x축 전방으로 2배 확장 (기존 1칸 → 2칸). y축은 아래쪽으로 더 길게 - 기존 상단 경계(y+1.0)는 유지하고 하단을 y-1.0까지 확장한다.
		        -- (기능 변경) 여러 차례 조정을 거쳐 "사거리를 2.5로 줄여달라"는 요청으로 원방 경계(사거리)를
		        -- 2.5로 고정한다. 근접 경계는 계속 캐릭터 바로 앞(0)에 붙어있어야 하므로 오프셋=박스 x폭의
		        -- 절반=1.25로 맞춘다.
		        local forwardReach = 2.5
		        -- (요청) 아래쪽 판정 범위 축소 - 위 1.0 / 아래 0.5로 비대칭. 박스는 대칭 도형이라
		        -- 높이를 1.5로 줄이고 중심을 위로 0.25만큼 올려서 같은 결과를 만든다.
		        local upHalf, downHalf = 1.0, 0.5
		        local attackOffset = Vector2(
		            curWorldPos.x + (forwardReach / 2) * dirX,
		            curWorldPos.y + (upHalf - downHalf) / 2
		        )
		        self._T.shape = BoxShape(attackOffset, Vector2(forwardReach, upHalf + downHalf), 0)
		        -- (버그 수정) "히트박스가 네모가 아닌 것 같다" 신고 - 대상 선정을 실제 판정 직전인 여기서,
		        -- 위와 완전히 동일한 전방 사각형 모양(x폭 forwardReach, y폭 2)으로 다시 고른다. 이제 "박스
		        -- 안에서 가장 가까운 대상"과 "실제로 맞는 대상"이 항상 같은 도형 기준이라 예측 가능한 사각형
		        -- 히트박스처럼 동작한다.
		        -- (요청) 캐릭터와 가까운 적부터 고른다. 차지 블로우는 가까운 순 최대 3명, 그 외에는 가장 가까운 1명.
		        -- 엔진이 IsAttackTarget에 넘겨주는 순서는 거리순이 아니라, 여기서 미리 정렬해 대상을 확정해둔다.
		        local cbMaxTargets = 1
		        if (self._T.chargeBlowMode or 0) > 0 then cbMaxTargets = 3 end
		        local nearestList = self:FindNearestMonstersInForwardBox(Vector2(curWorldPos.x, curWorldPos.y), dirX, forwardReach, upHalf, downHalf, cbMaxTargets)
		        self._T.powerStrikeTarget = nearestList[1]
		        self._T.chargeBlowTargetList = nearestList
		        -- 차지 블로우(전기)에서 빙결 대상에게 2배가 들어간 경우를 CalcDamageBase가 여기에 담는다.
		        self._T.chargeBlowShockHits = {}
		        -- 차지 블로우 다중 대상(최대 3명) 카운터를 이번 판정 기준으로 초기화한다.
		        self._T.chargeBlowHitSet = {}
		        self._T.chargeBlowHitCount = 0
		        local hitComps = self:AttackShadowSafe(self._T.shape, "skill.powerstrike", self._T.powerStrikeTarget)
		        local targets = {}
		        for _, hc in ipairs(hitComps) do
		            if isvalid(hc) and isvalid(hc.Entity) then
		                table.insert(targets, hc.Entity)
		            end
		        end
		
		        -- 차지 블로우 속성 궤적: 원래 궤적(클립/스프라이트) 대신 속성 전용 4프레임 아트로 대체한다.
		        local trailClipRuid = swing.ruid
		        local cbFrames = self:GetChargeBlowTrailFrames(self._T.chargeBlowMode or 0, swing.name)
		        if cbFrames ~= nil then
		            -- (요청) 차지 블로우는 파워스트라이크의 이미지 이펙트를 일절 가져오지 않는다 - 스윙 궤적
		            -- 클립도, 몬스터 뒤쪽 후방 히트 이펙트(파워 스트라이크 팩 dad03b3a)도 재생하지 않고
		            -- 속성 궤적만 띄운다. 타격 사운드는 이미지가 아니므로 그대로 유지한다.
		            local cbRow = self:GetChargeBlowTrailRow(swing.name)
		            self:SpawnChargeBlowTrailFrames(cbFrames, dirX, 0.75, 0.35, 1.0, self:IsChargeBlowTrailMirrored(self._T.chargeBlowMode or 0, cbRow), self:IsChargeBlowTrailFlippedY(swing.name), self:GetChargeBlowTrailScaleY(swing.name))
		            self:PlayChargeBlowHitSound(#targets)
		            self:ResolveChargeBlowHits(targets)
		            log("PlayerAttack: AttackChargeBlow dir=" .. tostring(dirX) .. " mode=" .. tostring(self._T.chargeBlowMode) .. " motion=" .. tostring(swing.name) .. " row=" .. tostring(cbRow) .. " targets=" .. tostring(#targets))
		            return
		        end
		        -- 단일 스프라이트 궤적(isSprite)은 클립 재생 경로 대신 전용 표시(SpawnSkillTrailSprite)로 띄운다.
		        if swing.isSprite == true then
		            self:SpawnSkillTrailSprite(swing.ruid, dirX, swing.trailOffsetX or 0.75, swing.trailOffsetY or 0.35, swing.trailScale or 1.0)
		            trailClipRuid = ""
		        end
		        self:PlayPowerStrikeEffects(self.Entity, dirX, targets, trailClipRuid, swing.name, false)
		        log("PlayerAttack: AttackPowerStrike dir=" .. tostring(dirX) .. " targets=" .. tostring(#targets))
	end

	method table GetPowerStrikeSwing(string weaponClass)
		        -- 파워스트라이크/슬래쉬블래스트 전용 모션/이펙트 후보 - 매 시전마다 하나를 무작위로 골라
		        -- 캐릭터 모션과 스윙 이펙트를 함께 통일한다. (요청) 무기 분류별로 후보가 다르다:
		        --   "spear"  (창/폴암)  : swingT2, stabT1, stabT2, swingP1, swingP2
		        --   "twohand"(두손검)   : swingT1, swingT2, swingT3
		        --   "onehand"(한손검)   : swingO1, swingO2, swingO3
		        -- 궤적 이펙트 RUID가 미확보인 모션은 빈 문자열 - PlayPowerStrikeEffects가 빈 RUID를
		        -- 건너뛰므로 모션만 재생되고 궤적 이펙트는 생략된다.
		        -- 궤적 이펙트는 파워 스트라이크 팩(skill/800033.img/skill/80003316)의 afterimage에서 자세가
		        -- 일치하는 것을 매칭했다: 찌르기 모션(stabT*)엔 찌르기 궤적(stabO*/TL), 한손검 스윙(swingO*)엔
		        -- 짧은 검 잔상(swingT*/TS), 창 스윙(swingP*)엔 큰 스윙 궤적(swingT*/TL). 전용 궤적이 없는
		        -- 모션의 근사 매칭이므로 화면 확인 후 교체 가능.
		        local candidates
		        if weaponClass == "spear" then
		            -- (요청) 창은 길어서 찌르기(stab) 외 "위에서 내려찍는" 스윙 계열 모션의 궤적은 전부
		            -- e46fe5e9(swingTF/TL 큰 내려찍기 궤적) 하나만 쓴다. 찌르기는 새로 구해온 주황 스프라이트.
		            candidates = {
		                { name = "swingT2", ruid = "e46fe5e970f84e3f8f75ea914b2e3bf7" },
		                { name = "stabT1",  ruid = "6aa85073bc87433fbbca0f04a00732d6", isSprite = true, trailOffsetY = 0.25 },
		                { name = "stabT2",  ruid = "80a1909b6de14954851a49cfd371d791", isSprite = true, trailOffsetY = 0.25 },
		                { name = "swingP1", ruid = "e46fe5e970f84e3f8f75ea914b2e3bf7" },
		                { name = "swingP2", ruid = "e46fe5e970f84e3f8f75ea914b2e3bf7" },
		            }
		        elseif weaponClass == "onehand" then
		            -- (요청) 한손검은 궤적 이펙트를 쓰지 않는다(TS 잔상이 모션과 안 맞음) - 대신 PlayAttackMotion이
		            -- swingO 계열 모션 동안 엔진 기본 검격 이펙트(ShowDefaultWeaponEffects)를 끄지 않고 그대로 살려둔다.
		            candidates = {
		                { name = "swingO1", ruid = "" },
		                { name = "swingO2", ruid = "" },
		                { name = "swingO3", ruid = "" },
		            }
		        else
		            -- "twohand" 및 미지정(활/아대 등 기타 무기 포함) 기본값: 두손검 후보.
		            candidates = {
		                { name = "swingT1", ruid = "98d2124f4c2740758a7ed92fb5aa3af1" },
		                { name = "swingT2", ruid = "447033cc51594e20a25d15bfe2995d2e" },
		                { name = "swingT3", ruid = "64e8406faa78478dbaccde3db7f074d1" },
		            }
		        end
		        local index = _UtilLogic:RandomIntegerRange(1, #candidates)
		        return candidates[index]
	end

	method table GetSlashBlastSwing(string weaponClass)
		        -- (요청 변경) 슬래시블러스트의 모든 동작/궤적 이펙트는 파워스트라이크와 완전히 동일하게 쓴다.
		        return self:GetPowerStrikeSwing(weaponClass)
	end

	method table GetSlashBlastFinalMotion(string weaponClass, boolean wasStab)
		        -- (요청 변경) 슬래시블러스트 파이널어택도 파워스트라이크 파이널과 모션/궤적을 완전히 동일하게 쓴다.
		        return self:GetFinalAttackMotion(weaponClass, wasStab)
	end

	method table GetFinalAttackMotion(string weaponClass, boolean wasStab)
		        -- 파이널어택(2차 패시브) 전용 모션. (요청) 무기 분류별 후보:
		        --   "spear"  (창/폴암)  : swingPF, stabTF
		        --   "twohand"(두손검)   : swingTF, stabOF
		        --   "onehand"(한손검)   : swingOF, stabOF
		        -- "원본 스킬 동작이 찌르기였으면 파이널어택도 찌르기를 연속으로 하지 말아달라"는 기존 요청 유지 -
		        -- wasStab이면 각 분류의 swing 쪽 모션으로 고정한다. 궤적 이펙트 RUID 미확보 모션은 빈 문자열(이펙트 생략).
		        -- 전용 궤적이 없는 모션은 파워 스트라이크 팩 afterimage에서 자세가 일치하는 것으로 근사 매칭
		        -- (swingPF→swingTF/TL, stabTF→stabOF/TL 찌르기, swingOF→swingTF/TS 짧은 검, onehand stabOF→stabOF/TS).
		        if weaponClass == "spear" then
		            if wasStab then
		                return { name = "swingPF", ruid = "e46fe5e970f84e3f8f75ea914b2e3bf7" }
		            end
		            -- (요청) 창 파이널 stabTF 궤적은 새로 구해온 주황 이미지(단일 스프라이트)로 교체.
		            local candidates = {
		                { name = "swingPF", ruid = "e46fe5e970f84e3f8f75ea914b2e3bf7" },
		                { name = "stabTF",  ruid = "04b47e478b824131bcf2b02a93a75702", isSprite = true, trailOffsetY = 0.25 },
		            }
		            return candidates[_UtilLogic:RandomIntegerRange(1, #candidates)]
		        elseif weaponClass == "onehand" then
		            -- (버그 수정 3차/요청) 과거 "swingOF는 존재하지 않는 액션"이라던 실측은 엔진 공격 종료 리셋이
		            -- raw 파이널을 덮어쓰던 버그(워치독으로 해결)의 오판이었다 - 단독 raw 재생 재검증으로
		            -- swingOF가 정상 렌더링됨을 확인, 원래 사양대로 swingOF/stabOF 2종으로 복원한다.
		            if wasStab then
		                return { name = "swingOF", ruid = "" }
		            end
		            local oneHandCandidates = {
		                { name = "swingOF", ruid = "" },
		                { name = "stabOF",  ruid = "" },
		            }
		            return oneHandCandidates[_UtilLogic:RandomIntegerRange(1, #oneHandCandidates)]
		        end
		        -- "twohand" 및 미지정 기본값.
		        if wasStab then
		            return { name = "swingTF", ruid = "e46fe5e970f84e3f8f75ea914b2e3bf7" }
		        end
		        local candidates = {
		            { name = "swingTF", ruid = "e46fe5e970f84e3f8f75ea914b2e3bf7" },
		            { name = "stabOF",  ruid = "d0515d7c8aef446d98e553a7f7c02696" },
		        }
		        local index = _UtilLogic:RandomIntegerRange(1, #candidates)
		        return candidates[index]
	end

	method boolean HasFinalAttackTarget(Vector2 fromPos, number dirX)
		-- 파이널어택 발동 여부를 결정하는 "인지범위" 전용 탐색(FindSlashBlastTargets와 같은 모양의
		-- 전방 박스지만, 슬래쉬블래스트 본체 사거리와는 완전히 분리된 범위). 기존 판정 범위
		-- (dx<=2.0, dy<=1.0)에서 "인지범위를 1.2배 늘려달라"는 요청으로 dx<=2.4, dy<=1.2로 조정.
		local map = self.Entity.CurrentMap
		if not isvalid(map) then return false end
		local monsterComps = map:GetChildComponentsByTypeName("script.Monster", true)
		for _, comp in ipairs(monsterComps) do
			---@type Monster
			local mc = comp
			if isvalid(mc) and isvalid(mc.Entity) and not mc.IsDead then
				local pos = mc.Entity.TransformComponent.WorldPosition
				local dx = pos.x - fromPos.x
				local dy = pos.y - fromPos.y
				if dx * dirX >= 0 and math.abs(dx) <= 2.4 and math.abs(dy) <= 1.2 then
					return true
				end
			end
		end
		return false
	end

	@ExecSpace("ServerOnly")
	method void TryTriggerFinalAttack(string sourceSkill, number combatPower, number atkMultiplier, string weaponClass)
		        -- 파워스트라이크/슬래쉬블래스트 시전 시 60% 확률로, 그 스킬의 컨트롤 잠금이 풀리는 시점(RestoreControl/
		        -- RestoreSlashBlastControl)에 곧바로(동기 호출로) 이어서 같은 스킬을 "현재 캐릭터 공격속도 + 4단계"에
		        -- 해당하는 속도로 한번 더 실행하고(전용 모션은 창/비창 구분), 데미지에 15%~30% 추가 배율을 얹는다
		        -- (CalcDamage의 ".final" 분기가 처리). 호출부(RestoreControl류)가 이미 딜레이가 다 지난 시점에서
		        -- 직접 호출하므로 여기서 별도 타이머로 다시 감쌀 필요가 없다 - 별도 타이머로 감싸면 RestoreControl
		        -- 타이머와 실행 순서가 보장되지 않아(같은 프레임에 만료되는 두 타이머의 큐 순서 의존) 컨트롤이
		        -- 먼저 풀렸다가 파이널어택이 나중에 다시 잠그는 순서가 뒤집힐 경우 그 사이에 다른 행동이 가능해지는
		        -- 레이스 컨디션이 있었다.
		        -- CharInfoManager.GetAttackSpeedMultiplier()의 공식(0.9^(단계-5), 1단계 오를 때마다 이전 대비 10%씩 단축·복리)과
		        -- 동일하게, 현재 배율(atkMultiplier)에 0.9^4를 곱해 "현재 단계+4단계"의 배율을 구한다.
		        -- (기능 변경) "파이널어택 발동확률을 60%로 바꿔달라"는 요청으로 30%->60% 상향.
		        if math.random() >= 0.6 then return end
		        -- (기능 추가) "맞을 타겟이 없으면 파이널어택이 발동하지 않게 해달라"는 요청 - 확률은
		        -- 통과했더라도 실제로 때릴 대상이 근처에 없으면(헛스윙) 모션/잠금/쿨다운 등 아무 부수효과도
		        -- 일으키지 않고 조용히 취소한다.
		        -- (버그 수정) 처음엔 파워스트라이크 쪽에 전방향(방향 무관) 근접 탐색인 FindNearestMonster를
		        -- 썼는데, 실제 파이널어택 판정(NotifyFinalMotionEnded)은 캐릭터가 "바라보는 방향"으로만
		        -- 박스가 나가는 전방 판정이라 - 대상이 등 뒤에 있어도 FindNearestMonster는 찾아버려서
		        -- 실제로는 헛스윙인데도 발동해버리는 문제가 실측 확인됐다. 파워스트라이크/슬래쉬블래스트
		        -- 둘 다 방향까지 고려하는 FindSlashBlastTargets(전방 박스 탐색)로 통일한다.
		        -- (기능 변경) "파이널어택의 인지범위(맞을 대상이 있는지 확인하는 범위)를 1.2배 늘려달라"는
		        -- 요청 - 예전에는 슬래쉬블래스트 실제 타격에 쓰이는 FindSlashBlastTargets를 그대로
		        -- 재사용했는데, 이제 전용 메서드(HasFinalAttackTarget)로 분리해 슬래쉬블래스트 본체
		        -- 사거리는 건드리지 않고 이 인지범위만 독립적으로 늘릴 수 있게 한다.
		        local worldPos = self.Entity.TransformComponent.WorldPosition
		        local dirX = (sourceSkill == "powerstrike") and (self._T.pendingDirX or 1) or (self._T.pendingSlashDirX or 1)
		        local hasTarget = self:HasFinalAttackTarget(Vector2(worldPos.x, worldPos.y), dirX)
		        if not hasTarget then
		            log("PlayerAttack: TryTriggerFinalAttack 취소(타겟 없음) source=" .. sourceSkill)
		            return
		        end
		        local finalMult = atkMultiplier * (0.9 ^ 4)
		        local userId = self.Entity.PlayerComponent.UserId
		        -- 파이널어택은 서버가 자체적으로(클라이언트 입력 없이) 발동시키므로, 클라이언트의 스킬 공용 쿨다운은
		        -- 원본 스킬의 쿨다운(0.75*atkMultiplier)이 이미 끝났거나 거의 끝난 상태다 - 그대로 두면 파이널어택
		        -- 모션이 재생되는 동안에도 다른 스킬 키를 눌러 딜레이 없이 다른 스킬을 쏠 수 있는 문제가 있었다.
		        -- 여기서 클라이언트의 공용 쿨다운을 다시 걸어(원본 스킬과 동일한 0.75*배율 공식) 파이널어택 모션
		        -- 동안에도 다른 스킬을 쓸 수 없도록 막는다.
		        local lockDuration = 0.75 * finalMult
		        if weaponClass == "onehand" then
		            -- (버그 수정) 한손검 파이널은 본체 엔진 공격의 종료 리셋을 워치독이 복구하면서 모션이 재시작
		            -- 오프셋(~0.25초, 실시간 - 공격속도 배율과 무관)만큼 늦게 끝난다. 후딜(공용 쿨다운)이 모션보다
		            -- 짧으면 홀드 연사의 다음 시전이 파이널 모션 꼬리를 캔슬하므로, 오프셋보다 넉넉한 고정 여유를 더해
		            -- 후딜이 항상 모션보다 길게 만든다.
		            lockDuration = lockDuration + 0.35
		        end
		        _SkillManager:LockSkillUse(lockDuration, userId)
		        -- (기능 추가) "원본 스킬 동작이 찌르기였으면 파이널어택도 찌르기를 연속으로 하지 말아달라"는
		        -- 요청 - 방금 시전한 원본 스킬(파워스트라이크/슬래쉬블래스트)이 골랐던 모션 이름이 "stab"로
		        -- 시작하는지 확인해 GetFinalAttackMotion에 전달한다.
		        local wasStab = false
		        if sourceSkill == "powerstrike" then
		            wasStab = self._T.pendingSwing ~= nil and (self._T.pendingSwing.name or ""):sub(1, 4) == "stab"
		        else
		            wasStab = self._T.pendingSlashSwing ~= nil and (self._T.pendingSlashSwing.name or ""):sub(1, 4) == "stab"
		        end
		        if sourceSkill == "powerstrike" then
		            self:AttackPowerStrikeFinal(combatPower, finalMult, weaponClass, wasStab)
		        else
		            self:AttackSlashBlastFinal(combatPower, finalMult, weaponClass, wasStab)
		        end
	end

	@ExecSpace("ServerOnly")
	method void AttackPowerStrikeFinal(number combatPower, number atkMultiplier, string weaponClass, boolean wasStab)
		        -- (기능 추가) "다른 스킬을 쓰면 숨고르기 모션은 중지" 요청 - 이 스킬을 새로 시전하는 시점에 이전 숨고르기가 재생 중이었다면 즉시 정리한다.
		        self:StopBreather()
		        -- 파이널어택으로 발동되는 파워스트라이크 추가타. 원본 파워스트라이크와 동일한 단일 대상 판정 구조를
		        -- 쓰되, 대상/컨트롤 관련 상태는 전부 별도 필드로 분리해 원본 스킬과 서로 간섭하지 않게 한다.
		        -- 단, 재시전 게이트(isPowerStriking)만은 원본과 **공유**한다 - 홀드 입력 중 클라이언트의 공용
		        -- 쿨다운(skillOnCooldown) 재설정이 네트워크 지연으로 파이널어택 시작보다 늦게 도착하면, 그 사이
		        -- 홀드-반복이 새 파워스트라이크 요청을 보낼 수 있는데(서버 입장에선 정상 요청처럼 보임), 이 요청이
		        -- isPowerStriking을 공유하지 않으면 그대로 통과해 파이널어택과 겹쳐 별도로 스윙만 재생되고 대상은
		        -- 이미 죽었거나 다른 이유로 빗나가 "헛빵"이 나는 문제가 있었다. 공유 게이트로 막으면 서버가
		        -- 네트워크 지연과 무관하게 항상 이 요청을 거부한다.
		        local currentState = self.Entity.StateComponent.CurrentStateName
		        if currentState == "DEAD" or currentState == "CLIMB" or currentState == "LADDER" then
		            return
		        end
		        self._T.isPowerStriking = true

		        self._T.pendingFinalCombatPower = combatPower
		        local playerCtrl = self.Entity.PlayerControllerComponent
		        local dirX = playerCtrl.LookDirectionX
		        self._T.pendingFinalDirX = dirX
		        -- (버그 수정) "히트박스가 네모가 아니다"(파워스트라이크에서 실측된 것과 동일한 버그)가
		        -- 파이널어택에도 그대로 있었다 - 대상 선정을 시전 시점에 전방향(원형) FindNearestMonster로
		        -- 미리 골라뒀는데, 실제 판정(NotifyFinalMotionEnded)은 전방 사각 박스라 서로 도형이 달랐다.
		        -- 대상 선정을 실제 판정 시점으로 옮기고 그 박스와 동일한 모양으로 다시 고르도록 아래
		        -- NotifyFinalMotionEnded로 옮긴다(파워스트라이크와 동일한 해결 방식).

		        self._T.pendingFinalWasControllerEnabled = isvalid(playerCtrl) and playerCtrl.Enable
		        if isvalid(playerCtrl) then
		            playerCtrl.Enable = false
		        end
		        if isvalid(self.Entity.MovementComponent) then
		            self.Entity.MovementComponent:Stop()
		        end

		        self:PlaySkillUseSound(self.Entity)
		        -- (요청) 차지 블로우로 시작된 연계라면 파워스트라이크 팩의 시전 시작 이펙트를 쓰지 않는다.
		        if (self._T.chargeBlowMode or 0) <= 0 then
		            self:PlaySkillStartEffect(self.Entity, dirX)
		        end

		        local swing = self:GetFinalAttackMotion(weaponClass, wasStab)
		        self._T.pendingFinalSwing = swing
		        self:SetChargeBlowVisualMode(self._T.chargeBlowMode or 0)
		        self:PlayAttackMotion(self.Entity, swing.name, dirX, atkMultiplier)

		        _TimerService:SetTimerOnce(function()
		            self:NotifyFinalMotionEnded()
		        end, 0.45 * atkMultiplier)

		        _TimerService:SetTimerOnce(function()
		            self:RestoreFinalControl()
		        end, 0.65 * atkMultiplier)
	end

	@ExecSpace("Server")
	method void RestoreFinalControl()
		        self._T.isPowerStriking = false
		        local playerCtrl = self.Entity.PlayerControllerComponent
		        if isvalid(playerCtrl) and self._T.pendingFinalWasControllerEnabled then
		            playerCtrl.Enable = true
		        end
		        -- (기능 추가) "파이널 어택 모션까지 끝나면 숨고르기를 하게 해달라"는 요청 - 원래 스킬
		        -- (RestoreControl)에서는 파이널 어택이 발동한 경우 숨고르기를 건너뛰지만(파이널 어택
		        -- 모션을 가리지 않기 위해), 파이널 어택 자신의 모션이 끝나는 이 시점에는 정상적으로
		        -- 숨고르기를 시작한다.
		        self:PlayBreather(self.Entity, self._T.pendingFinalDirX or 1)
	end

	method void NotifyFinalMotionEnded()
		        if not isvalid(self.Entity) then return end
		        local dirX = self._T.pendingFinalDirX or 1
		        local swing = self._T.pendingFinalSwing or { ruid = "", name = "?" }
		        local curWorldPos = self.Entity.TransformComponent.WorldPosition
		        -- (기능 변경) "파이널어택일 때 사거리를 1.5배 늘려달라"는 요청 - 기존 전방 사거리(오프셋 1.0+
		        -- 박스 반폭 1.0 = 2.0)를 1.5배 한 3.0으로 늘린다. 근접 경계는 캐릭터 바로 앞(0)에 그대로
		        -- 붙어있어야 하므로 오프셋=박스 x폭의 절반=1.5로 맞춘다(y축은 요청 범위 밖이라 그대로 둔다).
		        local finalForwardReach = 3.0
		        -- 본체와 동일하게 아래쪽 판정 범위를 줄인다(위 1.0 / 아래 0.5).
		        local upHalf, downHalf = 1.0, 0.5
		        local attackOffset = Vector2(
		            curWorldPos.x + (finalForwardReach / 2) * dirX,
		            curWorldPos.y + (upHalf - downHalf) / 2
		        )
		        local shape = BoxShape(attackOffset, Vector2(finalForwardReach, upHalf + downHalf), 0)
		        -- (버그 수정) 대상 선정을 위 박스와 완전히 동일한 모양(전방 사각형)으로 실제 판정 시점에
		        -- 다시 고른다(파워스트라이크 본체와 동일한 해결 방식 - AttackPowerStrikeFinal 주석 참고).
		        -- 본체와 동일 - 가까운 순으로 고르고, 차지 블로우면 최대 3명까지 확정한다.
		        local cbFinalMax = 1
		        if (self._T.chargeBlowMode or 0) > 0 then cbFinalMax = 3 end
		        local finalNearest = self:FindNearestMonstersInForwardBox(Vector2(curWorldPos.x, curWorldPos.y), dirX, finalForwardReach, upHalf, downHalf, cbFinalMax)
		        self._T.powerStrikeFinalTarget = finalNearest[1]
		        self._T.chargeBlowTargetList = finalNearest
		        self._T.chargeBlowShockHits = {}
		        -- 차지 블로우 다중 대상(최대 3명) 카운터를 이번 판정 기준으로 초기화한다.
		        self._T.chargeBlowHitSet = {}
		        self._T.chargeBlowHitCount = 0
		        local hitComps = self:AttackShadowSafe(shape, "skill.powerstrike.final", self._T.powerStrikeFinalTarget)
		        local targets = {}
		        for _, hc in ipairs(hitComps) do
		            if isvalid(hc) and isvalid(hc.Entity) then
		                table.insert(targets, hc.Entity)
		            end
		        end
		        -- 차지 블로우 속성 궤적: 본체와 같은 속성으로 파이널어택 궤적도 대체한다
		        -- (chargeBlowMode는 다음 일반 파워스트라이크 전까지 유지된다).
		        local finalTrailClipRuid = swing.ruid
		        local cbFinalFrames = self:GetChargeBlowTrailFrames(self._T.chargeBlowMode or 0, swing.name)
		        if cbFinalFrames ~= nil then
		            -- 본체와 동일 - 파워스트라이크/파이널어택 전용 히트 이펙트는 재생하지 않고 속성 궤적만 띄운다.
		            local cbFinalRow = self:GetChargeBlowTrailRow(swing.name)
		            self:SpawnChargeBlowTrailFrames(cbFinalFrames, dirX, 0.75, 0.35, 1.0, self:IsChargeBlowTrailMirrored(self._T.chargeBlowMode or 0, cbFinalRow), self:IsChargeBlowTrailFlippedY(swing.name), self:GetChargeBlowTrailScaleY(swing.name))
		            self:PlayChargeBlowHitSound(#targets)
		            self:ResolveChargeBlowHits(targets)
		            log("PlayerAttack: AttackChargeBlowFinal dir=" .. tostring(dirX) .. " mode=" .. tostring(self._T.chargeBlowMode) .. " motion=" .. tostring(swing.name) .. " row=" .. tostring(cbFinalRow) .. " targets=" .. tostring(#targets))
		            return
		        end
		        -- 단일 스프라이트 궤적(isSprite - 창 stabTF 등)은 클립 재생 경로 대신 전용 표시로 띄운다.
		        if swing.isSprite == true then
		            self:SpawnSkillTrailSprite(swing.ruid, dirX, swing.trailOffsetX or 0.75, swing.trailOffsetY or 0.35, swing.trailScale or 1.0)
		            finalTrailClipRuid = ""
		        end
		        self:PlayPowerStrikeEffects(self.Entity, dirX, targets, finalTrailClipRuid, swing.name, true)
		        for _, t in ipairs(targets) do
		            self:PlayFinalAttackHitEffect(t)
		        end
		        log("PlayerAttack: AttackPowerStrikeFinal dir=" .. tostring(dirX) .. " targets=" .. tostring(#targets))
	end

	@ExecSpace("ServerOnly")
	method void AttackSlashBlastFinal(number combatPower, number atkMultiplier, string weaponClass, boolean wasStab)
		        -- (기능 추가) "다른 스킬을 쓰면 숨고르기 모션은 중지" 요청 - 이 스킬을 새로 시전하는 시점에 이전 숨고르기가 재생 중이었다면 즉시 정리한다.
		        self:StopBreather()
		        -- 파이널어택으로 발동되는 슬래쉬블래스트 추가타. 원본과 동일한 다중 대상(최대 6명) 순차 타격 구조.
		        -- 재시전 게이트(isSlashBlasting)는 파워스트라이크와 동일한 이유로 원본과 공유한다 - 클라이언트
		        -- 공용 쿨다운 재설정(LockSkillUse)이 네트워크 지연으로 늦게 도착해 홀드-반복이 새 요청을 보내도
		        -- 서버가 이 공유 게이트로 항상 거부하게 하기 위함(안 그러면 별도로 스윙만 재생되고 대상은 이미
		        -- 죽었거나 빗나가 "헛빵"이 나는 문제가 있었다).
		        local currentState = self.Entity.StateComponent.CurrentStateName
		        if currentState == "DEAD" or currentState == "CLIMB" or currentState == "LADDER" then
		            return
		        end
		        self._T.isSlashBlasting = true

		        self._T.pendingFinalSlashCombatPower = combatPower
		        local playerCtrl = self.Entity.PlayerControllerComponent
		        local worldPos = self.Entity.TransformComponent.WorldPosition
		        local dirX = playerCtrl.LookDirectionX
		        self._T.pendingFinalSlashDirX = dirX

		        local targets = self:FindSlashBlastTargets(Vector2(worldPos.x, worldPos.y), dirX, 6, 2.0, 1.0)

		        self._T.pendingFinalSlashWasControllerEnabled = isvalid(playerCtrl) and playerCtrl.Enable
		        if isvalid(playerCtrl) then
		            playerCtrl.Enable = false
		        end
		        if isvalid(self.Entity.MovementComponent) then
		            self.Entity.MovementComponent:Stop()
		        end

		        -- (요청) 몸쪽 캐스트 이펙트(원본 4프레임 스파클) + 전용 사용 사운드.
		        self:SpawnSlashBlastCastEffect(dirX)
		        self:PlaySlashBlastUseSound(self.Entity)

		        -- (요청) 슬래시블러스트 파이널도 파워스트라이크 파이널과 완전 동일 - 모션 후보(GetSlashBlastFinalMotion
		        -- →GetFinalAttackMotion 위임)뿐 아니라 재생기도 PlayAttackMotion으로 통일한다(본체와 동일한 이유:
		        -- 기본 무기 이펙트 겹침 제거 + 시전 토큰 가드로 본체 IDLE 토글의 파이널 모션 덮어쓰기 방지).
		        local swing = self:GetSlashBlastFinalMotion(weaponClass, wasStab)
		        self:PlayAttackMotion(self.Entity, swing.name, dirX, atkMultiplier)

		        _TimerService:SetTimerOnce(function()
		            -- 첫 타격 시점에 궤적도 함께 표시한다 - 스프라이트/클립 모두 지원(파워스트라이크 파이널과 동일).
		            if swing.isSprite == true then
		                self:SpawnSkillTrailSprite(swing.ruid, dirX, swing.trailOffsetX or 0.75, swing.trailOffsetY or 0.35, swing.trailScale or 1.0)
		            else
		                self:PlaySwingTrailClip(self.Entity, swing.ruid, dirX)
		            end
		            self:DealNextSlashBlastFinalHit(targets, 1, atkMultiplier)
		        end, 0.45 * atkMultiplier)

		        _TimerService:SetTimerOnce(function()
		            self:RestoreSlashBlastFinalControl()
		        end, 0.65 * atkMultiplier)
	end

	@ExecSpace("Server")
	method void RestoreSlashBlastFinalControl()
		        self._T.isSlashBlasting = false
		        local playerCtrl = self.Entity.PlayerControllerComponent
		        if isvalid(playerCtrl) and self._T.pendingFinalSlashWasControllerEnabled then
		            playerCtrl.Enable = true
		        end
		        -- (기능 추가) "파이널 어택 모션까지 끝나면 숨고르기를 하게 해달라"는 요청 - 파워스트라이크와
		        -- 동일한 이유로, 파이널 어택 자신의 모션이 끝나는 이 시점에는 정상적으로 숨고르기를 시작한다.
		        self:PlayBreather(self.Entity, self._T.pendingFinalSlashDirX or 1)
	end

	@ExecSpace("Server")
	method void DealNextSlashBlastFinalHit(table targets, integer idx, number atkMultiplier)
		        if idx > #targets then return end
		        if not isvalid(self.Entity) then return end

		        local target = targets[idx]
		        if isvalid(target) then
		            self._T.slashBlastFinalCurrentTarget = target
		            local dirX = self._T.pendingFinalSlashDirX or 1
		            local curWorldPos = self.Entity.TransformComponent.WorldPosition
		            local attackOffset = Vector2(
		                curWorldPos.x + 1.0 * dirX,
		                curWorldPos.y
		            )
		            local shape = BoxShape(attackOffset, Vector2(2, 2), 0)
		            local hitComps = self:AttackShadowSafe(shape, "skill.slashblast.final", self._T.slashBlastFinalCurrentTarget)
		            local actuallyHit = false
		            for _, hc in ipairs(hitComps) do
		                if isvalid(hc) and isvalid(hc.Entity) and hc.Entity == target then
		                    actuallyHit = true
		                    break
		                end
		            end
		            if actuallyHit then
		                self:PlaySlashBlastHitEffect(target, true)
		                self:PlayFinalAttackHitEffect(target)
		            end
		            log("PlayerAttack: AttackSlashBlastFinal hit " .. tostring(idx) .. "/" .. tostring(#targets) .. " actuallyHit=" .. tostring(actuallyHit))
		        end

		        if idx < #targets then
		            -- (요청) 데미지가 퍼져 나가는 속도 1.5배 - 본체와 동일하게 간격 0.1초 → 0.1/1.5초.
		            _TimerService:SetTimerOnce(function()
		                self:DealNextSlashBlastFinalHit(targets, idx + 1, atkMultiplier)
		            end, 0.1 / 1.5)
		        end
	end

	@ExecSpace("Multicast")
	method void PlayFinalAttackHitEffect(Entity target)
		        -- 파이널어택 추가타에 맞은 몬스터 머리 위에 재생되는 전용 이펙트.
		        if not self:IsClient() then return end
		        if not isvalid(target) then return end
		        local headY = 0.5
		        local hit = target.HitComponent
		        if isvalid(hit) then
		            headY = hit.ColliderOffset.y + hit.BoxSize.y / 2
		        end
		        local serial = _EffectService:PlayEffectAttached("c36e70d7b1d84845bf4067d069ba5e1a", target, Vector3(0, headY, 0), 0, Vector3(1, 1, 1), false, {})
		        -- 쉐도우 파트너: 같은 히트 이펙트를 0.25초 시간차를 두고 그 자리에 한 번 더(70% 투명도) 재생
		        self:EchoShadowHitEffect("c36e70d7b1d84845bf4067d069ba5e1a", target, Vector3(0, headY, 0), 0, Vector3(1, 1, 1), {})
		        _TimerService:SetTimerOnce(function()
		            _EffectService:RemoveEffect(serial)
		        end, 1.0)
	end

	@ExecSpace("Multicast")
	method void PlaySkillUseSound(Entity attacker)
		        -- 파워스트라이크 사용 시 사운드 재생. Multicast는 서버 자신도 함께 실행하므로 클라이언트에서만 실행되게 막는다.
		        if not self:IsClient() then return end
		        if not isvalid(attacker) then return end
		        local hitSoundRUID = "e0178f48602742c0bd8b295fdc27261c"
		        _SoundService:PlaySound(hitSoundRUID, 1.0)
	end

	@ExecSpace("Multicast")
	method void PlaySlashBlastUseSound(Entity attacker)
		        -- (요청) 슬래시블러스트 전용 사용 사운드. PlaySkillUseSound와 동일 패턴(클라이언트에서만 재생).
		        -- 원본 팩 skill/100.img/skill/1001005(클래식 슬래시 블러스트)의 _audio/Use.
		        -- 처음엔 같은 팩의 _audio/Hit(타격음, ca35cb7d…)을 잘못 쓰고 있었다 - 스킬 라이브러리
		        -- 인덱스(msw-dev-tools/msw-library-index/)로 rel_path를 확인해 원본 사용음으로 교체.
		        if not self:IsClient() then return end
		        if not isvalid(attacker) then return end
		        _SoundService:PlaySound("afbb81b51fed47eaaee26cc403d59ccf", 1.0)
	end

	@ExecSpace("Multicast")
	method void SetChargeBlowVisualMode(integer chargeMode)
		-- 차지 블로우 여부를 클라이언트 쪽 연출 코드(PlayAttackMotion)에 알린다.
		-- self._T는 동기화되지 않는 서버 로컬 상태라, 서버가 정한 chargeBlowMode를 클라가 그대로 볼 수 없다 -
		-- 모션을 재생하기 직전에 이 Multicast를 한 번 보내 클라 쪽 사본을 맞춰둔다(같은 채널이라 순서 보장).
		-- 일반 파워스트라이크는 0을 보내 이전 시전의 값이 남지 않게 한다.
		if not self:IsClient() then return end
		self._T.chargeBlowVisual = chargeMode or 0
	end

	@ExecSpace("Multicast")
	method void PlayAttackMotion(Entity attacker, string motionName, number dirX, number atkMultiplier)
		        -- 파워스트라이크 전용 세부 모션(swingT1~TF, stabO1~OF)을 아바타 몸체에 직접 재생한다.
		        -- StateComponent:ChangeState("ATTACK")을 거치면 StateToAvatarBodyActionSheet의 기본 "attack" 클립이
		        -- 함께 재생을 시도해 이 이벤트와 경합하면서(레이스) 모든 시전이 같은 기본 자세로 보이는 문제가 있었다.
		        -- (animation-state.md 7절 "State change races animation" 패턴) 그래서 ATTACK 상태 전환 없이
		        -- ActionStateChangedEvent만으로 모션을 직접 재생해 7종 모션이 항상 구분되도록 한다.
		        -- Multicast는 서버 자신도 함께 실행하므로 클라이언트에서만 실행되게 막는다 (GetBodyEntity는 ClientOnly라 서버에서는 항상 실패한다).
		        if not self:IsClient() then return end
		        if not isvalid(attacker) then return end
		        local avatarRenderer = attacker.AvatarRendererComponent
		        if not isvalid(avatarRenderer) then return end
		        local body = avatarRenderer:GetBodyEntity()
		        if not isvalid(body) then return end

		        -- (버그 수정) 엔진 공격 종료 리셋 워치독 - body의 ActionStateChangedEvent를 도청해, 가드 창
		        -- (rawGuardUntil, 아래 raw 경로에서 설정) 안에 잠긴 모션이 아닌 액션(엔진의 stand1 리셋 등)이
		        -- 도착하는 즉시 잠긴 모션을 되받아쳐 재적용한다. 고정 타이머(0.18초) 재전송으로는 부족했다 -
		        -- 실측(이벤트 도청)에서 엔진 리셋이 재전송 0.02초 뒤에 도착해 또 덮어썼고, 리셋 도착 시점이
		        -- 엔진 공격 시작 시점에 따라 가변이라 고정 타이머로는 못 이겨 반응형으로 교체했다.
		        -- 자기가 보낸 동일 모션 이벤트는 무시하므로 무한루프는 없다. body가 재생성되면 다시 연결한다.
		        if self._T.watchdogBody ~= body then
		            self._T.watchdogBody = body
		            body:ConnectEvent(ActionStateChangedEvent, function(e)
		                local nowSec = _UtilLogic.ElapsedSeconds
		                -- ① 엔진 공격 가드 (연속 시전 보호): 공속이 빨라 쿨다운(0.75*mult)이 엔진 클립 길이(~0.87*mult)보다
		                -- 짧아지면, 이전 시전의 엔진 공격 종료 리셋이 다음 시전 시작 ~0.1초 뒤에 도착해 새 모션을 삼키는
		                -- 것이 이벤트 도청으로 실측됐다 - 가드 창 안의 침입 이벤트에는 엔진 공격을 다시 보낸다.
		                -- 엔진 공격 이벤트 자신이 만드는 모션 방출은 같은 틱(≤0.01초)에 도착하므로 0.03초 내만 무시한다 -
		                -- (실측) 이전 시전의 종료 리셋은 다음 시전 정확히 ~0.10초 뒤에 도착해, 무시 창을 0.1초로 잡으면
		                -- 침입자까지 무시해버려 가드가 무력화된다.
		                if self._T.engineGuardUntil ~= nil and nowSec <= self._T.engineGuardUntil then
		                    if self._T.lastEngineAttackAt ~= nil and (nowSec - self._T.lastEngineAttackAt) <= 0.03 then return end
		                    -- ⚠ SendEvent는 동기 디스패치라 이 핸들러가 그 호출 안에서 재진입한다 - 재전송 시각을
		                    -- 반드시 SendEvent **전에** 기록해야 재진입분이 위 무시 조건(0.03초)에 걸린다.
		                    -- 뒤에 기록하면 무한 재귀(FatalError: Too much recursion, 실측)로 클라이언트가 죽는다.
		                    self._T.lastEngineAttackAt = nowSec
		                    self._T.watchdogReappliedAt = nowSec
		                    local atkEvent = BodyActionStateChangeEvent()
		                    atkEvent.ActionState = MapleAvatarBodyActionState.Attack
		                    atkEvent.needResetAction = true
		                    -- 엔진 경로 전용 보정 배율(1.35)이 곱해진 재생속도를 그대로 사용한다(모션/판정 싱크 유지).
		                    atkEvent.playRate = self._T.lockedEnginePlayRate or self._T.lockedPlayRate or 1.0
		                    self.Entity:SendEvent(atkEvent)
		                    log("[PowerStrike] watchdog re-applied engine attack over " .. tostring(e.CoreActionName))
		                    return
		                end
		                -- ② raw 모션 가드 (파이널어택 보호)
		                if self._T.rawGuardUntil == nil then return end
		                if nowSec > self._T.rawGuardUntil then return end
		                local want = self._T.lockedMotionName
		                if want == nil or e.CoreActionName == want then return end
		                local ar2 = self.Entity.AvatarRendererComponent
		                if not isvalid(ar2) then return end
		                local b2 = ar2:GetBodyEntity()
		                if not isvalid(b2) then return end
		                b2:SendEvent(ActionStateChangedEvent(want, want, self._T.lockedPlayRate or 1.0, SpriteAnimClipPlayType.Onetime))
		                -- 재시작 시각 기록 - 언락 토글이 이 오프셋만큼 정리를 늦춰 재시작된 모션의 끝이 잘리지 않게 한다.
		                self._T.watchdogReappliedAt = nowSec
		                log("[PowerStrike] watchdog re-applied " .. tostring(want) .. " over " .. tostring(e.CoreActionName))
		            end)
		        end

		        -- 기본 무기 스윙 이펙트(ShowDefaultWeaponEffects)를 여기(클라이언트, 같은 Multicast 호출 안)에서 직접 끈다.
		        -- 서버에서 끄면 @Sync 전파 지연 때문에 모션 재생(아래 SendEvent)과 도착 순서가 보장되지 않아,
		        -- 파워스트라이크가 "attack" 계열 모션을 그대로 갖다 쓰면서 딸려오는 기본 스윙 이펙트가 한 프레임 섞여 보였다.
		        -- (요청 예외) 한손검 기본 모션(swingO1~O3)은 전용 궤적 이펙트가 없어, 기본공격(Ctrl)의 검격 이펙트를
		        -- 궤적 대용으로 그대로 살려둔다(엔진 기본 검격은 색상 제어 API가 없어 색만 못 맞춘다 - 원본 색 그대로).
		        -- (버그 수정) 파이널 swingOF까지 이 경로(엔진 공격 이벤트)로 빠지면서 swingOF 모션이 전혀 재생되지
		        -- 않았다 - 접두사 매칭 대신 정확히 swingO1/O2/O3만 엔진 경로를 타고, swingOF는 raw 이벤트로 재생한다.
		        -- (요청) 차지 블로우는 파워스트라이크의 이미지 이펙트를 하나도 가져오지 않는다 - 엔진 기본
		        -- 검격까지 끄고 속성 궤적만 보이게 한다. 그래서 한손검이어도 엔진 공격 파이프라인을 타지 않고
		        -- 아래 raw 경로로 재생한다(엔진이 무기 기준으로 모션을 고르지 않으므로 자세가 조금 달라질 수 있다).
		        -- 이 플래그는 1회용으로 소비한다 - PlayAttackMotion 호출부가 8곳(슬래시블러스트/브랜디쉬/러시 등)
		        -- 이나 되는데, 남아 있으면 차지 블로우 다음에 쓴 다른 스킬의 기본 검격까지 같이 꺼진다.
		        local cbVisual = self._T.chargeBlowVisual or 0
		        self._T.chargeBlowVisual = 0
		        local keepDefaultEffect = (motionName == "swingO1" or motionName == "swingO2" or motionName == "swingO3")
		            and cbVisual <= 0
		        if not keepDefaultEffect then
		            avatarRenderer.ShowDefaultWeaponEffects = false
		        end
		
		        -- 이동 중이던 잔여 이동을 클라이언트 화면에서도 즉시 멈추고(순서상 반드시 모션 전송보다 먼저),
		        -- 바라보는 방향을 지금 이 시점 값으로 고정한다. 모션 재생 중 반대 방향키를 눌러도 바라보는 방향이
		        -- 바뀌지 않도록 OnUpdate에서 매 프레임 이 방향으로 다시 고정한다(아래 OnUpdate 참고) -
		        -- PlayerControllerComponent.Enable = false만으로는 이동은 막히지만 방향 전환까지는 막히지 않는다.
		        local playerCtrl = attacker.PlayerControllerComponent
		        if isvalid(attacker.MovementComponent) then
		            attacker.MovementComponent:Stop()
		        end
		        if isvalid(playerCtrl) then
		            playerCtrl.LookDirectionX = dirX
		        end
		        self._T.isDirectionLocked = true
		        self._T.lockedDirX = dirX
		        self._T.lockedMotionName = motionName
		        self._T.isMotionPlaying = true
		        -- 홀드 지속발동 중 다음 시전이 쿨다운(0.75*mult)만큼 뒤에 시작될 수 있는데, 이 잠금 해제 타이머는
		        -- 그보다 늦은 0.80*mult 뒤에 실행된다. 즉 새 시전이 이미 방향을 다시 잠근 뒤에 이전 시전의 해제
		        -- 타이머가 뒤늦게 실행되며 새 시전의 잠금을 잘못 풀어버려, 그 틈에 이동키 입력으로 방향이 갑자기
		        -- 바뀌는 문제가 있었다. 시전마다 토큰을 발급해 "그 사이 더 최근 시전이 없었을 때만" 해제한다.
		        self._T.powerStrikeLockToken = (self._T.powerStrikeLockToken or 0) + 1
		        local myLockToken = self._T.powerStrikeLockToken
		
		        -- 공격속도 배율(atkMultiplier)이 짧을수록(=공격속도가 빠를수록) 모션 재생속도(PlayRate)를 그만큼 올려서
		        -- 실제 화면 재생 시간이 아래 타이머들(0.25/0.65초 * atkMultiplier)과 어긋나지 않게 맞춘다.
		        local mult = math.max(atkMultiplier or 1.0, 0.001)
		        local playRate = 1.0 / mult
		        self._T.lockedPlayRate = playRate
		
		        if keepDefaultEffect then
		            -- (요청) 한손검(swingO 계열): raw ActionStateChangedEvent로는 엔진 기본 검격 이펙트가 전혀
		            -- 재생되지 않는 것으로 실측됐다 - 기본공격(Ctrl)과 같은 엔진 공격 파이프라인
		            -- (BodyActionStateChangeEvent Attack)을 태워야 무기에 맞는 공격 모션 + 기본 검격이 함께 나온다.
		            -- 엔진이 무기 기준으로 swingO1~O3 중 하나를 골라 재생하므로 모션 계열은 동일하게 유지된다.
		            -- (버그 수정) 엔진 공격 클립의 기본 길이는 ~0.87초(종료 리셋 도착 시각으로 실측)로, 이 파일의
		            -- 판정(0.45*mult)/컨트롤(0.65*mult)/쿨다운(0.75*mult) 기준인 raw 모션 길이(0.65초)보다 길다 -
		            -- playRate를 1/mult로만 주면 공속이 오를수록 "모션 1번에 공격 2번"처럼 모션과 판정 싱크가
		            -- 어긋난다. 엔진 경로만 0.87/0.65≈1.35배 더 올려 화면 모션 길이를 0.65초*mult로 통일한다.
		            -- (부수 효과) 종료 리셋도 0.65*mult에 도착 - 쿨다운(0.75*mult)보다 빨라 시전 사이 빈틈에
		            -- 떨어지므로 연속 시전 침입도 구조적으로 사라진다(워치독 ①은 안전망으로 유지).
		            local enginePlayRate = playRate * 1.35
		            self._T.lockedEnginePlayRate = enginePlayRate
		            local bodyEvent = BodyActionStateChangeEvent()
		            bodyEvent.ActionState = MapleAvatarBodyActionState.Attack
		            bodyEvent.needResetAction = true
		            bodyEvent.playRate = enginePlayRate
		            attacker:SendEvent(bodyEvent)
		            -- (버그 수정) 아래 raw 경로의 "엔진 공격 종료 리셋이 raw 모션을 덮어쓰는" 문제 감지용 -
		            -- 엔진 공격 파이프라인을 마지막으로 태운 시각을 기록해 둔다.
		            self._T.lastEngineAttackAt = _UtilLogic.ElapsedSeconds
		            -- 엔진 가드 창을 연다(워치독 ① - 연속 시전 시 이전 시전의 종료 리셋이 이 모션을 삼키면 재전송).
		            -- raw 가드와 상호 배타 - 동시에 열려 있으면 파이널 raw 모션을 엔진 공격으로 되받아치는 오작동이 난다.
		            self._T.engineGuardUntil = _UtilLogic.ElapsedSeconds + 0.5 * mult
		            self._T.rawGuardUntil = nil
		            -- 언락 토글 지연 계산도 이번 시전 기준으로 리셋(이전 파이널의 잔존값이 새 시전의 토글을 늦추지 않게).
		            self._T.rawMotionSentAt = _UtilLogic.ElapsedSeconds
		            self._T.watchdogReappliedAt = nil
		            log("[PowerStrike] PlayAttackMotion sent(engine attack): " .. tostring(motionName) .. " enginePlayRate=" .. tostring(enginePlayRate))
		        else
		            -- (버그 수정) 한손검 파이널어택 모션이 화면에 안 보였던 원인: 직전 본체 모션이 엔진 공격
		            -- 파이프라인(swingO1~O3, BodyActionStateChangeEvent)으로 재생된 경우, 그 엔진 공격 클립이
		            -- 끝나는 시점에 엔진이 기본 상태 클립(stand)을 다시 내보내면서 그 사이에 시작한 이 raw
		            -- 파이널 모션(stabOF)을 덮어써버렸다(상태 변경이 없어 HandleStateChangeEvent 재적용 경로도
		            -- 타지 않는다). 엔진 공격 직후(1.2초 내)에 raw 모션을 재생할 때는 ①Stand 리셋 이벤트로
		            -- 진행 중인 엔진 공격을 먼저 끊고 ②짧은 지연 뒤 같은 모션을 한 번 재전송해, 뒤늦게
		            -- 도착하는 엔진 리셋까지 이겨내게 한다.
		            -- 엔진 가드는 raw 시전 시작 즉시 닫는다(상호 배타) - 열려 있으면 아래 raw 모션 이벤트를
		            -- 워치독 ①이 침입자로 오인해 엔진 공격으로 되받아쳐 버린다.
		            self._T.engineGuardUntil = nil
		            local prevEngineRecent = self._T.lastEngineAttackAt ~= nil and (_UtilLogic.ElapsedSeconds - self._T.lastEngineAttackAt) < 1.2
		            if prevEngineRecent then
		                self._T.lastEngineAttackAt = nil
		                local cancelEvent = BodyActionStateChangeEvent()
		                cancelEvent.ActionState = MapleAvatarBodyActionState.Stand
		                cancelEvent.needResetAction = true
		                attacker:SendEvent(cancelEvent)
		            end
		            -- 워치독 재시작 오프셋 계산용 - 이번 raw 시전 기준 시각을 기록하고 이전 시전의 재시작 기록을 지운다.
		            self._T.rawMotionSentAt = _UtilLogic.ElapsedSeconds
		            self._T.watchdogReappliedAt = nil
		            local motionEvent = ActionStateChangedEvent(motionName, motionName, playRate, SpriteAnimClipPlayType.Onetime)
		            body:SendEvent(motionEvent)
		            if prevEngineRecent then
		                -- 워치독 가드 창을 연다(위 ConnectEvent 참고). 언락 토글(0.80*mult)의 정상적인
		                -- IDLE→MOVE→IDLE 정리가 워치독에 잡히지 않도록 그보다 짧은 0.5*mult로 제한한다.
		                self._T.rawGuardUntil = _UtilLogic.ElapsedSeconds + 0.5 * mult
		            end
		            log("[PowerStrike] PlayAttackMotion sent: " .. tostring(motionName) .. " playRate=" .. tostring(playRate))
		        end
		
		        -- 기본 스윙 이펙트 복구 + 실제 모션 재생 구간 종료(_T.isMotionPlaying)는 서버 타격 판정과 같은 시간(기본 0.25초 * 배율)에 처리한다.
		        _TimerService:SetTimerOnce(function()
		            if isvalid(avatarRenderer) then
		                avatarRenderer.ShowDefaultWeaponEffects = true
		            end
		            self._T.isMotionPlaying = false
		        end, 0.25 * mult)
		
		        -- 방향 잠금은 서버의 컨트롤러 잠금과 같은 길이(기본 0.65초 * 배율) 뒤 해제한다.
		        _TimerService:SetTimerOnce(function()
		            if self._T.powerStrikeLockToken ~= myLockToken then return end
		            self._T.isDirectionLocked = false
		            -- 반대 방향키를 누르고 있는 상태로 이 시점을 맞으면, 아직 화면에 남아있는 스킬 모션(raw
		            -- ActionStateChangedEvent) 클립의 꼬리 프레임이 보이면서 캐릭터가 반대 방향으로 움직이기
		            -- 시작하는 문제가 있었다. 상태가 계속 IDLE으로만 유지되면(자연스러운 MOVE 전환이 한 번도
		            -- 없었던 경우) StateChangeEvent가 새로 발생하지 않아 위 스킬 모션 클립이 그대로 남아있기
		            -- 때문이다. 여기서 IDLE -> MOVE -> IDLE로 강제 토글해 StateChangeEvent를 한 번 더 일으켜,
		            -- AvatarStateAnimationComponent가 걷기/서기 클립을 다시 내보내 남은 스킬 모션을 확실히
		            -- 덮어쓰게 한다. 이동 봉인이 완전히 풀리기 직전에 실행되므로 실제 조작감에는 영향이 없다.
		            -- (버그 수정) 워치독이 raw 모션을 재시작시킨 시전(엔진 리셋 덮어쓰기 복구)은 모션 종료가 재시작
		            -- 오프셋만큼 늦어지는데, 여기서 바로 토글하면 그 끝부분이 잘려 "순식간에 끝나는" 느낌이 났다 -
		            -- 방향 잠금 해제 타이밍은 그대로 두고, 정리 토글만 재시작 오프셋만큼 늦춘다.
		            local toggleDelay = 0
		            if self._T.watchdogReappliedAt ~= nil and self._T.rawMotionSentAt ~= nil and self._T.watchdogReappliedAt > self._T.rawMotionSentAt then
		                toggleDelay = math.min(self._T.watchdogReappliedAt - self._T.rawMotionSentAt, 0.4)
		            end
		            local doToggle = function()
		                if self._T.powerStrikeLockToken ~= myLockToken then return end
		                local sc = self.Entity.StateComponent
		                if isvalid(sc) and sc.CurrentStateName ~= "DEAD" then
		                    sc:ChangeState("IDLE")
		                    sc:ChangeState("MOVE")
		                    sc:ChangeState("IDLE")
		                    log("[PowerStrike] unlock refresh toggle done (delay=" .. tostring(toggleDelay) .. ")")
		                end
		            end
		            if toggleDelay > 0 then
		                _TimerService:SetTimerOnce(doToggle, toggleDelay)
		            else
		                doToggle()
		            end
		        end, 0.80 * mult)
	end

	@ExecSpace("Multicast")
	method void PlayAttackMotionFramed(Entity attacker, string motionName, number dirX, number atkMultiplier, integer startFrame, integer endFrame)
		-- PlayAttackMotion과 동일하되, 재생 프레임 구간(startFrame~endFrame)만 재생한다.
		-- 러시 대쉬 = swingT3 앞부분(윈드업, 0~1), 러시 콤보 파워스트라이크 = swingT3 끝(휘두름, 2~끝).
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		local avatarRenderer = attacker.AvatarRendererComponent
		if not isvalid(avatarRenderer) then return end
		local body = avatarRenderer:GetBodyEntity()
		if not isvalid(body) then return end
		avatarRenderer.ShowDefaultWeaponEffects = false
		local playerCtrl = attacker.PlayerControllerComponent
		if isvalid(attacker.MovementComponent) then
			attacker.MovementComponent:Stop()
		end
		if isvalid(playerCtrl) then
			playerCtrl.LookDirectionX = dirX
		end
		self._T.isDirectionLocked = true
		self._T.lockedDirX = dirX
		self._T.lockedMotionName = motionName
		self._T.isMotionPlaying = true
		self._T.powerStrikeLockToken = (self._T.powerStrikeLockToken or 0) + 1
		local myLockToken = self._T.powerStrikeLockToken
		local mult = math.max(atkMultiplier or 1.0, 0.001)
		local playRate = 1.0 / mult
		self._T.lockedPlayRate = playRate
		local motionEvent = ActionStateChangedEvent(motionName, motionName, playRate, SpriteAnimClipPlayType.Onetime, startFrame, endFrame)
		body:SendEvent(motionEvent)
		log("[PowerStrike] PlayAttackMotionFramed: " .. tostring(motionName) .. " frames " .. tostring(startFrame) .. "~" .. tostring(endFrame))
		_TimerService:SetTimerOnce(function()
			if isvalid(avatarRenderer) then
				avatarRenderer.ShowDefaultWeaponEffects = true
			end
			self._T.isMotionPlaying = false
		end, 0.25 * mult)
		_TimerService:SetTimerOnce(function()
			if self._T.powerStrikeLockToken ~= myLockToken then return end
			self._T.isDirectionLocked = false
			local sc = self.Entity.StateComponent
			if isvalid(sc) and sc.CurrentStateName ~= "DEAD" then
				sc:ChangeState("IDLE")
				sc:ChangeState("MOVE")
				sc:ChangeState("IDLE")
			end
		end, 0.80 * mult)
	end

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		        -- (버그 수정) "여러 스킬을 사용해봤는데 스킬 사용 후 숨고르기 모션을 하지 않는다"는 신고 -
		        -- 원인은 각 스킬 모션 정리용 IDLE→MOVE→IDLE 강제 토글(PlayAttackMotion 등, 같은 서버 호출
		        -- 안에서 즉시 IDLE로 되돌아감)이 숨고르기 시작 직후와 시간상 겹쳐, 진짜 이동이 아닌 이 내부
		        -- 토글의 MOVE StateChangeEvent에 의해 숨고르기가 매번 취소되던 것이었다. StateChangeEvent
		        -- 즉시-반응 대신, 여러 프레임에 걸쳐 "실제로 지속되는" MOVE 상태만 진짜 이동으로 보고 매
		        -- 프레임 폴링으로 감지한다.
		        -- (버그 수정) "스피어 버스터는 정상인데 파워스트라이크/매직클로/슬래쉬블래스트 등은 숨고르기가
		        -- 한 번 잠깐 잡히고 바로 끝난다"는 신고 - 위 폴링이 "MOVE 상태가 딱 1프레임만 감지되면"
		        -- 바로 취소해버려서, 내부 토글의 IDLE→MOVE→IDLE 전환이 (스피어 버스터에는 이 토글 자체가
		        -- 없지만) 파워스트라이크류에는 있어 그 찰나의 MOVE 프레임 하나에 걸려 즉시 잘못 취소되던
		        -- 것이었다. 연속된 프레임에서 "계속" MOVE일 때만 진짜 이동으로 보도록 3프레임 연속 조건을
		        -- 추가한다 - 내부 토글은 같은 프레임(또는 아무리 길어도 1프레임) 안에 IDLE로 되돌아가므로
		        -- 3프레임 연속 조건을 절대 만족하지 못하고, 실제 이동은 방향키를 누르고 있는 한 계속
		        -- MOVE이므로 몇 프레임 안에 정상적으로 감지된다.
		        if self._T.isBreatherPlaying or self._T.isBreatherArmed then
		            local sc = self.Entity.StateComponent
		            if isvalid(sc) and sc.CurrentStateName == "MOVE" then
		                self._T.breatherMoveFrames = (self._T.breatherMoveFrames or 0) + 1
		                if self._T.breatherMoveFrames >= 3 then
		                    -- (기능 추가) IDLE 전환을 기다리는 중(armed)이었어도, 그 사이 실제로 계속
		                    -- 이동 중이면(=IDLE로 정착하지 않고 계속 MOVE) 숨고르기를 아예 시작하지 않고 취소한다.
		                    self._T.isBreatherPlaying = false
		                    self._T.isBreatherArmed = false
		                    self._T.breatherToken = (self._T.breatherToken or 0) + 1
		                    self._T.breatherMoveFrames = 0
		                    log("[Breather] 숨고르기 중단(이동 감지, 폴링)")
		                end
		            else
		                self._T.breatherMoveFrames = 0
		            end
		        end

		        -- 텔레포트 등으로 캐릭터가 카메라의 SoftZone을 벗어나면 부드러운 추적 대신 즉시 이동(스냅)으로
		        -- 바뀌는 것으로 추정됨(사용자 관찰) - SoftZone만 3배로 넓혀 텔레포트 거리(3유닛)가 이 범위 안에
		        -- 들어오게 한다. DeadZone은 건드리지 않는다 - DeadZone은 "카메라가 캐릭터를 안 움직이고 잡아두는
		        -- 영역"이라 이것까지 키우면 평소 걷기 이동에서도 캐릭터가 화면 정중앙까지 오지 않고 넓어진
		        -- 데드존 안 어딘가에서 멈춰버리는 문제가 있었다(사용자 재확인, 2026-07-05). 로컬 플레이어에게만,
		        -- 한 번만 적용(다른 클라이언트가 보는 원격 플레이어의 카메라 컴포넌트는 건드리지 않음).
		        if not self._T.cameraZoneApplied then
		            self._T.cameraZoneApplied = true
		            if self.Entity == _UserService.LocalPlayer then
		                local cam = self.Entity.CameraComponent
		                if isvalid(cam) then
		                    local ZONE_MULTIPLIER = 3.0
		                    local sz = cam.SoftZone
		                    cam.SoftZone = Vector2(math.min(sz.x * ZONE_MULTIPLIER, 1.0), math.min(sz.y * ZONE_MULTIPLIER, 1.0))
		                    log("[PlayerAttack] Camera zone enlarged: DeadZone=(" .. tostring(cam.DeadZone.x) .. "," .. tostring(cam.DeadZone.y) .. ") SoftZone=(" .. tostring(cam.SoftZone.x) .. "," .. tostring(cam.SoftZone.y) .. ")")
		                end
		            end
		        end
		        -- 파워스트라이크 모션 재생 중(_T.isDirectionLocked)에는 매 프레임 바라보는 방향을 고정해서,
		        -- 반대 방향키 입력으로 캐릭터가 순간적으로 반대쪽을 보며 모션이 어색하게 끊기는 것을 막는다.
		        if self._T.isDirectionLocked then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedDirX
		            end
		        end
		        -- 럭키세븐 모션 재생 중에도 매 프레임 바라보는 방향을 고정한다 (파워스트라이크/슬래쉬블래스트와 별도 플래그)
		        if self._T.isLuckySevenDirectionLocked then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedLuckySevenDirX
		            end
		        end
		        -- 슬래쉬블래스트 모션 재생 중에도 동일하게 방향을 고정한다 (파워스트라이크와 별도 플래그)
		        if self._T.isSlashDirectionLocked then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedSlashDirX
		            end
		        end
		        -- 더블스탭 모션 재생 중에도 동일하게 방향을 고정한다 (다른 스킬과 별도 플래그)
		        if self._T.isDoubleStabDirectionLocked then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedDoubleStabDirX
		            end
		        end
		        -- 새비지블로우 모션 재생 중에도 동일하게 방향을 고정한다 (다른 스킬과 별도 플래그)
		        if self._T.isSavageBlowDirectionLocked then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedSavageBlowDirX
		            end
		        end
		        -- 매직클로 모션 재생 중에도 동일하게 방향을 고정한다 (다른 스킬과 별도 플래그)
		        if self._T.isMagicClawDirectionLocked then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedMagicClawDirX
		            end
		        end
		        -- 썬더볼트 모션 재생 중에도 동일하게 방향을 고정한다 (다른 스킬과 별도 플래그)
		        if self._T.isThunderboltDirectionLocked then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedThunderboltDirX
		            end
		        end
		        -- 힐 모션 재생 중에도 동일하게 방향을 고정한다 (다른 스킬과 별도 플래그)
		        if self._T.isHealDirectionLocked then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedHealDirX
		            end
		        end
		        -- 파이어에로우 모션 재생 중에도 동일하게 방향을 고정한다 (다른 스킬과 별도 플래그)
		        if self._T.isFireArrowDirectionLocked then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedFireArrowDirX
		            end
		        end
		        -- 아이언에로우 모션 재생 중에도 동일하게 방향을 고정한다 (파이어에로우와 별도 플래그)
		        if self._T.isIronArrowDirectionLocked then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedIronArrowDirX
		            end
		        end
		        -- 더블샷 모션 재생 중에도 동일하게 방향을 고정한다 (다른 화살 스킬과 별도 플래그)
		        if self._T.isDoubleShotDirectionLocked then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedDoubleShotDirX
		            end
		        end
		        -- 에로우 블로우 모션 재생 중에도 동일하게 방향을 고정한다 (다른 화살 스킬과 별도 플래그)
		        if self._T.isArrowBlowDirectionLocked then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedArrowBlowDirX
		            end
		        end
		        -- 포이즌 미스트 모션 재생 중에도 동일하게 방향을 고정한다 (다른 스킬과 별도 플래그)
		        if self._T.isPoisonMistDirectionLocked then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedPoisonMistDirX
		            end
		        end
		        -- 익스플로젼 모션 재생 중에도 동일하게 방향을 고정한다 (다른 스킬과 별도 플래그)
		        if self._T.isExplosionDirectionLocked then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedExplosionDirX
		            end
		        end
		        -- 드래곤 로어 모션 재생 중에도 동일하게 방향을 고정한다 (다른 스킬과 별도 플래그)
		        if self._T.isDragonRoarDirectionLocked then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedDragonRoarDirX
		            end
		        end
		        -- 스피어 버스터 모션 재생 중에도 동일하게 방향을 고정한다 (다른 스킬과 별도 플래그).
		        -- (버그 수정) playerCtrl.Enable=false만으로는 "반대 방향키를 누르고 있으면 뒤로 돈다"는
		        -- 현상이 남아있어, 매 프레임 MovementComponent:Stop()도 함께 호출해 이동 자체를 확실히 막는다.
		        if self._T.isSpearBurstDirectionLocked then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedSpearBurstDirX
		            end
		            if isvalid(self.Entity.MovementComponent) then
		                self.Entity.MovementComponent:Stop()
		            end
		        end
		        -- 헤이스트 모션 재생 중에도 동일하게 방향을 고정한다 (다른 스킬과 별도 플래그)
		        if self._T.isHasteDirectionLocked then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedHasteDirX
		            end
		        end
		        -- 부스터 모션 재생 중에도 동일하게 방향을 고정한다 (다른 스킬과 별도 플래그)
		        if self._T.isBoosterDirectionLocked then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedBoosterDirX
		            end
		        end
	end

	@ExecSpace("Multicast")
	method void PlaySkillStartEffect(Entity attacker, number dirX)
		        -- 스킬 시전 시작 이펙트 재생: 파워 스트라이크 리소스팩(skill/800033.img/skill/80003316)의 "effect" 노드.
		        -- Multicast는 서버 자신도 함께 실행하므로 클라이언트에서만 실행되게 막는다.
		        if not self:IsClient() then return end
		        if not isvalid(attacker) then return end
		        local startEffectRUID = "522793cef4ff4b79bdf73b9eda9386f8"
		        local startOptions = { ["FlipX"] = dirX > 0 }
		        _EffectService:PlayEffectAttached(startEffectRUID, attacker, Vector3(0, 0, 0), 0, Vector3(1, 1, 1), false, startOptions)
		        -- 쉐도우 파트너: 같은 시작 이펙트를 x축 뒤쪽에서 투명도 70%로 복제 재생(그림자 몫 - 데미지 없음)
		        self:EchoShadowSkillEffectAttached(startEffectRUID, attacker, Vector3(0, 0, 0), 0, Vector3(1, 1, 1), startOptions, dirX)
		        log("[PowerStrike] 시전 시작 이펙트 재생")
	end

	@ExecSpace("ServerOnly")
	method Entity FindNearestMonster(Vector2 fromPos, number maxRange)
		        -- 파워스트라이크 대상 선정: 사거리 내 script.Monster 컴포넌트가 있는 살아있는 엔티티 중 가장 가까운 하나
		        local map = self.Entity.CurrentMap
		        if not isvalid(map) then return nil end
		        local monsterComps = map:GetChildComponentsByTypeName("script.Monster", true)
		        local nearest = nil
		        local nearestDist = maxRange
		        for _, comp in ipairs(monsterComps) do
		            ---@type Monster
		            local mc = comp
		            if isvalid(mc) and isvalid(mc.Entity) and not mc.IsDead then
		                local pos = mc.Entity.TransformComponent.WorldPosition
		                local dx = pos.x - fromPos.x
		                local dy = pos.y - fromPos.y
		                local dist = math.sqrt(dx * dx + dy * dy)
		                if dist <= nearestDist then
		                    nearest = mc.Entity
		                    nearestDist = dist
		                end
		            end
		        end
		        return nearest
	end

	@ExecSpace("ServerOnly")
	method table FindMonstersInRadius(Vector2 fromPos, number radius, integer maxCount)
		-- (다크드래곤) fromPos 반경 radius 안의 살아있는 몬스터를 가까운 순으로 최대 maxCount마리 반환한다.
		-- 드래곤이 "자기 주변"만 공격하게 하려는 용도(넓은 전방박스 대신 작은 원형 반경).
		local map = self.Entity.CurrentMap
		local out = {}
		if not isvalid(map) then return out end
		local monsterComps = map:GetChildComponentsByTypeName("script.Monster", true)
		local cand = {}
		for _, comp in ipairs(monsterComps) do
			---@type Monster
			local mc = comp
			if isvalid(mc) and isvalid(mc.Entity) and not mc.IsDead then
				local pos = mc.Entity.TransformComponent.WorldPosition
				local dx = pos.x - fromPos.x
				local dy = pos.y - fromPos.y
				local dist = math.sqrt(dx * dx + dy * dy)
				if dist <= radius then
					table.insert(cand, { e = mc.Entity, d = dist })
				end
			end
		end
		table.sort(cand, function(a, b) return a.d < b.d end)
		for i = 1, math.min(maxCount, #cand) do
			table.insert(out, cand[i].e)
		end
		return out
	end

	method table FindNearestMonstersInForwardBox(Vector2 fromPos, number dirX, number xReach, number upHalf, number downHalf, integer maxCount)
		-- FindNearestMonsterInForwardBox의 다중 대상판. 전방 사각형 안의 몬스터를 "가까운 순"으로 정렬해
		-- 최대 maxCount명까지 돌려준다. 위/아래 범위를 따로 받는다(요청: 아래쪽 판정만 줄임).
		local result = {}
		local map = self.Entity.CurrentMap
		if not isvalid(map) then return result end
		local cands = {}
		local monsterComps = map:GetChildComponentsByTypeName("script.Monster", true)
		for _, comp in ipairs(monsterComps) do
			---@type Monster
			local mc = comp
			if isvalid(mc) and isvalid(mc.Entity) and not mc.IsDead then
				local pos = mc.Entity.TransformComponent.WorldPosition
				local dx = pos.x - fromPos.x
				local dy = pos.y - fromPos.y
				if dx * dirX >= 0 and math.abs(dx) <= xReach and dy <= upHalf and dy >= -downHalf then
					table.insert(cands, { entity = mc.Entity, dist = math.sqrt(dx * dx + dy * dy) })
				end
			end
		end
		-- 거리 오름차순 정렬(후보 수가 적어 단순 삽입 정렬로 충분하다).
		for i = 2, #cands do
			local cur = cands[i]
			local j = i - 1
			while j >= 1 and cands[j].dist > cur.dist do
				cands[j + 1] = cands[j]
				j = j - 1
			end
			cands[j + 1] = cur
		end
		for i = 1, math.min(maxCount, #cands) do
			table.insert(result, cands[i].entity)
		end
		return result
	end

	method Entity FindNearestMonsterInForwardBox(Vector2 fromPos, number dirX, number xReach, number yHalfHeight)
		        -- (기능 추가) "히트박스가 네모가 아닌 것 같다" 신고 - FindNearestMonster(전방향 원형 탐색)와
		        -- 달리, 실제 타격 판정 박스와 완전히 동일한 모양(캐릭터 바로 앞부터 xReach만큼 전방으로,
		        -- 위아래로 yHalfHeight만큼)의 사각형 범위 안에서만 후보를 찾고, 그중 가장 가까운 하나를 고른다.
		        -- 박스 밖(등 뒤·대각선 등)에 있는 몬스터는 아무리 가까워도 애초에 후보에 들지 않는다.
		        local map = self.Entity.CurrentMap
		        if not isvalid(map) then return nil end
		        local monsterComps = map:GetChildComponentsByTypeName("script.Monster", true)
		        local nearest = nil
		        local nearestDist = xReach + yHalfHeight
		        for _, comp in ipairs(monsterComps) do
		            ---@type Monster
		            local mc = comp
		            if isvalid(mc) and isvalid(mc.Entity) and not mc.IsDead then
		                local pos = mc.Entity.TransformComponent.WorldPosition
		                local dx = pos.x - fromPos.x
		                local dy = pos.y - fromPos.y
		                -- 박스 안 판정: 바라보는 방향(dirX) 기준 0~xReach 사이, 세로는 ±yHalfHeight 이내
		                if dx * dirX >= 0 and math.abs(dx) <= xReach and math.abs(dy) <= yHalfHeight then
		                    local dist = math.sqrt(dx * dx + dy * dy)
		                    if dist <= nearestDist then
		                        nearest = mc.Entity
		                        nearestDist = dist
		                    end
		                end
		            end
		        end
		        return nearest
	end

	method Vector2 ComputeArrowAimDirection(number faceDirX, number xReach, number yHalfHeight)
		-- 화살류 스킬(에로우 블로우 / 더블샷) 공용 조준. 화살이 출발하는 지점(몸통 중심, 발끝 기준 y+0.35)에서
		-- 바라보는 방향으로 xReach만큼 뻗은 전방 박스(세로 ±yHalfHeight) 안에 몬스터가 있으면 그 몬스터의
		-- 몸통 중심을 향하는 정규화된 방향을 돌려주고, 없으면 순수 수평 방향을 돌려준다.
		local myPos = self.Entity.TransformComponent.WorldPosition
		local originY = myPos.y + 0.35
		local target = self:FindNearestMonsterInForwardBox(Vector2(myPos.x, originY), faceDirX, xReach, yHalfHeight)
		if not isvalid(target) then return Vector2(faceDirX, 0) end

		local tp = target.TransformComponent.WorldPosition
		local ty = tp.y
		local thc = target.HitComponent
		-- 몬스터의 WorldPosition은 발밑 기준이라, 실제 몸통 중심(히트박스 오프셋)을 겨냥해야 자연스럽다.
		if isvalid(thc) then ty = ty + thc.ColliderOffset.y end

		local dx = tp.x - myPos.x
		local dy = ty - originY
		-- 거의 같은 높이면 각도를 주지 않는다 - 미세한 높이차로 화살이 어정쩡하게 기우는 것을 막는다.
		if math.abs(dy) < 0.12 then return Vector2(faceDirX, 0) end
		-- 대상이 거의 바로 위/아래(dx ≈ 0)면 그대로 정규화할 경우 수직 발사가 되어 "전방으로 쏜다"는
		-- 스킬 성격에서 벗어난다 - 최소한의 전방 성분을 넣어 앞위/앞아래 대각선이 되게 한다.
		if dx * faceDirX < 0.35 then dx = faceDirX * 0.35 end
		local mag = math.sqrt(dx * dx + dy * dy)
		if mag < 0.0001 then return Vector2(faceDirX, 0) end
		return Vector2(dx / mag, dy / mag)
	end

	@ExecSpace("Multicast")
	method void PlaySwingTrailClip(Entity attacker, string clipRuid, number dirX)
		-- 클립형 궤적 이펙트를 파워스트라이크(PlayPowerStrikeEffects의 스윙 부분)와 동일하게 재생한다 -
		-- 슬래시블러스트가 PS와 같은 후보(클립 궤적 포함)를 쓰게 되면서, SB 경로에도 클립 재생이 필요해졌다.
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		if clipRuid == nil or clipRuid == "" then return end
		local swingOptions = { ["FlipX"] = dirX > 0, ["Alpha"] = 0.8 }
		_EffectService:PlayEffectAttached(clipRuid, attacker, Vector3(0.1 * dirX, 0, 0), 0, Vector3(1, 1, 1), false, swingOptions)
		self:EchoShadowSkillEffectAttached(clipRuid, attacker, Vector3(0.1 * dirX, 0, 0), 0, Vector3(1, 1, 1), swingOptions, dirX)
	end

	@ExecSpace("ServerOnly")
	method void SpawnSlashBlastCastEffect(number dirX)
		-- (요청/예시영상) 슬래시블러스트 몸쪽 캐스트 스파클: 원본 스킬의 4프레임 애니메이션
		-- (effect.0→2→3→4)을 순차 재생한다. "옅게 퍼진 스파클이 점점 진해지며 응집"되는 연출이
		-- 프레임 그림 자체에 들어있으므로 스케일/알파 트윈을 걸지 않고(알파 1 고정·크기 고정)
		-- ClipRUID만 순서대로 갈아끼운다 - @Sync 프로퍼티라 바뀔 때마다 클라 OnSyncProperty가
		-- SpriteRUID를 재적용한다. 이전의 단일 프레임+축소 트윈은 "퍼져나가는 느낌 + 투명해 보임"
		-- 피드백으로 폐기.
		local frames = {
			"28a559c14e6e497db84d4b70f4419ac6", -- effect.0 (옅게 퍼짐)
			"cd6a3d7ca3514862ade106e46dd0dfd3", -- effect.2
			"8de6e8d4e04b4d488662e73456d7639f", -- effect.3
			"1c9e86b289c249de8772fcbe1b9b1ae2", -- effect.4 (진하게 응집)
		}
		local frameInterval = 0.09
		self._T.trailFxSeq = (self._T.trailFxSeq or 0) + 1
		-- 위치/크기: (실측 반복 조정) y=0.5는 머리 위, y=0.15는 허리 아래에 몰려 보였다 - 예시 영상처럼
		-- 몸 전체를 덮도록 중심을 y=0.3(몸통)으로, 스케일 1.7로 확정. x는 몸 중앙(0) 고정 - 캐스트는
		-- 방향과 무관하게 몸에서 발현되는 이펙트라 전방 오프셋을 주지 않는다.
		local fx = _SpawnService:SpawnByModelId("spearburstfadingeffect", "SBCastFx" .. tostring(self._T.trailFxSeq), Vector3(0, 0.3, 0), self.Entity)
		if not isvalid(fx) then return end
		fx:AddComponent("script.SpearBurstFadingEffect")
		local comp = fx:GetComponent("script.SpearBurstFadingEffect")
		if isvalid(comp) then
			comp.IsFlipX = false
			comp.StartAlpha = 1.0
			comp.EndAlpha = 1.0            -- 투명해지지 않게 고정(사라짐은 아래 Destroy가 담당)
			comp.HoldDuration = 1.0        -- 전체 수명(0.4초)보다 길게 잡아 트윈이 아예 시작되지 않게 한다
			comp.TweenDuration = 0.0
			comp.StartScale = 1.7
			comp.EndScale = 1.7
			comp.OrderInLayerValue = 5
			comp.ClipRUID = frames[1]
		end
		for i = 2, #frames do
			local frameRuid = frames[i]
			_TimerService:SetTimerOnce(function()
				if isvalid(comp) then
					comp.ClipRUID = frameRuid
				end
			end, (i - 1) * frameInterval)
		end
		_TimerService:SetTimerOnce(function()
			if isvalid(fx) then fx:Destroy() end
		end, #frames * frameInterval + 0.03)
	end

	@ExecSpace("ServerOnly")
	method void SpawnHitSpriteOnTarget(Entity target, string spriteRuid)
		-- (요청) 슬래시블러스트 히트 이펙트를 폴더 이미지(단일 스프라이트)로 교체 - 맞은 몬스터 몸 위에
		-- 잠깐 표시 후 페이드(SpawnSkillTrailSprite와 동일한 SpearBurstFadingEffect 패턴, 대상 부착판).
		if not isvalid(target) then return end
		if spriteRuid == nil or spriteRuid == "" then return end
		local fx = _SpawnService:SpawnByModelId("spearburstfadingeffect", "SBHitFx", Vector3(0, 0.4, 0), target)
		if not isvalid(fx) then return end
		fx:AddComponent("script.SpearBurstFadingEffect")
		local comp = fx:GetComponent("script.SpearBurstFadingEffect")
		if isvalid(comp) then
			comp.IsFlipX = false
			comp.StartAlpha = 1.0
			comp.EndAlpha = 0.0
			comp.HoldDuration = 0.1
			comp.TweenDuration = 0.25
			comp.StartScale = 1.0
			comp.EndScale = 1.0
			comp.OrderInLayerValue = 5
			comp.ClipRUID = spriteRuid
		end
		_TimerService:SetTimerOnce(function()
			if isvalid(fx) then fx:Destroy() end
		end, 0.6)
	end

	@ExecSpace("ServerOnly")
	method void SpawnSkillTrailSprite(string spriteRuid, number dirX, number offsetX, number offsetY, number scaleValue)
		-- 업로드한 단일 스프라이트 궤적/이펙트를 캐릭터 기준 (offsetX*방향, offsetY) 위치에 scaleValue 크기로
		-- 잠깐 표시했다가(0.1초 유지 + 0.25초 페이드) 지운다. 정지 스프라이트는 EffectService(애니메이션클립
		-- 전용)로 재생할 수 없어, SpearBurstFadingEffect(스프라이트 페이드 전용 엔티티) 패턴을 재사용한다.
		-- 궤적 기본 위치는 (0.75, 0.35) - "캐릭터 위쪽에 떠 보인다"는 피드백으로 앞으로 당기고 아래로 내린 값.
		if spriteRuid == nil or spriteRuid == "" then return end
		-- 같은 프레임/짧은 간격에 여러 개(캐스트+궤적)가 겹칠 수 있어 이름을 고유하게 만든다(중복명 스폰 충돌 방지).
		self._T.trailFxSeq = (self._T.trailFxSeq or 0) + 1
		local fx = _SpawnService:SpawnByModelId("spearburstfadingeffect", "SkillTrailFx" .. tostring(self._T.trailFxSeq), Vector3(offsetX * dirX, offsetY, 0), self.Entity)
		if not isvalid(fx) then return end
		fx:AddComponent("script.SpearBurstFadingEffect")
		local comp = fx:GetComponent("script.SpearBurstFadingEffect")
		if isvalid(comp) then
			comp.IsFlipX = dirX > 0        -- 원본 이미지는 왼쪽 방향 - 오른쪽 볼 때 좌우 반전
			comp.StartAlpha = 0.8          -- 기존 궤적 이펙트와 동일한 투명도(80%)
			comp.EndAlpha = 0.0
			comp.HoldDuration = 0.1
			comp.TweenDuration = 0.25
			comp.StartScale = scaleValue
			comp.EndScale = scaleValue
			comp.OrderInLayerValue = 5     -- 캐릭터보다 앞에 그려지도록
			comp.ClipRUID = spriteRuid     -- 마지막에 설정(클라 OnSyncProperty가 실제 적용을 트리거)
		end
		_TimerService:SetTimerOnce(function()
			if isvalid(fx) then fx:Destroy() end
		end, 0.6)
	end

	method void BuildChargeBlowTrailFrames()
		-- 차지 블로우 속성 궤적 프레임 RUID 표를 만든다(최초 사용 시 1회).
		-- [속성][행] = 프레임 4장. 속성 인덱스는 SkillManager.GetChargeBlowModeIndex와 같은 순서다:
		--   1 디바인 스티그마 강화 = 얼음 / 2 디바인 스윙 강화 = 불 / 3 디바인 저지먼트 강화 = 전기 / 4 디바인 차지 = 성
		-- 원본 시트와 파일별 RUID 대응표: msw-dev-tools/resources/차지블로우속성궤적/RUID.md
		local t = {}
		t[1] = {   -- 얼음 (디바인 스티그마 강화)
			{ "256ed90a49b54a17a4be2280e49009ce", "919aec05616b464aba949064c65499b4", "435ac3806a924dc9b4239cb8c1c86243", "3f97672a96fa4dcdb9e274ea39673b09" },
			{ "7c0f3e19de034c12815247cb272f6301", "4938bb94bfb1455bbb483d805ee14d49", "c61a0eb09c35487ca1d45b74389afc0d", "4876d4a6544c45e0af9989877ab39e5b" },
			{ "4cce0f1075a843858a72f1c3934179df", "433bf9eb0b884b57bf2e379b75f0c9a8", "99acf5028d394e898cfcc780893578b3", "50a36c1b7d44453fbcbb8c518fd525ea" },
			{ "e34c657a37934280a2828c935ad90714", "8b3d8c43db4b4aabb93c194dc13062a2", "d39424cc827e4bbc9c62269a44ea97be", "22eed4ca45d241558dfd1cd41f802220" },
		}
		t[2] = {   -- 불 (디바인 스윙 강화)
			{ "8ed34627d76d4500907a123ec4817242", "c446252cdb9c4d9e936755e1b9138ac1", "20006015b5484621bade91e2afd63a6e", "5df7aba02f834818a92b07340736b0ef" },
			{ "ee783abac9c646aeb0a67da38471a50c", "dbba0b7f570c4a669604f326382bd738", "250ef83c342c4296bcde108e8bd80ecf", "ae0f4f68c5b44305bdf85e5524987c34" },
			{ "507d9c37ad214dd09a7123716eece5d3", "0916e5711ae04feb9265fc8db4dbc405", "ee8f14cd11c943e89c370352303eb8f5", "79e0485dea9a4bea85e09f70461cb9bb" },
			{ "475a253a7a0942918fa279f611577fa4", "f5d2a9d46cea47b7837c21d8c7647c73", "b4f5d7c8f21240d6b1cc2d2b8500b09b", "5bce29112dbf4393a30e59e852f94c52" },
		}
		t[3] = {   -- 전기 (디바인 저지먼트 강화)
			{ "0b0d53c99e514b21b1f3b94bf91c4410", "6e766ce2b33845c49e7a7a35ad0ea567", "0325c34e91a3425ca8d847bbdafe4c2b", "f9172c536716419e9096774d27594efe" },
			{ "615a87a6bcac4e7185778acf54787594", "d817abc05b1249f8a23c34e020616a7a", "a0eaef90d00246eebb97f24853cdec16", "2a3be62afb9448e3a11ab6a49ec1aa3f" },
			{ "f9c5606515d84a2ca5615ee3ef42efe0", "a1574059f19a4cc2837d8f2c47532665", "93012b7ce08240e79659e3d886591c72", "5d818f4df3714acfb97f4816027f928d" },
			{ "9979fce5082d47dd87c002c0bbd8ba87", "16b87869ef1e4b40955eebbb63b2e41c", "3031de3aad7d4736a6bd37b63dc72c84", "2fb4759ebfe5485bbb4eed246de191dd" },
		}
		t[4] = {   -- 성 (디바인 차지)
			{ "fc48f9ad06294b5dad48b846418363cd", "9e67fec6094445bfac073ca3769d4ccb", "7628999206e04ef8b3ed093d5827f9de", "ff3182dea66642348e77436ff63a36d0" },
			{ "6e565b598ba44799a507f0481c4e46ce", "aaad6f339ec84f3585edcd1e96d21369", "2a30d12e3196479f9e7b8ad7d7b0a2c7", "790c99921d95489abee6f427f6a8b58a" },
			{ "ef846906c4b54786b3017245a1fcb084", "4fd0804986e543688e875a59b446f744", "82c64a31f984418ba0a16592a556bbb4", "a1d1c7ecda334e7bb664e7bfff99f816" },
			{ "3b6e2f19df8e486dbad3cd6abf5d836d", "ade08cff629644f8817990e780523a66", "1f642456eb344ff980d13626861e4716", "5ba8a9e73caa44ab83fe4aef6d836410" },
		}
		self._T.chargeBlowTrailFrames = t
	end

	-- ── 차지 블로우 속성별 상태이상 ────────────────────────────────────────
	-- 속성 인덱스: 1 스티그마(얼음) / 2 스윙(불) / 3 저지먼트(전기) / 4 차지(성)
	--   얼음 : 50% 확률로 1.5초 빙결(푸른색 + 맞는 모션 그대로 정지 + 행동불능)
	--   불   : 50% 확률로 5초 화상(붉은색↔검붉은색 점멸 + 0.5초마다 전투력 50%)
	--   전기 : 빙결된 적을 때리면 데미지 2배 + 전용 히트 이펙트 + 그 자리에 10초 장판
	--   성   : 기본 데미지 +30% + 1초 스턴(머리 위 스턴 이펙트)
	-- 상태는 서버에서 대상 Path를 키로 _T에 기록한다(별도 상태이상 컴포넌트 시스템이 없어
	-- 코마/어썰터 스턴과 같은 "타이머로 AI/이동을 껐다 켜기" 방식을 그대로 쓴다).

	method boolean AcceptChargeBlowMultiTarget(Entity defender)
		-- (요청) 차지 블로우는 최대 3명까지 동시에 때린다. 판정 1회당 통과시킨 대상을 세어 3명까지만 받는다.
		-- 카운터는 판정 직전(AttackShadowSafe 호출 전)에 초기화된다.
		-- "목록 포함" 방식이 아니라 이번 판정에서 실제로 통과시킨 대상만 기록하므로, 같은 대상을
		-- 여러 번 받아 중복 타격되는 일은 없다.
		if not isvalid(defender) then return false end
		-- 판정 직전에 "가까운 순 최대 3명"으로 확정해둔 목록(chargeBlowTargetList)에 든 대상만 통과시킨다.
		-- 엔진이 넘겨주는 순서에 의존해 앞에서부터 3명을 받으면 먼 적이 먼저 선택될 수 있다.
		local list = self._T.chargeBlowTargetList
		if list == nil then return false end
		for _, t in ipairs(list) do
			if isvalid(t) and t == defender then return true end
		end
		return false
	end

	method boolean IsTargetBurning(Entity target)
		-- 차지 블로우(불) 화상이 진행 중인 대상인지. 얼음으로 때렸을 때의 "화상 저주" 판정에 쓰인다.
		if not isvalid(target) then return false end
		local burning = self._T.chargeBlowBurning
		if burning == nil then return false end
		return burning[target.Path] ~= nil
	end

	method boolean IsTargetFrozen(Entity target)
		-- 얼음 속성으로 빙결 중인 대상인지. 전기 속성의 2배 데미지 판정에 쓰인다.
		if not isvalid(target) then return false end
		local frozen = self._T.chargeBlowFrozen
		if frozen == nil then return false end
		local until_ = frozen[target.Path]
		if until_ == nil then return false end
		return _UtilLogic.ElapsedSeconds < until_
	end

	method number GetChargeBlowDamageFactor(Entity defender)
		-- 차지 블로우 본체/파이널 데미지에 곱해지는 속성 보정.
		--   성(4)  : +30%
		--   전기(3): 빙결된 적에게 2배(이때 전용 히트 이펙트/장판을 남기도록 대상을 기록해둔다)
		local mode = self._T.chargeBlowMode or 0
		if mode <= 0 then return 1.0 end
		if mode == 4 then return 1.3 end
		if mode == 3 and self:IsTargetFrozen(defender) then
			if self._T.chargeBlowShockHits == nil then self._T.chargeBlowShockHits = {} end
			table.insert(self._T.chargeBlowShockHits, defender)
			return 2.0
		end
		return 1.0
	end

	@ExecSpace("ServerOnly")
	method void ResolveChargeBlowHits(table targets)
		-- 차지 블로우 1회 판정이 끝난 뒤의 뒤처리. 명중한 대상마다 속성 상태이상을 걸고,
		-- 전기 속성에서 빙결 대상에게 2배가 들어갔다면 전용 히트 이펙트 + 잔류 장판을 남긴다.
		local mode = self._T.chargeBlowMode or 0
		if mode <= 0 then return end
		for _, t in ipairs(targets) do
			self:ApplyChargeBlowStatus(t)
		end
		local shockHits = self._T.chargeBlowShockHits
		if shockHits ~= nil then
			for _, t in ipairs(shockHits) do
				if isvalid(t) then
					self:PlayChargeBlowShockHitEffect(t)
					self:SpawnChargeBlowShockZone(t)
				end
			end
			self._T.chargeBlowShockHits = {}
		end
	end

	@ExecSpace("ServerOnly")
	method void ApplyChargeBlowStatus(Entity target)
		-- 차지 블로우가 실제로 명중한 대상 하나에 현재 속성의 상태이상을 건다.
		if not isvalid(target) then return end
		local mode = self._T.chargeBlowMode or 0
		if mode <= 0 then return end
		if mode == 1 then
			-- (요청) 화상에 걸린 적을 얼음으로 때리면 "화상 저주"가 걸린다 - 그 자리에 20초짜리 저주
			-- 장판을 남기고 3초마다 전투력의 100%를 입힌다. 빙결 여부(50% 확률)와는 별개로 항상 발동한다.
			if self:IsTargetBurning(target) then self:SpawnChargeBlowCurseZone(target) end
			if _UtilLogic:RandomDouble() < 0.5 then self:ApplyChargeBlowFreeze(target) end
		elseif mode == 2 then
			if _UtilLogic:RandomDouble() < 0.5 then self:ApplyChargeBlowBurn(target) end
		elseif mode == 4 then
			self:ApplyChargeBlowStun(target)
		end
	end

	@ExecSpace("ServerOnly")
	method void ApplyChargeBlowFreeze(Entity target)
		-- 3초 빙결(요청으로 1.5초 → 3초). 맞는 모션 그대로 얼어붙어야 하므로 애니메이션 재생속도를 0으로
		-- 세우고, 코마 스턴과 동일하게 AI/이동을 꺼서 행동불능으로 만든다.
		if not isvalid(target) then return end
		local duration = 3.0
		if self._T.chargeBlowFrozen == nil then self._T.chargeBlowFrozen = {} end
		self._T.chargeBlowFrozen[target.Path] = _UtilLogic.ElapsedSeconds + duration

		-- (실측) 이 프로젝트의 배치 몬스터(달팽이)는 AIChaseComponent가 아니라 AIWanderComponent를 쓴다 -
		-- 둘 다 꺼야 실제로 멈춘다. 어느 쪽이 붙어 있든 동작하도록 두 컴포넌트를 모두 처리한다.
		local aiChase = target.AIChaseComponent
		local wasChaseEnabled = isvalid(aiChase) and aiChase.Enable
		if isvalid(aiChase) then aiChase.Enable = false end
		local aiWander = target.AIWanderComponent
		local wasWanderEnabled = isvalid(aiWander) and aiWander.Enable
		if isvalid(aiWander) then aiWander.Enable = false end
		local movement = target.MovementComponent
		local wasMovementEnabled = isvalid(movement) and movement.Enable
		if isvalid(movement) then
			movement:Stop()
			movement.Enable = false
		end
		self:PlayChargeBlowFreezeVisual(target, duration)
		_TimerService:SetTimerOnce(function()
			if isvalid(target) then
				if self._T.chargeBlowFrozen ~= nil then self._T.chargeBlowFrozen[target.Path] = nil end
				if isvalid(aiChase) and wasChaseEnabled then aiChase.Enable = true end
				if isvalid(aiWander) and wasWanderEnabled then aiWander.Enable = true end
				if isvalid(movement) and wasMovementEnabled then movement.Enable = true end
			end
		end, duration)
	end

	@ExecSpace("Multicast")
	method void PlayChargeBlowFreezeVisual(Entity target, number duration)
		-- 몸을 푸른색으로 물들이고 스프라이트 재생을 멈춰 "맞는 모션 그대로" 얼어붙게 한다.
		if not self:IsClient() then return end
		if not isvalid(target) then return end
		local spr = target.SpriteRendererComponent
		if not isvalid(spr) then return end
		local prevAlpha = spr.Color.a
		spr.Color = Color(0.45, 0.65, 1.0, prevAlpha)
		spr.PlayRate = 0
		-- (버그 수정) 복구할 때 캡처해둔 spr 참조를 그대로 쓰면, 그 사이 대상이 죽어 렌더러가 잠깐
		-- 무효해졌을 때 복구가 통째로 건너뛰어져 리스폰된 몬스터가 파란색/정지 상태로 나온다.
		-- 복구 시점에 대상 엔티티에서 렌더러를 다시 가져오고, 원래 색을 "그때 캡처한 값"이 아니라
		-- 기본 흰색으로 되돌린다(빙결 중에 화상이 겹치면 캡처값 자체가 이미 물든 색일 수 있다).
		_TimerService:SetTimerOnce(function()
			self:ClearChargeBlowTint(target)
		end, duration)
	end

	@ExecSpace("ServerOnly")
	method void ApplyChargeBlowBurn(Entity target)
		-- 12초 화상 - 3초마다 전투력의 50%를 4회 입힌다(요청으로 "5초/0.5초마다"에서 변경).
		-- 이미 화상 중이면 새로 걸지 않고 남은 횟수만 다시 채운다.
		if not isvalid(target) then return end
		if self._T.chargeBlowBurning == nil then self._T.chargeBlowBurning = {} end
		local key = target.Path
		local totalTicks = 4          -- 12초 / 3초
		if self._T.chargeBlowBurning[key] ~= nil then
			self._T.chargeBlowBurning[key] = totalTicks
			return
		end
		self._T.chargeBlowBurning[key] = totalTicks
		local combatPower = self._T.pendingCombatPower or 0
		self:PlayChargeBlowBurnVisual(target, 12.0)
		local tick
		tick = function()
			if self._T.chargeBlowBurning == nil then return end
			local left = self._T.chargeBlowBurning[key]
			if left == nil then return end
			if not isvalid(target) then
				self._T.chargeBlowBurning[key] = nil
				return
			end
			local monster = target:GetComponent("script.Monster")
			if monster ~= nil and monster.IsDead then
				-- 죽은 시점에 바로 색을 되돌린다(리스폰된 몬스터가 붉게 물든 채 나오는 것 방지).
				self._T.chargeBlowBurning[key] = nil
				if self._T.chargeBlowFrozen ~= nil then self._T.chargeBlowFrozen[key] = nil end
				self:ClearChargeBlowTint(target)
				return
			end
			self:DealChargeBlowDotDamage(target, combatPower, "dot.chargeblow.burn")
			left = left - 1
			if left <= 0 then
				self._T.chargeBlowBurning[key] = nil
			else
				self._T.chargeBlowBurning[key] = left
				_TimerService:SetTimerOnce(tick, 3.0)
			end
		end
		_TimerService:SetTimerOnce(tick, 3.0)
	end

	@ExecSpace("Multicast")
	method void PlayChargeBlowBurnVisual(Entity target, number duration)
		-- 붉은색 ↔ 검붉은색을 0.15초 간격으로 번갈아 칠해 "반짝거리는" 화상 상태를 표현한다.
		if not self:IsClient() then return end
		if not isvalid(target) then return end
		local spr0 = target.SpriteRendererComponent
		if not isvalid(spr0) then return end
		local prevAlpha = spr0.Color.a
		local endTime = _UtilLogic.ElapsedSeconds + duration
		local bright = true
		local blink
		blink = function()
			-- 매번 대상에서 렌더러를 다시 가져온다 - 캡처 참조를 쓰면 죽었다 살아난 뒤 복구가 누락된다.
			if not isvalid(target) then return end
			local spr = target.SpriteRendererComponent
			if not isvalid(spr) then return end
			if _UtilLogic.ElapsedSeconds >= endTime then
				self:ClearChargeBlowTint(target)
				return
			end
			if bright then
				spr.Color = Color(1.0, 0.25, 0.2, prevAlpha)
			else
				spr.Color = Color(0.45, 0.05, 0.05, prevAlpha)
			end
			bright = not bright
			_TimerService:SetTimerOnce(blink, 0.15)
		end
		blink()
	end

	@ExecSpace("Multicast")
	method void ClearChargeBlowTint(Entity target)
		-- 상태이상 색/정지 연출을 원상복구한다. 죽고 리스폰된 몬스터가 물든 채로 나오는 것을 막기 위해
		-- 상태이상 종료 시점뿐 아니라 사망을 감지한 시점에도 호출한다.
		if not self:IsClient() then return end
		if not isvalid(target) then return end
		local spr = target.SpriteRendererComponent
		if not isvalid(spr) then return end
		spr.Color = Color(1, 1, 1, spr.Color.a)
		spr.PlayRate = 1
	end

	@ExecSpace("ServerOnly")
	method void ApplyChargeBlowStun(Entity target)
		-- 1초 스턴. 어썰터/코마 스턴과 동일한 방식(AI·이동 정지) + 머리 위 스턴 이펙트.
		if not isvalid(target) then return end
		local duration = 1.0
		-- 빙결과 동일 - AIChase/AIWander 중 붙어 있는 쪽을 모두 끈다(달팽이는 AIWander).
		local aiChase = target.AIChaseComponent
		local wasChaseEnabled = isvalid(aiChase) and aiChase.Enable
		if isvalid(aiChase) then aiChase.Enable = false end
		local aiWander = target.AIWanderComponent
		local wasWanderEnabled = isvalid(aiWander) and aiWander.Enable
		if isvalid(aiWander) then aiWander.Enable = false end
		local movement = target.MovementComponent
		local wasMovementEnabled = isvalid(movement) and movement.Enable
		if isvalid(movement) then
			movement:Stop()
			movement.Enable = false
		end
		self:PlayChargeBlowStunEffect(target, duration)
		_TimerService:SetTimerOnce(function()
			if isvalid(target) then
				if isvalid(aiChase) and wasChaseEnabled then aiChase.Enable = true end
				if isvalid(aiWander) and wasWanderEnabled then aiWander.Enable = true end
				if isvalid(movement) and wasMovementEnabled then movement.Enable = true end
			end
		end, duration)
	end

	@ExecSpace("Multicast")
	method void PlayChargeBlowStunEffect(Entity target, number duration)
		-- 드래곤 로어/어썰터 스턴과 동일한 위치(머리 위)에 스턴 이펙트를 띄운다.
		if not self:IsClient() then return end
		if not isvalid(target) then return end
		local headY = 0.5
		local hit = target.HitComponent
		if isvalid(hit) then
			headY = hit.ColliderOffset.y + hit.BoxSize.y / 2
		end
		local serial = _EffectService:PlayEffectAttached("b0bd80f44c1543438ddf8c2c31a0a7ce", target, Vector3(0, headY, 0), 0, Vector3(1, 1, 1), true, {})
		_TimerService:SetTimerOnce(function()
			_EffectService:RemoveEffect(serial)
		end, duration)
	end

	@ExecSpace("ServerOnly")
	method void DealChargeBlowDotDamage(Entity target, number combatPower, string attackInfo)
		-- 장판/화상 같은 지속 피해 1회. 포이즌 미스트(PoisonMistAttack.DealDamage)와 같은 구조 -
		-- 이번 호출 한정 단일 대상으로 좁혀(CurrentTarget) 밀집 지역에서 이웃까지 겹쳐 맞는 것을 막는다.
		if not isvalid(target) then return end
		if attackInfo == "dot.chargeblow.burn" then
			self._T.pendingChargeBlowBurnPower = combatPower
		else
			-- 전기 장판(shock)과 화상 저주(curse)가 같은 전투력 값을 공유한다(배율만 서로 다르다).
			self._T.pendingChargeBlowShockPower = combatPower
		end
		self._T.chargeBlowDotTarget = target
		local pos = target.TransformComponent.WorldPosition
		self:AttackFrom(Vector2(1.4, 2.0), Vector2(pos.x, pos.y + 0.7), attackInfo, CollisionGroups.HitBox)
		self._T.chargeBlowDotTarget = nil
	end

	@ExecSpace("ServerOnly")
	method void SpawnChargeBlowCurseZone(Entity target)
		-- (요청) 화상 저주 - 화상 중인 적을 얼음 속성으로 때렸을 때 그 자리에 생긴다.
		-- 이펙트를 20초간 재생하고, 3초마다 범위 안의 몬스터에게 전투력의 100%를 입힌다.
		-- 구조는 전기 장판(SpawnChargeBlowShockZone)과 동일하다.
		if not isvalid(target) then return end
		local map = self.Entity.CurrentMap
		if not isvalid(map) then return end
		local pos = target.TransformComponent.WorldPosition
		local combatPower = self._T.pendingCombatPower or 0
		local radiusX = 1.2
		local radiusY = 1.2
		self:PlayChargeBlowCurseZoneEffect(Vector3(pos.x, pos.y, 0), 20.0)
		local ticksLeft = 6          -- 20초 동안 3초 간격
		local tick
		tick = function()
			if ticksLeft <= 0 then return end
			ticksLeft = ticksLeft - 1
			if not isvalid(map) then return end
			local monsterComps = map:GetChildComponentsByTypeName("script.Monster", true)
			for _, comp in ipairs(monsterComps) do
				---@type Monster
				local mc = comp
				if isvalid(mc) and isvalid(mc.Entity) and not mc.IsDead then
					local mp = mc.Entity.TransformComponent.WorldPosition
					if math.abs(mp.x - pos.x) <= radiusX and math.abs(mp.y - pos.y) <= radiusY then
						self:DealChargeBlowDotDamage(mc.Entity, combatPower, "dot.chargeblow.curse")
					end
				end
			end
			_TimerService:SetTimerOnce(tick, 3.0)
		end
		_TimerService:SetTimerOnce(tick, 3.0)
		log("[ChargeBlow] 화상 저주 장판 생성 x=" .. string.format("%.2f", pos.x) .. " y=" .. string.format("%.2f", pos.y))
	end

	@ExecSpace("Multicast")
	method void PlayChargeBlowCurseZoneEffect(Vector3 pos, number duration)
		-- 화상 저주 장판 시각 표현 - 20초간 그 자리에 루프 재생하고 끝나면 제거한다.
		-- instigator에 nil을 넘기면 조용히 렌더링만 생략되므로 맵 엔티티를 넘긴다.
		if not self:IsClient() then return end
		local mapEntity = self.Entity.CurrentMap
		if not isvalid(mapEntity) then return end
		-- (요청) 캐릭터/몬스터와 겹쳐도 가리지 않도록 바닥 장판처럼 뒤에 깐다.
		-- (실측 이력) OrderInLayer만 낮춰서는 안 가려진다 - 이펙트의 기본 SortingLayer가 아바타 레이어보다
		-- 앞이라 레이어 자체를 아바타/몬스터와 같은 "MapLayer0"으로 맞춘 뒤 OrderInLayer를 아바타(4)보다
		-- 작게 줘야 확실히 뒤로 간다(파워가드 이펙트가 캐릭터를 가리던 것과 같은 원인).
		-- (요청) 투명도 60%. OrderInLayer는 "지형보다 앞 + 캐릭터/몬스터보다 뒤"인 좁은 구간을 노린다 -
		-- 아바타 바디가 같은 MapLayer0의 OrderInLayer=4(실측)라 그보다 1 작은 3으로 둔다.
		-- 0으로 두면 지형(타일맵)에까지 가려진다.
		local zoneOptions = { ["SortingLayer"] = "MapLayer0", ["OrderInLayer"] = 3, ["Alpha"] = 0.6 }
		local serial = _EffectService:PlayEffect("288e10be2948421ebd107829c10f07ba", mapEntity, pos, 0, Vector3(1, 1, 1), true, zoneOptions)
		_TimerService:SetTimerOnce(function()
			_EffectService:RemoveEffect(serial)
		end, duration)
	end

	@ExecSpace("ServerOnly")
	method void SpawnChargeBlowShockZone(Entity target)
		-- (전기) 빙결된 적에게 2배 데미지가 들어간 자리에 장판을 남긴다.
		-- (요청 변경) 이펙트는 1회만 재생하고, 판정은 0.4초마다 전투력의 500%를 총 3번 준다.
		-- 별도의 장판 모델을 새로 만들지 않고, 시각 표현은 EffectService 1회 재생으로,
		-- 판정은 이 컴포넌트의 타이머 + 좌표 스캔으로 처리한다(포이즌 미스트 존과 같은 스캔 방식).
		if not isvalid(target) then return end
		local map = self.Entity.CurrentMap
		if not isvalid(map) then return end
		local pos = target.TransformComponent.WorldPosition
		local combatPower = self._T.pendingCombatPower or 0
		local radiusX = 1.2
		local radiusY = 1.2
		self:PlayChargeBlowShockZoneEffect(Vector3(pos.x, pos.y, 0))
		local ticksLeft = 3
		local tick
		tick = function()
			if ticksLeft <= 0 then return end
			ticksLeft = ticksLeft - 1
			if not isvalid(map) then return end
			local monsterComps = map:GetChildComponentsByTypeName("script.Monster", true)
			for _, comp in ipairs(monsterComps) do
				---@type Monster
				local mc = comp
				if isvalid(mc) and isvalid(mc.Entity) and not mc.IsDead then
					local mp = mc.Entity.TransformComponent.WorldPosition
					if math.abs(mp.x - pos.x) <= radiusX and math.abs(mp.y - pos.y) <= radiusY then
						self:DealChargeBlowDotDamage(mc.Entity, combatPower, "dot.chargeblow.shock")
					end
				end
			end
			_TimerService:SetTimerOnce(tick, 0.4)
		end
		_TimerService:SetTimerOnce(tick, 0.4)
		log("[ChargeBlow] 전기 장판 생성 x=" .. string.format("%.2f", pos.x) .. " y=" .. string.format("%.2f", pos.y))
	end

	@ExecSpace("Multicast")
	method void PlayChargeBlowShockZoneEffect(Vector3 pos)
		-- 장판 시각 표현 - (요청) 반복 재생하지 않고 그 자리에서 딱 1회만 재생한다.
		-- (버그 수정) instigator에 nil을 넘기면 데미지 판정은 도는데 이펙트가 화면에 아예 안 나온다.
		-- 이 파일의 다른 좌표 고정 이펙트들과 동일하게 맵 엔티티를 instigator로 넘긴다.
		if not self:IsClient() then return end
		local mapEntity = self.Entity.CurrentMap
		if not isvalid(mapEntity) then return end
		_EffectService:PlayEffect("6beb8d728a7d4cca92eb7f4d2d9c45f9", mapEntity, pos, 0, Vector3(1, 1, 1), false, {})
	end

	@ExecSpace("Multicast")
	method void PlayChargeBlowShockHitEffect(Entity target)
		-- 빙결된 적에게 2배 데미지가 들어갔을 때의 전용 히트 이펙트.
		if not self:IsClient() then return end
		if not isvalid(target) then return end
		_EffectService:PlayEffectAttached("01a549ce77c14d7582799adeaab1ed2f", target, Vector3(0, 0.4, 0), 0, Vector3(1, 1, 1), false, {})
	end

	method integer GetChargeBlowTrailRow(string motionName)
		-- 모션 → 속성 시트의 행 번호. 요청대로 배정한다:
		--   1행 → swingO2 / 2행 → swingO1 / 3행 → 찌르기(stab 계열) / 4행 → swingO3·swingOF
		-- 한손검 외(창/두손검) 모션으로 나갈 때를 대비해 stab 계열은 3행, 나머지는 4행으로 폴백한다.
		if motionName == "swingO2" then return 1 end
		if motionName == "swingO1" then return 2 end
		if string.sub(tostring(motionName), 1, 4) == "stab" then return 3 end
		return 4
	end

	method number GetChargeBlowTrailScaleY(string motionName)
		-- (요청) swingO1 전용 시트는 초승달이 셀을 꽉 채우는 디자인이라 화면에서 너무 커 보인다 -
		-- 가로는 두고 세로만 2/3로 눌러 쓴다. 나머지 모션은 정비율(1.0).
		if motionName == "swingO1" then return 2.0 / 3.0 end
		return 1.0
	end

	method boolean IsChargeBlowTrailFlippedY(string motionName)
		-- (요청) swingO3의 궤적만 위아래를 뒤집어 재생한다. swingO3과 파이널의 swingOF가 같은 4행을
		-- 공유하는데, 세로 반전으로 두 모션의 궤적을 구분한다.
		-- (이전에 프레임 역순 재생으로 구분했던 방식은 요청대로 철회했다.)
		return motionName == "swingO3"
	end

	method boolean IsChargeBlowTrailMirrored(integer chargeMode, integer row)
		-- 원본 그림이 기본 방향(왼쪽 보기 기준)과 좌우가 반대로 그려진 경우의 예외 표.
		-- 원소/행 단위라 여기 한 곳에서만 판단한다.
		--   1행(swingO2) : 불(디바인 스윙)만 다른 원소와 반대로 그려져 있다.
		--   2행(swingO1) : 전용 시트(swingo1궤적.png)는 기본 방향과 같아 보정하지 않는다
		--                  (한 번 보정을 넣었다가 방향이 반대라는 확인을 받고 되돌렸다).
		if chargeMode == 2 and row == 1 then return true end
		return false
	end

	method table GetChargeBlowTrailFrames(integer chargeMode, string motionName)
		-- 차지 블로우 속성별 검 궤적 프레임 4장을 돌려준다(없으면 nil → 기본 궤적으로 폴백).
		-- 원본 시트: /Users/florence/Desktop/속성궤적/{얼음,전기,불,성}.png (1280x1280, 320px 셀 4행x4열).
		-- 잘라낸 프레임과 RUID 대응표: msw-dev-tools/resources/차지블로우속성궤적/
		if chargeMode == nil or chargeMode <= 0 then return nil end
		if self._T.chargeBlowTrailFrames == nil then
			self:BuildChargeBlowTrailFrames()
		end
		local frames = self._T.chargeBlowTrailFrames
		if frames == nil then return nil end
		local elem = frames[chargeMode]
		if elem == nil then return nil end
		return elem[self:GetChargeBlowTrailRow(motionName)]
	end

	method void SpawnChargeBlowTrailFrames(table frames, number dirX, number offsetX, number offsetY, number scaleValue, boolean mirrored, boolean flipY, number scaleYMul)
		-- 차지 블로우 속성 궤적 재생. 업로드는 sprite(정지 이미지)만 가능해 애니메이션클립을 만들 수 없으므로,
		-- 엔티티 하나의 ClipRUID를 프레임 순서대로 갈아끼워 클립처럼 재생한다
		-- (SpawnAdvSpearHitFrames / SpawnSlashBlastCastEffect와 동일한 프레임 교체 패턴).
		-- mirrored=true면 원본 그림이 다른 속성과 좌우가 반대로 그려진 경우라 뒤집기를 반전한다.
		if frames == nil or #frames == 0 then return end
		self._T.trailFxSeq = (self._T.trailFxSeq or 0) + 1
		local fx = _SpawnService:SpawnByModelId("spearburstfadingeffect", "ChargeBlowTrailFx" .. tostring(self._T.trailFxSeq), Vector3(offsetX * dirX, offsetY, 0), self.Entity)
		if not isvalid(fx) then return end
		fx:AddComponent("script.SpearBurstFadingEffect")
		local comp = fx:GetComponent("script.SpearBurstFadingEffect")
		local frameInterval = 0.05
		if isvalid(comp) then
			-- 원본 이미지는 왼쪽 방향 - 오른쪽 볼 때 좌우 반전(좌우가 반대로 그려진 시트는 조건을 뒤집는다).
			if mirrored == true then
				comp.IsFlipX = dirX < 0
			else
				comp.IsFlipX = dirX > 0
			end
			comp.IsFlipY = (flipY == true)
			-- (요청) 모든 차지 스킬 궤적의 투명도는 75%.
			comp.StartAlpha = 0.75
			comp.EndAlpha = 0.75           -- 프레임 재생 중에는 페이드하지 않는다(마지막 프레임 뒤 Destroy가 담당)
			comp.HoldDuration = 1.0        -- 전체 수명보다 길게 잡아 트윈이 아예 시작되지 않게 한다
			comp.TweenDuration = 0.0
			comp.StartScale = scaleValue
			comp.EndScale = scaleValue
			comp.ScaleYMul = scaleYMul or 1.0
			comp.OrderInLayerValue = 5     -- 캐릭터보다 앞에 그려지도록
			comp.ClipRUID = frames[1]      -- 마지막에 설정(클라 OnSyncProperty가 실제 적용을 트리거)
		end
		for i = 2, #frames do
			local frameRuid = frames[i]
			_TimerService:SetTimerOnce(function()
				if isvalid(comp) then comp.ClipRUID = frameRuid end
			end, (i - 1) * frameInterval)
		end
		_TimerService:SetTimerOnce(function()
			if isvalid(fx) then fx:Destroy() end
		end, #frames * frameInterval + 0.03)
	end

	@ExecSpace("Multicast")
	method void PlayChargeBlowHitSound(integer hitCount)
		-- 차지 블로우 타격음. 차지 블로우는 파워스트라이크의 이미지 이펙트를 전혀 쓰지 않으므로
		-- PlayPowerStrikeEffects를 호출하지 않는데, 그 안에 같이 들어 있던 타격 사운드는 남겨야 한다.
		-- 원본과 동일하게 실제로 몬스터에 적중했을 때만 울린다(빗나가면 무음).
		if not self:IsClient() then return end
		if hitCount == nil or hitCount <= 0 then return end
		_SoundService:PlaySound("d3205fdd08e34b68bc01292a997531ed", 1.0)
	end

	@ExecSpace("Multicast")
	method void PlayPowerStrikeEffects(Entity attacker, number dirX, table targets, string swingEffectRUID, string swingEffectName, boolean isFinal)
		        -- 스윙 궤적 이펙트 + 몬스터 뒤쪽 후방 이펙트 재생. 호출 시점 자체가 이미 NotifyMotionEnded(모션 종료) 시점이므로 즉시 재생한다.
		        -- swingEffectRUID/Name은 호출부(AttackPowerStrike)에서 GetPowerStrikeSwing()으로 한 번만 뽑아 전달한 값 -
		        -- 여기서 다시 뽑으면 캐릭터 모션(PlayAttackMotion)과 서로 다른 자세로 어긋날 수 있다.
		        -- Multicast는 서버 자신도 함께 실행하므로 클라이언트에서만 실행되게 막는다 - 안 그러면 서버 쪽 실행이 fallback RUID로 별도의 스윙 이펙트를 한 번 더 재생해 2개가 겹쳐 보인다.
		        if not self:IsClient() then return end
		        if not isvalid(attacker) then return end
		        local backEffectRUID  = "dad03b3a528348bf98295b01edd621a4"
		        local swingSoundRUID  = "d3205fdd08e34b68bc01292a997531ed"

		        log("[PowerStrike] 파워스트라이크 스윙 재생: " .. tostring(swingEffectName) .. " (RUID=" .. tostring(swingEffectRUID) .. ")")
		        -- 스킬 이펙트 투명도 80%. 궤적 이펙트 RUID가 아직 확보되지 않은 모션(stabT1/stabT2/stabPF 등)은
		        -- 빈 문자열로 들어오므로 이펙트 재생만 건너뛴다(모션/사운드/히트 이펙트는 그대로).
		        if swingEffectRUID ~= nil and swingEffectRUID ~= "" then
		            local swingOptions = { ["FlipX"] = dirX > 0, ["Alpha"] = 0.8 }
		            _EffectService:PlayEffectAttached(swingEffectRUID, attacker, Vector3(0.1 * dirX, 0, 0), 0, Vector3(1, 1, 1), false, swingOptions)
		            -- 쉐도우 파트너: 스윙 궤적 이펙트를 x축 뒤쪽에서 투명도 70%로 복제 재생(그림자 몫 - 데미지 없음)
		            self:EchoShadowSkillEffectAttached(swingEffectRUID, attacker, Vector3(0.1 * dirX, 0, 0), 0, Vector3(1, 1, 1), swingOptions, dirX)
		        end

		        -- (기능 변경) "파이널어택이 뜰 때 원래 히트 이펙트를 대체해서 파이널어택 히트 이펙트만 떠야
		        -- 한다"는 요청 - isFinal이면 몬스터 뒤쪽 후방 히트 이펙트(backEffectRUID)를 재생하지 않는다.
		        -- 호출부(NotifyFinalMotionEnded)가 곧이어 PlayFinalAttackHitEffect로 전용 이펙트를 대신 띄운다.
		        -- 스윙 궤적 이펙트(위)는 캐릭터 시전 모션에 붙는 연출이라 파이널어택에서도 그대로 유지한다.
		        if isFinal then return end

		        -- 스윙 사운드는 실제로 몬스터에 적중했을 때만 후방 이펙트와 함께 재생 (빗나가면 들리지 않아야 함)
		        for _, target in ipairs(targets) do
		            if isvalid(target) then
		                local flipBack   = dirX > 0
		                local backOffset = dirX > 0 and 0.4 or -0.4
		                local backOptions = { ["FlipX"] = flipBack }
		                _EffectService:PlayEffectAttached(backEffectRUID, target, Vector3(backOffset, 0, 0), 0, Vector3(1, 1, 1), false, backOptions)
		                -- 쉐도우 파트너: 같은 히트 이펙트를 0.25초 시간차를 두고 그 자리에 한 번 더(70% 투명도) 재생
		                self:EchoShadowHitEffect(backEffectRUID, target, Vector3(backOffset, 0, 0), 0, Vector3(1, 1, 1), backOptions)
		                _SoundService:PlaySound(swingSoundRUID, 1.0)
		            end
		        end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleStateChangeEvent(StateChangeEvent event)
		        -- 파워스트라이크 실제 모션 재생 구간(_T.isMotionPlaying, 0~0.25초)에 착지(FALL/JUMP -> IDLE) 등 다른 상태
		        -- 전환이 끼어들면 StateToAvatarBodyActionSheet의 기본 모션(stand/walk/fall 등)이 재생되어 스킬 모션이
		        -- 끊기는 문제가 있었다 - 이 구간에서만 방향을 다시 고정하고 스킬 모션을 즉시 다시 덮어씌운다.
		        --
		        -- 모션 재생이 끝난 뒤(0.25~0.65초, 추가 이동 봉인 구간)에는 모션을 다시 덮어씌우지 않는다. 이 구간에서도
		        -- 매번 재적용하면, 방향키를 눌러 MOVE 상태로 전환될 때마다 이미 끝난 스윙 모션이 처음부터 다시 재생되어
		        -- "방향을 바꾸면 모션이 한 번 더 재생된다"는 문제가 있었다. 대신 IDLE이 아닌 상태로 전환되려는 시도만
		        -- 즉시 IDLE로 되돌려서, 이동 봉인이 완전히 풀릴 때까지(RestoreControl) 겉보기에도 계속 서 있게 만든다.
		        if event.CurrentStateName == "DEAD" then return end
		        -- (요청) 브랜디쉬 시전 중에는 상태 전환이 몸동작을 건드리지 못하게 전부 건너뛴다.
		        -- 시전 중 피격 시 HIT로 상태가 바뀌는데, 아래 두 경로가 모두 새 클립을 내려보내 브랜디쉬
		        -- 자세를 끊는다: (1) isMotionPlaying 구간의 모션 재적용(= 스윙이 처음부터 다시 재생됨),
		        -- (2) isDirectionLocked 구간의 강제 IDLE 복귀(= IDLE에 매핑된 stand가 내려감).
		        -- HIT 몸동작 매핑은 AttackBrandish가 이미 빼뒀으므로, 여기서 아무것도 안 하면 상태만
		        -- 조용히 HIT에 머물고 화면에는 브랜디쉬 자세가 그대로 이어진다. 시전이 끝나 가드가 풀리면
		        -- PlayerHit의 클라이언트 워치독(0.1초마다 계속 돌고 있다)이 곧바로 IDLE로 되돌리므로
		        -- HIT 상태에 갇히지 않는다.
		        if self._T.brandishMotionGuard then return end
		        -- (기능 추가) "가만히 있을 때 기본모션으로 돌아갔다가 다시 숨고르기로 가서 불안정해 보인다 -
		        -- 기본모션으로 바뀌는 바로 그 타이밍에 숨고르기를 넣어달라"는 요청 - 각 스킬 정리용
		        -- IDLE→MOVE→IDLE 토글이 실제로 "IDLE"(기본 모션)로 전환되는 이 이벤트를 감지해, 그 순간
		        -- 지연 없이 곧바로 숨고르기로 덮어써서 기본 모션이 화면에 보일 틈을 없앤다.
		        if self._T.isBreatherArmed and event.CurrentStateName == "IDLE" then
		            self._T.isBreatherArmed = false
		            self:StartBreatherNow(self._T.breatherArmedAttacker, self._T.breatherToken)
		        end
		        if self._T.isMotionPlaying then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedDirX
		            end
		            local motionName = self._T.lockedMotionName
		            if not motionName then return end
		            local avatarRenderer = self.Entity.AvatarRendererComponent
		            if not isvalid(avatarRenderer) then return end
		            local body = avatarRenderer:GetBodyEntity()
		            if not isvalid(body) then return end
		            local motionEvent = ActionStateChangedEvent(motionName, motionName, self._T.lockedPlayRate or 1.0, SpriteAnimClipPlayType.Onetime)
		            body:SendEvent(motionEvent)
		            log("[PowerStrike] HandleStateChangeEvent re-applied motion over " .. tostring(event.CurrentStateName) .. ": " .. tostring(motionName))
		            return
		        end
		        if self._T.isDirectionLocked and event.CurrentStateName ~= "IDLE" then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedDirX
		            end
		            local sc = self.Entity.StateComponent
		            if isvalid(sc) then
		                sc:ChangeState("IDLE")
		                log("[PowerStrike] HandleStateChangeEvent forced back to IDLE from " .. tostring(event.CurrentStateName))
		            end
		        end
		
		        -- 럭키세븐 전용 처리 (파워스트라이크/슬래쉬블래스트와 동일한 패턴이지만 별도의 플래그를 사용 - 서로 간섭하지 않는다)
		        if self._T.isLuckySevenMotionPlaying then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedLuckySevenDirX
		            end
		            local motionName = self._T.lockedLuckySevenMotionName
		            if not motionName then return end
		            local avatarRenderer = self.Entity.AvatarRendererComponent
		            if not isvalid(avatarRenderer) then return end
		            local body = avatarRenderer:GetBodyEntity()
		            if not isvalid(body) then return end
		            local motionEvent = ActionStateChangedEvent(motionName, motionName, self._T.lockedLuckySevenPlayRate or 1.0, SpriteAnimClipPlayType.Onetime)
		            body:SendEvent(motionEvent)
		            log("[LuckySeven] HandleStateChangeEvent re-applied motion over " .. tostring(event.CurrentStateName) .. ": " .. tostring(motionName))
		            return
		        end
		        if self._T.isLuckySevenDirectionLocked and event.CurrentStateName ~= "IDLE" then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedLuckySevenDirX
		            end
		            local sc = self.Entity.StateComponent
		            if isvalid(sc) then
		                sc:ChangeState("IDLE")
		                log("[LuckySeven] HandleStateChangeEvent forced back to IDLE from " .. tostring(event.CurrentStateName))
		            end
		        end

		        -- 슬래쉬블래스트 전용 처리 (파워스트라이크와 동일한 패턴이지만 별도의 플래그를 사용 - 서로 간섭하지 않는다)
		        if self._T.isSlashMotionPlaying then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedSlashDirX
		            end
		            local motionName = self._T.lockedSlashMotionName
		            if not motionName then return end
		            local avatarRenderer = self.Entity.AvatarRendererComponent
		            if not isvalid(avatarRenderer) then return end
		            local body = avatarRenderer:GetBodyEntity()
		            if not isvalid(body) then return end
		            local motionEvent = ActionStateChangedEvent(motionName, motionName, self._T.lockedSlashPlayRate or 1.0, SpriteAnimClipPlayType.Onetime)
		            body:SendEvent(motionEvent)
		            log("[SlashBlast] HandleStateChangeEvent re-applied motion over " .. tostring(event.CurrentStateName) .. ": " .. tostring(motionName))
		            return
		        end
		        if self._T.isSlashDirectionLocked and event.CurrentStateName ~= "IDLE" then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedSlashDirX
		            end
		            local sc = self.Entity.StateComponent
		            if isvalid(sc) then
		                sc:ChangeState("IDLE")
		                log("[SlashBlast] HandleStateChangeEvent forced back to IDLE from " .. tostring(event.CurrentStateName))
		            end
		        end

		        -- 더블스탭 전용 처리 (파워스트라이크와 동일한 패턴이지만 별도의 플래그를 사용 - 서로 간섭하지 않는다)
		        if self._T.isDoubleStabMotionPlaying then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedDoubleStabDirX
		            end
		            local motionName = self._T.lockedDoubleStabMotionName
		            if not motionName then return end
		            local avatarRenderer = self.Entity.AvatarRendererComponent
		            if not isvalid(avatarRenderer) then return end
		            local body = avatarRenderer:GetBodyEntity()
		            if not isvalid(body) then return end
		            local motionEvent = ActionStateChangedEvent(motionName, motionName, self._T.lockedDoubleStabPlayRate or 1.0, SpriteAnimClipPlayType.Onetime)
		            body:SendEvent(motionEvent)
		            log("[DoubleStab] HandleStateChangeEvent re-applied motion over " .. tostring(event.CurrentStateName) .. ": " .. tostring(motionName))
		            return
		        end
		        if self._T.isDoubleStabDirectionLocked and event.CurrentStateName ~= "IDLE" then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedDoubleStabDirX
		            end
		            local sc = self.Entity.StateComponent
		            if isvalid(sc) then
		                sc:ChangeState("IDLE")
		                log("[DoubleStab] HandleStateChangeEvent forced back to IDLE from " .. tostring(event.CurrentStateName))
		            end
		        end

		        -- 새비지블로우 전용 처리 (더블스탭과 동일한 패턴이지만 별도의 플래그를 사용 - 서로 간섭하지 않는다)
		        -- 돌진 - 이동 중 시전하면 MOVE 상태 전환이 걷기 모션을 내보내 돌진 자세를 덮어쓴다.
		        -- 파워스트라이크/새비지블로우와 같은 패턴으로, 상태가 바뀔 때마다 잡고 있어야 할 포즈를
		        -- (같은 프레임으로) 다시 적용해 자세를 유지한다.
		        if self._T.isRushMotionPlaying then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedRushDirX
		            end
		            local motionName = self._T.lockedRushMotionName
		            if not motionName then return end
		            local avatarRenderer = self.Entity.AvatarRendererComponent
		            if not isvalid(avatarRenderer) then return end
		            local body = avatarRenderer:GetBodyEntity()
		            if not isvalid(body) then return end
		            local frameIdx = self._T.lockedRushFrame or 1
		            body:SendEvent(ActionStateChangedEvent(motionName, motionName, 1.0, SpriteAnimClipPlayType.Onetime, frameIdx, frameIdx))
		            log("[Rush] HandleStateChangeEvent re-applied pose over " .. tostring(event.CurrentStateName) .. ": " .. tostring(motionName) .. " frame=" .. tostring(frameIdx))
		            return
		        end

		        if self._T.isSavageBlowMotionPlaying then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedSavageBlowDirX
		            end
		            -- 8단 조합 모션 중이라면 지금 잡고 있어야 할 포즈(액션 + 프레임)를 그대로 다시 적용한다.
		            local action = self._T.lockedSavageBlowAction
		            if not action then return end
		            local avatarRenderer = self.Entity.AvatarRendererComponent
		            if not isvalid(avatarRenderer) then return end
		            local body = avatarRenderer:GetBodyEntity()
		            if not isvalid(body) then return end
		            local frameIdx = self._T.lockedSavageBlowFrameIdx or 0
		            local motionEvent = ActionStateChangedEvent(action, action, 0.001, SpriteAnimClipPlayType.Onetime, frameIdx, frameIdx + 1)
		            body:SendEvent(motionEvent)
		            log("[SavageBlow] HandleStateChangeEvent re-applied pose over " .. tostring(event.CurrentStateName) .. ": " .. tostring(action) .. " frame=" .. tostring(frameIdx))
		            return
		        end
		        if self._T.isSavageBlowDirectionLocked and event.CurrentStateName ~= "IDLE" then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedSavageBlowDirX
		            end
		            local sc = self.Entity.StateComponent
		            if isvalid(sc) then
		                sc:ChangeState("IDLE")
		                log("[SavageBlow] HandleStateChangeEvent forced back to IDLE from " .. tostring(event.CurrentStateName))
		            end
		        end

		        -- 매직클로 전용 처리 (다른 스킬과 동일한 패턴이지만 별도의 플래그를 사용 - 서로 간섭하지 않는다)
		        if self._T.isMagicClawMotionPlaying then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedMagicClawDirX
		            end
		            local motionName = self._T.lockedMagicClawMotionName
		            if not motionName then return end
		            local avatarRenderer = self.Entity.AvatarRendererComponent
		            if not isvalid(avatarRenderer) then return end
		            local body = avatarRenderer:GetBodyEntity()
		            if not isvalid(body) then return end
		            local motionEvent = ActionStateChangedEvent(motionName, motionName, self._T.lockedMagicClawPlayRate or 1.0, SpriteAnimClipPlayType.Onetime)
		            body:SendEvent(motionEvent)
		            log("[MagicClaw] HandleStateChangeEvent re-applied motion over " .. tostring(event.CurrentStateName) .. ": " .. tostring(motionName))
		            return
		        end
		        if self._T.isMagicClawDirectionLocked and event.CurrentStateName ~= "IDLE" then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedMagicClawDirX
		            end
		            local sc = self.Entity.StateComponent
		            if isvalid(sc) then
		                sc:ChangeState("IDLE")
		                log("[MagicClaw] HandleStateChangeEvent forced back to IDLE from " .. tostring(event.CurrentStateName))
		            end
		        end

		        -- 썬더볼트 전용 처리 (매직클로와 동일한 패턴이지만 별도의 플래그를 사용 - 서로 간섭하지 않는다)
		        if self._T.isThunderboltMotionPlaying then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedThunderboltDirX
		            end
		            local motionName = self._T.lockedThunderboltMotionName
		            if not motionName then return end
		            local avatarRenderer = self.Entity.AvatarRendererComponent
		            if not isvalid(avatarRenderer) then return end
		            local body = avatarRenderer:GetBodyEntity()
		            if not isvalid(body) then return end
		            local motionEvent = ActionStateChangedEvent(motionName, motionName, self._T.lockedThunderboltPlayRate or 1.0, SpriteAnimClipPlayType.Onetime)
		            body:SendEvent(motionEvent)
		            log("[Thunderbolt] HandleStateChangeEvent re-applied motion over " .. tostring(event.CurrentStateName) .. ": " .. tostring(motionName))
		            return
		        end
		        if self._T.isThunderboltDirectionLocked and event.CurrentStateName ~= "IDLE" then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedThunderboltDirX
		            end
		            local sc = self.Entity.StateComponent
		            if isvalid(sc) then
		                sc:ChangeState("IDLE")
		                log("[Thunderbolt] HandleStateChangeEvent forced back to IDLE from " .. tostring(event.CurrentStateName))
		            end
		        end

		        -- 힐 전용 처리 (다른 스킬과 동일한 패턴이지만 별도의 플래그를 사용 - 서로 간섭하지 않는다)
		        if self._T.isHealMotionPlaying then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedHealDirX
		            end
		            local motionName = self._T.lockedHealMotionName
		            if not motionName then return end
		            local avatarRenderer = self.Entity.AvatarRendererComponent
		            if not isvalid(avatarRenderer) then return end
		            local body = avatarRenderer:GetBodyEntity()
		            if not isvalid(body) then return end
		            local motionEvent = ActionStateChangedEvent(motionName, motionName, self._T.lockedHealPlayRate or 1.0, SpriteAnimClipPlayType.Onetime)
		            body:SendEvent(motionEvent)
		            log("[Heal] HandleStateChangeEvent re-applied motion over " .. tostring(event.CurrentStateName) .. ": " .. tostring(motionName))
		            return
		        end
		        if self._T.isHealDirectionLocked and event.CurrentStateName ~= "IDLE" then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedHealDirX
		            end
		            local sc = self.Entity.StateComponent
		            if isvalid(sc) then
		                sc:ChangeState("IDLE")
		                log("[Heal] HandleStateChangeEvent forced back to IDLE from " .. tostring(event.CurrentStateName))
		            end
		        end

		        -- 파이어에로우 전용 처리 (다른 스킬과 동일한 패턴이지만 별도의 플래그를 사용 - 서로 간섭하지 않는다)
		        if self._T.isFireArrowMotionPlaying then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedFireArrowDirX
		            end
		            local motionName = self._T.lockedFireArrowMotionName
		            if not motionName then return end
		            local avatarRenderer = self.Entity.AvatarRendererComponent
		            if not isvalid(avatarRenderer) then return end
		            local body = avatarRenderer:GetBodyEntity()
		            if not isvalid(body) then return end
		            local motionEvent = ActionStateChangedEvent(motionName, motionName, self._T.lockedFireArrowPlayRate or 1.0, SpriteAnimClipPlayType.Onetime)
		            body:SendEvent(motionEvent)
		            log("[FireArrow] HandleStateChangeEvent re-applied motion over " .. tostring(event.CurrentStateName) .. ": " .. tostring(motionName))
		            return
		        end
		        if self._T.isFireArrowDirectionLocked and event.CurrentStateName ~= "IDLE" then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedFireArrowDirX
		            end
		            local sc = self.Entity.StateComponent
		            if isvalid(sc) then
		                sc:ChangeState("IDLE")
		                log("[FireArrow] HandleStateChangeEvent forced back to IDLE from " .. tostring(event.CurrentStateName))
		            end
		        end

		        -- 아이언에로우 전용 처리 (파이어에로우와 동일한 패턴이지만 별도의 플래그를 사용 - 서로 간섭하지 않는다)
		        if self._T.isIronArrowMotionPlaying then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedIronArrowDirX
		            end
		            local motionName = self._T.lockedIronArrowMotionName
		            if not motionName then return end
		            local avatarRenderer = self.Entity.AvatarRendererComponent
		            if not isvalid(avatarRenderer) then return end
		            local body = avatarRenderer:GetBodyEntity()
		            if not isvalid(body) then return end
		            local motionEvent = ActionStateChangedEvent(motionName, motionName, self._T.lockedIronArrowPlayRate or 1.0, SpriteAnimClipPlayType.Onetime)
		            body:SendEvent(motionEvent)
		            log("[IronArrow] HandleStateChangeEvent re-applied motion over " .. tostring(event.CurrentStateName) .. ": " .. tostring(motionName))
		            return
		        end
		        if self._T.isIronArrowDirectionLocked and event.CurrentStateName ~= "IDLE" then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedIronArrowDirX
		            end
		            local sc = self.Entity.StateComponent
		            if isvalid(sc) then
		                sc:ChangeState("IDLE")
		                log("[IronArrow] HandleStateChangeEvent forced back to IDLE from " .. tostring(event.CurrentStateName))
		            end
		        end

		        -- 더블샷 전용 처리 (다른 화살 스킬과 동일한 패턴이지만 별도의 플래그를 사용 - 서로 간섭하지 않는다)
		        if self._T.isDoubleShotMotionPlaying then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedDoubleShotDirX
		            end
		            local motionName = self._T.lockedDoubleShotMotionName
		            if not motionName then return end
		            local avatarRenderer = self.Entity.AvatarRendererComponent
		            if not isvalid(avatarRenderer) then return end
		            local body = avatarRenderer:GetBodyEntity()
		            if not isvalid(body) then return end
		            local motionEvent = ActionStateChangedEvent(motionName, motionName, self._T.lockedDoubleShotPlayRate or 1.0, SpriteAnimClipPlayType.Onetime)
		            body:SendEvent(motionEvent)
		            log("[DoubleShot] HandleStateChangeEvent re-applied motion over " .. tostring(event.CurrentStateName) .. ": " .. tostring(motionName))
		            return
		        end
		        if self._T.isDoubleShotDirectionLocked and event.CurrentStateName ~= "IDLE" then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedDoubleShotDirX
		            end
		            local sc = self.Entity.StateComponent
		            if isvalid(sc) then
		                sc:ChangeState("IDLE")
		                log("[DoubleShot] HandleStateChangeEvent forced back to IDLE from " .. tostring(event.CurrentStateName))
		            end
		        end

		        -- 에로우 블로우 전용 처리 (아이언에로우와 동일한 패턴이지만 별도의 플래그를 사용 - 서로 간섭하지 않는다)
		        if self._T.isArrowBlowMotionPlaying then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedArrowBlowDirX
		            end
		            local motionName = self._T.lockedArrowBlowMotionName
		            if not motionName then return end
		            local avatarRenderer = self.Entity.AvatarRendererComponent
		            if not isvalid(avatarRenderer) then return end
		            local body = avatarRenderer:GetBodyEntity()
		            if not isvalid(body) then return end
		            local motionEvent = ActionStateChangedEvent(motionName, motionName, self._T.lockedArrowBlowPlayRate or 1.0, SpriteAnimClipPlayType.Onetime)
		            body:SendEvent(motionEvent)
		            log("[ArrowBlow] HandleStateChangeEvent re-applied motion over " .. tostring(event.CurrentStateName) .. ": " .. tostring(motionName))
		            return
		        end
		        if self._T.isArrowBlowDirectionLocked and event.CurrentStateName ~= "IDLE" then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedArrowBlowDirX
		            end
		            local sc = self.Entity.StateComponent
		            if isvalid(sc) then
		                sc:ChangeState("IDLE")
		                log("[ArrowBlow] HandleStateChangeEvent forced back to IDLE from " .. tostring(event.CurrentStateName))
		            end
		        end

		        -- 포이즌 미스트 전용 처리 (힐과 동일한 패턴이지만 별도의 플래그를 사용 - 서로 간섭하지 않는다)
		        if self._T.isPoisonMistMotionPlaying then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedPoisonMistDirX
		            end
		            local motionName = self._T.lockedPoisonMistMotionName
		            if not motionName then return end
		            local avatarRenderer = self.Entity.AvatarRendererComponent
		            if not isvalid(avatarRenderer) then return end
		            local body = avatarRenderer:GetBodyEntity()
		            if not isvalid(body) then return end
		            local motionEvent = ActionStateChangedEvent(motionName, motionName, self._T.lockedPoisonMistPlayRate or 1.0, SpriteAnimClipPlayType.Onetime)
		            body:SendEvent(motionEvent)
		            log("[PoisonMist] HandleStateChangeEvent re-applied motion over " .. tostring(event.CurrentStateName) .. ": " .. tostring(motionName))
		            return
		        end
		        if self._T.isPoisonMistDirectionLocked and event.CurrentStateName ~= "IDLE" then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedPoisonMistDirX
		            end
		            local sc = self.Entity.StateComponent
		            if isvalid(sc) then
		                sc:ChangeState("IDLE")
		                log("[PoisonMist] HandleStateChangeEvent forced back to IDLE from " .. tostring(event.CurrentStateName))
		            end
		        end

		        -- 익스플로젼 전용 처리 (힐과 동일한 패턴이지만 별도의 플래그를 사용 - 서로 간섭하지 않는다)
		        if self._T.isExplosionMotionPlaying then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedExplosionDirX
		            end
		            local motionName = self._T.lockedExplosionMotionName
		            if not motionName then return end
		            local avatarRenderer = self.Entity.AvatarRendererComponent
		            if not isvalid(avatarRenderer) then return end
		            local body = avatarRenderer:GetBodyEntity()
		            if not isvalid(body) then return end
		            local motionEvent = ActionStateChangedEvent(motionName, motionName, self._T.lockedExplosionPlayRate or 1.0, SpriteAnimClipPlayType.Onetime)
		            body:SendEvent(motionEvent)
		            log("[Explosion] HandleStateChangeEvent re-applied motion over " .. tostring(event.CurrentStateName) .. ": " .. tostring(motionName))
		            return
		        end
		        if self._T.isExplosionDirectionLocked and event.CurrentStateName ~= "IDLE" then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedExplosionDirX
		            end
		            local sc = self.Entity.StateComponent
		            if isvalid(sc) then
		                sc:ChangeState("IDLE")
		                log("[Explosion] HandleStateChangeEvent forced back to IDLE from " .. tostring(event.CurrentStateName))
		            end
		        end

		        -- 드래곤 로어 전용 처리 (익스플로젼과 동일한 패턴이지만 별도의 플래그를 사용 - 서로 간섭하지 않는다)
		        if self._T.isDragonRoarMotionPlaying then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedDragonRoarDirX
		            end
		            local motionName = self._T.lockedDragonRoarMotionName
		            if not motionName then return end
		            local avatarRenderer = self.Entity.AvatarRendererComponent
		            if not isvalid(avatarRenderer) then return end
		            local body = avatarRenderer:GetBodyEntity()
		            if not isvalid(body) then return end
		            local motionEvent = ActionStateChangedEvent(motionName, motionName, self._T.lockedDragonRoarPlayRate or 1.0, SpriteAnimClipPlayType.Onetime)
		            body:SendEvent(motionEvent)
		            log("[DragonRoar] HandleStateChangeEvent re-applied motion over " .. tostring(event.CurrentStateName) .. ": " .. tostring(motionName))
		            return
		        end
		        if self._T.isDragonRoarDirectionLocked and event.CurrentStateName ~= "IDLE" then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedDragonRoarDirX
		            end
		            local sc = self.Entity.StateComponent
		            if isvalid(sc) then
		                sc:ChangeState("IDLE")
		                log("[DragonRoar] HandleStateChangeEvent forced back to IDLE from " .. tostring(event.CurrentStateName))
		            end
		        end

		        -- 스피어 버스터 전용 처리 (익스플로젼과 동일한 패턴이지만 별도의 플래그를 사용 - 서로 간섭하지 않는다)
		        if self._T.isSpearBurstMotionPlaying then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedSpearBurstDirX
		            end
		            -- (기능 변경) 단일 액션(stabT2) 전체 재생 → 5단 조합 포즈로 바뀌면서, 지금 잡고 있어야
		            -- 할 포즈를 (액션 + 프레임) 그대로 다시 적용한다(새비지블로우 8단 조합과 동일한 패턴).
		            local action = self._T.lockedSpearBurstAction
		            if not action then return end
		            local avatarRenderer = self.Entity.AvatarRendererComponent
		            if not isvalid(avatarRenderer) then return end
		            local body = avatarRenderer:GetBodyEntity()
		            if not isvalid(body) then return end
		            local frameIdx = self._T.lockedSpearBurstFrameIdx or 0
		            local motionEvent = ActionStateChangedEvent(action, action, 0.001, SpriteAnimClipPlayType.Onetime, frameIdx, frameIdx + 1)
		            body:SendEvent(motionEvent)
		            log("[SpearBurst] HandleStateChangeEvent re-applied pose over " .. tostring(event.CurrentStateName) .. ": " .. tostring(action) .. " frame=" .. tostring(frameIdx))
		            return
		        end
		        if self._T.isSpearBurstDirectionLocked and event.CurrentStateName ~= "IDLE" then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedSpearBurstDirX
		            end
		            local sc = self.Entity.StateComponent
		            if isvalid(sc) then
		                sc:ChangeState("IDLE")
		                log("[SpearBurst] HandleStateChangeEvent forced back to IDLE from " .. tostring(event.CurrentStateName))
		            end
		        end
		        -- (버그 수정) "여러 스킬 사용 후 숨고르기가 발동하지 않는다"는 신고 - 원인은 여기 있던
		        -- StateChangeEvent 즉시-반응 방식이 각 스킬의 모션 정리용 IDLE→MOVE→IDLE 강제 토글(같은
		        -- 서버 호출 안에서 즉시 IDLE로 돌아가는 내부 정리 동작)까지 "실제 이동"으로 오인해, 숨고르기가
		        -- 시작되기도 전에 항상 취소해버리던 것이었다. 이동 감지는 OnUpdate에서 여러 프레임에 걸쳐
		        -- 지속되는 MOVE 상태만 진짜 이동으로 보는 폴링 방식으로 옮겼다(내부 토글은 한 프레임도 안 돼
		        -- 되돌아가므로 폴링에는 걸리지 않는다). 스킬 재사용으로 인한 중단은 각 Attack* 메서드 시작 시
		        -- StopBreather() 호출이 그대로 담당한다.


		        -- 헤이스트 전용 처리 (힐과 동일한 패턴이지만 별도의 플래그를 사용 - 서로 간섭하지 않는다)
		        if self._T.isHasteMotionPlaying then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedHasteDirX
		            end
		            local motionName = self._T.lockedHasteMotionName
		            if not motionName then return end
		            local avatarRenderer = self.Entity.AvatarRendererComponent
		            if not isvalid(avatarRenderer) then return end
		            local body = avatarRenderer:GetBodyEntity()
		            if not isvalid(body) then return end
		            local motionEvent = ActionStateChangedEvent(motionName, motionName, self._T.lockedHastePlayRate or 1.0, SpriteAnimClipPlayType.Onetime)
		            body:SendEvent(motionEvent)
		            log("[Haste] HandleStateChangeEvent re-applied motion over " .. tostring(event.CurrentStateName) .. ": " .. tostring(motionName))
		            return
		        end
		        if self._T.isHasteDirectionLocked and event.CurrentStateName ~= "IDLE" then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedHasteDirX
		            end
		            local sc = self.Entity.StateComponent
		            if isvalid(sc) then
		                sc:ChangeState("IDLE")
		                log("[Haste] HandleStateChangeEvent forced back to IDLE from " .. tostring(event.CurrentStateName))
		            end
		        end

		        -- 부스터 전용 처리 (힐과 동일한 패턴이지만 별도의 플래그를 사용 - 서로 간섭하지 않는다)
		        if self._T.isBoosterMotionPlaying then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedBoosterDirX
		            end
		            local motionName = self._T.lockedBoosterMotionName
		            if not motionName then return end
		            local avatarRenderer = self.Entity.AvatarRendererComponent
		            if not isvalid(avatarRenderer) then return end
		            local body = avatarRenderer:GetBodyEntity()
		            if not isvalid(body) then return end
		            local motionEvent = ActionStateChangedEvent(motionName, motionName, self._T.lockedBoosterPlayRate or 1.0, SpriteAnimClipPlayType.Onetime)
		            body:SendEvent(motionEvent)
		            log("[Booster] HandleStateChangeEvent re-applied motion over " .. tostring(event.CurrentStateName) .. ": " .. tostring(motionName))
		            return
		        end
		        if self._T.isBoosterDirectionLocked and event.CurrentStateName ~= "IDLE" then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedBoosterDirX
		            end
		            local sc = self.Entity.StateComponent
		            if isvalid(sc) then
		                sc:ChangeState("IDLE")
		                log("[Booster] HandleStateChangeEvent forced back to IDLE from " .. tostring(event.CurrentStateName))
		            end
		        end
	end

	@ExecSpace("ServerOnly")
	@EventSender("Self")
	handler HandlePlayerActionEvent(PlayerActionEvent event)
		        -- Fire attack on "Attack" action
		        if event.ActionName == "Attack" then
		            self:AttackNormal()
		        end
	end

	@ExecSpace("ServerOnly")
	method void AttackDoubleStab(number combatPower, number atkMultiplier)
		        -- (기능 추가) "다른 스킬을 쓰면 숨고르기 모션은 중지" 요청 - 이 스킬을 새로 시전하는 시점에 이전 숨고르기가 재생 중이었다면 즉시 정리한다.
		        self:StopBreather()
		        -- 더블스탭 발동: 파워스트라이크와 동일한 전방 박스 판정 구조를 재사용하되, 공격범위는 2/3로 좁히고
		        -- 럭키세븐처럼 같은 대상을 두 번 연속 찔러(2줄 스택 데미지 스킨) 단일 대상에게 타격한다.
		        -- 사다리/로프/사망 상태에서는 사용 불가 (다른 스킬과 동일 가드).
		        local currentState = self.Entity.StateComponent.CurrentStateName
		        if currentState == "DEAD" or currentState == "CLIMB" or currentState == "LADDER" then
		            return
		        end
		        if self._T.isDoubleStabbing then
		            return
		        end
		        self._T.isDoubleStabbing = true

		        local mult = math.max(0.1, math.min(atkMultiplier or 1.0, 3.0))
		        self._T.pendingDoubleStabCombatPower = combatPower

		        local playerCtrl = self.Entity.PlayerControllerComponent
		        local worldPos = self.Entity.TransformComponent.WorldPosition
		        local dirX = playerCtrl.LookDirectionX
		        self._T.pendingDoubleStabDirX = dirX

		        -- 단일 고정 표적: 방향(dirX)을 고려하는 전용 탐색(FindDoubleStabTarget)을 사용한다.
		        -- (파워스트라이크가 쓰는 FindNearestMonster는 방향을 보지 않아, 밀집 몬스터 구역에서 등 뒤의
		        -- 몬스터를 고르면 좁아진 전방 판정 박스가 빗나가는 문제가 있었다 - 럭키세븐과 동일한 방식으로 해결.)
		        self._T.doubleStabTarget = self:FindDoubleStabTarget(Vector2(worldPos.x, worldPos.y), dirX)

		        self._T.pendingDoubleStabWasControllerEnabled = isvalid(playerCtrl) and playerCtrl.Enable
		        if isvalid(playerCtrl) then
		            playerCtrl.Enable = false
		        end
		        if isvalid(self.Entity.MovementComponent) then
		            self.Entity.MovementComponent:Stop()
		        end

		        -- 스킬 사용 사운드 (더블 스탭 리소스팩 skill/400.img/skill/4001334의 "_audio/Use")
		        self:PlayDoubleStabUseSound(self.Entity)

		        -- 캐릭터 모션: 더블스탭은 단검으로 "찌르는" 모션이 맞아야 하므로, 알려진 찌르기(stab) 계열
		        -- 후보를 전부 모아 매 시전마다 순차 순환한다(GetDoubleStabStab) - 사용자가 실제 화면과
		        -- 로그(PlayDoubleStabMotion sent: <이름>)를 대조해 맞는 이름을 확인한다.
		        local swing = self:GetDoubleStabStab()
		        self:PlayDoubleStabMotion(self.Entity, swing.name, dirX, mult)

		        -- 1번째 찌르기는 파워스트라이크와 동일하게 0.45초 뒤, 2번째는 그 직후(0.15초 뒤, 공격속도 배율 적용)에 판정한다.
		        _TimerService:SetTimerOnce(function()
		            self:DealDoubleStabHit(1, mult)
		        end, 0.45 * mult)
		        _TimerService:SetTimerOnce(function()
		            self:DealDoubleStabHit(2, mult)
		        end, 0.60 * mult)

		        -- 컨트롤 잠금 해제: 파워스트라이크와 동일한 고정 여유분(0.65초 * 배율).
		        _TimerService:SetTimerOnce(function()
		            self:RestoreDoubleStabControl()
		        end, 0.65 * mult)
	end

	@ExecSpace("ServerOnly")
	method Entity FindDoubleStabTarget(Vector2 fromPos, number dirX)
		        -- 더블스탭 전용 대상 탐색: 럭키세븐(FindLuckySevenTarget)과 동일하게 바라보는 방향(dirX) 앞쪽에
		        -- 있는 몬스터만 후보로 삼는다. 파워스트라이크가 쓰는 FindNearestMonster는 방향과 무관하게 그냥
		        -- 가장 가까운 몬스터를 고르는데, 밀집 몬스터 구역에서 등 뒤의 몬스터를 고르면 좁아진(2/3) 전방
		        -- 판정 박스가 그 대상을 빗나가는 문제가 실제로 재현되어(테스트로 확인) 방향 필터가 필요했다.
		        local map = self.Entity.CurrentMap
		        if not isvalid(map) then return nil end
		        local monsterComps = map:GetChildComponentsByTypeName("script.Monster", true)
		        local boxSize = 2.0 * (2.0 / 3.0)
		        local nearest = nil
		        local nearestDist = boxSize
		        for _, comp in ipairs(monsterComps) do
		            ---@type Monster
		            local mc = comp
		            if isvalid(mc) and isvalid(mc.Entity) and not mc.IsDead then
		                local pos = mc.Entity.TransformComponent.WorldPosition
		                local dx = pos.x - fromPos.x
		                local dy = pos.y - fromPos.y
		                if dx * dirX >= 0 and math.abs(dx) <= boxSize and math.abs(dy) <= (boxSize / 2.0) then
		                    local dist = math.abs(dx)
		                    if dist <= nearestDist then
		                        nearest = mc.Entity
		                        nearestDist = dist
		                    end
		                end
		            end
		        end
		        return nearest
	end

	method table GetDoubleStabStab()
		        -- 더블스탭 전용 찌르기(stab) 모션 - 사용자가 실제 화면으로 재확인해 stabO1/stabO2 2개로 최종 확정.
		        -- 매 시전마다 이 둘 중 하나를 무작위로 골라 재생한다(파워스트라이크의 GetPowerStrikeSwing과 동일한 랜덤 방식).
		        local candidates = {
		            { name = "stabO1" },
		            { name = "stabO2" },
		        }
		        local index = _UtilLogic:RandomIntegerRange(1, #candidates)
		        return candidates[index]
	end

	@ExecSpace("Server")
	method void RestoreDoubleStabControl()
		        self._T.isDoubleStabbing = false
		        local playerCtrl = self.Entity.PlayerControllerComponent
		        if isvalid(playerCtrl) and self._T.pendingDoubleStabWasControllerEnabled then
		            playerCtrl.Enable = true
		        end
		        -- (기능 추가) "다른 스킬들을 사용하고 난 다음도 모두 숨고르기 모션을 3번 하도록 해달라"는 요청 -
		        -- 컨트롤이 복구된 이 시점에 공용 숨고르기(PlayBreather)를 시작한다.
		        self:PlayBreather(self.Entity, self._T.pendingDoubleStabDirX or 1)
	end

	@ExecSpace("Server")
	method void DealDoubleStabHit(integer idx, number atkMultiplier)
		        -- 예약된 딜레이(0.45초/0.60초 * 배율) 뒤 호출되어 같은 단일 대상을 향해 전방 박스 판정을 1회 실행한다.
		        -- 대상이 1타에 이미 죽었더라도 2타 판정은 그대로 진행한다 - 럭키세븐과 동일하게, 1타가 오버킬이어도
		        -- 2줄 모두 표시되는 것이 의도된 동작이다(Monster.HandleHitEvent가 IsDead면 실제 Hp 적용만 막고,
		        -- 판정 자체는 DestroyDelay(0.6초) 전까지 유효해 정상적으로 명중 처리된다).
		        if not isvalid(self.Entity) then return end
		        local target = self._T.doubleStabTarget
		        if not isvalid(target) then return end

		        local dirX = self._T.pendingDoubleStabDirX or 1
		        local curWorldPos = self.Entity.TransformComponent.WorldPosition
		        -- 파워스트라이크 판정 박스(2x2, 오프셋 1.0*dirX)의 2/3 크기로 좁힌다. 오프셋도 박스 크기의 절반(=boxSize/2)으로
		        -- 동일한 비율을 유지해, 캐릭터 바로 앞에서 시작해 앞으로 boxSize만큼 뻗는 판정 형태를 그대로 보존한다.
		        local boxSize = 2.0 * (2.0 / 3.0)
		        local attackOffset = Vector2(
		            curWorldPos.x + (boxSize / 2.0) * dirX,
		            curWorldPos.y
		        )

		        -- PlayerAttack이 직접 판정한다 (전용 DoubleStabAttack 컴포넌트에 위임하던 방식은 제거됨 - 플레이어
		        -- 엔티티에 AttackComponent 상속 컴포넌트가 2개(PlayerAttack + DoubleStabAttack) 붙어 있으면
		        -- 엔진이 [LWA-3048] DuplicateComponent로 취급해 자동 데미지 스킨이 우리 수동 표시와 별개로
		        -- 추가 발동되어 "2줄이 2번(총 4줄)" 뜨는 문제가 실측됨. IsAttackTarget/CalcDamage/CalcCritical/
		        -- GetDisplayHitCount를 전부 attackInfo 분기로 PlayerAttack 하나에 합쳐서 이 충돌을 없앤다.)
		        local shape = BoxShape(attackOffset, Vector2(boxSize, boxSize), 0)
		        -- 대상의 DamageSkinSpawnerComponent를 판정 직전 잠깐 떼었다가 붙인다 - 이 컴포넌트가 붙어있는 채로
		        -- 같은 AttackComponent 인스턴스가 같은 대상에게 두 번 연속 Attack()을 걸면(더블스탭 1타/2타),
		        -- GetDisplayHitCount=0을 반환해도 엔진이 히트마다 자동 데미지 숫자를 하나씩 추가로 띄워
		        -- "2줄이 2번(총 4줄)" 뜨는 문제가 있었다(럭키세븐은 매 타격마다 별도 투사체 엔티티를 새로 스폰해
		        -- 이 문제가 없었음 - 동일 컴포넌트 인스턴스 재사용이 근본 원인으로 추정).
		        local targetSkinSpawner = target:GetComponent("MOD.Core.DamageSkinSpawnerComponent")
		        if isvalid(targetSkinSpawner) then target:RemoveComponent("MOD.Core.DamageSkinSpawnerComponent") end
		        local hitComps = self:Attack(shape, "skill.doublestab", CollisionGroups.HitBox)
		        if not isvalid(target:GetComponent("MOD.Core.DamageSkinSpawnerComponent")) then target:AddComponent("MOD.Core.DamageSkinSpawnerComponent") end
		        local actuallyHit = false
		        for _, hc in ipairs(hitComps) do
		            if isvalid(hc) and isvalid(hc.Entity) and hc.Entity == target then
		                actuallyHit = true
		                break
		            end
		        end
		        local damage = self._T.lastDoubleStabDamage or 0
		        local baseCrit = self._T.lastDoubleStabIsCritical or false
		        local bonus = self._T.shadowEchoBonus or 0
		        local bonusCrit = self._T.shadowEchoBonusIsCritical or false
		        if not actuallyHit then
		            -- 대상이 1타에 이미 죽어 판정 자체가 실패해도(코르프스가 더 이상 충돌 판정에 걸리지 않음),
		            -- 럭키세븐과 동일하게 표시용 데미지를 동일 공식으로 새로 굴려 2줄이 항상 뜨도록 한다
		            -- (실제 Hp에는 영향 없는 표시 전용 값 - 이미 죽은 대상이므로 실제 데미지 적용은 불필요).
		            -- (버그 수정) "1타가 대상을 처치하면 2타는 항상 이 표시 전용 경로로 빠지는데, 크리티컬을
		            -- 통째로 꺼둬서 2번째 줄만 크리티컬이 거의 안 뜨는 것처럼 보였다"는 신고(럭키세븐에서
		            -- 동일 증상 실측) - 이 경로도 실제 히트와 동일하게 크리티컬을 독립적으로 굴린다. 또한
		            -- CalcDamage가 이번 호출에서 실행되지 않아 self._T.shadowEchoBonus가 이전 타격의 값을
		            -- 그대로 들고 있을 수 있어(stale), 쉐도우 파트너 보너스도 여기서 새로 굴린다.
		            local critRate = (self._T.currentCritRatePercent or 50) / 100
		            local critMult = (self._T.currentCritDamagePercent or 125) / 100
		            local mult = 1.0 + _UtilLogic:RandomDouble() * (2.6 - 1.0)
		            damage = math.floor((self._T.pendingDoubleStabCombatPower or 0) * mult)
		            baseCrit = _UtilLogic:RandomDouble() < critRate
		            if baseCrit then damage = math.floor(damage * critMult) end
		            bonus = 0
		            bonusCrit = false
		            if self._T.shadowPartnerActive then
		                bonus = math.floor(damage * (0.55 + _UtilLogic:RandomDouble() * 0.10))
		                bonusCrit = _UtilLogic:RandomDouble() < critRate
		                if bonusCrit then bonus = math.floor(bonus * critMult) end
		            end
		        end
		        self:ShowDoubleStabDamageSkin(target, damage, idx, bonus, baseCrit, bonusCrit)
		        if bonus > 0 then
		            self:PlayShadowEchoHitSound(target)
		        end
		        self:PlayDoubleStabHitEffect(target, dirX)
		        log("PlayerAttack: AttackDoubleStab hit idx=" .. tostring(idx) .. " actuallyHit=" .. tostring(actuallyHit) .. " damage=" .. tostring(damage))
	end

	@ExecSpace("Multicast")
	method void PlayDoubleStabUseSound(Entity attacker)
		        -- 더블 스탭 리소스팩(skill/400.img/skill/4001334)의 "_audio/Use" 사운드.
		        -- Multicast는 서버 자신도 함께 실행하므로 클라이언트에서만 실행되게 막는다.
		        if not self:IsClient() then return end
		        if not isvalid(attacker) then return end
		        _SoundService:PlaySound("ca4f802052184c0ba47f6971fde80bd0", 1.0)
	end

	@ExecSpace("Client")
	method void ShowDoubleStabDamageSkin(Entity target, integer damage, integer hitIndex, integer bonus, boolean baseIsCritical, boolean bonusIsCritical)
		        -- 다른 스킬과 동일한 기본 히트 데미지 스킨(RUID)을 사용해 룩앤필을 통일한다.
		        -- 럭키세븐과 동일한 간격(±0.2)으로 1번째/2번째 찌르기가 위아래로 나뉘어 2줄로 쌓인 것처럼 보이게 한다.
		        if not isvalid(target) then return end
		        local offsetY = -0.2
		        -- (버그 수정) "원래 2줄 뜨던 스킬이 한 줄에 겹쳐 뜬다" - hitIndex==2일 때 offsetY를 아래로
		        -- 내리는 분기가 누락되어 1타/2타가 항상 같은 위치(-0.2)에서 겹쳐 떴다. 쉐도우 파트너 보너스가
		        -- 없을 때는 기존 ±0.2 배치를 그대로 복원한다.
		        if hitIndex == 2 then offsetY = 0.2 end
		        local bonusGap = 0.15
		        if bonus > 0 then
		            -- (기능 수정) "1줄->2줄"로 늘어난 스킬들의 간격(0.3)은 적절하지만, 원래 2줄이던 스킬이
		            -- 쉐도우 파트너로 4줄이 될 때는 기존 간격(±0.2, 보너스는 +0.15)이 좁아 보인다는 피드백.
		            -- 버프가 없을 때의 2줄 배치(-0.2/0.2)는 그대로 두고, 버프로 4줄이 될 때만 "1->2줄" 간격과
		            -- 동일한 0.3 단위로 전체를 -0.45/-0.15/0.15/0.45로 재배치해 4줄 모두 균등하게 벌린다.
		            offsetY = (hitIndex == 2) and 0.15 or -0.45
		            bonusGap = 0.3
		        end
		        -- (버그 수정) 쉐도우 파트너 보너스를 damages 배열에 같이 묶어 한 번에 Play()하면 두 숫자가
		        -- 같은 위치에서 시간차로만 분리돼(DelayPerAttack) "2줄이 겹쳐 보인다"는 문제가 있었다(스피어
		        -- 버스터에서 동일 증상 실측). 원본과 보너스를 서로 다른 offsetY를 가진 별도의 Play() 호출로
		        -- 나눠, 항상 공간적으로도 분리된 줄로 보이게 한다.
		        -- (버그 수정) "각자 크리티컬 여부를 독립적으로 판단해야 한다" - 하드코딩된 false 대신 각 줄에
		        -- 대해 CalcDamage에서 독립적으로 굴린 크리티컬 결과를 그대로 전달해 강조 표시가 실제와 맞게 한다.
		        _DamageSkinService:Play(
		            target, self:GetHitDamageSkinId(), 0,
		            { damage }, DamageSkinTweenType.Default, baseIsCritical,
		            Vector2(0, offsetY), Vector2(1, 1), 1.0, 1.0, LitMode.Default
		        )
		        if bonus > 0 then
		            _DamageSkinService:Play(
		                target, self:GetHitDamageSkinId(), 0,
		                { bonus }, DamageSkinTweenType.Default, bonusIsCritical,
		                Vector2(0, offsetY + bonusGap), Vector2(1, 1), 1.0, 1.0, LitMode.Default
		            )
		        end
		        log("[DoubleStab] ShowDoubleStabDamageSkin hitIndex=" .. tostring(hitIndex) .. " damage=" .. tostring(damage) .. " offsetY=" .. tostring(offsetY) .. " baseCrit=" .. tostring(baseIsCritical) .. " bonusCrit=" .. tostring(bonusIsCritical))
	end

	@ExecSpace("Client")
	method void PlayDoubleStabHitEffect(Entity target, number dirX)
		        -- 몬스터 몸에서 나타나는 타격 이펙트 (더블 스탭 리소스팩의 CharLevel/20/hit/0)
		        if not isvalid(target) then return end
		        local flipBack = dirX > 0
		        local hitOptions = { ["FlipX"] = flipBack }
		        local serial = _EffectService:PlayEffectAttached("8de01c7022964b1b9d6cf96070073446", target, Vector3(0, 0, 0), 0, Vector3(1, 1, 1), false, hitOptions)
		        -- 쉐도우 파트너: 같은 히트 이펙트를 0.25초 시간차를 두고 그 자리에 한 번 더(70% 투명도) 재생
		        self:EchoShadowHitEffect("8de01c7022964b1b9d6cf96070073446", target, Vector3(0, 0, 0), 0, Vector3(1, 1, 1), hitOptions)
		        -- 몬스터에 어태치된 이펙트가 자연 종료 전에 몬스터가 죽고(Enable=false) 다시 리젠(Enable=true)되면
		        -- 재생이 멈췄다가 리젠 순간 다시 보이는 문제가 있었다 - 짧은 타이머로 명시적으로 제거해 방지한다.
		        _TimerService:SetTimerOnce(function()
		            _EffectService:RemoveEffect(serial)
		        end, 0.5)
	end

	@ExecSpace("Multicast")
	method void PlayDoubleStabMotion(Entity attacker, string motionName, number dirX, number atkMultiplier)
		        -- 더블스탭 전용 세부 모션 재생. 파워스트라이크(PlayAttackMotion)와 동일한 방식 - 별도 플래그로 서로 간섭하지 않는다.
		        if not self:IsClient() then return end
		        if not isvalid(attacker) then return end
		        local avatarRenderer = attacker.AvatarRendererComponent
		        if not isvalid(avatarRenderer) then return end
		        local body = avatarRenderer:GetBodyEntity()
		        if not isvalid(body) then return end

		        avatarRenderer.ShowDefaultWeaponEffects = false

		        local playerCtrl = attacker.PlayerControllerComponent
		        if isvalid(attacker.MovementComponent) then
		            attacker.MovementComponent:Stop()
		        end
		        if isvalid(playerCtrl) then
		            playerCtrl.LookDirectionX = dirX
		        end
		        self._T.isDoubleStabDirectionLocked = true
		        self._T.lockedDoubleStabDirX = dirX
		        self._T.lockedDoubleStabMotionName = motionName
		        self._T.isDoubleStabMotionPlaying = true

		        local mult = math.max(atkMultiplier or 1.0, 0.001)
		        local playRate = 1.0 / mult
		        self._T.lockedDoubleStabPlayRate = playRate

		        local motionEvent = ActionStateChangedEvent(motionName, motionName, playRate, SpriteAnimClipPlayType.Onetime)
		        body:SendEvent(motionEvent)
		        log("[DoubleStab] PlayDoubleStabMotion sent: " .. tostring(motionName) .. " playRate=" .. tostring(playRate))

		        _TimerService:SetTimerOnce(function()
		            if isvalid(avatarRenderer) then
		                avatarRenderer.ShowDefaultWeaponEffects = true
		            end
		            self._T.isDoubleStabMotionPlaying = false
		        end, 0.60 * mult)

		        _TimerService:SetTimerOnce(function()
		            self._T.isDoubleStabDirectionLocked = false
		            local sc = self.Entity.StateComponent
		            if isvalid(sc) and sc.CurrentStateName ~= "DEAD" then
		                sc:ChangeState("IDLE")
		                sc:ChangeState("MOVE")
		                sc:ChangeState("IDLE")
		            end
		        end, 0.80 * mult)
	end

	@ExecSpace("ServerOnly")
	method void AttackMagicClaw(number combatPower, number atkMultiplier)
		        -- (기능 추가) "다른 스킬을 쓰면 숨고르기 모션은 중지" 요청 - 이 스킬을 새로 시전하는 시점에 이전 숨고르기가 재생 중이었다면 즉시 정리한다.
		        self:StopBreather()
		        -- 매직클로 발동: 럭키세븐과 같은 단일 대상·2타·2줄 스택 데미지 스킨이지만, 표창을 던지지 않고
		        -- 더블스탭처럼 그 자리에서 즉시 전방 판정으로 데미지를 준다(리소스/이펙트만 다름).
		        -- 사다리/로프/사망 상태에서는 사용 불가 (다른 스킬과 동일 가드).
		        local currentState = self.Entity.StateComponent.CurrentStateName
		        if currentState == "DEAD" or currentState == "CLIMB" or currentState == "LADDER" then
		            return
		        end
		        if self._T.isMagicClawing then
		            return
		        end
		        self._T.isMagicClawing = true

		        local mult = math.max(0.1, math.min(atkMultiplier or 1.0, 3.0))
		        self._T.pendingMagicClawCombatPower = combatPower

		        local playerCtrl = self.Entity.PlayerControllerComponent
		        local worldPos = self.Entity.TransformComponent.WorldPosition
		        local dirX = playerCtrl.LookDirectionX
		        self._T.pendingMagicClawDirX = dirX

		        -- 단일 고정 표적: 더블스탭과 동일한 방향 인식 탐색(파워스트라이크 판정 박스 크기 그대로 사용).
		        self._T.magicClawTarget = self:FindMagicClawTarget(Vector2(worldPos.x, worldPos.y), dirX)

		        self._T.pendingMagicClawWasControllerEnabled = isvalid(playerCtrl) and playerCtrl.Enable
		        if isvalid(playerCtrl) then
		            playerCtrl.Enable = false
		        end
		        if isvalid(self.Entity.MovementComponent) then
		            self.Entity.MovementComponent:Stop()
		        end

		        -- 스킬 사용 사운드 (즉시)
		        self:PlayMagicClawUseSound(self.Entity)
		        -- 스킬 시전 시작 이펙트 (사용자 몸에서 발현)
		        self:PlayMagicClawStartEffect(self.Entity, dirX)

		        local swing = self:GetMagicClawSwing()
		        self:PlayMagicClawMotion(self.Entity, swing.name, dirX, mult)

		        -- 1번째 할큄은 파워스트라이크와 동일하게 0.45초 뒤, 2번째는 0.1초 텀을 두고 0.55초 뒤에 판정한다.
		        _TimerService:SetTimerOnce(function()
		            self:DealMagicClawHit(1, mult)
		        end, 0.45 * mult)
		        _TimerService:SetTimerOnce(function()
		            self:DealMagicClawHit(2, mult)
		        end, 0.55 * mult)

		        -- 컨트롤 잠금 해제: 2번째 타격 직후(0.60초 * 배율).
		        _TimerService:SetTimerOnce(function()
		            self:RestoreMagicClawControl()
		        end, 0.60 * mult)
	end

	@ExecSpace("ServerOnly")
	method Entity FindMagicClawTarget(Vector2 fromPos, number dirX)
		        -- 매직클로 전용 대상 탐색: 더블스탭(FindDoubleStabTarget)과 동일한 방향 인식 방식.
		        -- 사거리는 파워스트라이크 기준 박스(2칸) 대비 x축(전방) 2.5배·y축(위아래) 1.5배로 늘렸다.
		        local map = self.Entity.CurrentMap
		        if not isvalid(map) then return nil end
		        local monsterComps = map:GetChildComponentsByTypeName("script.Monster", true)
		        local forwardSize = 2.0 * 2.5
		        local verticalSize = 2.0 * 1.5
		        local nearest = nil
		        local nearestDist = forwardSize
		        for _, comp in ipairs(monsterComps) do
		            ---@type Monster
		            local mc = comp
		            if isvalid(mc) and isvalid(mc.Entity) and not mc.IsDead then
		                local pos = mc.Entity.TransformComponent.WorldPosition
		                local dx = pos.x - fromPos.x
		                local dy = pos.y - fromPos.y
		                if dx * dirX >= 0 and math.abs(dx) <= forwardSize and math.abs(dy) <= (verticalSize / 2.0) then
		                    local dist = math.abs(dx)
		                    if dist <= nearestDist then
		                        nearest = mc.Entity
		                        nearestDist = dist
		                    end
		                end
		            end
		        end
		        return nearest
	end

	method table GetMagicClawSwing()
		        -- 매직클로 전용 모션 - 우선 럭키세븐과 동일한 swingO1/O2/O3(한손무기 계열, "아대"로 확인됐던 것과
		        -- 동일 계열)을 순차 순환시켜 사용자가 화면으로 확인 후 확정할 수 있게 한다.
		        local candidates = {
		            { name = "swingO1" },
		            { name = "swingO2" },
		            { name = "swingO3" },
		        }
		        self._T.magicClawSwingIndex = (self._T.magicClawSwingIndex or 0) % #candidates + 1
		        return candidates[self._T.magicClawSwingIndex]
	end

	@ExecSpace("Server")
	method void RestoreMagicClawControl()
		        self._T.isMagicClawing = false
		        local playerCtrl = self.Entity.PlayerControllerComponent
		        if isvalid(playerCtrl) and self._T.pendingMagicClawWasControllerEnabled then
		            playerCtrl.Enable = true
		        end
		        -- (기능 추가) "다른 스킬들을 사용하고 난 다음도 모두 숨고르기 모션을 3번 하도록 해달라"는 요청 -
		        -- 컨트롤이 복구된 이 시점에 공용 숨고르기(PlayBreather)를 시작한다.
		        self:PlayBreather(self.Entity, self._T.pendingMagicClawDirX or 1)
	end

	@ExecSpace("Server")
	method void DealMagicClawHit(integer idx, number atkMultiplier)
		        -- 예약된 딜레이(0.45초/0.55초 * 배율) 뒤 호출되어 같은 단일 대상을 향해 전방 박스 판정을 1회 실행한다.
		        -- 더블스탭과 동일하게, 대상이 1타에 이미 죽었더라도 2타 판정은 그대로 진행해 럭키세븐과 같이
		        -- 1타가 오버킬이어도 2줄 모두 표시되도록 한다.
		        if not isvalid(self.Entity) then return end
		        local target = self._T.magicClawTarget
		        if not isvalid(target) then return end

		        local dirX = self._T.pendingMagicClawDirX or 1
		        local curWorldPos = self.Entity.TransformComponent.WorldPosition
		        -- FindMagicClawTarget과 동일한 사거리(x축 2.5배·y축 1.5배 확장)를 실제 판정 박스에도 적용한다.
		        local forwardSize = 2.0 * 2.5
		        local verticalSize = 2.0 * 1.5
		        local attackOffset = Vector2(
		            curWorldPos.x + (forwardSize / 2.0) * dirX,
		            curWorldPos.y
		        )

		        -- PlayerAttack이 직접 판정한다 (전용 MagicClawAttack 컴포넌트에 위임하던 방식은 제거됨 - 더블스탭과
		        -- 동일하게, 플레이어 엔티티에 AttackComponent 상속 컴포넌트가 2개 붙어 있으면 엔진이
		        -- [LWA-3048] DuplicateComponent로 취급해 자동 데미지 스킨이 추가로 발동되는 문제가 있었다.)
		        -- 대상의 DamageSkinSpawnerComponent도 판정 직전 잠깐 떼었다가 붙인다 - 더블스탭과 동일한 이유
		        -- (같은 AttackComponent 인스턴스로 같은 대상에게 두 번 연속 Attack()을 걸면 GetDisplayHitCount=0을
		        -- 반환해도 히트마다 자동 데미지 숫자가 추가로 뜨는 문제가 있었음 - 럭키세븐은 타격마다 별도
		        -- 투사체 엔티티를 새로 스폰해 이 문제가 없었던 것에서 착안).
		        local shape = BoxShape(attackOffset, Vector2(forwardSize, verticalSize), 0)
		        local targetSkinSpawner = target:GetComponent("MOD.Core.DamageSkinSpawnerComponent")
		        if isvalid(targetSkinSpawner) then target:RemoveComponent("MOD.Core.DamageSkinSpawnerComponent") end
		        local hitComps = self:Attack(shape, "skill.magicclaw", CollisionGroups.HitBox)
		        if not isvalid(target:GetComponent("MOD.Core.DamageSkinSpawnerComponent")) then target:AddComponent("MOD.Core.DamageSkinSpawnerComponent") end
		        local actuallyHit = false
		        for _, hc in ipairs(hitComps) do
		            if isvalid(hc) and isvalid(hc.Entity) and hc.Entity == target then
		                actuallyHit = true
		                break
		            end
		        end
		        local damage = self._T.lastMagicClawDamage or 0
		        local magicClawBaseCrit = self._T.lastMagicClawIsCritical or false
		        local bonus = self._T.shadowEchoBonus or 0
		        local bonusCrit = self._T.shadowEchoBonusIsCritical or false
		        if not actuallyHit then
		            -- 대상이 1타에 이미 죽어 판정 자체가 실패해도, 럭키세븐과 동일하게 표시용 데미지를
		            -- 동일 공식으로 새로 굴려 2줄이 항상 뜨도록 한다(실제 Hp에는 영향 없는 표시 전용 값).
		            -- (버그 수정) 더블스탭과 동일한 이유로, 이 경로도 크리티컬을 독립적으로 굴리고
		            -- self._T.shadowEchoBonus의 stale 값 대신 쉐도우 파트너 보너스도 여기서 새로 굴린다.
		            local critRate = (self._T.currentCritRatePercent or 50) / 100
		            local critMult = (self._T.currentCritDamagePercent or 125) / 100
		            local mult = 1.0 + _UtilLogic:RandomDouble() * (1.5 - 1.0)
		            damage = math.floor((self._T.pendingMagicClawCombatPower or 0) * mult)
		            magicClawBaseCrit = _UtilLogic:RandomDouble() < critRate
		            if magicClawBaseCrit then damage = math.floor(damage * critMult) end
		            bonus = 0
		            bonusCrit = false
		            if self._T.shadowPartnerActive then
		                bonus = math.floor(damage * (0.55 + _UtilLogic:RandomDouble() * 0.10))
		                bonusCrit = _UtilLogic:RandomDouble() < critRate
		                if bonusCrit then bonus = math.floor(bonus * critMult) end
		            end
		        end
		        self:ShowMagicClawDamageSkin(target, damage, idx, bonus, magicClawBaseCrit, bonusCrit)
		        if bonus > 0 then
		            self:PlayShadowEchoHitSound(target)
		        end
		        self:PlayMagicClawHitEffect(target, dirX)
		        log("PlayerAttack: AttackMagicClaw hit idx=" .. tostring(idx) .. " actuallyHit=" .. tostring(actuallyHit) .. " damage=" .. tostring(damage))
	end

	@ExecSpace("Multicast")
	method void PlayMagicClawUseSound(Entity attacker)
		        -- 매직클로 리소스팩(skill/800032.img/skill/80003294)의 사용 사운드. 사용 즉시 재생.
		        if not self:IsClient() then return end
		        if not isvalid(attacker) then return end
		        _SoundService:PlaySound("96edfa618f6a4fe4a4620a5c56eb93b6", 1.0)
	end

	@ExecSpace("Multicast")
	method void PlayMagicClawStartEffect(Entity attacker, number dirX)
		        -- 스킬 사용과 동시에 캐릭터 몸에서 발현되는 시작 이펙트
		        if not self:IsClient() then return end
		        if not isvalid(attacker) then return end
		        local startOptions = { ["FlipX"] = dirX > 0 }
		        _EffectService:PlayEffectAttached("2a0d72e836fb4862aae83087035f3d2a", attacker, Vector3(0, 0, 0), 0, Vector3(1, 1, 1), false, startOptions)
		        -- 쉐도우 파트너: 같은 시작 이펙트를 x축 뒤쪽에서 투명도 70%로 복제 재생(그림자 몫 - 데미지 없음)
		        self:EchoShadowSkillEffectAttached("2a0d72e836fb4862aae83087035f3d2a", attacker, Vector3(0, 0, 0), 0, Vector3(1, 1, 1), startOptions, dirX)
	end

	@ExecSpace("Client")
	method void ShowMagicClawDamageSkin(Entity target, integer damage, integer hitIndex, integer bonus, boolean baseIsCritical, boolean bonusIsCritical)
		        -- 다른 스킬과 동일한 기본 히트 데미지 스킨(RUID)을 사용해 룩앤필을 통일한다.
		        -- 럭키세븐/더블스탭과 동일한 간격(±0.2)으로 1번째/2번째 타격이 위아래로 나뉘어 2줄로 쌓인 것처럼 보이게 한다.
		        if not isvalid(target) then return end
		        local offsetY = -0.2
		        -- (버그 수정) 더블스탭과 동일한 원인 - hitIndex==2일 때 아래로 내리는 분기가 누락되어 1타/2타가
		        -- 항상 같은 위치(-0.2)에서 겹쳐 떴다. 쉐도우 파트너 보너스가 없을 때의 기존 ±0.2 배치를 복원한다.
		        if hitIndex == 2 then offsetY = 0.2 end
		        local bonusGap = 0.15
		        if bonus > 0 then
		            -- (기능 수정) 더블스탭과 동일한 이유 - 버프로 4줄이 될 때만 "1->2줄" 간격(0.3)과 동일한
		            -- 단위로 -0.45/-0.15/0.15/0.45로 재배치한다(버프가 없을 때의 2줄 배치는 그대로 유지).
		            offsetY = (hitIndex == 2) and 0.15 or -0.45
		            bonusGap = 0.3
		        end
		        -- (버그 수정) 더블스탭과 동일한 이유로 원본/보너스를 하나의 Play() 배열로 묶지 않고, 서로 다른
		        -- offsetY를 가진 별도의 Play() 호출로 나눠 겹쳐 보이지 않게 한다. 또한 각 줄의 크리티컬 여부도
		        -- 하드코딩된 false 대신 CalcDamage가 독립적으로 굴린 결과를 그대로 전달한다.
		        _DamageSkinService:Play(
		            target, self:GetHitDamageSkinId(), 0,
		            { damage }, DamageSkinTweenType.Default, baseIsCritical,
		            Vector2(0, offsetY), Vector2(1, 1), 1.0, 1.0, LitMode.Default
		        )
		        if bonus > 0 then
		            _DamageSkinService:Play(
		                target, self:GetHitDamageSkinId(), 0,
		                { bonus }, DamageSkinTweenType.Default, bonusIsCritical,
		                Vector2(0, offsetY + bonusGap), Vector2(1, 1), 1.0, 1.0, LitMode.Default
		            )
		        end
	end

	@ExecSpace("Client")
	method void PlayMagicClawHitEffect(Entity target, number dirX)
		        -- 맞는 몬스터 몸에서 나타나는 타격 이펙트 + 타격 사운드 (0.1초 텀을 두고 2번 재생됨 - 각 히트마다 1번씩)
		        if not isvalid(target) then return end
		        local flipBack = dirX > 0
		        local hitOptions = { ["FlipX"] = flipBack }
		        local serial = _EffectService:PlayEffectAttached("598d2d1859e84eaab18ae460a0a1e0a4", target, Vector3(0, 0, 0), 0, Vector3(1, 1, 1), false, hitOptions)
		        -- 쉐도우 파트너: 같은 히트 이펙트를 0.25초 시간차를 두고 그 자리에 한 번 더(70% 투명도) 재생
		        self:EchoShadowHitEffect("598d2d1859e84eaab18ae460a0a1e0a4", target, Vector3(0, 0, 0), 0, Vector3(1, 1, 1), hitOptions)
		        _SoundService:PlaySound("5f0c2e9b04ee4a3a9d493a863b8a1379", 1.0)
		        -- 몬스터에 어태치된 이펙트가 자연 종료 전에 몬스터가 죽고(Enable=false) 다시 리젠(Enable=true)되면
		        -- 재생이 멈췄다가 리젠 순간 다시 보이는 문제가 있었다 - 짧은 타이머로 명시적으로 제거해 방지한다.
		        _TimerService:SetTimerOnce(function()
		            _EffectService:RemoveEffect(serial)
		        end, 0.5)
	end

	@ExecSpace("Multicast")
	method void PlayMagicClawMotion(Entity attacker, string motionName, number dirX, number atkMultiplier)
		        -- 매직클로 전용 모션 재생. 다른 스킬과 동일한 방식 - 별도 플래그로 서로 간섭하지 않는다.
		        if not self:IsClient() then return end
		        if not isvalid(attacker) then return end
		        local avatarRenderer = attacker.AvatarRendererComponent
		        if not isvalid(avatarRenderer) then return end
		        local body = avatarRenderer:GetBodyEntity()
		        if not isvalid(body) then return end

		        avatarRenderer.ShowDefaultWeaponEffects = false

		        local playerCtrl = attacker.PlayerControllerComponent
		        if isvalid(attacker.MovementComponent) then
		            attacker.MovementComponent:Stop()
		        end
		        if isvalid(playerCtrl) then
		            playerCtrl.LookDirectionX = dirX
		        end
		        self._T.isMagicClawDirectionLocked = true
		        self._T.lockedMagicClawDirX = dirX
		        self._T.lockedMagicClawMotionName = motionName
		        self._T.isMagicClawMotionPlaying = true
		        -- 홀드 지속발동 중 다음 시전이 쿨다운(0.75*mult)만큼 뒤에 시작될 수 있는데, 이 잠금 해제 타이머는
		        -- 그보다 늦은 0.80*mult 뒤에 실행된다. 새 시전이 이미 방향을 다시 잠근 뒤에 이전 시전의 해제
		        -- 타이머가 뒤늦게 실행되며 새 시전의 잠금을 잘못 풀어버려, 그 틈에 방향이 갑자기 바뀌는 문제가
		        -- 있었다(파워스트라이크에서 동일하게 발견·수정한 것과 같은 원인). 시전마다 토큰을 발급해
		        -- "그 사이 더 최근 시전이 없었을 때만" 해제한다.
		        self._T.magicClawLockToken = (self._T.magicClawLockToken or 0) + 1
		        local myMagicClawLockToken = self._T.magicClawLockToken

		        local mult = math.max(atkMultiplier or 1.0, 0.001)
		        local playRate = 1.0 / mult
		        self._T.lockedMagicClawPlayRate = playRate

		        local motionEvent = ActionStateChangedEvent(motionName, motionName, playRate, SpriteAnimClipPlayType.Onetime)
		        body:SendEvent(motionEvent)
		        log("[MagicClaw] PlayMagicClawMotion sent: " .. tostring(motionName) .. " playRate=" .. tostring(playRate))

		        _TimerService:SetTimerOnce(function()
		            if isvalid(avatarRenderer) then
		                avatarRenderer.ShowDefaultWeaponEffects = true
		            end
		            self._T.isMagicClawMotionPlaying = false
		        end, 0.55 * mult)

		        _TimerService:SetTimerOnce(function()
		            if self._T.magicClawLockToken ~= myMagicClawLockToken then return end
		            self._T.isMagicClawDirectionLocked = false
		            local sc = self.Entity.StateComponent
		            if isvalid(sc) and sc.CurrentStateName ~= "DEAD" then
		                sc:ChangeState("IDLE")
		                sc:ChangeState("MOVE")
		                sc:ChangeState("IDLE")
		            end
		        end, 0.80 * mult)
	end

	@ExecSpace("ServerOnly")
	method void AttackTeleport(string direction)
		        -- 텔레포트: 즉시 순간이동 스킬 - 판정/데미지가 없고 모션 재생 딜레이도 없어 다른 스킬처럼 컨트롤러를 잠그지 않는다.
		        if not isvalid(self.Entity) then return end
		        local rb = self.Entity.RigidbodyComponent
		        if not isvalid(rb) then return end
		        local map = self.Entity.CurrentMap
		        if not isvalid(map) then return end
		        local fh = map.FootholdComponent
		        if not isvalid(fh) then return end

		        -- "짧은 거리를 순간이동한다"는 스킬 설명에 맞춰 다른 스킬 사거리(2.0~5.0)와 비슷한 수준으로 고정.
		        -- 기존 3.0 → 30% 감소로 2.1 → 사용자 요청으로 다시 10% 증가해 2.31로 조정.
		        local TELEPORT_DISTANCE = 2.31
		        -- 도착지점에 발판이 없을 때 위/아래로 이 거리 이내에 있는 발판을 대신 찾는다.
		        -- 기존 1.2에서 사용자 요청으로 절반(0.6)으로 축소 - 너무 높은/낮은 발판까지 끌어당겨지는 문제 완화.
		        local VERTICAL_TOLERANCE = 0.6
		        -- 발판 가장자리/벽에 딱 붙어 착지하지 않도록 살짝 여유를 둔다.
		        local EDGE_MARGIN = 0.15
		        -- 발판 표면에 살짝 파묻히지 않도록 위로 띄우는 높이 (다음 프레임에 중력이 바로 붙잡아준다).
		        local LAND_OFFSET = 0.05

		        local curPos3 = self.Entity.TransformComponent.WorldPosition
		        local curPos = Vector2(curPos3.x, curPos3.y)
		        local landing = nil

		        if direction == "up" or direction == "down" then
		            local dirY = (direction == "up") and 1 or -1
		            -- 현재 밟고 있는 발판 표면에서 그대로 위쪽으로 레이캐스트하면 자기 자신(현재 서있는 발판)을
		            -- 거리 0에서 다시 주워버리는 문제가 있다(한쪽면 충돌 판정) - 이동 방향으로 살짝 띄운 지점에서 시작한다.
		            local rayEpsilon = 0.05
		            local rayStart = Vector2(curPos.x, curPos.y + dirY * rayEpsilon)
		            -- 사거리 안에 발판이 여러 겹 있으면(예: 층층이 쌓인 발판) 가장 가까운 것이 아니라
		            -- 갈 수 있는 가장 먼 발판을 우선한다 - RaycastAll로 사거리 내 전부 찾아 거리가 최대인 것을 채택.
		            local hits = fh:RaycastAll(rayStart, Vector2(0, dirY), TELEPORT_DISTANCE - rayEpsilon)
		            local hit = nil
		            local farthestDist = -1
		            for _, h in ipairs(hits) do
		                local d = math.abs(h:GetYByX(curPos.x) - curPos.y)
		                if d > farthestDist then
		                    farthestDist = d
		                    hit = h
		                end
		            end
		            if hit ~= nil then
		                landing = Vector2(curPos.x, hit:GetYByX(curPos.x) + LAND_OFFSET)
		            end
		            -- 조건3: 거리 안에 발판이 없으면 사용 자체가 무효 - 사운드/이펙트도 재생하지 않는다.
		            if landing == nil then
		                log("[PlayerAttack] AttackTeleport 실패: " .. direction .. " 방향 " .. tostring(TELEPORT_DISTANCE) .. " 이내에 발판 없음")
		                return
		            end
		        else
		            local dirX = (direction == "left") and -1 or 1
		            local desiredX = curPos.x + dirX * TELEPORT_DISTANCE

		            -- 경로상에 진짜 벽(IsBlockVerticalLine=true)이 있으면 그 앞에서 멈추도록 목표 X를 앞당긴다.
		            -- 단순히 서로 다른 높이의 발판을 잇는 수직 연결선(절벽 가장자리, IsBlockVerticalLine=false)은
		            -- 실제로 이동을 막지 않으므로 벽으로 취급하지 않는다.
		            local wallHit = fh:Raycast(curPos, Vector2(dirX, 0), TELEPORT_DISTANCE)
		            if wallHit ~= nil and wallHit:IsVertical() and wallHit.IsBlockVerticalLine then
		                local wallX = wallHit:GetCenter().x
		                local clampedByWall = wallX - dirX * EDGE_MARGIN
		                if (dirX > 0 and clampedByWall < desiredX) or (dirX < 0 and clampedByWall > desiredX) then
		                    desiredX = clampedByWall
		                end
		            end

		            -- 조건1: 도착지점에 발판이 없으면 위아래 근접 발판을 찾는다.
		            local nearFh = self:FindNearbyFootholdAtX(fh, desiredX, curPos.y, VERTICAL_TOLERANCE)
		            if nearFh ~= nil then
		                landing = Vector2(desiredX, nearFh:GetYByX(desiredX) + LAND_OFFSET)
		            else
		                -- 조건2: 지금 서있는 발판이 목표 거리보다 먼저 끝나면 끝나는 지점까지만 이동한다.
		                local curFh = rb:GetCurrentFoothold()
		                if curFh ~= nil then
		                    -- 같은 지면이 여러 조각(발판 ID)으로 나뉘어 있을 수 있으므로, 지금 밟은 조각의
		                    -- StartPoint/EndPoint만 보지 않고 이동 방향으로 NextFootholdId/PreviousFootholdId
		                    -- 체인을 바라가며 실제로 지면이 끊기는 진짜 가장자리를 찾는다.
		                    local chainFh = curFh
		                    local farEdgeX = (dirX > 0) and math.max(curFh.StartPoint.x, curFh.EndPoint.x) or math.min(curFh.StartPoint.x, curFh.EndPoint.x)
		                    for _ = 1, 50 do
		                        if (dirX > 0 and farEdgeX >= desiredX) or (dirX < 0 and farEdgeX <= desiredX) then break end
		                        local nextId = (dirX > 0) and chainFh.NextFootholdId or chainFh.PreviousFootholdId
		                        if nextId == nil or nextId == 0 then break end
		                        local nextFh = fh:GetFoothold(nextId)
		                        if nextFh == nil then break end
		                        chainFh = nextFh
		                        farEdgeX = (dirX > 0) and math.max(nextFh.StartPoint.x, nextFh.EndPoint.x) or math.min(nextFh.StartPoint.x, nextFh.EndPoint.x)
		                    end
		                    local clampedX = farEdgeX - dirX * EDGE_MARGIN
		                    local reachesFullDistance = (dirX > 0 and clampedX >= desiredX) or (dirX < 0 and clampedX <= desiredX)
		                    if not reachesFullDistance then
		                        -- 축소된 지점에서도 위아래 발판을 다시 확인한다 (조건2의 "그 지점에서도 위아래 발판 구분" 요구사항).
		                        local nearFh2 = self:FindNearbyFootholdAtX(fh, clampedX, curPos.y, VERTICAL_TOLERANCE)
		                        if nearFh2 ~= nil then
		                            landing = Vector2(clampedX, nearFh2:GetYByX(clampedX) + LAND_OFFSET)
		                        else
		                            landing = Vector2(clampedX, curFh:GetYByX(clampedX) + LAND_OFFSET)
		                        end
		                    end
		                end
		            end

		            if landing == nil then
		                log("[PlayerAttack] AttackTeleport 실패: " .. direction .. " 방향에 착지 가능한 발판 없음")
		                return
		            end
		        end

		        if isvalid(self.Entity.MovementComponent) then
		            self.Entity.MovementComponent:Stop()
		        end
		        -- 실측 결과: SetWorldPosition을 짧은 시간 동안 여러 프레임에 걸쳐 나눠 호출하는 "대시" 방식을 시도했으나,
		        -- 몇 틱 뒤 위치가 원래 자리로 되돌아가는 현상이 재현됨(엔진의 물리/동기화 쪽에서 반복적인 위치
		        -- 갱신을 되돌리는 것으로 추정 - 정확한 내부 매커니즘은 불명). 한 번만 호출하는 방식은 이 세션
		        -- 내내 안정적으로 확인되었으므로, 검증된 단일 호출 방식을 유지한다.
		        rb:SetWorldPosition(landing)
		        self:PlayTeleportEffects(self.Entity, curPos)
		        log("[PlayerAttack] AttackTeleport 성공! direction=" .. direction .. " from=(" .. tostring(curPos.x) .. "," .. tostring(curPos.y) .. ") to=(" .. tostring(landing.x) .. "," .. tostring(landing.y) .. ")")
	end

	method Foothold FindNearbyFootholdAtX(FootholdComponent fh, number x, number y, number tolerance)
		        -- 지정한 x좌표에서 위/아래로 tolerance 거리 이내에 있는 가장 가까운 발판을 찾는다 (없으면 nil).
		        -- 이 지점이 마침 어떤 발판과 정확히 겹쳐 거리 0으로 찾아지는 것은 정상(그 발판 위에 착지)이므로,
		        -- AttackTeleport의 위/아래 이동 분기와 달리 여기서는 시작점을 띄우지 않는다.
		        local upHit = fh:Raycast(Vector2(x, y), Vector2(0, 1), tolerance)
		        local downHit = fh:Raycast(Vector2(x, y), Vector2(0, -1), tolerance)
		        if upHit ~= nil and downHit ~= nil then
		            local upDist = math.abs(upHit:GetYByX(x) - y)
		            local downDist = math.abs(downHit:GetYByX(x) - y)
		            if upDist <= downDist then return upHit end
		            return downHit
		        elseif upHit ~= nil then
		            return upHit
		        elseif downHit ~= nil then
		            return downHit
		        end
		        return nil
	end
	@ExecSpace("Multicast")
	method void PlayTeleportEffects(Entity attacker, Vector2 originPos)
		        -- 텔레포트 사용 사운드 + 이동 전 위치에 잠깐 나타나는 잔상 이펙트. Multicast는 서버도 함께 실행하므로 클라이언트에서만 실행되게 막는다.
		        if not self:IsClient() then return end
		        if not isvalid(attacker) then return end
		        _SoundService:PlaySound("4c1eb6001e9c47eda239cc58443b79cd", 1.0)
		        local serial = _EffectService:PlayEffect("b34e818d784f4a3891c2d50e48ca559d", attacker, Vector3(originPos.x, originPos.y, 0), 0, Vector3(1, 1, 1), false, {})
		        -- 쉐도우 파트너: 텔레포트 잔상 이펙트를 x축 뒤쪽에서 투명도 70%로 복제 재생(그림자 몫)
		        local echoSerial = self:EchoShadowSkillEffect("b34e818d784f4a3891c2d50e48ca559d", Vector3(originPos.x, originPos.y, 0), 0, Vector3(1, 1, 1), {}, 0)
		        _TimerService:SetTimerOnce(function()
		            _EffectService:RemoveEffect(serial)
		            if echoSerial ~= 0 then
		                _EffectService:RemoveEffect(echoSerial)
		            end
		        end, 0.1)
		        -- 텔레포트 전용 카메라 제어(Damping 임시 조정)는 사용자 요청으로 제거함 - 기본 카메라 동작만 남긴다.
	end

	@ExecSpace("ServerOnly")
	method void AttackThunderbolt(number combatPower, number atkMultiplier)
		-- (기능 추가) "다른 스킬을 쓰면 숨고르기 모션은 중지" 요청 - 이 스킬을 새로 시전하는 시점에 이전 숨고르기가 재생 중이었다면 즉시 정리한다.
		self:StopBreather()
		-- 썬더볼트 발동: 방향(앞/뒤) 무관하게 캐릭터 주변의 몬스터 최대 6명을 동시에 타격한다.
		-- 사다리/로프/사망 상태에서는 사용 불가 (다른 스킬과 동일 가드).
		local currentState = self.Entity.StateComponent.CurrentStateName
		if currentState == "DEAD" or currentState == "CLIMB" or currentState == "LADDER" then
			return
		end
		if self._T.isThunderbolting then
			return
		end
		self._T.isThunderbolting = true

		local mult = math.max(0.1, math.min(atkMultiplier or 1.0, 3.0))
		self._T.pendingThunderboltCombatPower = combatPower

		local playerCtrl = self.Entity.PlayerControllerComponent
		local worldPos = self.Entity.TransformComponent.WorldPosition
		local dirX = playerCtrl.LookDirectionX
		self._T.pendingThunderboltDirX = dirX

		-- 방향과 무관하게 앞뒤 모두에서 가까운 순으로 최대 6명을 미리 골라둔다 (실제 Attack 판정 없이 위치만으로 탐색).
		local targets = self:FindThunderboltTargets(Vector2(worldPos.x, worldPos.y), 6)
		self._T.thunderboltTargets = targets

		self._T.pendingThunderboltWasControllerEnabled = isvalid(playerCtrl) and playerCtrl.Enable
		if isvalid(playerCtrl) then
			playerCtrl.Enable = false
		end
		if isvalid(self.Entity.MovementComponent) then
			self.Entity.MovementComponent:Stop()
		end

		-- 스킬 사용 사운드 + 몸쪽 시전 이펙트 (즉시, 1회) + 캐릭터 모션(매직클로와 동일한 후보군/재생 방식)
		self:PlayThunderboltUseSound(self.Entity)
		self:PlayThunderboltStartEffect(self.Entity, dirX)
		local swing = self:GetThunderboltSwing()
		self:PlayThunderboltMotion(self.Entity, swing.name, dirX, mult)

		-- 딜레이 후 미리 골라둔 대상 전원에게 동시에 타격 판정 + 이펙트를 발생시킨다
		-- (슬래쉬블래스트처럼 대상마다 나눠서 순차 타격하는 것이 아니라, 같은 프레임 안에서 한꺼번에 처리).
		_TimerService:SetTimerOnce(function()
			self:DealThunderboltHits(targets)
		end, 0.4 * mult)

		-- 컨트롤 잠금 해제: 타격 판정 직후 여유(0.2초)를 두고, 배율을 적용한다.
		_TimerService:SetTimerOnce(function()
			self:RestoreThunderboltControl()
		end, 0.6 * mult)
	end

	@ExecSpace("ServerOnly")
	method table FindThunderboltTargets(Vector2 fromPos, integer maxCount)
		-- 썬더볼트 대상 선정: 다른 스킬과 달리 방향(dirX) 무관 - 앞뒤 판정 범위(가로 6칸, 세로 1칸) 안의
		-- 살아있는 script.Monster를 가까운 순으로 정렬해 최대 maxCount명까지 후보로 반환한다
		-- (실제 Attack 판정 없이 위치만으로 탐색). 좌우(가로) 범위는 기존 2.0에서 사용자 요청으로 1.5배인 3.0으로 확대.
		local map = self.Entity.CurrentMap
		if not isvalid(map) then return {} end
		local monsterComps = map:GetChildComponentsByTypeName("script.Monster", true)
		local candidates = {}
		for _, comp in ipairs(monsterComps) do
			---@type Monster
			local mc = comp
			if isvalid(mc) and isvalid(mc.Entity) and not mc.IsDead then
				local pos = mc.Entity.TransformComponent.WorldPosition
				local dx = pos.x - fromPos.x
				local dy = pos.y - fromPos.y
				if math.abs(dx) <= 3.0 and math.abs(dy) <= 1.0 then
					table.insert(candidates, { entity = mc.Entity, dist = math.abs(dx) })
				end
			end
		end
		table.sort(candidates, function(a, b) return a.dist < b.dist end)
		local result = {}
		for i = 1, math.min(#candidates, maxCount) do
			table.insert(result, candidates[i].entity)
		end
		return result
	end

	@ExecSpace("Server")
	method void RestoreThunderboltControl()
		self._T.isThunderbolting = false
		local playerCtrl = self.Entity.PlayerControllerComponent
		if isvalid(playerCtrl) and self._T.pendingThunderboltWasControllerEnabled then
			playerCtrl.Enable = true
		end
		-- (기능 추가) "다른 스킬들을 사용하고 난 다음도 모두 숨고르기 모션을 3번 하도록 해달라"는 요청 -
		-- 컨트롤이 복구된 이 시점에 공용 숨고르기(PlayBreather)를 시작한다.
		self:PlayBreather(self.Entity, self._T.pendingThunderboltDirX or 1)
	end

	@ExecSpace("Server")
	method void DealThunderboltHits(table targets)
		-- 예약된 딜레이 뒤 호출되어, 미리 골라둔 대상 전원에게 같은 프레임 안에서 동시에 타격 판정과
		-- 이펙트를 발생시킨다 (슬래쉬블래스트처럼 대상마다 나눠서 순차 타격하지 않음).
		if not isvalid(self.Entity) then return end
		local hitIndex = 0
		for _, target in ipairs(targets) do
			if isvalid(target) then
				-- 이번 Attack() 호출은 이 대상 하나만 통과하도록 지정 (몬스터 밀집 지역에서 이웃까지
				-- 겹쳐 중복 피해가 들어가는 것을 방지 - IsAttackTarget의 thunderboltCurrentTarget 체크 참고).
				self._T.thunderboltCurrentTarget = target
				local targetPos = target.TransformComponent.WorldPosition
				local shape = CircleShape(Vector2(targetPos.x, targetPos.y), 0.6)
				local hitComps = self:AttackShadowSafe(shape, "skill.thunderbolt", target)
				local actuallyHit = false
				for _, hc in ipairs(hitComps) do
					if isvalid(hc) and isvalid(hc.Entity) and hc.Entity == target then
						actuallyHit = true
						break
					end
				end
				if actuallyHit then
					-- 피격 이펙트/데미지는 동시에 처리하되, 타격음만 맞은 순서대로 0.04초 간격으로 재생한다
					-- (예: 6마리가 맞으면 0.04초 간격으로 6번 소리가 들림).
					self:PlayThunderboltHitEffect(target)
					local soundDelay = hitIndex * 0.04
					_TimerService:SetTimerOnce(function()
						self:PlayThunderboltHitSound()
					end, soundDelay)
					hitIndex = hitIndex + 1
				end
			end
		end
		log("PlayerAttack: AttackThunderbolt " .. tostring(#targets) .. "명 동시 타격, 실제 명중 " .. tostring(hitIndex) .. "명")
	end

	@ExecSpace("Multicast")
	method void PlayThunderboltUseSound(Entity attacker)
		-- 스킬 사용 즉시 재생되는 사운드. Multicast는 서버 자신도 함께 실행하므로 클라이언트에서만 실행되게 막는다.
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		_SoundService:PlaySound("3a8cf5d7d10f47f79f7bc9bdad81a746", 1.0)
	end

	@ExecSpace("Multicast")
	method void PlayThunderboltStartEffect(Entity attacker, number dirX)
		-- 스킬 사용과 동시에 캐릭터 몸에서 발현되는 시작 이펙트 (1회).
		-- 오프셋: 캐릭터 살짝 앞쪽 위에 있던 것을 사용자 요청으로 살짝 아래·몸쪽으로 이동 -
		-- x는 0.2*dirX(앞쪽으로 치우침) → 0.08*dirX(몸에 더 가깝게), y는 0.15 → 0.0으로 낮춤.
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		local startOptions = { ["FlipX"] = dirX > 0 }
		_EffectService:PlayEffectAttached("7b1fbc817b9a478e9f5c384dfc1a7176", attacker, Vector3(0.08 * dirX, 0.0, 0), 0, Vector3(1, 1, 1), false, startOptions)
		-- 쉐도우 파트너: 같은 시작 이펙트를 x축 뒤쪽에서 투명도 70%로 복제 재생(그림자 몫 - 데미지 없음)
		self:EchoShadowSkillEffectAttached("7b1fbc817b9a478e9f5c384dfc1a7176", attacker, Vector3(0.08 * dirX, 0.0, 0), 0, Vector3(1, 1, 1), startOptions, dirX)
	end

	method table GetThunderboltSwing()
		-- 매직클로와 동일한 모션 후보군(swingO1/O2/O3, 한손무기 계열)을 그대로 사용해 매 시전마다 순환 재생한다.
		local candidates = {
			{ name = "swingO1" },
			{ name = "swingO2" },
			{ name = "swingO3" },
		}
		self._T.thunderboltSwingIndex = (self._T.thunderboltSwingIndex or 0) % #candidates + 1
		return candidates[self._T.thunderboltSwingIndex]
	end

	@ExecSpace("Multicast")
	method void PlayThunderboltMotion(Entity attacker, string motionName, number dirX, number atkMultiplier)
		-- 썬더볼트 전용 모션 재생. 매직클로(PlayMagicClawMotion)와 완전히 동일한 방식 - 별도 플래그로 서로 간섭하지 않는다.
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		local avatarRenderer = attacker.AvatarRendererComponent
		if not isvalid(avatarRenderer) then return end
		local body = avatarRenderer:GetBodyEntity()
		if not isvalid(body) then return end

		avatarRenderer.ShowDefaultWeaponEffects = false

		local playerCtrl = attacker.PlayerControllerComponent
		if isvalid(attacker.MovementComponent) then
			attacker.MovementComponent:Stop()
		end
		if isvalid(playerCtrl) then
			playerCtrl.LookDirectionX = dirX
		end
		self._T.isThunderboltDirectionLocked = true
		self._T.lockedThunderboltDirX = dirX
		self._T.lockedThunderboltMotionName = motionName
		self._T.isThunderboltMotionPlaying = true

		local mult = math.max(atkMultiplier or 1.0, 0.001)
		local playRate = 1.0 / mult
		self._T.lockedThunderboltPlayRate = playRate

		local motionEvent = ActionStateChangedEvent(motionName, motionName, playRate, SpriteAnimClipPlayType.Onetime)
		body:SendEvent(motionEvent)
		log("[Thunderbolt] PlayThunderboltMotion sent: " .. tostring(motionName) .. " playRate=" .. tostring(playRate))

		_TimerService:SetTimerOnce(function()
			if isvalid(avatarRenderer) then
				avatarRenderer.ShowDefaultWeaponEffects = true
			end
			self._T.isThunderboltMotionPlaying = false
		end, 0.55 * mult)

		_TimerService:SetTimerOnce(function()
			self._T.isThunderboltDirectionLocked = false
			local sc = self.Entity.StateComponent
			if isvalid(sc) and sc.CurrentStateName ~= "DEAD" then
				sc:ChangeState("IDLE")
				sc:ChangeState("MOVE")
				sc:ChangeState("IDLE")
			end
		end, 0.80 * mult)
	end

	@ExecSpace("Multicast")
	method void PlayThunderboltHitEffect(Entity target)
		-- 타격받는 몬스터 머리 위에 나타나는 이펙트 (대상마다 1회, 전원 동시에 재생됨).
		-- 높이 오프셋은 기존 0.6에서 사용자 요청으로 조금 낮춰 0.3으로 조정.
		if not self:IsClient() then return end
		if not isvalid(target) then return end
		local serial = _EffectService:PlayEffectAttached("bb8d0c3c8b9940dfa5e4678bc642fa8d", target, Vector3(0, 0.3, 0), 0, Vector3(1, 1, 1), false, {})
		-- 쉐도우 파트너: 같은 히트 이펙트를 0.25초 시간차를 두고 그 자리에 한 번 더(70% 투명도) 재생
		self:EchoShadowHitEffect("bb8d0c3c8b9940dfa5e4678bc642fa8d", target, Vector3(0, 0.3, 0), 0, Vector3(1, 1, 1), {})
		_TimerService:SetTimerOnce(function()
			_EffectService:RemoveEffect(serial)
		end, 1.0)
	end

	@ExecSpace("Multicast")
	method void PlayThunderboltHitSound()
		-- 몬스터 타격음. 맞은 몬스터 수만큼, 0.04초 간격으로 순서대로 재생된다
		-- (호출 시점 자체가 DealThunderboltHits에서 인덱스*0.04초 딜레이로 예약되어 있음).
		if not self:IsClient() then return end
		_SoundService:PlaySound("d3205fdd08e34b68bc01292a997531ed", 1.0)
	end

	@ExecSpace("ServerOnly")
	method void AttackHeal(number combatPower, number atkMultiplier)
		-- (기능 추가) "다른 스킬을 쓰면 숨고르기 모션은 중지" 요청 - 이 스킬을 새로 시전하는 시점에 이전 숨고르기가 재생 중이었다면 즉시 정리한다.
		self:StopBreather()
		-- 힐 발동: 항상 자기 자신을 회복시키고, 주변(썬더볼트와 동일한 탐색 범위/최대 6명, 방향 무관)의
		-- 다른 플레이어는 함께 회복시키며, 그 범위 안의 언데드 몬스터(script.Monster.IsUndead=true)는 대신 피해를 입힌다.
		local currentState = self.Entity.StateComponent.CurrentStateName
		if currentState == "DEAD" or currentState == "CLIMB" or currentState == "LADDER" then
			return
		end
		if self._T.isHealing then
			return
		end
		self._T.isHealing = true

		local mult = math.max(0.1, math.min(atkMultiplier or 1.0, 3.0))
		self._T.pendingHealCombatPower = combatPower

		local playerCtrl = self.Entity.PlayerControllerComponent
		local worldPos = self.Entity.TransformComponent.WorldPosition
		local dirX = playerCtrl.LookDirectionX
		self._T.pendingHealDirX = dirX

		-- 자신을 제외한 범위 내 대상(다른 플레이어 + 언데드 몬스터)을 미리 골라둔다 (썬더볼트와 동일한 탐색 범위/최대 6명).
		local targets = self:FindHealTargets(Vector2(worldPos.x, worldPos.y), 6)
		self._T.healTargets = targets

		self._T.pendingHealWasControllerEnabled = isvalid(playerCtrl) and playerCtrl.Enable
		if isvalid(playerCtrl) then
			playerCtrl.Enable = false
		end
		if isvalid(self.Entity.MovementComponent) then
			self.Entity.MovementComponent:Stop()
		end

		-- 스킬 사용 사운드 + 몸쪽 시전 이펙트 (즉시, 1회) + 캐릭터 모션(버프/숨고르기 계열 후보 - 사용자가 화면으로 확인 후 확정 예정)
		self:PlayHealUseSound(self.Entity)
		self:PlayHealStartEffect(self.Entity)
		local motion = self:GetHealMotion()
		self:PlayHealMotion(self.Entity, motion.name, dirX, mult)

		-- 딜레이 후 자신을 무조건 회복시키고, 미리 골라둔 대상 전원에게 동시에 회복/피해를 적용한다.
		_TimerService:SetTimerOnce(function()
			self:DealHealEffects(targets)
		end, 0.4 * mult)

		-- 컨트롤 잠금 해제: 처리 직후 여유(0.2초)를 두고, 배율을 적용한다.
		_TimerService:SetTimerOnce(function()
			self:RestoreHealControl()
		end, 0.6 * mult)
	end

	@ExecSpace("ServerOnly")
	method table FindHealTargets(Vector2 fromPos, integer maxCount)
		-- 힐 대상 선정: 썬더볼트와 동일한 탐색 범위(방향 무관, 가로 6칸·세로 1칸)에서 자신을 제외한
		-- 다른 플레이어(회복 대상)와 언데드 몬스터(script.Monster.IsUndead=true, 피해 대상)를 함께 찾아
		-- 가까운 순으로 정렬해 최대 maxCount명까지 후보로 반환한다. 각 항목은 { entity, kind = "player"|"undead" }.
		local map = self.Entity.CurrentMap
		if not isvalid(map) then return {} end
		local candidates = {}

		local mapComp = map.MapComponent
		if isvalid(mapComp) then
			local users = _UserService:GetUsersByMapComponent(mapComp)
			if users ~= nil then
				for _, userEntity in ipairs(users) do
					if isvalid(userEntity) and userEntity ~= self.Entity then
						local pc = userEntity.PlayerComponent
						if isvalid(pc) and not pc:IsDead() then
							local pos = userEntity.TransformComponent.WorldPosition
							local dx = pos.x - fromPos.x
							local dy = pos.y - fromPos.y
							if math.abs(dx) <= 3.0 and math.abs(dy) <= 1.0 then
								table.insert(candidates, { entity = userEntity, dist = math.abs(dx), kind = "player" })
							end
						end
					end
				end
			end
		end

		local monsterComps = map:GetChildComponentsByTypeName("script.Monster", true)
		for _, comp in ipairs(monsterComps) do
			---@type Monster
			local mc = comp
			if isvalid(mc) and isvalid(mc.Entity) and not mc.IsDead and mc.IsUndead then
				local pos = mc.Entity.TransformComponent.WorldPosition
				local dx = pos.x - fromPos.x
				local dy = pos.y - fromPos.y
				if math.abs(dx) <= 3.0 and math.abs(dy) <= 1.0 then
					table.insert(candidates, { entity = mc.Entity, dist = math.abs(dx), kind = "undead" })
				end
			end
		end

		table.sort(candidates, function(a, b) return a.dist < b.dist end)
		local result = {}
		for i = 1, math.min(#candidates, maxCount) do
			table.insert(result, candidates[i])
		end
		return result
	end

	@ExecSpace("Server")
	method void RestoreHealControl()
		self._T.isHealing = false
		local playerCtrl = self.Entity.PlayerControllerComponent
		if isvalid(playerCtrl) and self._T.pendingHealWasControllerEnabled then
			playerCtrl.Enable = true
		end
		-- (기능 추가) "다른 스킬들을 사용하고 난 다음도 모두 숨고르기 모션을 3번 하도록 해달라"는 요청 -
		-- 컨트롤이 복구된 이 시점에 공용 숨고르기(PlayBreather)를 시작한다.
		self:PlayBreather(self.Entity, self._T.pendingHealDirX or 1)
	end

	@ExecSpace("Server")
	method void DealHealEffects(table targets)
		-- 예약된 딜레이 뒤 호출된다. 자신은 무조건 회복시키고(대상 목록과 무관), 목록의 각 대상은
		-- 종류(kind)에 따라 회복 또는 언데드 피해를 동시에 처리한다 (썬더볼트처럼 순차 딜레이 없음).
		if not isvalid(self.Entity) then return end

		self:ApplyHealToPlayer(self.Entity, self._T.pendingHealCombatPower or 0)

		for _, t in ipairs(targets) do
			if isvalid(t.entity) then
				if t.kind == "player" then
					self:ApplyHealToPlayer(t.entity, self._T.pendingHealCombatPower or 0)
				elseif t.kind == "undead" then
					-- 이번 Attack() 호출은 이 대상 하나만 통과하도록 지정 (썬더볼트와 동일한 교차 히트 방지 패턴).
					self._T.healCurrentUndeadTarget = t.entity
					local targetPos = t.entity.TransformComponent.WorldPosition
					local shape = CircleShape(Vector2(targetPos.x, targetPos.y), 0.6)
					local hitComps = self:AttackShadowSafe(shape, "skill.heal", t.entity)
					local actuallyHit = false
					for _, hc in ipairs(hitComps) do
						if isvalid(hc) and isvalid(hc.Entity) and hc.Entity == t.entity then
							actuallyHit = true
							break
						end
					end
					if actuallyHit then
						self:PlayHealUndeadHitSound()
						self:PlayHealUndeadHitEffect(t.entity)
					end
				end
			end
		end
		log("PlayerAttack: AttackHeal 처리 완료 대상=" .. tostring(#targets))
	end

	@ExecSpace("Server")
	method void ApplyHealToPlayer(Entity target, number combatPower)
		-- 전투력의 10%를 기준으로 ±50% 범위(즉 전투력의 5%~15%) 내에서 랜덤한 양만큼 HP를 회복시킨다
		-- (보유 중인 최대 HP를 넘지 않도록 클램프). 실제로 회복된 양만큼만 데미지스킨으로 숫자 표시 + 대상 머리 위 이펙트 재생.
		if not isvalid(target) then return end
		local pc = target.PlayerComponent
		if not isvalid(pc) then return end
		local baseHeal = combatPower * 0.10
		local mult = 0.5 + _UtilLogic:RandomDouble() * 1.0
		local healAmount = math.floor(baseHeal * mult)
		if healAmount <= 0 then return end
		local newHp = math.min(pc.Hp + healAmount, pc.MaxHp)
		local actualHealed = newHp - pc.Hp
		if actualHealed <= 0 then return end
		pc.Hp = newHp
		-- (버그 수정) "피를 채울 때만 머리 위에 이펙트가 하나 더 뜬다" - 시전자 본인은 시전과 동시에
		-- PlayHealStartEffect가 **같은 RUID**의 이펙트를 몸(0,0,0)에서 이미 재생하는데, 여기서 머리
		-- 위(0,0.6)에 한 번 더 재생해 두 개가 겹쳤다. HP가 꽉 차 있으면 위의 actualHealed <= 0에서
		-- 일찍 빠져나가 이 줄을 타지 않으므로 "피가 안 찰 때만 정상"으로 보였던 것.
		-- 본인은 시작 이펙트로 충분하니 머리 위 이펙트는 다른 대상에게만 재생한다(회복 숫자 표시는
		-- 본인도 그대로 - 그건 겹치는 게 아니다).
		if target ~= self.Entity then
			self:PlayHealTargetEffect(target)
		end
		self:ShowHealDamageSkin(target, actualHealed)
	end

	@ExecSpace("Multicast")
	method void PlayHealUseSound(Entity attacker)
		-- 스킬 사용 즉시 재생되는 사운드. Multicast는 서버 자신도 함께 실행하므로 클라이언트에서만 실행되게 막는다.
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		_SoundService:PlaySound("a1a425ae3c1c49afa068ee212676c5dc", 1.0)
	end

	@ExecSpace("Multicast")
	method void PlayHealStartEffect(Entity attacker)
		-- 스킬 사용과 동시에 캐릭터 몸에서 발현되는 시작 이펙트 (1회).
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		_EffectService:PlayEffectAttached("26a8af1751324d2c9f14b1719a28d3c8", attacker, Vector3(0, 0, 0), 0, Vector3(1, 1, 1), false, {})
		-- 쉐도우 파트너: 같은 시작 이펙트를 x축 뒤쪽에서 투명도 70%로 복제 재생(그림자 몫 - 데미지 없음)
		self:EchoShadowSkillEffectAttached("26a8af1751324d2c9f14b1719a28d3c8", attacker, Vector3(0, 0, 0), 0, Vector3(1, 1, 1), {}, 0)
	end

	@ExecSpace("Multicast")
	method void PlayHealTargetEffect(Entity target)
		-- 힐을 받은 대상(자신 포함) 머리 위에 나타나는 이펙트 (1회).
		if not self:IsClient() then return end
		if not isvalid(target) then return end
		local serial = _EffectService:PlayEffectAttached("26a8af1751324d2c9f14b1719a28d3c8", target, Vector3(0, 0.6, 0), 0, Vector3(1, 1, 1), false, {})
		_TimerService:SetTimerOnce(function()
			_EffectService:RemoveEffect(serial)
		end, 1.0)
	end

	@ExecSpace("Multicast")
	method void PlayHealUndeadHitSound()
		-- 언데드 몬스터가 힐로 피해를 입을 때 재생되는 사운드.
		if not self:IsClient() then return end
		_SoundService:PlaySound("38052d3003a941759a340ae28611d4dd", 1.0)
	end

	@ExecSpace("Multicast")
	method void PlayHealUndeadHitEffect(Entity target)
		-- 언데드 몬스터가 힐로 피해를 입을 때만 머리 위에 나타나는 이펙트 (1회). 다른 공격에는 재생되지 않는다.
		if not self:IsClient() then return end
		if not isvalid(target) then return end
		local headY = 0.5
		local hit = target.HitComponent
		if isvalid(hit) then
			headY = hit.ColliderOffset.y + hit.BoxSize.y / 2
		end
		local serial = _EffectService:PlayEffectAttached("e81f0ba3f2b545d7895b98b1cf9be879", target, Vector3(0, headY, 0), 0, Vector3(1, 1, 1), false, {})
		-- 쉐도우 파트너: 같은 히트 이펙트를 0.25초 시간차를 두고 그 자리에 한 번 더(70% 투명도) 재생
		self:EchoShadowHitEffect("e81f0ba3f2b545d7895b98b1cf9be879", target, Vector3(0, headY, 0), 0, Vector3(1, 1, 1), {})
		_TimerService:SetTimerOnce(function()
			_EffectService:RemoveEffect(serial)
		end, 1.0)
	end

	@ExecSpace("Client")
	method void ShowHealDamageSkin(Entity target, integer healAmount)
		-- 회복된 양을 데미지처럼 숫자로 표시한다 (전용 데미지스킨 RUID 사용).
		if not isvalid(target) then return end
		_DamageSkinService:Play(
			target, "d58b67cf0f3a4eaf9fe1ad87c0ffac8a", 0,
			{ healAmount }, DamageSkinTweenType.Default, false,
			Vector2(0, 0), Vector2(1, 1), 1.0, 1.0, LitMode.Default
		)
	end

	method table GetHealMotion()
		-- 사용자가 실제 화면으로 비교한 뒤 "alert" 동작으로 최종 확정.
		return { name = "alert" }
	end

	@ExecSpace("Multicast")
	method void PlayHealMotion(Entity attacker, string motionName, number dirX, number atkMultiplier)
		-- 힐 전용 모션 재생. 썬더볼트/매직클로와 동일한 방식 - 별도 플래그로 서로 간섭하지 않는다.
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		local avatarRenderer = attacker.AvatarRendererComponent
		if not isvalid(avatarRenderer) then return end
		local body = avatarRenderer:GetBodyEntity()
		if not isvalid(body) then return end

		avatarRenderer.ShowDefaultWeaponEffects = false

		local playerCtrl = attacker.PlayerControllerComponent
		if isvalid(attacker.MovementComponent) then
			attacker.MovementComponent:Stop()
		end
		if isvalid(playerCtrl) then
			playerCtrl.LookDirectionX = dirX
		end
		self._T.isHealDirectionLocked = true
		self._T.lockedHealDirX = dirX
		self._T.lockedHealMotionName = motionName
		self._T.isHealMotionPlaying = true

		local mult = math.max(atkMultiplier or 1.0, 0.001)
		local playRate = 1.0 / mult
		self._T.lockedHealPlayRate = playRate

		local motionEvent = ActionStateChangedEvent(motionName, motionName, playRate, SpriteAnimClipPlayType.Onetime)
		body:SendEvent(motionEvent)
		log("[Heal] PlayHealMotion sent: " .. tostring(motionName) .. " playRate=" .. tostring(playRate))

		_TimerService:SetTimerOnce(function()
			if isvalid(avatarRenderer) then
				avatarRenderer.ShowDefaultWeaponEffects = true
			end
			self._T.isHealMotionPlaying = false
		end, 0.55 * mult)

		_TimerService:SetTimerOnce(function()
			self._T.isHealDirectionLocked = false
			local sc = self.Entity.StateComponent
			if isvalid(sc) and sc.CurrentStateName ~= "DEAD" then
				sc:ChangeState("IDLE")
				sc:ChangeState("MOVE")
				sc:ChangeState("IDLE")
			end
		end, 0.80 * mult)
	end

	@ExecSpace("ServerOnly")
	method void AttackHaste(number atkMultiplier)
		-- (기능 추가) "다른 스킬을 쓰면 숨고르기 모션은 중지" 요청 - 이 스킬을 새로 시전하는 시점에 이전 숨고르기가 재생 중이었다면 즉시 정리한다.
		self:StopBreather()
		-- 헤이스트: 이동속도 40%, 점프력 20% 증가(5분). 최초 사용 시 원본 값을 한 번만 캡처해두고
		-- 이후에는 항상 그 원본 값 기준으로 배율을 재계산하므로, 지속 중 다시 사용해도 중첩되지 않고
		-- 지속시간만 갱신된다(토큰 비교로 먼저 걸린 타이머의 원복을 무시).
		local currentState = self.Entity.StateComponent.CurrentStateName
		if currentState == "DEAD" then
			return
		end

		local movement = self.Entity.MovementComponent
		if not isvalid(movement) then
			return
		end

		-- 힐과 동일한 모션(alert)을 재생하고, 그동안 다른 행동을 제한한다.
		local mult = math.max(atkMultiplier or 1.0, 0.001)
		local playerCtrl = self.Entity.PlayerControllerComponent
		local dirX = isvalid(playerCtrl) and playerCtrl.LookDirectionX or 1
		self._T.pendingHasteDirX = dirX
		self._T.pendingHasteWasControllerEnabled = isvalid(playerCtrl) and playerCtrl.Enable
		if isvalid(playerCtrl) then
			playerCtrl.Enable = false
		end
		movement:Stop()
		self:PlayHasteMotion(self.Entity, "alert", dirX, mult)
		_TimerService:SetTimerOnce(function()
			self:RestoreHasteControl()
		end, 0.6 * mult)

		if not self._T.hasteBaseCaptured then
			self._T.hasteBaseInputSpeed = movement.InputSpeed
			self._T.hasteBaseJumpForce = movement.JumpForce
			self._T.hasteBaseCaptured = true
		end

		movement.InputSpeed = self._T.hasteBaseInputSpeed * 1.4
		movement.JumpForce = self._T.hasteBaseJumpForce * 1.2

		self._T.hasteToken = (self._T.hasteToken or 0) + 1
		local myHasteToken = self._T.hasteToken
		local duration = 300

		self:PlayHasteCastEffect(self.Entity)

		local userId = self.Entity.PlayerComponent.UserId
		self:NotifyHasteStart(duration, userId)

		_TimerService:SetTimerOnce(function()
			if self._T.hasteToken ~= myHasteToken then return end
			if isvalid(movement) then
				movement.InputSpeed = self._T.hasteBaseInputSpeed
				movement.JumpForce = self._T.hasteBaseJumpForce
			end
		end, duration)
	end

	@ExecSpace("Multicast")
	method void PlayHasteCastEffect(Entity attacker)
		-- 헤이스트 시전 이펙트: 캐릭터 몸쪽에서 1회 재생 + 사용 사운드.
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		local serial = _EffectService:PlayEffectAttached("410e6a09f8ec471f87bd8d55c34cc48d", attacker, Vector3(0, 0, 0), 0, Vector3(1, 1, 1), false, {})
		-- 쉐도우 파트너: 같은 시전 이펙트를 x축 뒤쪽에서 투명도 70%로 복제 재생(그림자 몫)
		local echoSerial = self:EchoShadowSkillEffectAttached("410e6a09f8ec471f87bd8d55c34cc48d", attacker, Vector3(0, 0, 0), 0, Vector3(1, 1, 1), {}, 0)
		_SoundService:PlaySound("64795afda95e4b7dbdbdfe731e7d405a", 1.0)
		_TimerService:SetTimerOnce(function()
			_EffectService:RemoveEffect(serial)
			if echoSerial ~= 0 then
				_EffectService:RemoveEffect(echoSerial)
			end
		end, 1.5)
	end

	@ExecSpace("Client")
	method void NotifyHasteStart(number duration)
		-- 헤이스트 버프 타이머 UI 표시(본인 클라이언트에게만 - 호출부에서 UserId를 마지막 인자로 추가해 타겟팅).
		_HasteBuffUI:ShowBuff(duration)
	end

	@ExecSpace("Multicast")
	method void PlayHasteMotion(Entity attacker, string motionName, number dirX, number atkMultiplier)
		-- 헤이스트 전용 모션 재생 (힐과 동일한 방식/모션 - 별도 플래그로 서로 간섭하지 않는다).
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		local avatarRenderer = attacker.AvatarRendererComponent
		if not isvalid(avatarRenderer) then return end
		local body = avatarRenderer:GetBodyEntity()
		if not isvalid(body) then return end

		avatarRenderer.ShowDefaultWeaponEffects = false

		local playerCtrl = attacker.PlayerControllerComponent
		if isvalid(attacker.MovementComponent) then
			attacker.MovementComponent:Stop()
		end
		if isvalid(playerCtrl) then
			playerCtrl.LookDirectionX = dirX
		end
		self._T.isHasteDirectionLocked = true
		self._T.lockedHasteDirX = dirX
		self._T.lockedHasteMotionName = motionName
		self._T.isHasteMotionPlaying = true

		local mult = math.max(atkMultiplier or 1.0, 0.001)
		local playRate = 1.0 / mult
		self._T.lockedHastePlayRate = playRate

		local motionEvent = ActionStateChangedEvent(motionName, motionName, playRate, SpriteAnimClipPlayType.Onetime)
		body:SendEvent(motionEvent)
		log("[Haste] PlayHasteMotion sent: " .. tostring(motionName) .. " playRate=" .. tostring(playRate))

		_TimerService:SetTimerOnce(function()
			if isvalid(avatarRenderer) then
				avatarRenderer.ShowDefaultWeaponEffects = true
			end
			self._T.isHasteMotionPlaying = false
		end, 0.55 * mult)

		_TimerService:SetTimerOnce(function()
			self._T.isHasteDirectionLocked = false
			local sc = self.Entity.StateComponent
			if isvalid(sc) and sc.CurrentStateName ~= "DEAD" then
				sc:ChangeState("IDLE")
				sc:ChangeState("MOVE")
				sc:ChangeState("IDLE")
			end
		end, 0.80 * mult)
	end

	@ExecSpace("Server")
	method void RestoreHasteControl()
		local playerCtrl = self.Entity.PlayerControllerComponent
		if isvalid(playerCtrl) and self._T.pendingHasteWasControllerEnabled then
			playerCtrl.Enable = true
		end
		-- (기능 추가) "다른 스킬들을 사용하고 난 다음도 모두 숨고르기 모션을 3번 하도록 해달라"는 요청 -
		-- 컨트롤이 복구된 이 시점에 공용 숨고르기(PlayBreather)를 시작한다.
		self:PlayBreather(self.Entity, self._T.pendingHasteDirX or 1)
	end

	@ExecSpace("ServerOnly")
	method void AttackComboAttack(number atkMultiplier)
		-- (기능 추가) "다른 스킬을 쓰면 숨고르기 모션은 중지" 요청 - 이 스킬을 새로 시전하는 시점에 이전 숨고르기가 재생 중이었다면 즉시 정리한다.
		self:StopBreather()
		-- 콤보 어택(3차 버프, 30분): 시전 이펙트(skill/1111.img/skill/11111001의 effect 클립) +
		-- 사용 사운드(_audio/Use)를 1회 재생하고, 버프 지속 중 적을 hit할 때마다(OnAttack) 콤보
		-- 구슬이 1개씩(최대 10개, 물리적 구슬 엔티티는 5개까지만 스폰되고 6~10번째는 색 전환으로 표시)
		-- 몸 주위를 공전하며 쌓인다. 구슬 1개당 데미지 +20%(10개 = +200%,
		-- CalcDamage의 ApplyComboAttackBonus에서 일괄 적용). 헤이스트와 동일하게 시전 중에는
		-- 컨트롤을 잠그고(딜레이), 지속 중 재사용하면 중첩 없이 지속시간만 갱신된다(토큰 비교).
		local currentState = self.Entity.StateComponent.CurrentStateName
		if currentState == "DEAD" then
			return
		end

		local mult = math.max(atkMultiplier or 1.0, 0.001)
		local playerCtrl = self.Entity.PlayerControllerComponent
		local dirX = isvalid(playerCtrl) and playerCtrl.LookDirectionX or 1
		self._T.pendingComboDirX = dirX
		self._T.pendingComboWasControllerEnabled = isvalid(playerCtrl) and playerCtrl.Enable
		if isvalid(playerCtrl) then
			playerCtrl.Enable = false
		end
		if isvalid(self.Entity.MovementComponent) then
			self.Entity.MovementComponent:Stop()
		end

		-- 시전 모션: 정확한 전용 자세를 아직 실측 확정하지 못해 사용할 때마다 후보를 순서대로
		-- 하나씩 바꿔가며 재생하고 로그로 남긴다 - 화면과 로그를 대조해 마음에 드는 이름을
		-- 알려주면 그걸로 고정한다(스피어 버스터의 stabT2 확정 때와 동일한 절차).
		local motionName = self:GetComboAttackMotionName()
		self:PlayComboAttackMotion(self.Entity, dirX, mult, motionName)
		_TimerService:SetTimerOnce(function()
			self:RestoreComboAttackControl()
		end, 0.6 * mult)

		self:PlayComboAttackCastEffect(self.Entity, dirX)

		self._T.comboAttackToken = (self._T.comboAttackToken or 0) + 1
		local myToken = self._T.comboAttackToken
		local duration = 1800 -- 30분
		self._T.comboAttackActive = true

		local userId = self.Entity.PlayerComponent.UserId
		self:NotifyComboAttackStart(duration, userId)

		_TimerService:SetTimerOnce(function()
			if self._T.comboAttackToken ~= myToken then return end
			self._T.comboAttackActive = false
			self:ClearComboOrbs()
			log("[ComboAttack] 버프 종료(30분 경과)")
		end, duration)
		log("[ComboAttack] 버프 시작 duration=" .. tostring(duration))
	end

	method string GetComboAttackMotionName()
		-- 시전 자세 모션. 후보 순환 테스트 결과 첫 번째 후보(alert)로 확정했다 - 고정 재생.
		return "alert"
	end

	@ExecSpace("Multicast")
	method void PlayComboAttackMotion(Entity attacker, number dirX, number atkMultiplier, string motionName)
		-- 시전 모션을 1회 재생한다(헤이스트의 PlayHasteMotion과 동일한 방식 - 별도 플래그 없이
		-- 컨트롤 잠금(0.6*mult) 구간 동안만 재생되는 짧은 자세라 상태 재적용 훅은 두지 않는다).
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		local avatarRenderer = attacker.AvatarRendererComponent
		if not isvalid(avatarRenderer) then return end
		local body = avatarRenderer:GetBodyEntity()
		if not isvalid(body) then return end

		local playerCtrl = attacker.PlayerControllerComponent
		if isvalid(attacker.MovementComponent) then
			attacker.MovementComponent:Stop()
		end
		if isvalid(playerCtrl) then
			playerCtrl.LookDirectionX = dirX
		end

		local mult = math.max(atkMultiplier or 1.0, 0.001)
		local playRate = 1.0 / mult
		local motionEvent = ActionStateChangedEvent(motionName, motionName, playRate, SpriteAnimClipPlayType.Onetime)
		body:SendEvent(motionEvent)
		log("[ComboAttack] PlayComboAttackMotion sent " .. tostring(motionName) .. " playRate=" .. tostring(playRate))

		_TimerService:SetTimerOnce(function()
			local sc = attacker.StateComponent
			if isvalid(sc) and sc.CurrentStateName ~= "DEAD" then
				sc:ChangeState("IDLE")
				sc:ChangeState("MOVE")
				sc:ChangeState("IDLE")
			end
		end, 0.80 * mult)
	end

	@ExecSpace("Multicast")
	method void PlayComboAttackCastEffect(Entity attacker, number dirX)
		-- 시전 이펙트(마법진 버스트, 참고 영상 '콤보어택 사용시') 1회 + 사용 사운드.
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		local flipX = dirX > 0
		_EffectService:PlayEffectAttached("19e3ba3ab994431b81a3d4ee7a1b86e0", attacker, Vector3(0, 0, 0), 0, Vector3(1, 1, 1), false, { ["FlipX"] = flipX })
		-- 쉐도우 파트너: 같은 시전 이펙트를 x축 뒤쪽에서 투명도 70%로 복제 재생(그림자 몫)
		self:EchoShadowSkillEffectAttached("19e3ba3ab994431b81a3d4ee7a1b86e0", attacker, Vector3(0, 0, 0), 0, Vector3(1, 1, 1), { ["FlipX"] = flipX }, dirX)
		_SoundService:PlaySound("4b254b65adbe4df4885acbe2e2fa3671", 1.0)
		log("[ComboAttack] 시전 이펙트/사운드 재생")
	end

	@ExecSpace("Client")
	method void NotifyComboAttackStart(number duration)
		-- 콤보 어택 버프 타이머 UI 표시(본인 클라이언트에게만 - 호출부에서 UserId를 마지막 인자로 타겟팅).
		_ComboBuffUI:ShowBuff(duration)
	end

	@ExecSpace("Server")
	method void RestoreComboAttackControl()
		local playerCtrl = self.Entity.PlayerControllerComponent
		if isvalid(playerCtrl) and self._T.pendingComboWasControllerEnabled then
			playerCtrl.Enable = true
		end
		-- (기능 추가) "다른 스킬들을 사용하고 난 다음도 모두 숨고르기 모션을 3번 하도록 해달라"는 요청 -
		-- 컨트롤이 복구된 이 시점에 공용 숨고르기(PlayBreather)를 시작한다.
		self:PlayBreather(self.Entity, self._T.pendingComboDirX or 1)
	end

	@ExecSpace("ServerOnly")
	method void AttackShadowPartner(number atkMultiplier)
		-- (기능 추가) "다른 스킬을 쓰면 숨고르기 모션은 중지" 요청 - 이 스킬을 새로 시전하는 시점에 이전 숨고르기가 재생 중이었다면 즉시 정리한다.
		self:StopBreather()
		-- 쉐도우 파트너(버프, 30분): 헤이스트/콤보어택과 동일한 패턴 - 지속 중 재사용하면 중첩 없이
		-- 지속시간만 갱신된다(토큰 비교). 그림자 시각 표현(등뒤에 붙어 본체 모션을 따라하는 실루엣)은
		-- ShadowPartnerVisual 컴포넌트가 전담하고, 여기서는 그 엔티티를 최초 1회만 스폰해 재사용한다.
		local currentState = self.Entity.StateComponent.CurrentStateName
		if currentState == "DEAD" then
			return
		end

		local mult = math.max(atkMultiplier or 1.0, 0.001)
		local playerCtrl = self.Entity.PlayerControllerComponent
		local dirX = isvalid(playerCtrl) and playerCtrl.LookDirectionX or 1
		self._T.pendingShadowPartnerDirX = dirX
		self._T.pendingShadowPartnerWasControllerEnabled = isvalid(playerCtrl) and playerCtrl.Enable
		if isvalid(playerCtrl) then
			playerCtrl.Enable = false
		end
		if isvalid(self.Entity.MovementComponent) then
			self.Entity.MovementComponent:Stop()
		end

		self:PlayShadowPartnerMotion(self.Entity, "alert", dirX, mult)
		_TimerService:SetTimerOnce(function()
			self:RestoreShadowPartnerControl()
		end, 0.6 * mult)

		self:PlayShadowPartnerCastEffect(self.Entity, dirX)
		self:SpawnOrShowShadowEntity()

		self._T.shadowPartnerToken = (self._T.shadowPartnerToken or 0) + 1
		local myToken = self._T.shadowPartnerToken
		local duration = 1800 -- 30분
		self._T.shadowPartnerActive = true
		self.ShadowPartnerOn = true

		local userId = self.Entity.PlayerComponent.UserId
		self:NotifyShadowPartnerStart(duration, userId)

		_TimerService:SetTimerOnce(function()
			if self._T.shadowPartnerToken ~= myToken then return end
			self._T.shadowPartnerActive = false
			self.ShadowPartnerOn = false
			if isvalid(self._T.shadowPartnerEntity) then
				self._T.shadowPartnerEntity.Enable = false
			end
			log("[ShadowPartner] 버프 종료(30분 경과)")
		end, duration)
		log("[ShadowPartner] 버프 시작 duration=" .. tostring(duration))
	end

	@ExecSpace("ServerOnly")
	method void SpawnOrShowShadowEntity()
		-- 그림자 엔티티는 최초 1회만 스폰하고(플레이어의 자식 - SpearBurstFadingEffect/ComboOrb와 동일한
		-- 부모-자식 스폰 패턴), 이후 재사용 시에는 Enable만 다시 켠다. ShadowPartnerVisual 스크립트는
		-- .model 자체에 포함돼 있어(런타임 AddComponent는 클라이언트로 복제되지 않아 OnBeginPlay의
		-- ClientOnly 분기가 실행되지 않는 문제가 실측됨) 스폰과 동시에 모든 클라이언트에 정상 복제된다.
		if isvalid(self._T.shadowPartnerEntity) then
			self._T.shadowPartnerEntity.Enable = true
			return
		end
		local map = self.Entity.CurrentMap
		if not isvalid(map) then return end
		local shadow = _SpawnService:SpawnByModelId("shadowpartnershadow", "ShadowPartnerShadow_" .. self.Entity.Name, Vector3(-0.22, -0.02, 0), self.Entity)
		if not isvalid(shadow) then
			log_warning("[ShadowPartner] 그림자 엔티티 스폰 실패")
			return
		end
		shadow.Enable = true
		self._T.shadowPartnerEntity = shadow
		log("[ShadowPartner] 그림자 엔티티 스폰 완료")
	end

	@ExecSpace("Multicast")
	method void PlayShadowPartnerMotion(Entity attacker, string motionName, number dirX, number atkMultiplier)
		-- 쉐도우 파트너 시전 모션(헤이스트/콤보어택과 동일한 방식 - 별도 플래그로 서로 간섭하지 않는다).
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		local avatarRenderer = attacker.AvatarRendererComponent
		if not isvalid(avatarRenderer) then return end
		local body = avatarRenderer:GetBodyEntity()
		if not isvalid(body) then return end

		avatarRenderer.ShowDefaultWeaponEffects = false

		local playerCtrl = attacker.PlayerControllerComponent
		if isvalid(attacker.MovementComponent) then
			attacker.MovementComponent:Stop()
		end
		if isvalid(playerCtrl) then
			playerCtrl.LookDirectionX = dirX
		end
		self._T.isShadowPartnerDirectionLocked = true
		self._T.lockedShadowPartnerDirX = dirX
		self._T.lockedShadowPartnerMotionName = motionName
		self._T.isShadowPartnerMotionPlaying = true

		local mult = math.max(atkMultiplier or 1.0, 0.001)
		local playRate = 1.0 / mult
		self._T.lockedShadowPartnerPlayRate = playRate

		local motionEvent = ActionStateChangedEvent(motionName, motionName, playRate, SpriteAnimClipPlayType.Onetime)
		body:SendEvent(motionEvent)
		log("[ShadowPartner] PlayShadowPartnerMotion sent: " .. tostring(motionName) .. " playRate=" .. tostring(playRate))

		_TimerService:SetTimerOnce(function()
			if isvalid(avatarRenderer) then
				avatarRenderer.ShowDefaultWeaponEffects = true
			end
			self._T.isShadowPartnerMotionPlaying = false
		end, 0.55 * mult)

		_TimerService:SetTimerOnce(function()
			self._T.isShadowPartnerDirectionLocked = false
			local sc = self.Entity.StateComponent
			if isvalid(sc) and sc.CurrentStateName ~= "DEAD" then
				sc:ChangeState("IDLE")
				sc:ChangeState("MOVE")
				sc:ChangeState("IDLE")
			end
		end, 0.80 * mult)
	end

	@ExecSpace("Multicast")
	method void PlayShadowPartnerCastEffect(Entity attacker, number dirX)
		-- 시전 이펙트: 캐릭터 몸쪽에서 1회 재생되는 이펙트 2종 + 사용 사운드.
		-- (사용자 확정) 8ef08d99...(effect, 큰 이미지)가 앞, 6db426f9...(effect0, 작은 이미지)가 뒤(zorder).
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		local flipX = dirX > 0
		local backSerial = _EffectService:PlayEffectAttached("6db426f91ed54b83beddb7837d96fb4c", attacker, Vector3(0, 0, 0), 0, Vector3(1, 1, 1), false, { ["FlipX"] = flipX, ["OrderInLayer"] = 5 })
		local frontSerial = _EffectService:PlayEffectAttached("8ef08d990aeb452bad114479f6bc76fd", attacker, Vector3(0, 0, 0), 0, Vector3(1, 1, 1), false, { ["FlipX"] = flipX, ["OrderInLayer"] = 10 })
		_SoundService:PlaySound("6c7c28167b9049419435cc53001cef0c", 1.0)
		log("[ShadowPartner] 시전 이펙트/사운드 재생")
	end

	@ExecSpace("Client")
	method void NotifyShadowPartnerStart(number duration)
		-- 쉐도우 파트너 버프 타이머 UI 표시(본인 클라이언트에게만 - 호출부에서 UserId를 마지막 인자로 타겟팅).
		_ShadowPartnerBuffUI:ShowBuff(duration)
	end

	@ExecSpace("Server")
	method void RestoreShadowPartnerControl()
		local playerCtrl = self.Entity.PlayerControllerComponent
		if isvalid(playerCtrl) and self._T.pendingShadowPartnerWasControllerEnabled then
			playerCtrl.Enable = true
		end
		-- (기능 추가) "다른 스킬들을 사용하고 난 다음도 모두 숨고르기 모션을 3번 하도록 해달라"는 요청 -
		-- 컨트롤이 복구된 이 시점에 공용 숨고르기(PlayBreather)를 시작한다.
		self:PlayBreather(self.Entity, self._T.pendingShadowPartnerDirX or 1)
	end

	-- 쉐도우 파트너 활성 중 self:Attack()으로 단일 대상을 판정할 때 공용으로 쓰는 래퍼. 대상의
	-- MOD.Core.DamageSkinSpawnerComponent를 판정 직전 잠깐 떼었다가 붙인다 - 이 컴포넌트가 붙어있는 채로
	-- 같은 AttackComponent 인스턴스가 같은 대상을 짧은 간격으로(예: 기본공격 연타) 반복 타격하면
	-- GetDisplayHitCount=0을 반환해도 엔진이 히트마다 자동 데미지 숫자를 하나씩 추가로 띄우는 문제가
	-- DoubleStab/MagicClaw/SpearBurst에서 실측 확인됐다(DealDoubleStabHit 등 참고) - 이 래퍼로 모든
	-- 일반 스킬(기본공격/파워스트라이크/슬래쉬블래스트/썬더볼트/힐/익스플로젼/드래곤로어/패닉/코마)의
	-- Attack() 호출에도 동일하게 적용해 "1줄이던 스킬이 3번 뜨는" 버그를 없앤다. 버프가 꺼져있으면
	-- 평소와 동일하게 그냥 self:Attack()만 호출한다(불필요한 컴포넌트 탈부착 방지).
	-- shape는 BoxShape/CircleShape 등 여러 Shape 하위 타입을 그대로 받아 넘기기 위해 any로 선언한다
	-- (커스텀 스크립트 메서드 파라미터에 추상 타입 Shape을 직접 쓰면 LEA-4002 컴파일 에러가 난다).
	method table AttackShadowSafe(any shape, string attackInfo, Entity target)
		if not self._T.shadowPartnerActive or not isvalid(target) then
			return self:Attack(shape, attackInfo, CollisionGroups.HitBox)
		end
		local skin = target:GetComponent("MOD.Core.DamageSkinSpawnerComponent")
		local stripped = isvalid(skin)
		if stripped then
			target:RemoveComponent("MOD.Core.DamageSkinSpawnerComponent")
		end
		local hitComps = self:Attack(shape, attackInfo, CollisionGroups.HitBox)
		if stripped and isvalid(target) and not isvalid(target:GetComponent("MOD.Core.DamageSkinSpawnerComponent")) then
			target:AddComponent("MOD.Core.DamageSkinSpawnerComponent")
		end
		return hitComps
	end

	-- AttackShadowSafe의 AttackFast 버전(기본공격 전용 - AttackFast는 히트 목록을 만들지 않아 반환값이 없다).
	method void AttackFastShadowSafe(any shape, string attackInfo, Entity target)
		if not self._T.shadowPartnerActive or not isvalid(target) then
			self:AttackFast(shape, attackInfo, CollisionGroups.HitBox)
			return
		end
		local skin = target:GetComponent("MOD.Core.DamageSkinSpawnerComponent")
		local stripped = isvalid(skin)
		if stripped then
			target:RemoveComponent("MOD.Core.DamageSkinSpawnerComponent")
		end
		self:AttackFast(shape, attackInfo, CollisionGroups.HitBox)
		if stripped and isvalid(target) and not isvalid(target:GetComponent("MOD.Core.DamageSkinSpawnerComponent")) then
			target:AddComponent("MOD.Core.DamageSkinSpawnerComponent")
		end
	end

	-- 쉐도우 파트너 - 투척류가 아닌 스킬(모션만 그림자가 따라하는 스킬)은 실제 히트가 여전히 1번뿐이므로,
	-- 타격음도 함께 2배로 들리도록 몬스터의 기본 피격음을 한 번 더 재생해준다("타격음이 2배로 많이
	-- 들리고" 요청). 던지는 스킬(파이어에로우/아이언에로우/럭키세븐)은 그림자가 실제로 투사체를 하나
	-- 더 쏴서 자연스럽게 히트음도 2번 나므로 이 메서드를 호출하지 않는다.
	@ExecSpace("Server")
	method void PlayShadowEchoHitSound(Entity defender)
		if not isvalid(defender) then return end
		---@type Monster
		local monsterComp = defender:GetComponent("script.Monster")
		if isvalid(monsterComp) then
			monsterComp:PlayHitSound()
		end
	end

	@ExecSpace("ServerOnly")
	method void SpawnShadowEchoArrowProjectile(string modelId, string projScriptType, string arrowRuid, Vector3 spawnPos, number dirX, number dirY, number combatPower)
		-- 쉐도우 파트너 - 그림자가 화살을 하나 더 쏴서 2개가 날아가는 것처럼 보이는 연출.
		-- (기능 변경) 그림자 화살은 "시각 전용"이다 - 그림자 스킬 이펙트는 몬스터에게 직접적인 데미지를
		-- 주지 않는다는 요청. 타수 2배는 원본 화살의 히트 하나에 원본+보너스(55~65%)를 합산하고 데미지
		-- 숫자를 2줄로 나눠 표시하는 방식(각 *ProjectileAttack.CalcDamage)으로 처리한다.
		-- 화살 자체는 발사 방향의 반대쪽(x축 뒤쪽)에서 원본과 같은 모습, 투명도 70%로 날아간다.
		if not self._T.shadowPartnerActive then return end
		local map = self.Entity.CurrentMap
		if not isvalid(map) then return end
		self._T.shadowEchoProjCount = (self._T.shadowEchoProjCount or 0) + 1
		local name = "shadowecho_" .. tostring(self.Entity.Name) .. "_" .. tostring(self._T.shadowEchoProjCount)
		local echoPos = Vector3(spawnPos.x - 0.45 * dirX, spawnPos.y - 0.45 * dirY, spawnPos.z)
		local proj = _SpawnService:SpawnByModelId(modelId, name, echoPos, map)
		if not isvalid(proj) then return end
		local sprite = proj.SpriteRendererComponent
		if isvalid(sprite) then
			sprite.SpriteRUID = arrowRuid
			sprite.Color = Color(1, 1, 1, 0.7)
		end
		local projComp = proj:GetComponent(projScriptType)
		if isvalid(projComp) then
			projComp.VisualOnly = true
			projComp:Fire(dirX, dirY)
		end
	end

	@ExecSpace("Multicast")
	method void ShowShadowEchoDamageSkin(Entity defender, integer original, integer bonus, boolean originalIsCritical, boolean bonusIsCritical)
		-- 쉐도우 파트너 - 이번 진짜 히트 하나(원본+보너스가 이미 합산된 실제 적용 데미지)를 화면에는
		-- 더블스탭과 동일한 방식으로 [원본, 보너스] 두 줄을 한 번에 묶어서 표시한다("공격도 개별로
		-- 공격하면 안되고 묶어서 2줄로 떠야 한다"는 요청). 대상이 이 히트로 즉시 죽어도 실제 적용된
		-- 데미지는 CalcDamage가 이미 합산해 반환했으므로 표시만 여기서 그리는 것 - 별도의 재진입
		-- Attack() 호출이 없어 "죽는 순간엔 에코가 안 붙는다"는 문제가 구조적으로 사라진다.
		if not self:IsClient() then return end
		if not isvalid(defender) then return end
		local skinRuid = self:GetHitDamageSkinId()
		-- (버그 수정) 원본/보너스를 하나의 Play() 배열로 묶으면 두 숫자가 같은 위치에서 시간차로만
		-- 분리돼 겹쳐 보인다(더블스탭/스피어버스터에서 실측된 것과 동일한 증상) - "데미지가 겹치지 않게"
		-- 요청에 따라 서로 다른 offsetY를 가진 별도의 Play() 호출 2번으로 나눠 항상 2줄로 분리해 띄운다.
		-- (버그 수정) "2줄 중 하나만 뜨는 경우 없이 항상 같이 뜬다" - 원본/보너스가 CalcCritical의 결과
		-- 하나(isCritical)를 공유해서 생긴 문제였다. CalcDamage에서 각 줄에 대해 독립적으로 굴린 결과를
		-- 각각 별도 파라미터(originalIsCritical/bonusIsCritical)로 받아 그대로 전달한다.
		_DamageSkinService:Play(defender, skinRuid, 0, { original }, DamageSkinTweenType.Default, originalIsCritical, Vector2(0, 0), Vector2(1, 1), 1.0, 1.0, LitMode.Default)
		_DamageSkinService:Play(defender, skinRuid, 0, { bonus }, DamageSkinTweenType.Default, bonusIsCritical, Vector2(0, 0.3), Vector2(1, 1), 1.0, 1.0, LitMode.Default)
		log("[ShadowPartner] 데미지 2줄 표시 original=" .. tostring(original) .. " bonus=" .. tostring(bonus) .. " originalCrit=" .. tostring(originalIsCritical) .. " bonusCrit=" .. tostring(bonusIsCritical))
	end

	-- ===== 쉐도우 파트너 그림자 이펙트 헬퍼 =====
	-- 아래 4개 헬퍼는 전부 클라이언트에서 실행 중인 이펙트 메서드(Multicast/Client) 안에서 호출된다.
	-- ShadowPartnerOn(@Sync)이 꺼져 있으면 아무것도 하지 않으므로, 버프가 없을 때 기존 동작은 그대로다.

	method table BuildShadowEffectOptions(table options)
		-- 그림자 몫 이펙트 옵션: 원본 옵션을 복사하고 투명도 70%(Alpha=0.7)를 얹는다.
		-- 원본에 이미 Alpha가 있으면(예: 파워스트라이크 스윙 0.8) 그 값에 70%를 곱한다.
		local copy = {}
		if options ~= nil then
			for k, v in pairs(options) do
				copy[k] = v
			end
		end
		local baseAlpha = copy["Alpha"] or 1.0
		copy["Alpha"] = baseAlpha * 0.7
		return copy
	end

	method number ResolveShadowDirX(number dirX)
		-- 그림자 이펙트를 띄울 "뒤쪽" 방향 계산용. dirX가 0(미지정/수직 발사)이면 현재 바라보는 방향을 쓴다.
		local d = dirX or 0
		if d == 0 then
			local pc = self.Entity.PlayerControllerComponent
			d = isvalid(pc) and pc.LookDirectionX or 1
			if d == 0 then d = 1 end
		end
		return d
	end

	method integer EchoShadowSkillEffectAttached(string ruid, Entity parent, Vector3 localPos, number zRot, Vector3 scale, table options, number dirX)
		-- 그림자 스킬 이펙트(시전/궤적): 버프 중이면 같은 이펙트를 x축 뒤쪽(-0.45 * 바라보는 방향)에서
		-- 투명도 70%로 1회 더 재생한다. 반환값은 이펙트 시리얼(재생 안 했으면 0) - 원본이 RemoveEffect
		-- 타이머로 정리되는 호출부는 이 시리얼도 같이 정리한다.
		if not self.ShadowPartnerOn then return 0 end
		if not isvalid(parent) then return 0 end
		local d = self:ResolveShadowDirX(dirX)
		log("[ShadowPartner] 그림자 스킬이펙트(부착) 재생 ruid=" .. tostring(ruid) .. " dirX=" .. tostring(d))
		return _EffectService:PlayEffectAttached(ruid, parent, Vector3(localPos.x - 0.45 * d, localPos.y, localPos.z), zRot, scale, false, self:BuildShadowEffectOptions(options))
	end

	method integer EchoShadowSkillEffect(string ruid, Vector3 pos, number zRot, Vector3 scale, table options, number dirX)
		-- 그림자 스킬 이펙트의 고정 좌표(맵 기준) 버전 - 텔레포트 잔상/독구름 파열처럼 월드 좌표에
		-- 직접 재생되는 이펙트용. x축 뒤쪽 오프셋 + 투명도 70%는 부착형과 동일하다.
		if not self.ShadowPartnerOn then return 0 end
		local mapEntity = self.Entity.CurrentMap
		if not isvalid(mapEntity) then return 0 end
		local d = self:ResolveShadowDirX(dirX)
		log("[ShadowPartner] 그림자 스킬이펙트(고정) 재생 ruid=" .. tostring(ruid) .. " dirX=" .. tostring(d))
		return _EffectService:PlayEffect(ruid, mapEntity, Vector3(pos.x - 0.45 * d, pos.y, pos.z), zRot, scale, false, self:BuildShadowEffectOptions(options))
	end

	method void EchoShadowHitEffectAtPos(string ruid, Vector3 pos, number zRot, Vector3 scale, table options)
		-- 히트 이펙트 2배(고정 좌표 버전): 지금 좌표를 그대로 캡처해 0.25초 뒤 한 번 더(투명도 70%) 재생한다.
		-- 고정 좌표(PlayEffect)라서 그 사이 대상이 죽어 사라져도 항상 그 자리(허공)에서 발동한다.
		if not self.ShadowPartnerOn then return end
		local mapEntity = self.Entity.CurrentMap
		if not isvalid(mapEntity) then return end
		local px, py, pz = pos.x, pos.y, pos.z
		local shadowOptions = self:BuildShadowEffectOptions(options)
		_TimerService:SetTimerOnce(function()
			if not isvalid(mapEntity) then return end
			_EffectService:PlayEffect(ruid, mapEntity, Vector3(px, py, pz), zRot, scale, false, shadowOptions)
			log("[ShadowPartner] 그림자 히트이펙트 발동(0.25초 지연, 고정좌표) ruid=" .. tostring(ruid) .. " pos=(" .. tostring(px) .. "," .. tostring(py) .. ")")
		end, 0.25)
	end

	method void EchoShadowHitEffect(string ruid, Entity target, Vector3 localOffset, number zRot, Vector3 scale, table options)
		-- 히트 이펙트 2배(대상 부착형 원본용): 대상의 현재 월드 위치 + 원본의 로컬 오프셋을 즉시 스냅샷해
		-- 시간차(0.25초)를 두고 고정 좌표로 한 번 더 재생한다 - "플레이어가 몬스터를 바로 죽였어도
		-- 그자리에 허공에서라도 발동해야 한다"는 요청을 고정 좌표 재생으로 보장한다.
		if not self.ShadowPartnerOn then return end
		if not isvalid(target) then return end
		local wp = target.TransformComponent.WorldPosition
		self:EchoShadowHitEffectAtPos(ruid, Vector3(wp.x + localOffset.x, wp.y + localOffset.y, wp.z + localOffset.z), zRot, scale, options)
	end

	method void OnAttack(Entity defender)
		-- 콤보 어택 버프 지속 중 적을 실제로 적중시킬 때마다 콤보 구슬 +1(최대 10).
		-- 부모 AttackComponent.OnAttack은 ExecSpace 미지정(All)이라 어노테이션 없이 오버라이드해야
		-- 한다(LEA-3014 방지). 실제 히트 파이프라인은 서버에서만 돌지만 안전하게 한 번 더 거른다.
		-- 스피어 버스터(3연타)/더블스탭(2연타)/썬더볼트(최대 6대상 동시)처럼 스킬 1회 사용이 여러 번
		-- OnAttack을 호출하는 경우에도 스택은 1회만 쌓여야 한다 - 같은 사용(cast) 안의 모든 히트는
		-- 0.4초 이내에 몰려서 들어오고(가장 느린 스피어버스터도 히트 간격 최대 ~0.3초), 다음 재사용은
		-- 쿨다운(0.7초 이상)이 지난 뒤라 서로 겹치지 않는다는 실측 타이밍에 기반한 시간창 방식.
		if not self:IsServer() then return end
		-- (기능 추가) 쉐도우 파트너 - 더블스탭/매직클로/스피어버스터(수동 표시 스킬)는 각자 전용
		-- Show*DamageSkin에서 직접 보너스를 묶어 표시하므로 여기서는 건너뛴다(shadowEchoIsManualSkin).
		if self._T.shadowEchoBonus ~= nil and not self._T.shadowEchoIsManualSkin and isvalid(defender) then
			self:ShowShadowEchoDamageSkin(defender, self._T.shadowEchoOriginal, self._T.shadowEchoBonus, self._T.shadowEchoOriginalIsCritical or false, self._T.shadowEchoBonusIsCritical or false)
			-- (기능 추가) "타격음이 2배로 많이 들리게 해달라" 요청 - 실제 히트는 1번뿐이므로 몬스터 기본
			-- 피격음을 한 번 더 재생해 청각적으로도 2배처럼 느껴지게 한다.
			self:PlayShadowEchoHitSound(defender)
		end
		-- (기능 추가) "패닉 공격으로는 콤보 어택이 차면 안 된다"는 요청 - 패닉은 구슬을 모두 소모하는
		-- 스킬이라, 그 판정 자체가 다시 구슬을 채워버리면 소모한 의미가 없어진다. 패닉 판정(Attack)이
		-- 진행 중인 구간(AttackPanic~RestorePanicControl 사이, isPanicking=true)에는 구슬 획득을 건너뛴다.
		if self._T.isPanicking then return end
		if not self._T.comboAttackActive then return end
		if not isvalid(defender) then return end
		local now = _UtilLogic.ElapsedSeconds
		if self._T.lastComboStackTime and (now - self._T.lastComboStackTime) < 0.4 then
			return
		end
		self._T.lastComboStackTime = now
		-- (기능 추가) "히트 시 50% 확률로 구슬이 생기게 해달라"는 요청 - 매 히트마다 확정 지급하던 것을
		-- 절반 확률로 바꾼다. math.random() 대신 _UtilLogic:RandomDouble()을 쓴다 - 이 파일에서 이미
		-- 실측 확인된 버그(스피어 버스터 등 여러 히트가 0.1~0.2초 간격으로 잇따라 호출되면 math.random()이
		-- 같은 값을 두 번 반환)를 피하기 위해서다.
		if _UtilLogic:RandomDouble() >= 0.5 then return end
		-- (기능 추가) "어드밴스드 콤보(4차 패시브)가 있으면 여기서 다시 확률로 구슬 1개가 아니라
		-- 2개가 한번에 찬다"는 요청. (버그 수정) 패시브 스킬은 파이널어택(2차 패시브 - TryTriggerFinalAttack
		-- 참고)과 동일하게 스킬바 슬롯 배정과 무관하게 항상 적용되는 효과다 - "패시브는 클릭-클릭으로
		-- 슬롯에 옮길 수 없다"는 피드백으로, 슬롯 배정 여부를 확인하던 이전 방식(HasAdvancedCombo +
		-- SkillManager 동기화)은 실제 플레이에서 조건이 절대 참이 될 수 없어 항상 적용되지 않던 원인이었다 -
		-- 제거하고 파이널어택과 같은 방식(무조건 적용)으로 되돌린다.
		-- (기능 추가) "콤보어택이 차는 속도가 너무 빠르다"는 피드백으로 2개 동시 지급 확률을 50%→20%로 낮춘다.
		-- (구슬 10개 상한은 AddComboOrb 자체가 개별 호출마다 다시 확인하므로, 9개 상태에서 두 번째
		-- AddComboOrb 호출은 자동으로 무시되어 10개를 넘지 않는다 - 아래에서 실제로 몇 개가 늘었는지
		-- 확인해 로그도 그 실제 증가량만 "2개 동시 지급"으로 표시한다.)
		local before = self.ComboOrbCount
		if _UtilLogic:RandomDouble() < 0.2 then
			self:AddComboOrb()
			self:AddComboOrb()
		else
			self:AddComboOrb()
		end
		if self.ComboOrbCount - before >= 2 then
			log("[ComboAttack] 어드밴스드 콤보 발동 - 구슬 2개 동시 지급")
		end
	end

	method string GetComboOrbSpriteRuid(integer idx)
		-- state 클립(8c563f54...)의 프레임 1~5가 룬 문양 구슬 스프라이트다(msw-search 실측). 기본(파란) 색상.
		local ruids = {
			"594f34c4103145a28951780047e71e42",
			"eefe86c8b370407aa16c9fe34f12c98d",
			"dfb6702ddc994b8b8b24acf3c695020b",
			"18b94fa75cc54db0a806f522564ba449",
			"1c603235dffd468f8b28b36aa8cb3df2",
		}
		return ruids[math.max(1, math.min(idx, #ruids))]
	end

	method string GetComboOrbPinkSpriteRuid(integer idx)
		-- (기능 추가) "6콤보 이상일 때 구슬 색을 분홍색으로 바꿔달라"는 요청 - 파란 룬 클립과 동일한
		-- 6프레임 구조를 가진 분홍 버전 클립(113a68a27b50432eb00a82e131c2dd72, msw-search 실측)의
		-- 프레임 1~5.
		local ruids = {
			"4711c880fffd4da694871cf1fe331e7d",
			"8abd73b1954e42f5af565af4426ae582",
			"eaede9190e7f48e5a78123777220ebbf",
			"6360c35bf2ad47b0b68235182c063f80",
			"45c5effa123f463296b9c861fe017215",
		}
		return ruids[math.max(1, math.min(idx, #ruids))]
	end

	@ExecSpace("ServerOnly")
	method void AddComboOrb()
		-- 콤보 구슬 1개를 추가한다: 카운트(@Sync) 증가 + 플레이어의 자식으로 구슬 엔티티 스폰.
		-- 공전/크기 연출은 ComboOrb 컴포넌트가 클라이언트에서 담당한다. 첫 구슬이 생길 때 캐릭터
		-- 중심에 고정되는 큰 원(8c563f54... 클립 프레임0)도 함께 스폰한다.
		-- (기능 추가) "최대 10콤보까지 쌓을 수 있게 해달라"는 요청으로 상한을 5→10으로 올린다.
		-- 다만 궤도 슬롯은 ComboOrb.mlua에 5칸(2π/5 간격)으로 고정되어 있어 구슬 엔티티 자체는
		-- 여전히 최대 5개만 스폰한다 - 6번째부터는 새 구슬을 만들지 않고, 기존 구슬 중 하나(그리고
		-- 6번째가 되는 순간 가운데 큰 원)를 분홍색으로 전환해 6~10콤보를 표시한다.
		if self.ComboOrbCount >= 10 then return end
		local idx = self.ComboOrbCount + 1
		self.ComboOrbCount = idx

		if idx == 1 then
			self:SpawnComboOrbCenter()
		end

		if idx <= 5 then
			local fx = _SpawnService:SpawnByModelId("spearburstfadingeffect", "ComboOrb" .. idx, Vector3(0, 0.35, 0), self.Entity)
			if isvalid(fx) then
				fx:AddComponent("script.ComboOrb")
				local comp = fx:GetComponent("script.ComboOrb")
				if isvalid(comp) then
					comp.OrbIndex = idx
					comp.OrbSpriteRUID = self:GetComboOrbSpriteRuid(idx)
				end
				self._T.comboOrbEntities = self._T.comboOrbEntities or {}
				table.insert(self._T.comboOrbEntities, fx)
			end
			log("[ComboAttack] 콤보 구슬 +1 → " .. tostring(idx) .. "/10 (데미지 +" .. tostring(idx * 20) .. "%)")
		else
			-- 6번째부터는 새 구슬 엔티티 없이, (idx-5)번째 기존 구슬을 분홍으로 전환한다.
			-- 6번째가 되는 순간(처음 분홍이 등장하는 시점) 가운데 큰 원도 함께 분홍으로 바뀐다.
			if idx == 6 then
				self:SetComboOrbCenterPink()
			end
			self:UpgradeComboOrbToPink(idx - 5)
			log("[ComboAttack] 콤보 구슬 +1 → " .. tostring(idx) .. "/10 (분홍 전환 " .. tostring(idx - 5) .. "/5, 데미지 +" .. tostring(idx * 20) .. "%)")
		end
	end

	@ExecSpace("ServerOnly")
	method void UpgradeComboOrbToPink(integer orbIndex)
		-- 기존에 떠 있는 구슬 중 슬롯 번호가 orbIndex인 것을 찾아 분홍 스프라이트로 바꾼다.
		-- OrbSpriteRUID는 @Sync라 값이 바뀌면 ComboOrb.OnSyncProperty가 재적용을 감지하고,
		-- 거기서 생성 연출(커졌다 작아지는 이펙트) 타이머도 함께 리셋해 색이 바뀌는 순간 다시 재생된다.
		local orbs = self._T.comboOrbEntities or {}
		for _, e in ipairs(orbs) do
			if isvalid(e) then
				---@type ComboOrb
				local comp = e:GetComponent("script.ComboOrb")
				if isvalid(comp) and comp.OrbIndex == orbIndex then
					comp.OrbSpriteRUID = self:GetComboOrbPinkSpriteRuid(orbIndex)
					log("[ComboAttack] 구슬 " .. tostring(orbIndex) .. "번 분홍 전환")
					break
				end
			end
		end
	end

	@ExecSpace("ServerOnly")
	method void SetComboOrbCenterPink()
		-- 가운데 큰 원을 분홍 버전(분홍 클립 프레임0)으로 전환한다.
		if isvalid(self._T.comboOrbCenterEntity) then
			---@type ComboOrb
			local comp = self._T.comboOrbCenterEntity:GetComponent("script.ComboOrb")
			if isvalid(comp) then
				comp.OrbSpriteRUID = "5f5348ebeb2345f0869d1682828a848d"
				log("[ComboAttack] 가운데 원 분홍 전환")
			end
		end
	end

	@ExecSpace("ServerOnly")
	method void SpawnComboOrbCenter()
		-- 구슬들 한가운데(캐릭터 중심)에 고정되는 큰 원. state 클립 프레임0 스프라이트(72x76,
		-- 작은 구슬보다 큼)를 사용하고 IsCenterOrb=true라 공전하지 않는다.
		local center = _SpawnService:SpawnByModelId("spearburstfadingeffect", "ComboOrbCenter", Vector3(0, 0.35, 0), self.Entity)
		if isvalid(center) then
			center:AddComponent("script.ComboOrb")
			local comp = center:GetComponent("script.ComboOrb")
			if isvalid(comp) then
				comp.IsCenterOrb = true
				comp.OrbSpriteRUID = "9cfc22d7db1842608b648d9d7b5d216e"
			end
			self._T.comboOrbCenterEntity = center
		end
	end

	@ExecSpace("ServerOnly")
	method void ClearComboOrbs()
		-- 버프 종료 시 구슬 전부 + 중앙 큰 원 제거, 카운트 초기화.
		self.ComboOrbCount = 0
		local orbs = self._T.comboOrbEntities or {}
		for _, e in ipairs(orbs) do
			if isvalid(e) then
				e:Destroy()
			end
		end
		self._T.comboOrbEntities = {}
		if isvalid(self._T.comboOrbCenterEntity) then
			self._T.comboOrbCenterEntity:Destroy()
		end
		self._T.comboOrbCenterEntity = nil
	end

	method integer ApplyComboAttackBonus(integer damage)
		-- 콤보 어택 버프 보너스: 구슬 1개당 +20%(최대 10개 = +200%). CalcDamage의 모든 분기 반환값에
		-- 일괄 적용된다. 부모 훅(CalcDamage)에서 호출되므로 ExecSpace 어노테이션 없이 선언한다.
		if not self._T.comboAttackActive then return damage end
		local count = self.ComboOrbCount or 0
		if count <= 0 then return damage end
		return math.floor(damage * (1 + 0.2 * count))
	end

	@ExecSpace("ServerOnly")
	method void AttackPanic(number combatPower, number atkMultiplier)
		-- (기능 추가) "다른 스킬을 쓰면 숨고르기 모션은 중지" 요청 - 이 스킬을 새로 시전하는 시점에 이전 숨고르기가 재생 중이었다면 즉시 정리한다.
		self:StopBreather()
		-- 패닉: 콤보 어택 버프로 쌓인 콤보 구슬을 전부 소모해 단일 대상에게 강력한 피해를 입힌다.
		-- 구슬이 하나도 없으면 사용할 수 없다(요청사항). 모션/히트 타이밍은 파워스트라이크와 동일하게
		-- GetPowerStrikeSwing + PlayAttackMotion을 그대로 재사용하고, 판정도 동일한 고정 딜레이(0.45초 * 배율)
		-- 뒤에 진행한다. 재시전 방지 게이트(isPanicking)/컨트롤 잠금 관련 필드는 다른 스킬들과 동일한 관례대로
		-- 패닉 전용 필드로 완전히 분리해, 클라이언트 공용 쿨다운(SkillManager.skillOnCooldown)이 스킬 간
		-- 사용을 이미 직렬화하는 것과 별개로 서버 쪽에서도 안전하게 독립적으로 동작하게 한다.
		local currentState = self.Entity.StateComponent.CurrentStateName
		if currentState == "DEAD" or currentState == "CLIMB" or currentState == "LADDER" then
			return
		end
		if self._T.isPanicking then
			log("PlayerAttack: AttackPanic 요청 차단됨(이미 진행 중)")
			return
		end
		-- 콤보 구슬이 하나도 없으면 사용 불가 - 클라이언트(SkillManager)도 미리 확인하지만 서버가 최종 판정한다.
		local orbCount = self.ComboOrbCount
		if orbCount <= 0 then
			log("PlayerAttack: AttackPanic 요청 차단됨(콤보 구슬 없음)")
			return
		end
		self._T.isPanicking = true
		self._T.panicMotionEndHandled = false

		local mult = math.max(0.1, math.min(atkMultiplier or 1.0, 3.0))
		self._T.pendingPanicCombatPower = combatPower
		-- 소모할 구슬 개수(1~10)를 시전 시점 값으로 스냅샷해둔다 - 바로 아래에서 ClearComboOrbs로
		-- ComboOrbCount를 0으로 되돌리기 때문에, 데미지 공식/이펙트 선택은 반드시 이 스냅샷 값을 써야 한다.
		self._T.pendingPanicOrbCount = orbCount

		local playerCtrl = self.Entity.PlayerControllerComponent
		local worldPos = self.Entity.TransformComponent.WorldPosition
		local dirX = playerCtrl.LookDirectionX
		self._T.pendingPanicDirX = dirX

		-- 단일 대상 스킬: 판정 전에 가장 가까운 몬스터 하나만 골라 IsAttackTarget에서 그 대상만 통과시킨다(파워스트라이크와 동일).
		-- (기능 추가) "데미지를 입히는 범위를 전방·위아래로 2배 늘려달라"는 요청으로, 판정 박스가
		-- 넓어진 것과 함께 탐색 반경도 2.0→4.0으로 늘려 더 먼 대상도 실제로 판정 박스 안에 들어오게 한다.
		self._T.panicTarget = self:FindNearestMonster(Vector2(worldPos.x, worldPos.y), 4.0)

		self._T.pendingPanicWasControllerEnabled = isvalid(playerCtrl) and playerCtrl.Enable
		if isvalid(playerCtrl) then
			playerCtrl.Enable = false
		end
		if isvalid(self.Entity.MovementComponent) then
			self.Entity.MovementComponent:Stop()
		end

		-- 구슬은 시전 즉시(모션 시작과 동시에) 전부 소모한다 - ApplyComboAttackBonus가 CalcDamage 반환값에
		-- 자동으로 얹는 구슬 보너스(+20%/개)보다 먼저 ComboOrbCount를 0으로 비워둬야, 패닉 자체 공식
		-- (구슬 1개당 1000~1200%)에 그 보너스가 중복으로 얹히지 않는다.
		self:ClearComboOrbs()

		-- (기능 추가) "패닉 전용 사운드로 바꿔달라"는 요청 - 파워스트라이크와 공유하던
		-- PlaySkillUseSound 대신 패닉 전용 PlayPanicUseSound(d01b135e62a74129b1515c8e0250a2f5)를 재생한다.
		self:PlayPanicUseSound(self.Entity)
		self:PlayPanicCastEffect(self.Entity, dirX, orbCount)

		-- 캐릭터 모션은 파워스트라이크와 동일한 후보군(GetPowerStrikeSwing)에서 하나를 골라 재생한다.
		local swing = self:GetPowerStrikeSwing("twohand")
		self._T.pendingPanicSwing = swing
		self:PlayAttackMotion(self.Entity, swing.name, dirX, mult)

		-- 타격 판정 타이밍은 파워스트라이크와 동일하게 고정 딜레이(0.45초 * 배율) 뒤에 진행한다.
		_TimerService:SetTimerOnce(function()
			self:NotifyPanicMotionEnded()
		end, 0.45 * mult)

		-- 컨트롤 잠금 해제도 파워스트라이크와 동일한 총 딜레이(0.65초 * 배율).
		_TimerService:SetTimerOnce(function()
			self:RestorePanicControl()
		end, 0.65 * mult)

		log("[Panic] 발동 orbCount=" .. tostring(orbCount))
	end

	@ExecSpace("Server")
	method void RestorePanicControl()
		-- AttackPanic에서 예약한 고정 딜레이(0.65초 = 모션 0.25초 + 추가 이동 봉인 0.4초, 파워스트라이크와 동일) 뒤 호출된다.
		self._T.isPanicking = false
		local playerCtrl = self.Entity.PlayerControllerComponent
		if isvalid(playerCtrl) and self._T.pendingPanicWasControllerEnabled then
			playerCtrl.Enable = true
		end
		-- (기능 추가) "다른 스킬들을 사용하고 난 다음도 모두 숨고르기 모션을 3번 하도록 해달라"는 요청 -
		-- 컨트롤이 복구된 이 시점에 공용 숨고르기(PlayBreather)를 시작한다.
		self:PlayBreather(self.Entity, self._T.pendingPanicDirX or 1)
	end

	method void NotifyPanicMotionEnded()
		-- AttackPanic에서 예약한 고정 딜레이(0.25초 * 배율, 파워스트라이크와 동일) 타이머로 호출된다.
		if self._T.panicMotionEndHandled then return end
		self._T.panicMotionEndHandled = true

		if not isvalid(self.Entity) then return end
		local dirX = self._T.pendingPanicDirX or 1
		local curWorldPos = self.Entity.TransformComponent.WorldPosition
		-- 판정 범위: 원래 파워스트라이크와 동일(전방 가로 2칸·세로 2칸)했으나, "전방·위아래로 2배
		-- 늘려달라"는 요청으로 전방 오프셋과 박스 가로/세로 크기를 모두 2배로 늘렸다(가로 4칸·세로 4칸,
		-- 전방 오프셋 1.0→2.0 - 뒤쪽 경계는 그대로 캐릭터 위치에 걸쳐 있고 앞/위/아래로만 넓어진다).
		local attackOffset = Vector2(
			curWorldPos.x + 2.0 * dirX,
			curWorldPos.y
		)
		local shape = BoxShape(attackOffset, Vector2(4, 4), 0)
		local hitComps = self:AttackShadowSafe(shape, "skill.panic", self._T.panicTarget)
		local targets = {}
		for _, hc in ipairs(hitComps) do
			if isvalid(hc) and isvalid(hc.Entity) then
				table.insert(targets, hc.Entity)
			end
		end

		local swing = self._T.pendingPanicSwing or { ruid = "", name = "?" }
		self:PlayPanicEffects(self.Entity, dirX, targets, self._T.pendingPanicOrbCount or 0, swing.ruid)
		log("PlayerAttack: AttackPanic dir=" .. tostring(dirX) .. " targets=" .. tostring(#targets))
	end

	method string GetPanicEffectRuid(integer orbCount)
		-- 소모한 콤보 구슬 개수(1~10)별 캐릭터 이펙트(시전 시 재생).
		local ruids = {
			"73ca2da2e4174b88b79b2f53aec7d231",
			"59220240d7004a439c16329b829a6900",
			"e150a53e0a61454b9fde4e53380cd9ab",
			"3e7aef83235b4e8ebd28ba9462d9b8c0",
			"1be23b85b0b44b84bc6e88a2caf986de",
			"8cbbf339d9de40b09d933cc9d4e8b803",
			"9c267e7da01c4c34992cfbfd02132a5f",
			"4561e55a44f74a3086d4e88a4c2c8f01",
			"aab1604317524fc78ab79e23416d6947",
			"aab1604317524fc78ab79e23416d6947",
		}
		return ruids[math.max(1, math.min(orbCount, #ruids))]
	end

	@ExecSpace("Multicast")
	method void PlayPanicUseSound(Entity attacker)
		-- 패닉 전용 사용 사운드. Multicast는 서버 자신도 함께 실행하므로 클라이언트에서만 실행되게 막는다.
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		local panicSoundRUID = "d01b135e62a74129b1515c8e0250a2f5"
		_SoundService:PlaySound(panicSoundRUID, 1.0)
	end

	@ExecSpace("Multicast")
	method void PlayPanicCastEffect(Entity attacker, number dirX, integer orbCount)
		-- 소모한 구슬 개수에 맞는 캐릭터 이펙트를 시전 즉시 1회 재생한다. Multicast는 서버 자신도
		-- 함께 실행하므로 클라이언트에서만 실행되게 막는다.
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		local effectRuid = self:GetPanicEffectRuid(orbCount)
		local options = { ["FlipX"] = dirX > 0 }
		-- (기능 추가) "캐릭터 이펙트 크기를 10% 상승시키고 y축을 약간 위로 올려달라"는 요청 -
		-- 기본 스케일(1,1,1)을 10% 키운다(1.1,1.1,1.1).
		-- (기능 추가) "패닉 이펙트의 전체적인 위치를 조금 아래로 내려달라"는 요청 - 이전에 위로
		-- 올렸던 y오프셋(0.15)을 다시 낮춰 원래 높이(0)로 되돌린다.
		_EffectService:PlayEffectAttached(effectRuid, attacker, Vector3(0, 0, 0), 0, Vector3(1.1, 1.1, 1.1), false, options)
		-- 쉐도우 파트너: 같은 시전 이펙트를 x축 뒤쪽에서 투명도 70%로 복제 재생(그림자 몫 - 데미지 없음)
		self:EchoShadowSkillEffectAttached(effectRuid, attacker, Vector3(0, 0, 0), 0, Vector3(1.1, 1.1, 1.1), options, dirX)
		log("[Panic] 시전 이펙트 재생 orbCount=" .. tostring(orbCount) .. " ruid=" .. tostring(effectRuid))
	end

	@ExecSpace("Multicast")
	method void PlayPanicEffects(Entity attacker, number dirX, table targets, integer orbCount, string swingEffectRUID)
		-- 파워스트라이크와 동일한 스윙 궤적 이펙트를 재생하고(모션 재사용), 실제로 맞은 대상에게는
		-- 패닉 전용 몬스터 히트 이펙트를 재생한다. Multicast는 서버 자신도 함께 실행하므로
		-- 클라이언트에서만 실행되게 막는다 - 안 그러면 서버 쪽 실행이 이펙트를 한 번 더 재생해 겹쳐 보인다.
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		local hitEffectRUID  = "4b8e5b7b21f74a26a54cf3a17d91930c"
		local swingSoundRUID = "d3205fdd08e34b68bc01292a997531ed"

		if swingEffectRUID ~= "" then
			local swingOptions = { ["FlipX"] = dirX > 0, ["Alpha"] = 0.8 }
			_EffectService:PlayEffectAttached(swingEffectRUID, attacker, Vector3(0.1 * dirX, 0, 0), 0, Vector3(1, 1, 1), false, swingOptions)
			-- 쉐도우 파트너: 스윙 궤적 이펙트를 x축 뒤쪽에서 투명도 70%로 복제 재생(그림자 몫 - 데미지 없음)
			self:EchoShadowSkillEffectAttached(swingEffectRUID, attacker, Vector3(0.1 * dirX, 0, 0), 0, Vector3(1, 1, 1), swingOptions, dirX)
		end

		-- (기능 추가) "히트 이펙트 크기를 소모한 구슬 개수에 따라 1.1배씩 크게 하고 y축을 약간 위로
		-- 올려달라"는 요청 - 구슬 1개당 1.1배씩 복리로 커진다(1개=1.1배, 2개=1.21배, 3개=1.331배 ...).
		-- (기능 추가) "패닉 이펙트의 전체적인 위치를 조금 아래로 내려달라"는 요청 - 이전에 위로
		-- 올렸던 y오프셋(0.15)을 다시 낮춰 원래 높이(0)로 되돌렸었다.
		-- (기능 추가) "히트 이펙트는 y를 0.1로 올려달라"는 요청으로 다시 0.1로 조정.
		local hitScale = 1.1 ^ math.max(orbCount, 0)
		for _, target in ipairs(targets) do
			if isvalid(target) then
				local hitOptions = { ["FlipX"] = dirX > 0 }
				_EffectService:PlayEffectAttached(hitEffectRUID, target, Vector3(0, 0.1, 0), 0, Vector3(hitScale, hitScale, hitScale), false, hitOptions)
				-- 쉐도우 파트너: 같은 히트 이펙트를 0.25초 시간차를 두고 그 자리에 한 번 더(70% 투명도) 재생
				self:EchoShadowHitEffect(hitEffectRUID, target, Vector3(0, 0.1, 0), 0, Vector3(hitScale, hitScale, hitScale), hitOptions)
				_SoundService:PlaySound(swingSoundRUID, 1.0)
			end
		end
		log("[Panic] 히트 이펙트 스케일 orbCount=" .. tostring(orbCount) .. " scale=" .. tostring(hitScale))
		log("[Panic] 히트 이펙트 재생 orbCount=" .. tostring(orbCount) .. " targets=" .. tostring(#targets))
	end

	@ExecSpace("ServerOnly")
	method void AttackComa(number combatPower, number atkMultiplier)
		-- (기능 추가) "다른 스킬을 쓰면 숨고르기 모션은 중지" 요청 - 이 스킬을 새로 시전하는 시점에 이전 숨고르기가 재생 중이었다면 즉시 정리한다.
		self:StopBreather()
		-- 코마: 패닉과 구조가 비슷하다 - 콤보 어택 버프로 쌓은 콤보 구슬을 전부 소모해서 발동하고,
		-- 구슬이 하나도 없으면 사용할 수 없다. 다만 패닉(단일 대상)과 달리 코마는 드래곤로어와 동일한
		-- 범위(FindDragonRoarTargets 재사용)에서 가까운 대상부터 최대 15명을 동시에 타격하는 다중 대상
		-- 스킬이다. 캐릭터 모션/시전 타이밍은 패닉과 동일하게 GetPowerStrikeSwing + PlayAttackMotion을
		-- 그대로 재사용하고, 판정도 동일한 고정 딜레이(0.45초 * 배율) 뒤에 진행한다.
		local currentState = self.Entity.StateComponent.CurrentStateName
		if currentState == "DEAD" or currentState == "CLIMB" or currentState == "LADDER" then
			return
		end
		if self._T.isComaAttacking then
			log("PlayerAttack: AttackComa 요청 차단됨(이미 진행 중)")
			return
		end
		-- 콤보 구슬이 하나도 없으면 사용 불가 - 클라이언트(SkillManager)도 미리 확인하지만 서버가 최종 판정한다.
		local orbCount = self.ComboOrbCount
		if orbCount <= 0 then
			log("PlayerAttack: AttackComa 요청 차단됨(콤보 구슬 없음)")
			return
		end
		self._T.isComaAttacking = true
		self._T.comaMotionEndHandled = false

		local mult = math.max(0.1, math.min(atkMultiplier or 1.0, 3.0))
		self._T.pendingComaCombatPower = combatPower
		-- 소모할 구슬 개수(1~10)를 시전 시점 값으로 스냅샷해둔다 - 바로 아래에서 ClearComboOrbs로
		-- ComboOrbCount를 0으로 되돌리기 때문에, 데미지 공식/이펙트 선택은 반드시 이 스냅샷 값을 써야 한다.
		self._T.pendingComaOrbCount = orbCount

		local playerCtrl = self.Entity.PlayerControllerComponent
		local dirX = playerCtrl.LookDirectionX
		self._T.pendingComaDirX = dirX

		self._T.pendingComaWasControllerEnabled = isvalid(playerCtrl) and playerCtrl.Enable
		if isvalid(playerCtrl) then
			playerCtrl.Enable = false
		end
		if isvalid(self.Entity.MovementComponent) then
			self.Entity.MovementComponent:Stop()
		end

		-- 구슬은 시전 즉시(모션 시작과 동시에) 전부 소모한다 - 패닉과 동일한 이유(콤보 어택 버프의
		-- +20%/개 보너스가 코마 자체 공식에 중복으로 얹히지 않도록).
		self:ClearComboOrbs()

		self:PlayComaUseSound(self.Entity)
		self:PlayComaCastEffect(self.Entity, dirX, orbCount)

		-- 캐릭터 모션은 패닉과 동일한 후보군(GetPowerStrikeSwing)에서 하나를 골라 재생한다.
		local swing = self:GetPowerStrikeSwing("twohand")
		self._T.pendingComaSwing = swing
		self:PlayAttackMotion(self.Entity, swing.name, dirX, mult)

		-- 타격 판정 타이밍은 패닉과 동일하게 고정 딜레이(0.45초 * 배율) 뒤에 진행한다.
		_TimerService:SetTimerOnce(function()
			self:NotifyComaMotionEnded()
		end, 0.45 * mult)

		-- 컨트롤 잠금 해제도 패닉과 동일한 총 딜레이(0.65초 * 배율).
		_TimerService:SetTimerOnce(function()
			self:RestoreComaControl()
		end, 0.65 * mult)

		log("[Coma] 발동 orbCount=" .. tostring(orbCount))
	end

	@ExecSpace("Server")
	method void RestoreComaControl()
		-- AttackComa에서 예약한 고정 딜레이(0.65초 = 모션 0.25초 + 추가 이동 봉인 0.4초, 패닉과 동일) 뒤 호출된다.
		self._T.isComaAttacking = false
		local playerCtrl = self.Entity.PlayerControllerComponent
		if isvalid(playerCtrl) and self._T.pendingComaWasControllerEnabled then
			playerCtrl.Enable = true
		end
		-- (기능 추가) "다른 스킬들을 사용하고 난 다음도 모두 숨고르기 모션을 3번 하도록 해달라"는 요청 -
		-- 컨트롤이 복구된 이 시점에 공용 숨고르기(PlayBreather)를 시작한다.
		self:PlayBreather(self.Entity, self._T.pendingComaDirX or 1)
	end

	method void NotifyComaMotionEnded()
		-- AttackComa에서 예약한 고정 딜레이(0.25초 * 배율, 패닉과 동일) 타이머로 호출된다.
		if self._T.comaMotionEndHandled then return end
		self._T.comaMotionEndHandled = true

		if not isvalid(self.Entity) then return end
		local worldPos = self.Entity.TransformComponent.WorldPosition
		-- 사용범위는 드래곤로어와 동일(FindDragonRoarTargets 재사용) - 전방위, 가까운 대상부터 정렬,
		-- 최대 15명까지.
		local targets = self:FindDragonRoarTargets(Vector2(worldPos.x, worldPos.y), 15)
		for _, t in ipairs(targets) do
			self:DealComaHit(t)
		end
		log("PlayerAttack: AttackComa targets=" .. tostring(#targets))
	end

	-- 대상 하나에게만 코마 데미지를 적중시킨다(드래곤로어/익스플로젼과 동일한 단일 대상 패턴 - 밀집
	-- 지역에서 판정 박스가 이웃까지 겹쳐 맞히는 것을 막는다).
	@ExecSpace("ServerOnly")
	method void DealComaHit(Entity target)
		if not isvalid(target) then return end
		self._T.comaCurrentTarget = target
		local pos = target.TransformComponent.WorldPosition
		local shape = BoxShape(Vector2(pos.x, pos.y), Vector2(1.0, 1.6), 0)
		local hitComps = self:AttackShadowSafe(shape, "skill.coma", target)
		local actuallyHit = false
		for _, hc in ipairs(hitComps) do
			if isvalid(hc) and isvalid(hc.Entity) and hc.Entity == target then
				actuallyHit = true
				break
			end
		end
		if actuallyHit then
			self:PlayComaHitEffect(target, self._T.pendingComaOrbCount or 0)
			self:PlayComaStunEffect(target)
			self:ApplyComaStun(target)
		end
	end

	@ExecSpace("ServerOnly")
	method void ApplyComaStun(Entity target)
		-- (기능 추가) "코마에 맞은 적은 3초간 이동이 제한된다"는 요청 - 몬스터 전용 AI 추적 컴포넌트
		-- (AIChaseComponent)를 3초간 꺼서 새로운 이동 결정을 못 내리게 하고, 이미 진행 중이던 이동도
		-- 즉시 멈춘다. 별도의 커스텀 상태이상 시스템 없이 기존 컴포넌트만으로 최소한의 스턴을 구현한다.
		-- (버그 수정) "스턴이 걸렸는데도 이동한다"는 신고 - AIChaseComponent.Enable=false + 최초 1회
		-- MovementComponent:Stop()만으로는 부족했다(AIChase가 이미 내려둔 이동 명령이 몇 프레임 더
		-- 이어지거나, 다른 경로로 다시 이동이 걸릴 수 있음). MovementComponent 자체도 3초간 완전히
		-- 꺼서(Enable=false) 그 사이엔 어떤 경로로도 이동 로직이 아예 실행되지 않게 한다.
		if not isvalid(target) then return end
		local aiChase = target.AIChaseComponent
		local wasAIEnabled = isvalid(aiChase) and aiChase.Enable
		if isvalid(aiChase) then
			aiChase.Enable = false
		end
		local movement = target.MovementComponent
		local wasMovementEnabled = isvalid(movement) and movement.Enable
		if isvalid(movement) then
			movement:Stop()
			movement.Enable = false
		end
		_TimerService:SetTimerOnce(function()
			if isvalid(target) and isvalid(aiChase) and wasAIEnabled then
				aiChase.Enable = true
			end
			if isvalid(target) and isvalid(movement) and wasMovementEnabled then
				movement.Enable = true
			end
		end, 3.0)
	end

	method string GetComaEffectRuid(integer orbCount)
		-- 소모한 콤보 구슬 개수(1~10)별 캐릭터 시전 이펙트 (skill/1111.img/skill/11111003의 finish/1~10).
		local ruids = {
			"8f260fa8eb49460691544a8806e80342",
			"e6eefdb13ca4452ba51437f1bca9d165",
			"7b5b0596abbd4f44afaa332f11943ebf",
			"6c60534394bf4fba8a2553528f3f9ec3",
			"8d638b1a7d5a4fac9de02f4c875ab956",
			"7805bdc3c28b471fb90fc27b51801d1b",
			"1e5b27a588564f44ab0ffc30040c1308",
			"895a0c9854634b88af00e658e2fb5327",
			"2672e793d7274cb5b8e4daa716671832",
			"3f6088e8a7134c5aaa65b4f5ac12e374",
		}
		return ruids[math.max(1, math.min(orbCount, #ruids))]
	end

	@ExecSpace("Multicast")
	method void PlayComaUseSound(Entity attacker)
		-- 코마 전용 사용 사운드. Multicast는 서버 자신도 함께 실행하므로 클라이언트에서만 실행되게 막는다.
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		_SoundService:PlaySound("15cbdb9c56db4e87a379ba631e06a3d1", 1.0)
	end

	@ExecSpace("Multicast")
	method void PlayComaCastEffect(Entity attacker, number dirX, integer orbCount)
		-- 소모한 구슬 개수에 맞는 캐릭터 이펙트를 시전 즉시 1회 재생한다. 위치는 패닉의 몸쪽 이펙트와
		-- 동일(캐릭터 중심, Y오프셋 없음). Multicast는 서버 자신도 함께 실행하므로 클라이언트에서만
		-- 실행되게 막는다.
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		local effectRuid = self:GetComaEffectRuid(orbCount)
		local options = { ["FlipX"] = dirX > 0 }
		_EffectService:PlayEffectAttached(effectRuid, attacker, Vector3(0, 0, 0), 0, Vector3(1, 1, 1), false, options)
		-- 쉐도우 파트너: 같은 시전 이펙트를 x축 뒤쪽에서 투명도 70%로 복제 재생(그림자 몫 - 데미지 없음)
		self:EchoShadowSkillEffectAttached(effectRuid, attacker, Vector3(0, 0, 0), 0, Vector3(1, 1, 1), options, dirX)
		log("[Coma] 시전 이펙트 재생 orbCount=" .. tostring(orbCount) .. " ruid=" .. tostring(effectRuid))
	end

	@ExecSpace("Multicast")
	method void PlayComaHitEffect(Entity target, integer orbCount)
		-- 코마에 맞은 몬스터 전용 히트 이펙트. 소모한 구슬 개수에 따라 두 종류 중 하나를 재생한다
		-- (5콤보 이하 / 6~10콤보).
		if not self:IsClient() then return end
		if not isvalid(target) then return end
		local hitEffectRUID = (orbCount <= 5) and "df55af646a634f62a9a167a1380a147e" or "17b87afe9f03458cbaf63c0194d699ae"
		_EffectService:PlayEffectAttached(hitEffectRUID, target, Vector3(0, 0, 0), 0, Vector3(1, 1, 1), false, {})
		-- 쉐도우 파트너: 같은 히트 이펙트를 0.25초 시간차를 두고 그 자리에 한 번 더(70% 투명도) 재생
		self:EchoShadowHitEffect(hitEffectRUID, target, Vector3(0, 0, 0), 0, Vector3(1, 1, 1), {})
	end

	@ExecSpace("Multicast")
	method void PlayComaStunEffect(Entity target)
		-- 코마에 맞은 대상 머리 위에 3초간 뜨는 스턴 표시 이펙트. 몬스터마다 크기가 달라도 항상 머리
		-- 바로 위에 뜨도록, 파이널어택 히트 이펙트와 동일하게 HitComponent의 콜라이더 크기로 머리
		-- 높이를 계산한다.
		if not self:IsClient() then return end
		if not isvalid(target) then return end
		local headY = 0.5
		local hit = target.HitComponent
		if isvalid(hit) then
			headY = hit.ColliderOffset.y + hit.BoxSize.y / 2
		end
		local serial = _EffectService:PlayEffectAttached("b798d9bdc19e4bfab33ccc906f4ccd2a", target, Vector3(0, headY, 0), 0, Vector3(1, 1, 1), true, {})
		_TimerService:SetTimerOnce(function()
			_EffectService:RemoveEffect(serial)
		end, 3.0)
	end

	@ExecSpace("ServerOnly")
	method void AttackBooster(boolean isMage, number atkMultiplier)
		-- 부스터(2차 버프): 실제 공격속도 상승 효과는 CharInfoManager가 클라에서 이미 적용했다.
		-- (요청) 모션 alert2 + 구버전 WZ 프레임 이펙트. isMage는 더 이상 쓰지 않는다.
		-- RUID 대응표: msw-dev-tools/resources/부스터/RUID.md
		-- (요청) 각 프레임의 눈에 보이는 바닥을 발과 네임태그 사이(BUFF_ANCHOR_Y)에 고정.
		self:CastBuffMotion("a83d56a314fd449cad236fd7d9b2fa63", atkMultiplier, nil)
		local dirX = self._T.pendingBoosterDirX or 1
		local ruids = {
			"42514aa334774d0bb0fade61945e5970", "9d4e8b3b2eab441a8aa42ef883531704",
			"b7b99713c5ba4a55948ee31c7e213820", "c94fc0ca497c4ee2b2496bae4ded3259",
			"d5f5ceb4d0a04e25b3b978755d7a2f85", "3d84f51e0bc84c99b90e1e299338401f",
			"ea23c07eb82742709a0cad07d9614954", "c112602d64c84307b0438420d8d8a394",
			"85ed511773ff4ba1be37b92190c0cd50",
		}
		-- (요청) 코드 보정(무게중심/x=0)이 아니라 원본 WZ origin(ox,oy)에 따라 각 프레임을 배치한다.
		-- 각 프레임의 origin 점을 캐릭터 부착점(발끝)에 맞춘다: xs=-(ox-W/2)/100, ys=(oy-H/2)/100.
		-- (centerX가 좌우반전 시 origin이 계속 부착점에 오도록 처리.) ox={25,20,20,20,25,25,25,15,12},
		-- oy={12,15,33,34,34,33,33,32,32}, W={44,45,48,62,79,79,56,51,48}, H={12,15,33,34,34,26,21,20,20}.
		local xs = { -0.03, 0.025, 0.04, 0.11, 0.145, 0.145, 0.03, 0.105, 0.12 }
		local ys = { 0.06, 0.075, 0.165, 0.17, 0.17, 0.20, 0.225, 0.22, 0.22 }
		-- 부스터: 9프레임 90ms 재생 후 0.2s 페이드아웃(영상은 작은 발끝 반짝임이 흩어지며 사라짐).
		self:SpawnBuffFrameEffect(self:MakeOriginFrames(ruids, xs, ys, 5), dirX, 0.1, 0.2)
	end

	@ExecSpace("ServerOnly")
	method void AttackRage(number atkMultiplier)
		-- 분노(2차 버프): 모션 alert2 + 이펙트/사운드. RUID: msw-dev-tools/resources/분노/RUID.md
		-- (요청) 각 프레임의 눈에 보이는 바닥을 발과 네임태그 사이(0.1)에 고정, 위로만 성장.
		-- (요청) 이펙트가 다 끝나기 전에 움직여지지 않도록 분노는 조작잠금을 이펙트 길이에 맞게 길게(1.2s).
		self:CastBuffMotion("267c7840593c419098060eb07e2b4dbb", atkMultiplier, 1.2)
		local dirX = self._T.pendingBoosterDirX or 1
		self:SpawnBuffFrameEffect(self:BuildRageFrames(), dirX, 0.1, 0.25)
	end

	method table BuildRageFrames()
		-- 분노 프레임 디스크립터(플레이어/드래곤 공용). AttackRage와 드래곤 검은색 버전이 함께 쓴다.
		-- (요청) 1~6번(흰 스파클 상승)은 빼고 7~19번만 이어서 재생한다(7_ 보라/흰 폭발 → 파란 오라 → 스파크).
		-- (강제이동 근본 수정 + 원작 정합) 프레임마다 크기가 달라 하단 고정 시 매 프레임 y를 바꿔 순간이동처럼
		-- 보였고, 하단 정렬은 원작의 스파크 분출 방향/높이도 없앴다. 그래서 7~19를 동일 캔버스(130×182)로
		-- 패딩하되 각 프레임의 원본 WZ origin(ox,oy)을 한 점(canvas 65,124)에 정렬해 재업로드했다
		-- (msw-dev-tools/resources/분노/padded_origin). 이제 모든 프레임 origin이 같은 캔버스 위치라 단일 고정
		-- 위치로 놓아도 강제이동이 없고, 폭발·오라·스파크가 원작처럼 각자 위치에 배치된다(스파크는 위/옆으로
		-- 분출). origin이 canvas y=124(center 91 기준 +33px)이므로 y=0.33에서 origin이 world 0(발끝)에 온다.
		-- (요청/영상 정합) 7~12번(폭발+오라 빌드업)은 캐릭터에 고정돼야 하는데, origin 정렬본은 프레임마다
		-- origin이 내용 중심과 달라(cx 58~65 들쭉날쭉) 가로로 밀려 보였다. 원작 영상은 7~12가 "가로 중심 +
		-- 내용 하단이 발끝"으로 캐릭터에 고정이라, 7~12를 내용중심(col65)·내용하단(row124) 기준으로 재패딩해
		-- 재업로드했다(padded_fix78). 13~19(스파크 분출)는 밖으로 퍼지는 게 의도라 origin 정렬본 유지.
		-- 전부 같은 130×182 캔버스라 단일 위치(y=0.33)에서 정렬된다.
		local ruids = {
			"c2a6680d91c84a98a42151cc5b47299a", "451ad9c3daf242c2bcc0ca704c171231",   -- 7,8 (내용정렬)
			"1b63db8e85e543738c3172c669651a62", "a02b80f5599f481f9818166f4e3abe9d",   -- 9,10 (내용정렬)
			"36faa085b70f4dceb681b13c5e507aec", "b0eac942e50d42e58cf37ba082fb7a6e",   -- 11,12 (내용정렬)
			"efad481e5db5447bbcff52debe1c15e3", "e6828bdf4c8147739b60285a680558a4",   -- 13,14
			"526568bad72b4dd4a516415c26d1110c", "d54c705fb1dc4a0ca06efa00d4148d0d",   -- 15,16
			"3f38641f56ab4c988966952ed951f723", "1c44ed375d9d477bb12dc29fdbbe2880",   -- 17,18
			"bbc5c210f9ef4fb6b83fccf2a9e41d4b",                                       -- 19
		}
		-- (요청) 전체 높이: 단일 y=0.33(origin=발끝). 이 값 하나만 올리고/내리면 전체가 동일 이동.
		-- (요청) 프레임당 기본 100ms, 단 12→13, 13→14 구간(프레임12·13)만 80ms로 빠르게.
		local rageFrames = self:MakeConstantFrames(ruids, 0, 0.33, 5)
		rageFrames[6].interval = 0.08   -- 프레임12(12→13)
		rageFrames[7].interval = 0.08   -- 프레임13(13→14)
		return rageFrames
	end

	@ExecSpace("ServerOnly")
	method void AttackMeditation(number atkMultiplier)
		-- 메디테이션(2차 버프): 모션 alert2 + 이펙트/사운드. RUID: msw-dev-tools/resources/메디테이션/RUID.md
		-- (요청) 각 프레임의 눈에 보이는 바닥을 발과 네임태그 사이(0.1)에 고정, 위로만 성장(분노와 동일).
		self:CastBuffMotion("3fa020cfd70f495c89c39fd3a3dd480a", atkMultiplier, nil)
		local dirX = self._T.pendingBoosterDirX or 1
		self:SpawnBuffFrameEffect(self:BuildMeditationFrames(), dirX, 0.1, 0.3)
	end

	method table BuildMeditationFrames()
		-- 메디테이션 프레임 디스크립터(플레이어/드래곤 공용).
		-- (요청/영상 실측) 메디테이션 이펙트는 "나무가 발밑에서 위로 자라남" 시퀀스(프레임 1~9)뿐이다.
		-- 원본 팩의 _10~_17은 나무가 아니라 별도의 작은 "나뭇잎+반짝임" 표식(버프 지속 표시)이라
		-- 시전 이펙트로 붙이면 큰 나무가 갑자기 작은 잎으로 튀어 부자연스러웠다 - 1~9만 사용한다.
		-- 영상 길이 0.76s / 9프레임 ≈ 45ms(기존 90ms는 2배 느렸음). 다 자란 뒤 0.3s 페이드아웃.
		-- (강제이동 근본 수정) 기존 소스 PNG는 프레임마다 크기가 달라(H 15~156), 중앙 피벗 특성상 밑동을
		-- 발끝에 고정하려면 코드가 매 프레임 위치(FrameLocalPos)를 다시 세팅해야 했다 - 이 프레임별 강제이동이
		-- 느린 재생에서 "튐"으로 보였다. 그래서 9장을 동일 캔버스(158×156)로 패딩하고 각 프레임의 밑동
		-- (가로=하단밴드 중심, 세로=origin oy)을 같은 캔버스 위치에 정렬해 재업로드했다(msw-dev-tools/
		-- resources/메디테이션/padded). 이제 모든 프레임이 같은 크기·같은 밑동위치라 단일 고정 위치로 놓으면
		-- 프레임별 이동이 전혀 없다. 위치: 밑동이 canvas y=147(center 78 기준 +69px)이므로 y=0.69에서 밑동이
		-- world 0(발끝)에 온다. x=0(캔버스 중심=밑동). RUID: msw-dev-tools/resources/메디테이션/RUID.md
		local ruids = {
			"fbf3efdbb65a471296d3b6932faaaccb", "b36a872cc61f401fa248d9483c7baa48",
			"587f1c0fdc254cabad1701395814498c", "1b78e68cd9c14ddfb8b5b1dd5ef51f30",
			"e868faf607ce4698a538053515026e2d", "5b4258569fd447ba952faf18383a7e49",
			"d790809da58249a9bffe6fec4c684587", "8ddd66f6b9844b23aa789859bcac064b",
			"03128f23618849e98d401d05b944bd28",
		}
		-- (끝프레임 미세 이동 보정) 패딩 정렬 잔차로 후반 프레임(7~9)의 밑동이 캔버스 중심에서 좌측으로
		-- ~0.6~1.9px 치우쳐(캔버스 고정밴드 y130-150 실측) 끝쪽에서 캐릭터 앞으로 살짝 이동해 보였다.
		-- 각 프레임 밑동을 정확히 world 0(중심=캐릭터)에 오도록 미세 x보정: xs=-(밑동offset px)/100
		-- (centerX로 좌우반전 대응). 대부분 0에 가깝고 7~9만 유효 보정. ys는 0.69 고정(밑동=발끝).
		-- baseXs = 밑동을 캐릭터 중심에 정렬하는 보정값(끝프레임 미세 이동 방지).
		local baseXs = { -0.003, -0.002, -0.001, -0.001, -0.005, -0.002, 0.006, 0.014, 0.019 }
		local ys = { 0.69, 0.69, 0.69, 0.69, 0.69, 0.69, 0.69, 0.69, 0.69 }
		-- (요청) 다시 캐릭터를 가리도록 앞에 그린다(order 5, 기본 SortingLayer) - 뒤로보내기(MapLayer0) 제거.
		-- (요청) 이펙트 전체를 바라보는 방향(앞)으로 당긴다. centerX는 FrameLocalPos.x=-xs*dirX라, 앞으로
		-- +forwardX*dirX 만큼 옮기려면 각 xs에서 forwardX를 빼면 된다(더/덜 당기려면 forwardX만 조정).
		local forwardX = 0.1
		local xs = {}
		for i, v in ipairs(baseXs) do xs[i] = v - forwardX end
		return self:MakeOriginFrames(ruids, xs, ys, 5)
	end

	-- ===== 다크드래곤이 걸어주는 버프 전용(캐릭터 시전모션 없음, 시전 이펙트는 드래곤 위치) =====

	@ExecSpace("ServerOnly")
	method void ActivateComboAttackSilent(number duration)
		-- (다크드래곤) 콤보 어택 버프를 캐릭터 모션/시전이펙트 없이 활성화만 한다. 구슬(원) 회전은 기존대로
		-- 캐릭터가 적을 때릴 때 OnAttack에서 캐릭터 몸 주위에 쌓인다(= 캐릭터에게 나타남).
		if not isvalid(self.Entity.PlayerComponent) then return end
		local currentState = self.Entity.StateComponent.CurrentStateName
		if currentState == "DEAD" then return end
		self._T.comboAttackToken = (self._T.comboAttackToken or 0) + 1
		local myToken = self._T.comboAttackToken
		self._T.comboAttackActive = true
		local userId = self.Entity.PlayerComponent.UserId
		self:NotifyComboAttackStart(duration, userId)
		_TimerService:SetTimerOnce(function()
			if self._T.comboAttackToken ~= myToken then return end
			self._T.comboAttackActive = false
			self:ClearComboOrbs()
			log("[ComboAttack] 드래곤 버프 종료(" .. tostring(duration) .. "초)")
		end, duration)
		log("[ComboAttack] 드래곤 버프 시작 duration=" .. tostring(duration))
	end

	@ExecSpace("ServerOnly")
	method void ActivateShadowPartnerSilent(number duration)
		-- (다크드래곤) 쉐도우 파트너 버프를 캐릭터 모션/시전이펙트 없이 활성화만 한다. 그림자(등뒤 실루엣)는
		-- 기존대로 캐릭터의 자식으로 스폰돼 캐릭터에게 나타난다.
		if not isvalid(self.Entity.PlayerComponent) then return end
		local currentState = self.Entity.StateComponent.CurrentStateName
		if currentState == "DEAD" then return end
		self:SpawnOrShowShadowEntity()
		self._T.shadowPartnerToken = (self._T.shadowPartnerToken or 0) + 1
		local myToken = self._T.shadowPartnerToken
		self._T.shadowPartnerActive = true
		self.ShadowPartnerOn = true
		local userId = self.Entity.PlayerComponent.UserId
		self:NotifyShadowPartnerStart(duration, userId)
		_TimerService:SetTimerOnce(function()
			if self._T.shadowPartnerToken ~= myToken then return end
			self._T.shadowPartnerActive = false
			self.ShadowPartnerOn = false
			if isvalid(self._T.shadowPartnerEntity) then
				self._T.shadowPartnerEntity.Enable = false
			end
			log("[ShadowPartner] 드래곤 버프 종료(" .. tostring(duration) .. "초)")
		end, duration)
		log("[ShadowPartner] 드래곤 버프 시작 duration=" .. tostring(duration))
	end

	@ExecSpace("ServerOnly")
	method void CastDragonRageEffect(Entity anchor, number dirX)
		-- (다크드래곤) 분노 이펙트를 드래곤(anchor) 위치에서 검은색(틴트 0,0,0)으로 재생. 스탯 버프는
		-- CharInfoManager가 소유주 클라에서 별도 적용한다.
		self:SpawnBuffFrameEffectEx(self:BuildRageFrames(), dirX, 0.1, 0.25, anchor, 0.0, 0.0, 0.0)
	end

	@ExecSpace("ServerOnly")
	method void CastDragonMeditationEffect(Entity anchor, number dirX)
		-- (다크드래곤) 메디테이션 이펙트를 드래곤(anchor) 위치에서 검은색으로 재생.
		self:SpawnBuffFrameEffectEx(self:BuildMeditationFrames(), dirX, 0.1, 0.3, anchor, 0.0, 0.0, 0.0)
	end

	@ExecSpace("ServerOnly")
	method void AttackPowerGuard(number atkMultiplier)
		-- 파워가드(2차 버프): 모션 alert2 + 이펙트/사운드. 30% 회복은 PlayerHit(서버) 담당.
		-- 파워가드 팩엔 사운드가 없어 기존 버프음 재사용. RUID: msw-dev-tools/resources/파워가드/RUID.md
		-- (요청/WZ origin 실측) 업로드 PNG는 중앙 피벗이므로, 각 프레임을 원본 origin(ox,oy)이 한 점
		-- (캐릭터 부착점)에 오도록 중앙 오프셋 dx=-(ox-W/2)/100, dy=(oy-H/2)/100 만큼 옮겨 배치한다.
		-- 그러면 프레임 안에 그려진 "좌/우에서 합쳐짐" 모션이 그대로 살아난다(별도 슬라이드 불필요).
		-- 구성(요청): 좌측 절반 1~4 + 우측 절반 13~16 이 동시에 좌우에서 생성돼 합쳐지고(각 100ms),
		-- 그 뒤 본체 실드 5~12 가 캐릭터에서 1회 재생(100ms). 부착점 세로 = anchorY.
		-- dx,dy 는 PIL 실측(각 PNG 크기 + 사용자가 준 origin). y = anchorY + dy.
		self:CastBuffMotion("a83d56a314fd449cad236fd7d9b2fa63", atkMultiplier, nil)
		local dirX = self._T.pendingBoosterDirX or 1
		local anchorY = 0
		-- (요청) 파워가드 이펙트 전체를 캐릭터 정면 쪽으로 이동하는 공통 오프셋. build에서 모든 프레임
		-- x에 더한다(dirX가 곱해지므로 +면 항상 바라보는 정면 쪽). 더 앞/뒤로는 이 값만 조정.
		local forwardX = 0.0
		-- { ruid, dx, dy }
		-- (요청) 앞/뒤 order는 그대로 두고 1~4와 13~16의 가로 위치만 맞바꿈(dx 스왑).
		local leftHalf = {   -- 1~4 (앞, order 6): 위치를 우측(+0.185)으로 스왑
			{ "3697356e16ba486cb9069c432d976235", 0.185, 0.385 },
			{ "d3c16c82974b4933b03eeba3c2ec644c", 0.185, 0.385 },
			{ "88b7df45f13e43f5acdb374b9d5286a8", 0.185, 0.385 },
			{ "f12bdb312e404be5a58e7fb157ee9b8f", 0.185, 0.385 },
		}
		local rightHalf = {  -- 13~16 (뒤): 위치는 -0.245 그대로, 가려짐은 z-order(캐릭터보다 뒤)로 처리
			{ "6fcc6e7183704cff9ec8a356ff477c64", -0.245, 0.385 },
			{ "a49bed1bd7f04571b78a6507bcc5f2b2", -0.245, 0.385 },
			{ "88175dd62ea3411faffee0446b5716f6", -0.245, 0.385 },
			{ "5e9e7bdbc0624cd8b9aac4698f3ade58", -0.245, 0.385 },
		}
		-- 본체 실드 5~12: 한 덩어리 실드가 제자리에 서 있어야 하므로 전 프레임 위치를 (0.00, 0.425)로
		-- 통일한다(프레임별 크기/origin 차이로 인한 8~9번 근처 미세 떨림 제거).
		local mainShield = {
			{ "b68ea6ee3e0445a0898f02da53070dab", 0.00, 0.395 },
			{ "8bac5a8b9fe04382a50afac0bc65a994", 0.00, 0.395 },
			{ "04ab10c58c174b27b11be0beaf30f1b9", 0.00, 0.395 },
			{ "23a03201d15f46dc8b7d34d9af562c04", 0.00, 0.395 },
			{ "14d58140ffe94bb383d8ce4fb7fef2d5", 0.00, 0.395 },
			{ "b3199ee4a4ec48fc84a6aab4a824cd74", 0.00, 0.395 },
			{ "b1585d55ff8f4bb2af9e23d0fc4abe72", 0.00, 0.395 },
			{ "a52d7487325540fea53e92d14b4e023f", 0.00, 0.395 },
		}
		local function build(list, order, sortingLayer)
			local frames = {}
			for _, e in ipairs(list) do
				table.insert(frames, { ruid = e[1], x = e[2] + forwardX, y = anchorY + e[3], order = order, sortingLayer = sortingLayer })
			end
			return frames
		end
		-- 좌/우 절반 동시 생성 → 합쳐짐(각 4프레임 × 100ms = 0.4s, 페이드 없이 본체로 전환).
		-- 좌측 1~4/본체 실드는 캐릭터 앞(order 10, 기본 SortingLayer).
		-- (요청) 우측 13~16만 캐릭터 뒤로: OrderInLayer는 같은 SortingLayer 안에서만 비교되는데 이 이펙트의
		-- 기본 SortingLayer가 아바타(MapLayer0)보다 통째로 앞이라 order를 아무리 내려도 소용없다 - 아바타와
		-- 같은 SortingLayer("MapLayer0")로 올리고 OrderInLayer를 아바타(4)보다 작게(3, 지형 타일 1보다는 앞) 준다.
		self:SpawnBuffFrameEffect(build(leftHalf, 10, ""), dirX, 0.1, 0)
		self:SpawnBuffFrameEffect(build(rightHalf, 3, "MapLayer0"), dirX, 0.1, 0)
		-- 본체 실드는 합쳐짐이 끝난 뒤(0.4s) 캐릭터에서 1회 재생 + 0.2s 페이드아웃(앞, order 10)
		_TimerService:SetTimerOnce(function()
			self:SpawnBuffFrameEffect(build(mainShield, 10, ""), dirX, 0.1, 0.2)
		end, 0.4)
	end

	@ExecSpace("ServerOnly")
	method void CastBuffMotion(string soundRuid, number atkMultiplier, number lockDuration)
		-- 4종 버프 공용 시전의 모션/조작잠금/사운드 부분(이펙트는 각 Attack* 메서드가 직접 스폰).
		-- (요청) 사용 즉시 "숨고르기"(breather = alert 루프) 모션을 재생한다. 예전엔 PlayBoosterMotion에
		-- "alert2"를 넘겼는데 유효 클립이 아니라 아무 모션도 안 나왔다 - PlayBreatherImmediate로 즉시 재생.
		-- 스탯 효과는 CharInfoManager가 클라에서 이미 적용했다.
		self:StopBreather()
		local currentState = self.Entity.StateComponent.CurrentStateName
		if currentState == "DEAD" then return end
		local mult = math.max(atkMultiplier or 1.0, 0.001)
		local playerCtrl = self.Entity.PlayerControllerComponent
		local dirX = isvalid(playerCtrl) and playerCtrl.LookDirectionX or 1
		self._T.pendingBoosterDirX = dirX
		self._T.pendingBoosterWasControllerEnabled = isvalid(playerCtrl) and playerCtrl.Enable
		if isvalid(playerCtrl) then playerCtrl.Enable = false end
		if isvalid(self.Entity.MovementComponent) then self.Entity.MovementComponent:Stop() end
		-- 즉시 숨고르기(alert 루프) 재생. 컨트롤 복구(RestoreBoosterControl) 시점의 PlayBreather가
		-- 복구 직후 컨트롤러의 IDLE 스냅을 잡아 숨고르기를 이어가므로 끊기지 않는다.
		self:PlayBreatherImmediate(self.Entity, dirX)
		-- (요청) 조작잠금 시간: lockDuration이 주어지면 그 절대값(초), 없으면 기존 0.6*mult. 분노는 이펙트가
		-- 끝나기 전에 못 움직이도록 길게(1.2s) 넘긴다. 나머지 버프는 nil로 넘겨 기존 동작 유지.
		local lock = lockDuration or (0.6 * mult)
		_TimerService:SetTimerOnce(function()
			self:RestoreBoosterControl()
		end, lock)
		self:PlayBuffSound(soundRuid)
	end

	method table MakeConstantFrames(table ruids, number x, number y, integer order)
		-- 모든 프레임을 같은 x/y/order에 두는 디스크립터 목록을 만든다(부스터/파워가드 B레이어용).
		local out = {}
		for _, ruid in ipairs(ruids) do
			table.insert(out, { ruid = ruid, x = x, y = y, order = order })
		end
		return out
	end

	method table MakeOriginFrames(table ruids, table xs, table ys, integer order)
		-- (요청/원본 origin 실측) 각 프레임의 WZ origin(ox,oy)을 캐릭터 부착점에 맞추기 위한 중앙피벗
		-- 오프셋을 미리 계산해 넘긴다: x=dx=-(ox-W/2)/100, y=dy=(oy-H/2)/100 (world 단위, 100px=1unit).
		-- SpawnBuffFrameEffect에서 x는 dirX가 곱해져 좌우 반전되고, y는 그대로 적용된다.
		-- centerX=true: x는 origin 중앙피벗 보정값이라 좌우반전(IsFlipX) 시 부호가 뒤집혀야 origin이
		-- 한 점에 고정된다(SpawnBuffFrameEffect에서 -x*dirX로 적용). 프레임마다 dx가 달라도 안 밀린다.
		local out = {}
		for i, ruid in ipairs(ruids) do
			table.insert(out, { ruid = ruid, x = xs[i] or 0, y = ys[i] or 0, order = order, centerX = true })
		end
		return out
	end

	method table MakeAnchoredFrames(table ruids, table offsets, number anchorY, integer order)
		-- (요청) 각 프레임의 "눈에 보이는 실제 바닥"(투명 여백 제외 마지막 불투명 픽셀)을 anchorY 한
		-- 지점(발과 네임태그 사이)에 고정하고 위로만 자라게 한다. offsets[i] = 스프라이트 중심에서
		-- 내용 하단까지의 거리(px, 아래로 +, PIL로 실측). 중앙 피벗이라 내용 하단 world = Position.y -
		-- offset/100 이므로, y = anchorY + offset/100 로 주면 크기가 달라도 모든 프레임의 내용 하단이
		-- anchorY에 정렬된다. 위치는 FrameLocalPos로 클라가 직접 적용해 프레임마다 y가 바뀌어도
		-- 떨리지 않는다(SpawnBuffFrameEffect 참고). (100px = 1 world unit)
		local out = {}
		for i, ruid in ipairs(ruids) do
			table.insert(out, { ruid = ruid, x = 0, y = anchorY + (offsets[i] or 0) / 100, order = order })
		end
		return out
	end

	@ExecSpace("ServerOnly")
	method void SpawnBuffFrameEffect(table frames, number dirX, number frameInterval, number fadeDuration)
		-- 기존 호출부(부스터/분노/메디테이션/파워가드)용 래퍼: 캐릭터(self.Entity)에 원본색(틴트 1,1,1)으로.
		self:SpawnBuffFrameEffectEx(frames, dirX, frameInterval, fadeDuration, self.Entity, 1.0, 1.0, 1.0)
	end

	@ExecSpace("ServerOnly")
	method void SpawnBuffFrameEffectEx(table frames, number dirX, number frameInterval, number fadeDuration, Entity anchor, number tr, number tg, number tb)
		-- 프레임 교체 방식 이펙트. 각 프레임 디스크립터 { ruid, x, y, order }를 frameInterval 간격으로 재생.
		-- (다크드래곤) anchor에 부착(캐릭터 대신 드래곤 가능) + tint(tr,tg,tb) 색 적용(검은색 버프용).
		-- (요청 - 영상 매칭) frameInterval을 스킬별로 받아 재생속도를 영상에 맞춘다(메디테이션 45ms 등).
		-- 재생 동안 solid(alpha 1)로 유지하고, 다 재생한 뒤 fadeDuration>0이면 마지막 프레임에서 알파를
		-- 1→0으로 페이드아웃한다(영상처럼 "다 자란 뒤 사라짐"). fadeDuration=0이면 그냥 컷.
		-- (요청 - 지진 제거) 위치는 서버가 TransformComponent.Position을 옮기지 않고 FrameLocalPos(@Sync)만
		-- 갱신 - 클라가 OnUpdate에서 보간 없이 직접 적용해 프레임마다 위치가 바뀌어도 떨리지 않는다.
		self._T.buffFxSeq = (self._T.buffFxSeq or 0) + 1
		local f0 = frames[1]
		if f0 == nil then return end
		-- (요청) 프레임별 개별 딜레이 지원: 각 프레임에 interval 필드가 있으면 그 값을, 없으면 기본
		-- frameInterval을 그 프레임의 표시 시간으로 쓴다(분노 8·9번만 80ms). 시작 시각을 누적 계산한다.
		-- interval 필드가 하나도 없으면 결과는 기존 (#frames * frameInterval)과 동일하다(하위호환).
		local starts = {}
		local acc = 0
		for i = 1, #frames do
			starts[i] = acc
			acc = acc + (frames[i].interval or frameInterval)
		end
		local playTime = acc
		local parentEntity = isvalid(anchor) and anchor or self.Entity
		local fx = _SpawnService:SpawnByModelId("spearburstfadingeffect", "BuffFx" .. tostring(self._T.buffFxSeq), Vector3(0, 0, 0), parentEntity)
		if not isvalid(fx) then return end
		fx:AddComponent("script.SpearBurstFadingEffect")
		local comp = fx:GetComponent("script.SpearBurstFadingEffect")
		if isvalid(comp) then
			comp.TintR = tr
			comp.TintG = tg
			comp.TintB = tb
			comp.IsFlipX = dirX > 0
			comp.StartScale = 1.0
			comp.EndScale = 1.0
			comp.StartAlpha = 1.0
			if fadeDuration > 0 then
				comp.EndAlpha = 0.0
				comp.HoldDuration = playTime           -- 재생 동안 solid
				comp.TweenDuration = fadeDuration       -- 재생 후 페이드아웃
			else
				comp.EndAlpha = 1.0
				comp.HoldDuration = 5.0
				comp.TweenDuration = 0.0
			end
			comp.OrderInLayerValue = f0.order or 5
			-- (버그 수정) 캐릭터 뒤로 보내려면 OrderInLayer만으론 부족하고 SortingLayer를 아바타와 같은
			-- 레이어("MapLayer0")로 맞춰야 한다(파워가드 13~16 가림 원인). 프레임 디스크립터에 sortingLayer가
			-- 있으면 적용, 없으면 기본 SortingLayer 그대로(부스터/분노/메디테이션 등 기존 사용처 영향 없음).
			comp.SortingLayerName = f0.sortingLayer or ""
			comp.UseFrameLocalPos = true
			-- centerX 프레임(origin 중앙보정)은 반전 시 부호 반전(-x*dirX), 그 외(위치성 offset)는 x*dirX.
			local f0x = f0.centerX and (-(f0.x or 0) * dirX) or ((f0.x or 0) * dirX)
			comp.FrameLocalPos = Vector2(f0x, f0.y or 0)
			comp.ClipRUID = f0.ruid
		end
		for i = 2, #frames do
			local fr = frames[i]
			local prev = frames[i - 1]
			local orderChanged = (fr.order ~= prev.order)
			_TimerService:SetTimerOnce(function()
				if not isvalid(comp) then return end
				comp.ClipRUID = fr.ruid
				if orderChanged then comp.OrderInLayerValue = fr.order or 5 end
				local frx = fr.centerX and (-(fr.x or 0) * dirX) or ((fr.x or 0) * dirX)
				comp.FrameLocalPos = Vector2(frx, fr.y or 0)
			end, starts[i])
		end
		_TimerService:SetTimerOnce(function()
			if isvalid(fx) then fx:Destroy() end
		end, playTime + fadeDuration + 0.05)
	end

	@ExecSpace("Multicast")
	method void PlayBuffSound(string soundRuid)
		-- 버프 사용음(클라이언트에서만 재생).
		if not self:IsClient() then return end
		if soundRuid == nil or soundRuid == "" then return end
		_SoundService:PlaySound(soundRuid, 1.0)
	end

	@ExecSpace("Multicast")
	method void PlayBoosterMotion(Entity attacker, string motionName, number dirX, number atkMultiplier)
		-- 부스터 전용 모션 재생 (힐과 동일한 방식/모션 - 별도 플래그로 서로 간섭하지 않는다).
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		local avatarRenderer = attacker.AvatarRendererComponent
		if not isvalid(avatarRenderer) then return end
		local body = avatarRenderer:GetBodyEntity()
		if not isvalid(body) then return end

		avatarRenderer.ShowDefaultWeaponEffects = false

		local playerCtrl = attacker.PlayerControllerComponent
		if isvalid(attacker.MovementComponent) then
			attacker.MovementComponent:Stop()
		end
		if isvalid(playerCtrl) then
			playerCtrl.LookDirectionX = dirX
		end
		self._T.isBoosterDirectionLocked = true
		self._T.lockedBoosterDirX = dirX
		self._T.lockedBoosterMotionName = motionName
		self._T.isBoosterMotionPlaying = true

		local mult = math.max(atkMultiplier or 1.0, 0.001)
		local playRate = 1.0 / mult
		self._T.lockedBoosterPlayRate = playRate

		local motionEvent = ActionStateChangedEvent(motionName, motionName, playRate, SpriteAnimClipPlayType.Onetime)
		body:SendEvent(motionEvent)
		log("[Booster] PlayBoosterMotion sent: " .. tostring(motionName) .. " playRate=" .. tostring(playRate))

		_TimerService:SetTimerOnce(function()
			if isvalid(avatarRenderer) then
				avatarRenderer.ShowDefaultWeaponEffects = true
			end
			self._T.isBoosterMotionPlaying = false
		end, 0.55 * mult)

		_TimerService:SetTimerOnce(function()
			self._T.isBoosterDirectionLocked = false
			local sc = self.Entity.StateComponent
			if isvalid(sc) and sc.CurrentStateName ~= "DEAD" then
				sc:ChangeState("IDLE")
				sc:ChangeState("MOVE")
				sc:ChangeState("IDLE")
			end
		end, 0.80 * mult)
	end

	@ExecSpace("Server")
	method void RestoreBoosterControl()
		local playerCtrl = self.Entity.PlayerControllerComponent
		if isvalid(playerCtrl) and self._T.pendingBoosterWasControllerEnabled then
			playerCtrl.Enable = true
		end
		-- (기능 추가) "다른 스킬들을 사용하고 난 다음도 모두 숨고르기 모션을 3번 하도록 해달라"는 요청 -
		-- 컨트롤이 복구된 이 시점에 공용 숨고르기(PlayBreather)를 시작한다.
		self:PlayBreather(self.Entity, self._T.pendingBoosterDirX or 1)
	end

	@ExecSpace("ServerOnly")
	method void AttackPoisonMist(number combatPower, number atkMultiplier)
		-- (기능 추가) "다른 스킬을 쓰면 숨고르기 모션은 중지" 요청 - 이 스킬을 새로 시전하는 시점에 이전 숨고르기가 재생 중이었다면 즉시 정리한다.
		self:StopBreather()
		-- 포이즌 미스트: 시전 위치에 독안개(PoisonMist)를 소환한다. 실제 독 데미지는 안개가
		-- 대상에게 부착하는 PoisonDebuffComponent가 독립적인 1초 틱으로 처리한다(공격속도 영향 없음,
		-- 헤이스트/부스터처럼 여기서는 시전 이펙트/사운드 재생과 소환만 담당한다).
		local currentState = self.Entity.StateComponent.CurrentStateName
		if currentState == "DEAD" then
			return
		end

		-- 힐과 동일한 모션(alert)을 재생하고, 그동안 다른 행동을 제한한다.
		local mult = math.max(atkMultiplier or 1.0, 0.001)
		local playerCtrl = self.Entity.PlayerControllerComponent
		local dirX = isvalid(playerCtrl) and playerCtrl.LookDirectionX or 1
		self._T.pendingPoisonMistDirX = dirX
		self._T.pendingPoisonMistWasControllerEnabled = isvalid(playerCtrl) and playerCtrl.Enable
		if isvalid(playerCtrl) then
			playerCtrl.Enable = false
		end
		if isvalid(self.Entity.MovementComponent) then
			self.Entity.MovementComponent:Stop()
		end
		self:PlayPoisonMistMotion(self.Entity, "alert", dirX, mult)
		_TimerService:SetTimerOnce(function()
			self:RestorePoisonMistControl()
		end, 0.6 * mult)

		self:PlayPoisonMistCastEffect(self.Entity)

		local map = self.Entity.CurrentMap
		if not isvalid(map) then return end
		self._T.poisonMistCount = (self._T.poisonMistCount or 0) + 1
		local name = "poisonmist_" .. tostring(self._T.poisonMistCount)
		local pos = self.Entity.TransformComponent.WorldPosition
		local mist = _SpawnService:SpawnByModelId("poisonmist", name, Vector3(pos.x, pos.y, pos.z), map)
		if not isvalid(mist) then
			log_warning("[PoisonMist] 스폰 실패")
			return
		end
		local zone = mist:GetComponent("script.PoisonMistZone")
		if zone ~= nil then
			zone:Init(combatPower)
		end
		log("[PoisonMist] 소환 x=" .. tostring(pos.x) .. " y=" .. tostring(pos.y))
	end

	@ExecSpace("Multicast")
	method void PlayPoisonMistCastEffect(Entity attacker)
		-- 사용 시 캐릭터 몸쪽 이펙트 + 사용 사운드 (skill/211.img/skill/2111003 리소스팩의 "effect"/"_audio/Use" 노드)
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		local serial = _EffectService:PlayEffectAttached("b0d47a8948314a5ea04a00690d921fc3", attacker, Vector3(0, 0, 0), 0, Vector3(1, 1, 1), false, {})
		-- 쉐도우 파트너: 같은 시전 이펙트를 x축 뒤쪽에서 투명도 70%로 복제 재생(그림자 몫)
		local echoSerial = self:EchoShadowSkillEffectAttached("b0d47a8948314a5ea04a00690d921fc3", attacker, Vector3(0, 0, 0), 0, Vector3(1, 1, 1), {}, 0)
		_SoundService:PlaySound("eb7f504670a14802a48cc94f4eb66848", 1.0)
		_TimerService:SetTimerOnce(function()
			_EffectService:RemoveEffect(serial)
			if echoSerial ~= 0 then
				_EffectService:RemoveEffect(echoSerial)
			end
		end, 1.5)
	end

	@ExecSpace("Multicast")
	method void PlayPoisonMistMotion(Entity attacker, string motionName, number dirX, number atkMultiplier)
		-- 포이즌 미스트 전용 모션 재생 (힐과 동일한 방식/모션 - 별도 플래그로 서로 간섭하지 않는다).
		if not self:IsClient() then return end
		if not isvalid(attacker) then return end
		local avatarRenderer = attacker.AvatarRendererComponent
		if not isvalid(avatarRenderer) then return end
		local body = avatarRenderer:GetBodyEntity()
		if not isvalid(body) then return end

		avatarRenderer.ShowDefaultWeaponEffects = false

		local playerCtrl = attacker.PlayerControllerComponent
		if isvalid(attacker.MovementComponent) then
			attacker.MovementComponent:Stop()
		end
		if isvalid(playerCtrl) then
			playerCtrl.LookDirectionX = dirX
		end
		self._T.isPoisonMistDirectionLocked = true
		self._T.lockedPoisonMistDirX = dirX
		self._T.lockedPoisonMistMotionName = motionName
		self._T.isPoisonMistMotionPlaying = true

		local mult = math.max(atkMultiplier or 1.0, 0.001)
		local playRate = 1.0 / mult
		self._T.lockedPoisonMistPlayRate = playRate

		local motionEvent = ActionStateChangedEvent(motionName, motionName, playRate, SpriteAnimClipPlayType.Onetime)
		body:SendEvent(motionEvent)
		log("[PoisonMist] PlayPoisonMistMotion sent: " .. tostring(motionName) .. " playRate=" .. tostring(playRate))

		_TimerService:SetTimerOnce(function()
			if isvalid(avatarRenderer) then
				avatarRenderer.ShowDefaultWeaponEffects = true
			end
			self._T.isPoisonMistMotionPlaying = false
		end, 0.55 * mult)

		_TimerService:SetTimerOnce(function()
			self._T.isPoisonMistDirectionLocked = false
			local sc = self.Entity.StateComponent
			if isvalid(sc) and sc.CurrentStateName ~= "DEAD" then
				sc:ChangeState("IDLE")
				sc:ChangeState("MOVE")
				sc:ChangeState("IDLE")
			end
		end, 0.80 * mult)
	end

	@ExecSpace("Server")
	method void RestorePoisonMistControl()
		local playerCtrl = self.Entity.PlayerControllerComponent
		if isvalid(playerCtrl) and self._T.pendingPoisonMistWasControllerEnabled then
			playerCtrl.Enable = true
		end
		-- (기능 추가) "다른 스킬들을 사용하고 난 다음도 모두 숨고르기 모션을 3번 하도록 해달라"는 요청 -
		-- 컨트롤이 복구된 이 시점에 공용 숨고르기(PlayBreather)를 시작한다.
		self:PlayBreather(self.Entity, self._T.pendingPoisonMistDirX or 1)
	end

	@ExecSpace("ServerOnly")
	method void AttackExplosion(number combatPower, number atkMultiplier)
		-- (기능 추가) "다른 스킬을 쓰면 숨고르기 모션은 중지" 요청 - 이 스킬을 새로 시전하는 시점에 이전 숨고르기가 재생 중이었다면 즉시 정리한다.
		self:StopBreather()
		-- 익스플로젼: 시전 이펙트 재생 후 1초 뒤 실제로 터진다(몸쪽 스페셜 이펙트 + 전방 무관 최대 6명 500~700%
		-- 데미지). 폭발 시점에 주변(독구름의 확대된 시각적 크기의 1.0배)에 있는 독구름을 최대 6개까지 0.1초
		-- 간격으로 하나씩 터뜨리며, 터진 자리마다 이펙트/사운드와 함께 500~700% 추가 데미지를 준다.
		local currentState = self.Entity.StateComponent.CurrentStateName
		if currentState == "DEAD" or currentState == "CLIMB" or currentState == "LADDER" then
			return
		end
		if self._T.isExploding then
			log("PlayerAttack: AttackExplosion 요청 차단됨(이미 진행 중)")
			return
		end
		self._T.isExploding = true
		self._T.pendingExplosionCombatPower = combatPower

		-- 힐과 동일한 모션(alert)을 재생하고, 그동안 다른 행동을 제한한다.
		local mult = math.max(atkMultiplier or 1.0, 0.001)
		local playerCtrl = self.Entity.PlayerControllerComponent
		local dirX = isvalid(playerCtrl) and playerCtrl.LookDirectionX or 1
		self._T.pendingExplosionDirX = dirX
		self._T.pendingExplosionWasControllerEnabled = isvalid(playerCtrl) and playerCtrl.Enable
		if isvalid(playerCtrl) then
			playerCtrl.Enable = false
		end
		if isvalid(self.Entity.MovementComponent) then
			self.Entity.MovementComponent:Stop()
		end
		self:PlayExplosionMotion(self.Entity, "alert", dirX, mult)
		_TimerService:SetTimerOnce(function()
			self:RestoreExplosionControl()
		end, 0.6 * mult)

		self:PlayExplosionCastEffect(self.Entity)

		_TimerService:SetTimerOnce(function()
			self:DetonateExplosion()
		end, 1.0)
	end

	@ExecSpace("Multicast")
	method void PlayExplosionMotion(Entity attacker, string motionName, number dirX, number atkMultiplier)
		-- 익스플로젼 전용 모션 재생 (힐과 동일한 방식/모션 - 별도 플래그로 서로 간섭하지 않는다).
