@Component
script PlayerAttack extends AttackComponent

	-- 콤보 어택 버프로 쌓인 콤보 구슬 수(0~5). 서버가 갱신하고 모든 클라이언트에 동기화돼
	-- ComboOrb(구슬 엔티티)가 균등 간격 공전 계산에 읽어 쓴다. 구슬 1개당 데미지 +20%.
	@Sync property integer ComboOrbCount = 0

	@ExecSpace("ClientOnly")
	method void OnSyncProperty(string name, any value)
		-- (버그 수정) "스탯창의 데미지가 오르지 않는다 - 스탯창이 열려있어도 즉시 반영돼야 한다"는
		-- 피드백. 콤보 구슬 개수(ComboOrbCount)가 바뀔 때마다, 스탯창이 열려 있으면 즉시 다시 계산해
		-- 표시한다(창이 닫혀 있으면 다음에 열 때 어차피 새로 계산되므로 건너뛴다).
		if name ~= "ComboOrbCount" then return end
		local window = _EntityService:GetEntityByPath("/ui/DefaultGroup/CharInfoWindow")
		if isvalid(window) and window.Enable then
			_CharInfoManager:UpdateStats()
		end
	end

	@ExecSpace("ServerOnly")
	method void OnBeginPlay()
		        -- Ready: player attack component initialized
		        self._T.shape = BoxShape(Vector2.zero, Vector2.one, 0)
		        log("PlayerAttack: OnBeginPlay")
	end

	@ExecSpace("ServerOnly")
	method void AttackNormal()
		        -- Calculate frontal box in the direction the player is looking
		        local playerCtrl = self.Entity.PlayerControllerComponent
		        local worldPos = self.Entity.TransformComponent.WorldPosition
		        local attackOffset = Vector2(
		            worldPos.x + 0.5 * playerCtrl.LookDirectionX,
		            worldPos.y + 0.5
		        )
		        -- 기본 공격(Control)은 단일 대상 공격이다 - 몬스터가 밀집한 구역에서 AttackFast의 박스 판정이
		        -- 여러 마리를 동시에 맞히는 문제가 있어, 판정 전에 가장 가까운 몬스터 하나만 골라
		        -- IsAttackTarget에서 그 대상만 통과시킨다 (파워스트라이크와 동일한 FindNearestMonster 재사용).
		        self._T.normalAttackTarget = self:FindNearestMonster(Vector2(worldPos.x, worldPos.y), 1.5)
		        self._T.shape = BoxShape(attackOffset, Vector2.one, 0)
		        self:AttackFast(self._T.shape, nil, CollisionGroups.HitBox)
		        log("PlayerAttack: AttackNormal at x=" .. tostring(attackOffset.x) .. " y=" .. tostring(attackOffset.y))
	end

	method boolean IsAttackTarget(Entity defender, string attackInfo)
		        -- Skip other players; only hit non-player entities (monsters)
		        if isvalid(defender.PlayerComponent) then
		            return false
		        end
		        -- 기본 공격(attackInfo가 nil)은 단일 대상 - 미리 골라둔 가장 가까운 대상만 통과시킨다
		        if attackInfo == nil then
		            if not isvalid(self._T.normalAttackTarget) or defender ~= self._T.normalAttackTarget then
		                return false
		            end
		        end
		        -- 파워스트라이크는 단일 대상 스킬 - 미리 골라둔 가장 가까운 대상만 통과시킨다
		        if attackInfo == "skill.powerstrike" then
		            if not isvalid(self._T.powerStrikeTarget) or defender ~= self._T.powerStrikeTarget then
		                return false
		            end
		        end
		        -- 슬래쉬블래스트는 0.2초 간격으로 한 명씩 순차 타격 - 이번 차례의 대상(slashBlastCurrentTarget)만 통과시킨다
		        if attackInfo == "skill.slashblast" then
		            if not isvalid(self._T.slashBlastCurrentTarget) or defender ~= self._T.slashBlastCurrentTarget then
		                return false
		            end
		        end
		        -- 파이널어택으로 발동된 파워스트라이크/슬래쉬블래스트 추가타 - 원본과 동일한 방식이지만 별도 대상 필드를 쓴다.
		        if attackInfo == "skill.powerstrike.final" then
		            if not isvalid(self._T.powerStrikeFinalTarget) or defender ~= self._T.powerStrikeFinalTarget then
		                return false
		            end
		        end
		        if attackInfo == "skill.slashblast.final" then
		            if not isvalid(self._T.slashBlastFinalCurrentTarget) or defender ~= self._T.slashBlastFinalCurrentTarget then
		                return false
		            end
		        end
		        -- 더블스탭은 단일 고정 대상(doubleStabTarget)만 통과시킨다
		        if attackInfo == "skill.doublestab" then
		            if not isvalid(self._T.doubleStabTarget) or defender ~= self._T.doubleStabTarget then
		                return false
		            end
		        end
		        -- 매직클로는 단일 고정 대상(magicClawTarget)만 통과시킨다
		        if attackInfo == "skill.magicclaw" then
		            if not isvalid(self._T.magicClawTarget) or defender ~= self._T.magicClawTarget then
		                return false
		            end
		        end
		        -- 썬더볼트는 앞뒤 주변 최대 6명을 동시에 타격하는 다중 대상 스킬이지만, 몬스터가 밀집한 지역에서는
		        -- 개별 판정 범위가 이웃 대상까지 겹칠 수 있다. "6명 목록 중 아무나"가 아니라 이번 Attack() 호출의
		        -- 대상(thunderboltCurrentTarget) 하나만 통과시켜야 한 번의 호출이 이웃까지 중복으로 맞히지 않는다
		        -- (슬래쉬블래스트의 slashBlastCurrentTarget과 동일한 패턴).
		        if attackInfo == "skill.thunderbolt" then
		            if not isvalid(self._T.thunderboltCurrentTarget) or defender ~= self._T.thunderboltCurrentTarget then
		                return false
		            end
		        end
		        -- 힐이 언데드 몬스터에게 데미지를 입힐 때도 썬더볼트와 동일한 이유로 "이번 호출 전용 단일 대상"만 통과시킨다.
		        if attackInfo == "skill.heal" then
		            if not isvalid(self._T.healCurrentUndeadTarget) or defender ~= self._T.healCurrentUndeadTarget then
		                return false
		            end
		        end
		        -- 익스플로젼(본체 폭발 + 독구름 파열 데미지 공용) - 이번 호출 전용 단일 대상만 통과시킨다.
		        if attackInfo == "skill.explosion" then
			            if not isvalid(self._T.explosionCurrentTarget) or defender ~= self._T.explosionCurrentTarget then
			                return false
			            end
		        end
		        -- 드래곤 로어 - 이번 호출 전용 단일 대상만 통과시킨다(익스플로젼과 동일한 패턴).
		        if attackInfo == "skill.dragonroar" then
			            if not isvalid(self._T.dragonRoarCurrentTarget) or defender ~= self._T.dragonRoarCurrentTarget then
			                return false
			            end
		        end
		        -- 스피어 버스터 - 이번 호출 전용 단일 대상만 통과시킨다(익스플로젼과 동일한 패턴).
		        if attackInfo == "skill.spearburst" then
			            if not isvalid(self._T.spearBurstCurrentTarget) or defender ~= self._T.spearBurstCurrentTarget then
			                return false
			            end
		        end
		        -- 패닉은 파워스트라이크와 동일한 단일 대상 스킬 - 미리 골라둔 가장 가까운 대상만 통과시킨다.
		        if attackInfo == "skill.panic" then
		            if not isvalid(self._T.panicTarget) or defender ~= self._T.panicTarget then
		                return false
		            end
		        end
		        return __base:IsAttackTarget(defender, attackInfo)
	end

	method integer CalcDamage(Entity attacker, Entity defender, string attackInfo)
		-- 실제 공식은 CalcDamageBase에 있고, 여기서는 콤보 어택 버프 보너스(구슬 1개당 +20%)만
		-- 모든 스킬/기본공격에 일괄 적용한다. 수동 데미지 표시용 캐시(lastDoubleStabDamage 등)는
		-- Base 안에서 보너스 미반영 값으로 먼저 채워지므로, 여기서 보너스 반영값으로 재갱신해
		-- 화면 표시와 실제 적용량을 일치시킨다.
		local dmg = self:ApplyComboAttackBonus(self:CalcDamageBase(attacker, defender, attackInfo))
		if attackInfo == "skill.doublestab" then
			self._T.lastDoubleStabDamage = dmg
		elseif attackInfo == "skill.magicclaw" then
			self._T.lastMagicClawDamage = dmg
		elseif attackInfo == "skill.spearburst" then
			self._T.lastSpearBurstDamage = dmg
		end
		return dmg
	end

	method integer CalcDamageBase(Entity attacker, Entity defender, string attackInfo)
		        if attackInfo == "skill.powerstrike" then
		            local combatPower = self._T.pendingCombatPower or 0
		            local mult = 0.5 + math.random() * (3.0 - 1.0)
		            return math.floor(combatPower * mult)
		        elseif attackInfo == "skill.slashblast" then
		            -- 전투력의 30%~150% 사이 랜덤
		            local combatPower = self._T.pendingSlashCombatPower or 0
		            local mult = 0.5 + math.random() * (1.5 - 0.5)
		            return math.floor(combatPower * mult)
		        elseif attackInfo == "skill.powerstrike.final" then
		            -- 파이널어택: 파워스트라이크와 동일한 공식에 15%~30% 추가 데미지를 곱한다.
		            local combatPower = self._T.pendingFinalCombatPower or 0
		            local mult = 0.5 + math.random() * (3.0 - 1.0)
		            local bonus = 1.15 + math.random() * (1.30 - 1.15)
		            return math.floor(combatPower * mult * bonus)
		        elseif attackInfo == "skill.slashblast.final" then
		            -- 파이널어택: 슬래쉬블래스트와 동일한 공식에 15%~30% 추가 데미지를 곱한다.
		            local combatPower = self._T.pendingFinalSlashCombatPower or 0
		            local mult = 0.5 + math.random() * (1.5 - 0.5)
		            local bonus = 1.15 + math.random() * (1.30 - 1.15)
		            return math.floor(combatPower * mult * bonus)
		        elseif attackInfo == "skill.doublestab" then
		            -- 전투력의 100%~260% 사이 랜덤 (매 타격마다 새로 굴림). math.random() 대신
		            -- _UtilLogic:RandomDouble()을 쓰는 이유: idx=1/idx=2가 0.1~0.2초 간격으로 짧게
		            -- 잇따라 호출될 때 math.random()이 동일한 값을 두 번 반환하는 현상이 실측됨.
		            local combatPower = self._T.pendingDoubleStabCombatPower or 0
		            local mult = 1.0 + _UtilLogic:RandomDouble() * (2.6 - 1.0)
		            self._T.lastDoubleStabDamage = math.floor(combatPower * mult)
		            return self._T.lastDoubleStabDamage
		        elseif attackInfo == "skill.magicclaw" then
		            -- 전투력의 100%~150% 사이 랜덤 (럭키세븐과 동일 비율)
		            local combatPower = self._T.pendingMagicClawCombatPower or 0
		            local mult = 1.0 + _UtilLogic:RandomDouble() * (1.5 - 1.0)
		            self._T.lastMagicClawDamage = math.floor(combatPower * mult)
		            return self._T.lastMagicClawDamage
		        elseif attackInfo == "skill.thunderbolt" then
		            -- 전투력의 80%~130% 사이 랜덤 (최대 6명에게 동시 적용 - 대상마다 독립적으로 새로 굴림).
		            -- 더블스탭 사례처럼 같은 프레임 안에서 연달아 호출되므로 math.random() 대신 _UtilLogic:RandomDouble() 사용.
		            local combatPower = self._T.pendingThunderboltCombatPower or 0
		            local mult = 0.8 + _UtilLogic:RandomDouble() * (1.3 - 0.8)
		            return math.floor(combatPower * mult)
		        elseif attackInfo == "skill.heal" then
		            -- 힐이 언데드 몬스터에게 입히는 데미지 - 썬더볼트와 동일한 전투력 80%~130% 공식.
		            local combatPower = self._T.pendingHealCombatPower or 0
		            local mult = 0.8 + _UtilLogic:RandomDouble() * (1.3 - 0.8)
		            return math.floor(combatPower * mult)
		elseif attackInfo == "skill.explosion" then
		-- 전투력의 500%~700% 사이 랜덤 (본체 폭발/독구름 파열 데미지 공용 - 대상마다 독립적으로 새로 굴림)
		local combatPower = self._T.pendingExplosionCombatPower or 0
		local mult = 5.0 + _UtilLogic:RandomDouble() * (7.0 - 5.0)
		return math.floor(combatPower * mult)
		        elseif attackInfo == "skill.dragonroar" then
			            -- 전투력의 1000%~1300% 사이 랜덤 (대상마다 독립적으로 새로 굴림)
			            local combatPower = self._T.pendingDragonRoarCombatPower or 0
			            local mult = 10.0 + _UtilLogic:RandomDouble() * (13.0 - 10.0)
			            return math.floor(combatPower * mult)
		        elseif attackInfo == "skill.spearburst" then
			            -- (임시) 히트 사운드 테스트용으로 전투력의 10%~20%로 낮춤 - 몬스터가 한방에 죽지 않아야
			            -- 피격음/사망음을 구분해서 확인하기 쉽다는 요청. 원래 값(240%~390%)은 아래 주석으로 보존.
			            -- local mult = 2.4 + _UtilLogic:RandomDouble() * (3.9 - 2.4)
			            local combatPower = self._T.pendingSpearBurstCombatPower or 0
			            local mult = 0.1 + _UtilLogic:RandomDouble() * (0.2 - 0.1)
			            -- 3연타 표시(ShowSpearBurstStabDamageSkin)가 실제 판정 성공 여부와 무관하게 보여줄
			            -- 데미지 값을 캐싱해둔다(더블스탭과 동일한 방식) - 앞선 타격에 대상이 이미 죽어
			            -- 이후 타격의 충돌 판정 자체가 실패해도 표시용 데미지를 새로 굴려 항상 3줄이 뜨게 한다.
			            self._T.lastSpearBurstDamage = math.floor(combatPower * mult)
			            return self._T.lastSpearBurstDamage
		        elseif attackInfo == "skill.panic" then
			            -- 구슬 1개당 전투력의 1000%~1200% - 소모한 구슬 개수(pendingPanicOrbCount)만큼
			            -- 그대로 곱해진다 (예: 구슬 2개 소모 시 2000%~2400%). 콤보 어택 버프의 +20%/개
			            -- 보너스(ApplyComboAttackBonus)는 AttackPanic에서 판정 전에 구슬을 이미 전부
			            -- 비워두므로(ComboOrbCount=0) 중복 적용되지 않는다.
			            local combatPower = self._T.pendingPanicCombatPower or 0
			            local orbCount = self._T.pendingPanicOrbCount or 0
			            local perOrbMult = 10.0 + _UtilLogic:RandomDouble() * (12.0 - 10.0)
			            return math.floor(combatPower * orbCount * perOrbMult)
		        end
		        return 50
	end

	method boolean CalcCritical(Entity attacker, Entity defender, string attackInfo)
		        -- 더블스탭/매직클로는 크리티컬 미적용 - 수동 2줄 데미지 스킨이 CalcDamage 반환값만 캐싱해
		        -- 보여주는데, 크리티컬이 뜨면 엔진이 실제 적용 데미지에 배율을 추가로 곱해 화면 표시와
		        -- 실제 적용량이 어긋나는 문제가 있었다.
		        if attackInfo == "skill.doublestab" or attackInfo == "skill.magicclaw" then
		            return false
		        end
		        return math.random() < 0.3
	end

	method float GetCriticalDamageRate()
		        return 2.0
	end

	method int32 GetDisplayHitCount(string attackInfo)
		        -- 더블스탭/매직클로/스피어 버스터는 각각 전용 Show*DamageSkin에서 수동으로 다중 줄을
		        -- 표시하므로 이 attackInfo들에 한해서만 엔진 자동 데미지 스킨 표시를 끈다 - 끄지 않으면
		        -- 같은 AttackComponent 인스턴스로 같은 대상을 짧은 간격으로 반복 타격할 때 자동표시가
		        -- 우리 수동 표시와 별개로 중복으로 겹쳐 뜨는 문제가 있다(더블스탭에서 실측 확인). 스피어
		        -- 버스터는 "3번 찌르기" 타격감을 위해 대상 하나당 실제 판정을 3회 진행하도록 재설계돼
		        -- 이 목록에 추가한다. 다른 스킬(파워스트라이크/슬래쉬블래스트/기본공격)은 부모 기본값(1) 유지.
		        if attackInfo == "skill.doublestab" or attackInfo == "skill.magicclaw" or attackInfo == "skill.spearburst" then
		            return 0
		        end
		        return 1
	end

	@ExecSpace("ServerOnly")
	method void AttackPowerStrike(number combatPower, number atkMultiplier, boolean isSpear)
		        -- (기능 추가) "다른 스킬을 쓰면 숨고르기 모션은 중지" 요청 - 이 스킬을 새로 시전하는 시점에 이전 숨고르기가 재생 중이었다면 즉시 정리한다.
		        self:StopBreather()
		        -- 파워스트라이크 전용 발동: 기본공격과 동일한 전방 박스 판정을 쓰되, attackInfo로 태그해 CalcDamage에서 별도 공식을 적용한다
		        -- 사다리/로프에 매달린 상태(CLIMB/LADDER)나 사망한 상태(DEAD)에서는 스킬을 사용할 수 없다.
		        local currentState = self.Entity.StateComponent.CurrentStateName
		        if currentState == "DEAD" or currentState == "CLIMB" or currentState == "LADDER" then
		            return
		        end
		        -- 이미 파워스트라이크 모션이 진행 중이면(모션 딜레이 구간, 파이널어택 진행 중 포함) 재시전을 막는다.
		        if self._T.isPowerStriking then
		            log("PlayerAttack: AttackPowerStrike 요청 차단됨(이미 진행 중 - 파이널어택 포함)")
		            return
		        end
		        self._T.isPowerStriking = true
		        self._T.motionEndHandled = false
		
		        -- 공격속도 배율: 클라이언트(CharInfoManager)가 소비한 "공격 속도의 비약" 단계로 계산해 넘겨준 값.
		        -- combatPower와 같은 이유로 클라이언트에서 계산해 RPC로 전달한다(서버에는 인벤토리 상태가 없음).
		        -- 1보다 작을수록 빠름(모션/딜레이 단축). 비정상적으로 극단적인 값이 오는 경우를 대비해 안전 범위로 clamp한다.
		        local mult = math.max(0.1, math.min(atkMultiplier or 1.0, 3.0))
		        self._T.pendingAtkMultiplier = mult
		        self._T.pendingIsSpear = isSpear
		
		        self._T.pendingCombatPower = combatPower
		        local playerCtrl = self.Entity.PlayerControllerComponent
		        local worldPos = self.Entity.TransformComponent.WorldPosition
		        local dirX = playerCtrl.LookDirectionX
		        self._T.pendingDirX = dirX
		
		        -- 단일 대상 스킬: 판정 전에 가장 가까운 몬스터 하나만 골라 IsAttackTarget에서 그 대상만 통과시킨다
		        self._T.powerStrikeTarget = self:FindNearestMonster(Vector2(worldPos.x, worldPos.y), 2.0)
		
		        -- (주의) 기본 무기 스윙 이펙트(ShowDefaultWeaponEffects) 끄기/복구는 여기(서버)가 아니라
		        -- PlayAttackMotion(클라이언트, Multicast)에서 직접 처리한다. ShowDefaultWeaponEffects는 @Sync라
		        -- 서버에서 바꾸면 클라이언트에 반영되기까지 네트워크 지연이 있고, 모션을 재생하는 Multicast 호출과
		        -- 도착 순서가 보장되지 않아 첫 프레임에 기본 스윙 이펙트가 잠깐 섞여 보이는 문제가 있었다.
		
		        -- 모션 재생 동안은 이동/점프/기본공격/반대방향 전환 등 다른 행동을 할 수 없도록 컨트롤러를 먼저 잠근다.
		        -- 모션(PlayAttackMotion) 재생보다 반드시 먼저 잠가야 한다 - 이동 중에 캐릭터 모션을 재생하면
		        -- 이동 입력이 계속 걸어가기 애니메이션을 다시 밀어넣어 스윙 모션이 씹히는(끊기는) 문제가 있었다.
		        -- 다른 이유로 이미 꺼져있던 경우(예: 사망 처리 등)까지 되살리지 않도록 이전 값을 기억해뒀다가 그대로 복구한다.
		        self._T.pendingWasControllerEnabled = isvalid(playerCtrl) and playerCtrl.Enable
		        if isvalid(playerCtrl) then
		            playerCtrl.Enable = false
		        end
		        -- 이동 중 시전한 경우 관성/잔여 이동으로 모션이 어색하게 끊기지 않도록 서버 쪽에서도 즉시 이동을 멈춘다.
		        if isvalid(self.Entity.MovementComponent) then
		            self.Entity.MovementComponent:Stop()
		        end
		
		        -- 스킬 사용 사운드 재생
		        self:PlaySkillUseSound(self.Entity)
		        -- 스킬 시전 시작 이펙트 재생 (파워 스트라이크 리소스팩의 시전 전용 이펙트)
		        self:PlaySkillStartEffect(self.Entity, dirX)
		
		        -- 캐릭터 공격 모션 재생: 매 시전마다 하나를 골라(GetPowerStrikeSwing) 캐릭터 모션과 스윙 이펙트를 동일하게 맞춘다.
		        -- 두 번 호출해서 각각 다시 뽑으면 모션과 이펙트가 서로 다른 자세로 어긋날 수 있으므로, 한 번만 뽑아 저장해둔다.
		        local swing = self:GetPowerStrikeSwing()
		        self._T.pendingSwing = swing
		        self:PlayAttackMotion(self.Entity, swing.name, dirX, mult)
		
		        -- 타격 판정은 실제 애니메이션 종료 이벤트가 아니라 고정 딜레이(기본 0.25초)로 진행한다.
		        -- 애니메이션 종료 이벤트 기준으로 하면 이동 중 걷기 모션이 끊기거나 점프 착지 모션이 끼어들 때도
		        -- 같은 종료 이벤트가 발생해 파워스트라이크 모션이 끝나기도 전에 타격 판정이 발생하는 문제가 있었다.
		        -- 공격속도 배율(mult)만큼 딜레이를 단축/연장한다 (mult<1이면 더 빠르게 타격 판정).
		        _TimerService:SetTimerOnce(function()
		            self:NotifyMotionEnded()
		        end, 0.45 * mult)
		
		        -- 컨트롤러 잠금(이동 봉인)은 모션이 끝난 뒤에도 추가 딜레이만큼 더 유지한다 (기본 0.25초 + 0.4초 = 0.65초).
		        -- 이 전체 잠금 시간도 공격속도 배율만큼 단축된다.
		        _TimerService:SetTimerOnce(function()
		            self:RestoreControl()
		        end, 0.65 * mult)
	end

	@ExecSpace("Server")
	method void RestoreControl()
		        -- AttackPowerStrike에서 예약한 고정 딜레이(0.65초 = 모션 0.25초 + 추가 이동 봉인 0.4초) 뒤 호출된다.
		        -- 재시전 가능 상태로 되돌리고, 잠가뒀던 컨트롤러를 원래 값으로 복구한다.
		        self._T.isPowerStriking = false
		        local playerCtrl = self.Entity.PlayerControllerComponent
		        if isvalid(playerCtrl) and self._T.pendingWasControllerEnabled then
		            playerCtrl.Enable = true
		        end
		        -- 파이널어택(2차 패시브): 60% 확률로, 컨트롤이 "실제로" 돌아오는 이 시점에 바로 이어서(동기 호출)
		        -- 강화된 추가타를 한 번 더 실행한다. 이전에는 이 호출을 별도의 동일 딜레이 타이머로 나란히 예약했는데,
		        -- 그 타이머와 RestoreControl 타이머가 같은 프레임에 만료될 때 어느 쪽이 먼저 실행되는지가 타이머 큐
		        -- 순서에 의존해 보장되지 않았다 - RestoreControl이 파이널어택의 컨트롤 잠금보다 "나중에" 실행되면
		        -- 컨트롤이 즉시 풀려버려(이동/다른 스킬 등 다른 행동이 가능해짐) 파이널어택 모션 동안 다른 행동이
		        -- 가능한 버그가 있었다. 이 메서드 안에서 직접(동기적으로) 호출하면 항상 컨트롤 복구 다음에 실행되어
		        -- 순서가 보장된다.
		        self:TryTriggerFinalAttack("powerstrike", self._T.pendingCombatPower, self._T.pendingAtkMultiplier, self._T.pendingIsSpear)
		        -- (기능 추가) "다른 스킬들을 사용하고 난 다음도 모두 숨고르기 모션을 3번 하도록 해달라"는 요청 -
		        -- 컨트롤이 복구된 이 시점에 공용 숨고르기(PlayBreather)를 시작한다.
		        -- (버그 수정) "파워스트라이크 사용 후 파이널어택이 발동하면 숨고르기 때문에 파이널어택
		        -- 모션을 볼 수 없다"는 신고 - TryTriggerFinalAttack이 방금 발동했다면(동기 호출이라 위 줄에서
		        -- 이미 isPowerStriking=true로 다시 잠긴 상태) 숨고르기를 시작하지 않는다. 발동하지 않았을
		        -- 때만(isPowerStriking이 여전히 false) 숨고르기를 시작한다.
		        if not self._T.isPowerStriking then
		            self:PlayBreather(self.Entity, self._T.pendingDirX or 1)
		        end
	end

	@ExecSpace("ServerOnly")
	method void AttackSlashBlast(number combatPower, number atkMultiplier, boolean isSpear)
		        -- (기능 추가) "다른 스킬을 쓰면 숨고르기 모션은 중지" 요청 - 이 스킬을 새로 시전하는 시점에 이전 숨고르기가 재생 중이었다면 즉시 정리한다.
		        self:StopBreather()
		        -- 슬래쉬블래스트 발동. 사다리/로프/사망 상태에서는 사용 불가 (파워스트라이크와 동일 가드).
		        local currentState = self.Entity.StateComponent.CurrentStateName
		        if currentState == "DEAD" or currentState == "CLIMB" or currentState == "LADDER" then
		            return
		        end
		        -- 이미 슬래쉬블래스트 모션/타격 시퀀스가 진행 중이면(파이널어택 진행 중 포함) 재시전을 막는다.
		        if self._T.isSlashBlasting then
		            log("PlayerAttack: AttackSlashBlast 요청 차단됨(이미 진행 중 - 파이널어택 포함)")
		            return
		        end
		        self._T.isSlashBlasting = true
		
		        -- 공격속도 배율: 파워스트라이크와 동일하게 클라이언트(CharInfoManager)가 계산해 넘겨준 값을 그대로 적용한다.
		        -- 1보다 작을수록 빠름(모션/딜레이/타격 간격 전부 단축). 안전 범위로 clamp.
		        local mult = math.max(0.1, math.min(atkMultiplier or 1.0, 3.0))
		        self._T.pendingSlashMult = mult
		        self._T.pendingSlashIsSpear = isSpear
		
		        self._T.pendingSlashCombatPower = combatPower
		        local playerCtrl = self.Entity.PlayerControllerComponent
		        local worldPos = self.Entity.TransformComponent.WorldPosition
		        local dirX = playerCtrl.LookDirectionX
		        self._T.pendingSlashDirX = dirX
		
		        -- 전방 판정 범위(파워스트라이크 최종 판정 박스와 동일한 가로 2칸·세로 1칸) 안의 적을
		        -- 가까운 순으로 최대 6명까지 미리 골라둔다. 실제 Attack 판정 없이 위치만으로 탐색한다.
		        local targets = self:FindSlashBlastTargets(Vector2(worldPos.x, worldPos.y), dirX, 6)
		
		        self._T.pendingSlashWasControllerEnabled = isvalid(playerCtrl) and playerCtrl.Enable
		        if isvalid(playerCtrl) then
		            playerCtrl.Enable = false
		        end
		        if isvalid(self.Entity.MovementComponent) then
		            self.Entity.MovementComponent:Stop()
		        end
		
		        -- 스킬 사용과 동시에 플레이어 몸쪽에서 발현되는 시작 이펙트
		        self:PlaySlashBlastStartEffect(self.Entity, dirX)
		
		        -- 캐릭터 모션은 파워스트라이크와 같은 후보군(GetPowerStrikeSwing)에서 하나를 골라 재생한다.
		        -- (모션 이름만 재사용 - 스윙 궤적 이펙트 RUID는 사용하지 않는다.)
		        local swing = self:GetPowerStrikeSwing()
		        -- (기능 추가) "원본 동작이 찌르기였으면 파이널어택도 찌르기를 연속으로 하지 말아달라"는
		        -- 요청 - TryTriggerFinalAttack이 이 값을 읽어 GetFinalAttackMotion에 전달한다.
		        self._T.pendingSlashSwing = swing
		        self:PlaySlashBlastMotion(self.Entity, swing.name, dirX, mult)
		
		        -- 첫 타격은 파워스트라이크와 동일하게 0.45초 뒤 판정하고, 이후 0.1초 고정 간격(공격속도 영향 없음)으로 다음 대상을 이어서 타격한다.
		        -- 대상 목록(targets)은 클로저 인자로 직접 전달한다 - 재시전으로 새 시퀀스가 시작돼도 이전 시퀀스의
		        -- 남은 타격이 뒤섞이지 않도록(공유 상태 대신 각자 자기 목록을 들고 있게) 하기 위함이다.
		        _TimerService:SetTimerOnce(function()
		            self:DealNextSlashBlastHit(targets, 1, mult)
		        end, 0.45 * mult)
		
		        -- 컨트롤 잠금 해제 시점: 대상 수와 무관하게 파워스트라이크와 동일한 고정 여유분(0.65초 = 0.45 + 0.2)에
		        -- 공격속도 배율을 적용한다. 타격이 여러 명에게 퍼져나가는 것(0.1초 고정 간격)은 이 잠금 시간과 별개로 계속 진행된다 -
		        -- 즉 컨트롤은 먼저 돌아오고, 남은 타격은 백그라운드에서 계속 이어진다.
		        _TimerService:SetTimerOnce(function()
		            self:RestoreSlashBlastControl()
		        end, 0.65 * mult)
	end

	@ExecSpace("Server")
	method void RestoreSlashBlastControl()
		        -- AttackSlashBlast에서 예약한(대상 수에 따라 가변인) 딜레이 뒤 호출된다.
		        -- 재시전 가능 상태로 되돌리고, 잠가뒀던 컨트롤러를 원래 값으로 복구한다.
		        self._T.isSlashBlasting = false
		        local playerCtrl = self.Entity.PlayerControllerComponent
		        if isvalid(playerCtrl) and self._T.pendingSlashWasControllerEnabled then
		            playerCtrl.Enable = true
		        end
		        -- 파이널어택(2차 패시브): 60% 확률로, 컨트롤이 실제로 돌아오는 이 시점에 바로 이어서(동기 호출) 추가타를
		        -- 실행한다. 파워스트라이크와 동일한 이유(별도 동일-딜레이 타이머의 실행 순서 레이스 방지)로 이 메서드
		        -- 안에서 직접 호출한다.
		        self:TryTriggerFinalAttack("slashblast", self._T.pendingSlashCombatPower, self._T.pendingSlashMult, self._T.pendingSlashIsSpear)
		        -- (기능 추가) "다른 스킬들을 사용하고 난 다음도 모두 숨고르기 모션을 3번 하도록 해달라"는 요청 -
		        -- 컨트롤이 복구된 이 시점에 공용 숨고르기(PlayBreather)를 시작한다.
		        -- (버그 수정) 파워스트라이크와 동일한 이유로, 파이널어택이 방금 발동했다면(isSlashBlasting이
		        -- 다시 true로 잠긴 상태) 숨고르기를 시작하지 않는다.
		        if not self._T.isSlashBlasting then
		            self:PlayBreather(self.Entity, self._T.pendingSlashDirX or 1)
		        end
	end

	@ExecSpace("Server")
	method void DealNextSlashBlastHit(table targets, integer idx, number atkMultiplier)
		        -- 0.1초 고정 간격(공격속도 영향 없음)으로 재귀 예약되며, 호출부(AttackSlashBlast)가 넘겨준 대상 목록을 앞에서부터 한 명씩 타격한다.
		        -- 목록/인덱스/배율을 클로저 인자로 직접 들고 있어서, 컨트롤 잠금(RestoreSlashBlastControl)이나
		        -- 재시전 여부와 무관하게 이 시퀀스만의 진행 상태로 계속 이어진다.
		        if idx > #targets then return end
		        if not isvalid(self.Entity) then return end
		
		        local target = targets[idx]
		        if isvalid(target) then
		            -- IsAttackTarget이 이번 차례의 대상만 통과시키도록 지정한 뒤 동일한 전방 판정 박스로 Attack한다.
		            self._T.slashBlastCurrentTarget = target
		            local dirX = self._T.pendingSlashDirX or 1
		            local curWorldPos = self.Entity.TransformComponent.WorldPosition
		            local attackOffset = Vector2(
		                curWorldPos.x + 1.0 * dirX,
		                curWorldPos.y
		            )
		            local shape = BoxShape(attackOffset, Vector2(2, 2), 0)
		            local hitComps = self:Attack(shape, "skill.slashblast", CollisionGroups.HitBox)
		            -- IsHitTarget 등으로 실제로는 빗나갔을 수 있으므로, Attack()이 반환한 실제 명중 목록에서
		            -- 이번 대상이 있는지 확인한 뒤에만 히트 이펙트/사운드를 재생한다.
		            local actuallyHit = false
		            for _, hc in ipairs(hitComps) do
		                if isvalid(hc) and isvalid(hc.Entity) and hc.Entity == target then
		                    actuallyHit = true
		                    break
		                end
		            end
		            if actuallyHit then
		                self:PlaySlashBlastHitEffect(target, false)
		            end
		            log("PlayerAttack: AttackSlashBlast hit " .. tostring(idx) .. "/" .. tostring(#targets) .. " actuallyHit=" .. tostring(actuallyHit))
		        end

		        if idx < #targets then
		            _TimerService:SetTimerOnce(function()
		                self:DealNextSlashBlastHit(targets, idx + 1, atkMultiplier)
		            end, 0.1)
		        end
	end

	@ExecSpace("ServerOnly")
	method void AttackLuckySeven(number combatPower, number atkMultiplier)
		        -- (기능 추가) "다른 스킬을 쓰면 숨고르기 모션은 중지" 요청 - 이 스킬을 새로 시전하는 시점에 이전 숨고르기가 재생 중이었다면 즉시 정리한다.
		        self:StopBreather()
		        -- 럭키세븐 발동: 표창 2개를 0.4초/0.5초 뒤 하나의 고정 표적에게 순서대로 던진다.
		        -- 딜레이 구조·컨트롤 잠금은 파워스트라이크와 동일한 공격속도 배율(atkMultiplier)을 적용한다.
		        local currentState = self.Entity.StateComponent.CurrentStateName
		        if currentState == "DEAD" or currentState == "CLIMB" or currentState == "LADDER" then
		            return
		        end
		        if self._T.isLuckySeven then
		            return
		        end

		        self._T.isLuckySeven = true

		        local mult = math.max(0.1, math.min(atkMultiplier or 1.0, 3.0))
		        self._T.pendingLuckySevenCombatPower = combatPower

		        local playerCtrl = self.Entity.PlayerControllerComponent
		        local worldPos = self.Entity.TransformComponent.WorldPosition
		        local dirX = playerCtrl.LookDirectionX
		        self._T.pendingLuckySevenDirX = dirX

		        -- 단일 고정 표적: 전방(x축) 사거리를 기존 대비 4배(2.0 → 8.0)로 늘린 럭키세븐 전용 탐색을 사용한다.
		        self._T.luckySevenTarget = self:FindLuckySevenTarget(Vector2(worldPos.x, worldPos.y), dirX)
		        -- 캐스팅 시점의 대상 위치를 스냅샷 - 표창이 날아가는 도중 대상이 죽어서 사라져도
		        -- 마지막 위치까지는 도달시켜 데미지 숫자(2줄)가 항상 뜨도록 한다.
		        self._T.luckySevenTargetPos = nil
		        if isvalid(self._T.luckySevenTarget) then
		            self._T.luckySevenTargetPos = self._T.luckySevenTarget.TransformComponent.Position
		        end

		        self._T.pendingLuckySevenWasControllerEnabled = isvalid(playerCtrl) and playerCtrl.Enable
		        if isvalid(playerCtrl) then
		            playerCtrl.Enable = false
		        end
		        if isvalid(self.Entity.MovementComponent) then
		            self.Entity.MovementComponent:Stop()
		        end

		        self:PlayLuckySevenUseSound(self.Entity)
		        self:PlayLuckySevenStartEffect(self.Entity, dirX)

		        local swing = self:GetLuckySevenSwing()
		        self:PlayLuckySevenMotion(self.Entity, swing.name, dirX, mult)

		        -- 표창 발사: 사용 후 0.4초/0.5초 뒤(공격속도 배율 적용) 순서대로 발사
		        _TimerService:SetTimerOnce(function()
		            self:FireLuckySevenShuriken(1)
		        end, 0.4 * mult)
		        _TimerService:SetTimerOnce(function()
		            self:FireLuckySevenShuriken(2)
		        end, 0.5 * mult)

		        -- 컨트롤 잠금 해제: 파워스트라이크와 동일한 고정 여유분(0.65초 * 배율). 표창 비행/타격은 이 시점 이후에도 계속된다.
		        _TimerService:SetTimerOnce(function()
		            self:RestoreLuckySevenControl()
		        end, 0.65 * mult)
	end

	@ExecSpace("Server")
	method void RestoreLuckySevenControl()
		        self._T.isLuckySeven = false
		        local playerCtrl = self.Entity.PlayerControllerComponent
		        if isvalid(playerCtrl) and self._T.pendingLuckySevenWasControllerEnabled then
		            playerCtrl.Enable = true
		        end
		        -- (기능 추가) "다른 스킬들을 사용하고 난 다음도 모두 숨고르기 모션을 3번 하도록 해달라"는 요청 -
		        -- 컨트롤이 복구된 이 시점에 공용 숨고르기(PlayBreather)를 시작한다.
		        self:PlayBreather(self.Entity, self._T.pendingLuckySevenDirX or 1)
	end

	@ExecSpace("Server")
	method void FireLuckySevenShuriken(integer idx)
		        -- 예약된 딜레이(0.4초/0.5초 * 배율) 뒤 호출되어 표창 1개를 스폰하고 고정 표적을 향해 발사한다.
		        -- 대상이 이미 죽어서 사라졌어도 캐스팅 시점에 저장해둔 마지막 위치(fallbackPos)가 있으면
		        -- 그쪽으로 발사해 데미지 숫자(2줄)가 항상 뜨도록 한다 - 완전히 처음부터 대상이 없었을 때만 스킵.
		        if not isvalid(self.Entity) then return end
		        local target = self._T.luckySevenTarget
		        local fallbackPos = self._T.luckySevenTargetPos
		        if not isvalid(target) and fallbackPos == nil then
		            log("[LuckySeven] 대상 없음 - 표창 스킵 idx=" .. tostring(idx))
		            return
		        end
		        local parent = self.Entity.CurrentMap
		        if not isvalid(parent) then return end

		        self._T.luckySevenProjCount = (self._T.luckySevenProjCount or 0) + 1
		        local name = "luckyseven_proj_" .. tostring(self._T.luckySevenProjCount)
		        local pos = self.Entity.TransformComponent.WorldPosition
		        local spawnPos = Vector3(pos.x, pos.y + 0.4, pos.z)
		        local proj = _SpawnService:SpawnByModelId("luckysevenprojectile", name, spawnPos, parent)
		        if not isvalid(proj) then
		            log_warning("[LuckySeven] 표창 스폰 실패 idx=" .. tostring(idx))
		            return
		        end

		        ---@type LuckySevenProjectile
		        local pc = proj:GetComponent("script.LuckySevenProjectile")
		        if pc == nil then return end
		        pc.CombatPower = self._T.pendingLuckySevenCombatPower or 0
		        pc.HitIndex = idx
		        pc:Fire(target, fallbackPos)
		        local targetLabel = isvalid(target) and target.Name or "(대상 소멸, 마지막 위치로 발사)"
		        log("[LuckySeven] 표창 발사 idx=" .. tostring(idx) .. " target=" .. tostring(targetLabel))
	end

	@ExecSpace("ServerOnly")
	method Entity FindLuckySevenTarget(Vector2 fromPos, number dirX)
		local map = self.Entity.CurrentMap
		if not isvalid(map) then return nil end
		local monsterComps = map:GetChildComponentsByTypeName("script.Monster", true)
		local nearest = nil
		local nearestDist = 8.0
		for _, comp in ipairs(monsterComps) do
			---@type Monster
			local mc = comp
			if isvalid(mc) and isvalid(mc.Entity) and not mc.IsDead then
				local pos = mc.Entity.TransformComponent.WorldPosition
				local dx = pos.x - fromPos.x
				local dy = pos.y - fromPos.y
				if dx * dirX >= 0 and math.abs(dx) <= 8.0 and math.abs(dy) <= 1.0 then
					local dist = math.abs(dx)
					if dist <= nearestDist then
						nearest = mc.Entity
						nearestDist = dist
					end
				end
			end
		end
		return nearest
	end

	method table GetLuckySevenSwing()
		-- 사용자가 실제 화면으로 확인해 확정: swingO1/O2/O3(한손무기 계열)이 아대 모션으로 맞다.
		-- 존재하는 순서대로 1~3번 번호를 매겨 매 시전마다 순차적으로(랜덤 아님) 순환 재생한다.
		local candidates = {
			{ name = "swingO1" },
			{ name = "swingO2" },
			{ name = "swingO3" },
		}
		self._T.luckySevenSwingIndex = (self._T.luckySevenSwingIndex or 0) % #candidates + 1
		return candidates[self._T.luckySevenSwingIndex]
	end

	@ExecSpace("Multicast")
	method void PlayLuckySevenStartEffect(Entity attacker, number dirX)
		        -- 스킬 사용과 동시에 캐릭터 앞에서 발현되는 시작 이펙트 (skill/400.img/skill/4001344의 "effect" 노드)
		        if not self:IsClient() then return end
		        if not isvalid(attacker) then return end
		        local startEffectRUID = "0ae88fa494e743158da6ddb81c0c55f2"
		        local startOptions = { ["FlipX"] = dirX > 0 }
		        -- 이펙트 자체 아트의 피벗이 바깥쪽으로 치우쳐 있어 몸에서 멀어 보이던 것을 몸통 높이로 당김
		        -- (0.3은 너무 높다는 피드백으로 0.12로 낮춤)
		        _EffectService:PlayEffectAttached(startEffectRUID, attacker, Vector3(0, 0.12, 0), 0, Vector3(1, 1, 1), false, startOptions)
		        log("[LuckySeven] 시작 이펙트 재생")
	end

	@ExecSpace("Multicast")
	method void PlayLuckySevenUseSound(Entity attacker)
		        -- 스킬 사용 즉시 재생되는 사운드 (같은 리소스팩의 "_audio/Use")
		        if not self:IsClient() then return end
		        if not isvalid(attacker) then return end
		        _SoundService:PlaySound("879c81c8fc274aea87dc673de48ab5d1", 1.0)
	end

	@ExecSpace("Multicast")
	method void PlayLuckySevenMotion(Entity attacker, string motionName, number dirX, number atkMultiplier)
		        -- 럭키세븐 전용 모션 재생. 파워스트라이크/슬래쉬블래스트와 동일한 후보군(GetPowerStrikeSwing)에서
		        -- 고른 모션을 그대로 재생한다 - 표창 투척 전용 모션이 엔진에 없어 기존 스윙 모션을 재사용하는 단순화.
		        if not self:IsClient() then return end
		        if not isvalid(attacker) then return end
		        local avatarRenderer = attacker.AvatarRendererComponent
		        if not isvalid(avatarRenderer) then return end
		        local body = avatarRenderer:GetBodyEntity()
		        if not isvalid(body) then return end

		        local playerCtrl = attacker.PlayerControllerComponent
		        if isvalid(attacker.MovementComponent) then
		            attacker.MovementComponent:Stop()
		        end
		        if isvalid(playerCtrl) then
		            playerCtrl.LookDirectionX = dirX
		        end
		        self._T.isLuckySevenDirectionLocked = true
		        self._T.lockedLuckySevenDirX = dirX
		        self._T.lockedLuckySevenMotionName = motionName
		        self._T.isLuckySevenMotionPlaying = true

		        local mult = math.max(atkMultiplier or 1.0, 0.001)
		        local playRate = 1.0 / mult
		        self._T.lockedLuckySevenPlayRate = playRate

		        local motionEvent = ActionStateChangedEvent(motionName, motionName, playRate, SpriteAnimClipPlayType.Onetime)
		        body:SendEvent(motionEvent)
		        log("[LuckySeven] PlayLuckySevenMotion sent: " .. tostring(motionName) .. " playRate=" .. tostring(playRate))

		        _TimerService:SetTimerOnce(function()
		            self._T.isLuckySevenMotionPlaying = false
		        end, 0.25 * mult)

		        _TimerService:SetTimerOnce(function()
		            self._T.isLuckySevenDirectionLocked = false
		            local sc = self.Entity.StateComponent
		            if isvalid(sc) and sc.CurrentStateName ~= "DEAD" then
		                sc:ChangeState("IDLE")
		                sc:ChangeState("MOVE")
		                sc:ChangeState("IDLE")
		            end
		        end, 0.80 * mult)
	end

	@ExecSpace("ServerOnly")
	method table FindSlashBlastTargets(Vector2 fromPos, number dirX, integer maxCount)
		        -- 슬래쉬블래스트 대상 선정: 전방 판정 범위(가로 2칸, 세로 1칸) 안의 살아있는 script.Monster를
		        -- 가까운 순으로 정렬해 최대 maxCount명까지 후보로 반환한다 (실제 Attack 판정 없이 위치만으로 탐색).
		        local map = self.Entity.CurrentMap
		        if not isvalid(map) then return {} end
		        local monsterComps = map:GetChildComponentsByTypeName("script.Monster", true)
		        local candidates = {}
		        for _, comp in ipairs(monsterComps) do
		            ---@type Monster
		            local mc = comp
		            if isvalid(mc) and isvalid(mc.Entity) and not mc.IsDead then
		                local pos = mc.Entity.TransformComponent.WorldPosition
		                local dx = pos.x - fromPos.x
		                local dy = pos.y - fromPos.y
		                if dx * dirX >= 0 and math.abs(dx) <= 2.0 and math.abs(dy) <= 1.0 then
		                    table.insert(candidates, { entity = mc.Entity, dist = math.abs(dx) })
		                end
		            end
		        end
		        table.sort(candidates, function(a, b) return a.dist < b.dist end)
		        local result = {}
		        for i = 1, math.min(#candidates, maxCount) do
		            table.insert(result, candidates[i].entity)
		        end
		        return result
	end

	@ExecSpace("Multicast")
	method void PlaySlashBlastStartEffect(Entity attacker, number dirX)
		        -- 스킬 사용과 동시에 플레이어 몸쪽에서 발현되는 시작 이펙트 (skill/1100.img/skill/11001003 리소스팩의 "effect" 노드)
		        if not self:IsClient() then return end
		        if not isvalid(attacker) then return end
		        local startEffectRUID = "44c1d14578e24c639e480f54b156a8a2"
		        local startOptions = { ["FlipX"] = dirX > 0 }
		        _EffectService:PlayEffectAttached(startEffectRUID, attacker, Vector3(0, 0, 0), 0, Vector3(1, 1, 1), false, startOptions)
		        log("[SlashBlast] 시작 이펙트 재생")
	end

	@ExecSpace("Multicast")
	method void PlaySlashBlastHitEffect(Entity target, boolean isFinal)
		        -- hit 시 몬스터 몸에서 3종류 중 하나가 랜덤으로 발현 (같은 리소스팩의 hit/0, hit/1, hit/2)
		        if not self:IsClient() then return end
		        if not isvalid(target) then return end
		        -- (기능 변경) "파이널어택이 뜰 때 원래 히트 이펙트를 대체해서 파이널어택 히트 이펙트만 떠야
		        -- 한다"는 요청 - isFinal이면 이 기본 히트 이펙트(3종 랜덤)를 재생하지 않는다. 호출부
		        -- (DealNextSlashBlastFinalHit)가 곧이어 PlayFinalAttackHitEffect로 전용 이펙트를 대신 띄운다.
		        if not isFinal then
		            local hitEffects = {
		                "41e13add2ba746d9bbe624a31205a848",
		                "880e540095704e30af6a554d51b8a3b3",
		                "eed46092f65940a7a8e77a1bd8e2aa75",
		            }
		            local index = _UtilLogic:RandomIntegerRange(1, #hitEffects)
		            _EffectService:PlayEffectAttached(hitEffects[index], target, Vector3(0, 0, 0), 0, Vector3(1, 1, 1), false, {})
		        end
		        -- 슬래쉬블래스트로 몬스터가 데미지를 받는 순간마다(대상 무관) 지정된 사운드를 1회 재생한다.
		        _SoundService:PlaySound("0f213b255ab34a0e8ed258c89f3b62fe", 1.0)
	end

	@ExecSpace("Multicast")
	method void PlaySlashBlastMotion(Entity attacker, string motionName, number dirX, number atkMultiplier)
		        -- 슬래쉬블래스트 전용 모션 재생. 파워스트라이크와 같은 방식(ActionStateChangedEvent 직접 전송)으로 동작하되,
		        -- 기본 무기 스윙 이펙트(ShowDefaultWeaponEffects)는 끄지 않는다 - 별도의 스윙 궤적 이펙트가 없고
		        -- 기본 공격의 스윙 이펙트를 그대로 사용하기 때문이다 (파워스트라이크와의 유일한 차이점).
		        if not self:IsClient() then return end
		        if not isvalid(attacker) then return end
		        local avatarRenderer = attacker.AvatarRendererComponent
		        if not isvalid(avatarRenderer) then return end
		        local body = avatarRenderer:GetBodyEntity()
		        if not isvalid(body) then return end
		
		        local playerCtrl = attacker.PlayerControllerComponent
		        if isvalid(attacker.MovementComponent) then
		            attacker.MovementComponent:Stop()
		        end
		        if isvalid(playerCtrl) then
		            playerCtrl.LookDirectionX = dirX
		        end
		        self._T.isSlashDirectionLocked = true
		        self._T.lockedSlashDirX = dirX
		        self._T.lockedSlashMotionName = motionName
		        self._T.isSlashMotionPlaying = true
		
		        -- 파워스트라이크(PlayAttackMotion)와 동일하게, 공격속도 배율이 짧을수록(빠를수록) 모션 재생속도(PlayRate)를
		        -- 그만큼 올려서 화면 재생 시간이 아래 타이머들(0.25/0.80초 * mult)과 어긋나지 않게 맞춘다.
		        local mult = math.max(atkMultiplier or 1.0, 0.001)
		        local playRate = 1.0 / mult
		        self._T.lockedSlashPlayRate = playRate
		
		        local motionEvent = ActionStateChangedEvent(motionName, motionName, playRate, SpriteAnimClipPlayType.Onetime)
		        body:SendEvent(motionEvent)
		        log("[SlashBlast] PlaySlashBlastMotion sent: " .. tostring(motionName) .. " playRate=" .. tostring(playRate))
		
		        -- 서버 RestoreSlashBlastControl과 동일한 길이(0.65초*mult + 0.15초 여유)로 잠금을 해제한다.
		        -- 대상 수와 무관하다 - 타격이 여러 명에게 퍼져나가는 것은 이 잠금과 별개로 계속 진행된다.
		        _TimerService:SetTimerOnce(function()
		            self._T.isSlashMotionPlaying = false
		        end, 0.25 * mult)
		
		        _TimerService:SetTimerOnce(function()
		            self._T.isSlashDirectionLocked = false
		            local sc = self.Entity.StateComponent
		            if isvalid(sc) and sc.CurrentStateName ~= "DEAD" then
		                sc:ChangeState("IDLE")
		                sc:ChangeState("MOVE")
		                sc:ChangeState("IDLE")
		            end
		        end, 0.80 * mult)
	end

	@ExecSpace("Server")
	method void NotifyMotionEnded()
		        -- AttackPowerStrike에서 예약한 고정 딜레이(0.25초) 타이머로 호출된다. 타격 판정/이펙트 재생만 여기서 처리한다.
		        -- (컨트롤러 잠금 해제와 재시전 허용은 RestoreControl에서 별도의 더 긴 딜레이로 처리한다.)
		        if self._T.motionEndHandled then return end
		        self._T.motionEndHandled = true
		
		        if not isvalid(self.Entity) then return end
		        local dirX = self._T.pendingDirX or 1
		        local swing = self._T.pendingSwing or { ruid = "", name = "?" }
		        local curWorldPos = self.Entity.TransformComponent.WorldPosition
		        -- 공격범위 x축 전방으로 2배 확장 (기존 1칸 → 2칸). y축은 아래쪽으로 더 길게 - 기존 상단 경계(y+1.0)는 유지하고 하단을 y-1.0까지 확장한다.
		        local attackOffset = Vector2(
		            curWorldPos.x + 1.0 * dirX,
		            curWorldPos.y
		        )
		        self._T.shape = BoxShape(attackOffset, Vector2(2, 2), 0)
		        local hitComps = self:Attack(self._T.shape, "skill.powerstrike", CollisionGroups.HitBox)
		        local targets = {}
		        for _, hc in ipairs(hitComps) do
		            if isvalid(hc) and isvalid(hc.Entity) then
		                table.insert(targets, hc.Entity)
		            end
		        end
		
		        self:PlayPowerStrikeEffects(self.Entity, dirX, targets, swing.ruid, swing.name, false)
		        log("PlayerAttack: AttackPowerStrike dir=" .. tostring(dirX) .. " targets=" .. tostring(#targets))
	end

	method table GetPowerStrikeSwing()
		        -- 파워스트라이크 전용 모션/이펙트 후보 - 매 시전마다 하나를 무작위로 골라 캐릭터 모션과 스윙 이펙트를 함께 통일한다.
		        -- (엔진이 기본 공격의 실제 재생 모션을 구분해 알려줄 방법이 없어서, 대신 스킬 전용 모션을 직접 지정하는 방식으로 바꿨다.)
		        -- swingTF(한바퀴 돌면서 공격하는 모션)는 기본 스킬 모션이 아니라 파이널어택 전용 모션이라는 사용자 지적으로
		        -- 이 후보군에서 제외하고 GetFinalAttackMotion()으로 옮겼다.
		        local candidates = {
		            { name = "swingT1", ruid = "98d2124f4c2740758a7ed92fb5aa3af1" },
		            { name = "swingT2", ruid = "447033cc51594e20a25d15bfe2995d2e" },
		            { name = "swingT3", ruid = "64e8406faa78478dbaccde3db7f074d1" },
		            { name = "stabO1",  ruid = "4e050b0cdec3479bb3ea4130b6f5e8a4" },
		            { name = "stabO2",  ruid = "e59f666887f14d498fed28682990f192" },
		            { name = "stabOF",  ruid = "d0515d7c8aef446d98e553a7f7c02696" },
		        }
		        local index = _UtilLogic:RandomIntegerRange(1, #candidates)
		        return candidates[index]
	end

	method table GetFinalAttackMotion(boolean isSpear, boolean wasStab)
		        -- 파이널어택(2차 패시브) 전용 모션. 창 장착 시에는 점프 찌르기/내려찍기 2종을 순환하고
		        -- (실제 화면으로 아직 확인되지 않은 추정 모션명 - 다르면 알려주면 바로 교체 가능),
		        -- 그 외 무기는 기존 파워스트라이크 후보군에서 빼온 회전 공격 모션(swingTF)에 더해
		        -- (기능 추가) "파이널 어택 모션이 하나뿐인데 찌르기 모션도 추가해달라"는 요청으로 찌르기
		        -- 모션(stabOF, 파워스트라이크 후보군의 최상급 찌르기)도 후보에 넣어 매번 무작위로 고른다.
		        -- (기능 추가) "원본 스킬(파워스트라이크/슬래쉬블래스트) 동작이 찌르기였으면 파이널어택도
		        -- 찌르기를 연속으로 하지 말아달라"는 요청 - wasStab이면 찌르기(stabOF) 후보를 아예 빼고
		        -- swingTF로 고정한다. 원본이 찌르기가 아니었을 때만 기존처럼 무작위로 고른다.
		        if isSpear then
		            local candidates = {
		                { name = "swingP1", ruid = "" },
		                { name = "swingPF", ruid = "" },
		            }
		            self._T.finalAttackSpearIndex = (self._T.finalAttackSpearIndex or 0) % #candidates + 1
		            return candidates[self._T.finalAttackSpearIndex]
		        end
		        if wasStab then
		            return { name = "swingTF", ruid = "e46fe5e970f84e3f8f75ea914b2e3bf7" }
		        end
		        local candidates = {
		            { name = "swingTF", ruid = "e46fe5e970f84e3f8f75ea914b2e3bf7" },
		            { name = "stabOF",  ruid = "d0515d7c8aef446d98e553a7f7c02696" },
		        }
		        local index = _UtilLogic:RandomIntegerRange(1, #candidates)
		        return candidates[index]
	end

	@ExecSpace("ServerOnly")
	method void TryTriggerFinalAttack(string sourceSkill, number combatPower, number atkMultiplier, boolean isSpear)
		        -- 파워스트라이크/슬래쉬블래스트 시전 시 60% 확률로, 그 스킬의 컨트롤 잠금이 풀리는 시점(RestoreControl/
		        -- RestoreSlashBlastControl)에 곧바로(동기 호출로) 이어서 같은 스킬을 "현재 캐릭터 공격속도 + 4단계"에
		        -- 해당하는 속도로 한번 더 실행하고(전용 모션은 창/비창 구분), 데미지에 15%~30% 추가 배율을 얹는다
		        -- (CalcDamage의 ".final" 분기가 처리). 호출부(RestoreControl류)가 이미 딜레이가 다 지난 시점에서
		        -- 직접 호출하므로 여기서 별도 타이머로 다시 감쌀 필요가 없다 - 별도 타이머로 감싸면 RestoreControl
		        -- 타이머와 실행 순서가 보장되지 않아(같은 프레임에 만료되는 두 타이머의 큐 순서 의존) 컨트롤이
		        -- 먼저 풀렸다가 파이널어택이 나중에 다시 잠그는 순서가 뒤집힐 경우 그 사이에 다른 행동이 가능해지는
		        -- 레이스 컨디션이 있었다.
		        -- CharInfoManager.GetAttackSpeedMultiplier()의 공식(0.9^(단계-5), 1단계 오를 때마다 이전 대비 10%씩 단축·복리)과
		        -- 동일하게, 현재 배율(atkMultiplier)에 0.9^4를 곱해 "현재 단계+4단계"의 배율을 구한다.
		        -- (기능 변경) "파이널어택 발동확률을 60%로 바꿔달라"는 요청으로 30%->60% 상향.
		        if math.random() >= 0.6 then return end
		        local finalMult = atkMultiplier * (0.9 ^ 4)
		        local userId = self.Entity.PlayerComponent.UserId
		        -- 파이널어택은 서버가 자체적으로(클라이언트 입력 없이) 발동시키므로, 클라이언트의 스킬 공용 쿨다운은
		        -- 원본 스킬의 쿨다운(0.75*atkMultiplier)이 이미 끝났거나 거의 끝난 상태다 - 그대로 두면 파이널어택
		        -- 모션이 재생되는 동안에도 다른 스킬 키를 눌러 딜레이 없이 다른 스킬을 쏠 수 있는 문제가 있었다.
		        -- 여기서 클라이언트의 공용 쿨다운을 다시 걸어(원본 스킬과 동일한 0.75*배율 공식) 파이널어택 모션
		        -- 동안에도 다른 스킬을 쓸 수 없도록 막는다.
		        _SkillManager:LockSkillUse(0.75 * finalMult, userId)
		        -- (기능 추가) "원본 스킬 동작이 찌르기였으면 파이널어택도 찌르기를 연속으로 하지 말아달라"는
		        -- 요청 - 방금 시전한 원본 스킬(파워스트라이크/슬래쉬블래스트)이 골랐던 모션 이름이 "stab"로
		        -- 시작하는지 확인해 GetFinalAttackMotion에 전달한다.
		        local wasStab = false
		        if sourceSkill == "powerstrike" then
		            wasStab = self._T.pendingSwing ~= nil and (self._T.pendingSwing.name or ""):sub(1, 4) == "stab"
		        else
		            wasStab = self._T.pendingSlashSwing ~= nil and (self._T.pendingSlashSwing.name or ""):sub(1, 4) == "stab"
		        end
		        if sourceSkill == "powerstrike" then
		            self:AttackPowerStrikeFinal(combatPower, finalMult, isSpear, wasStab)
		        else
		            self:AttackSlashBlastFinal(combatPower, finalMult, isSpear, wasStab)
		        end
	end

	@ExecSpace("ServerOnly")
	method void AttackPowerStrikeFinal(number combatPower, number atkMultiplier, boolean isSpear, boolean wasStab)
		        -- (기능 추가) "다른 스킬을 쓰면 숨고르기 모션은 중지" 요청 - 이 스킬을 새로 시전하는 시점에 이전 숨고르기가 재생 중이었다면 즉시 정리한다.
		        self:StopBreather()
		        -- 파이널어택으로 발동되는 파워스트라이크 추가타. 원본 파워스트라이크와 동일한 단일 대상 판정 구조를
		        -- 쓰되, 대상/컨트롤 관련 상태는 전부 별도 필드로 분리해 원본 스킬과 서로 간섭하지 않게 한다.
		        -- 단, 재시전 게이트(isPowerStriking)만은 원본과 **공유**한다 - 홀드 입력 중 클라이언트의 공용
		        -- 쿨다운(skillOnCooldown) 재설정이 네트워크 지연으로 파이널어택 시작보다 늦게 도착하면, 그 사이
		        -- 홀드-반복이 새 파워스트라이크 요청을 보낼 수 있는데(서버 입장에선 정상 요청처럼 보임), 이 요청이
		        -- isPowerStriking을 공유하지 않으면 그대로 통과해 파이널어택과 겹쳐 별도로 스윙만 재생되고 대상은
		        -- 이미 죽었거나 다른 이유로 빗나가 "헛빵"이 나는 문제가 있었다. 공유 게이트로 막으면 서버가
		        -- 네트워크 지연과 무관하게 항상 이 요청을 거부한다.
		        local currentState = self.Entity.StateComponent.CurrentStateName
		        if currentState == "DEAD" or currentState == "CLIMB" or currentState == "LADDER" then
		            return
		        end
		        self._T.isPowerStriking = true

		        self._T.pendingFinalCombatPower = combatPower
		        local playerCtrl = self.Entity.PlayerControllerComponent
		        local worldPos = self.Entity.TransformComponent.WorldPosition
		        local dirX = playerCtrl.LookDirectionX
		        self._T.pendingFinalDirX = dirX
		        self._T.powerStrikeFinalTarget = self:FindNearestMonster(Vector2(worldPos.x, worldPos.y), 2.0)

		        self._T.pendingFinalWasControllerEnabled = isvalid(playerCtrl) and playerCtrl.Enable
		        if isvalid(playerCtrl) then
		            playerCtrl.Enable = false
		        end
		        if isvalid(self.Entity.MovementComponent) then
		            self.Entity.MovementComponent:Stop()
		        end

		        self:PlaySkillUseSound(self.Entity)
		        self:PlaySkillStartEffect(self.Entity, dirX)

		        local swing = self:GetFinalAttackMotion(isSpear, wasStab)
		        self._T.pendingFinalSwing = swing
		        self:PlayAttackMotion(self.Entity, swing.name, dirX, atkMultiplier)

		        _TimerService:SetTimerOnce(function()
		            self:NotifyFinalMotionEnded()
		        end, 0.45 * atkMultiplier)

		        _TimerService:SetTimerOnce(function()
		            self:RestoreFinalControl()
		        end, 0.65 * atkMultiplier)
	end

	@ExecSpace("Server")
	method void RestoreFinalControl()
		        self._T.isPowerStriking = false
		        local playerCtrl = self.Entity.PlayerControllerComponent
		        if isvalid(playerCtrl) and self._T.pendingFinalWasControllerEnabled then
		            playerCtrl.Enable = true
		        end
		        -- (기능 추가) "파이널 어택 모션까지 끝나면 숨고르기를 하게 해달라"는 요청 - 원래 스킬
		        -- (RestoreControl)에서는 파이널 어택이 발동한 경우 숨고르기를 건너뛰지만(파이널 어택
		        -- 모션을 가리지 않기 위해), 파이널 어택 자신의 모션이 끝나는 이 시점에는 정상적으로
		        -- 숨고르기를 시작한다.
		        self:PlayBreather(self.Entity, self._T.pendingFinalDirX or 1)
	end

	method void NotifyFinalMotionEnded()
		        if not isvalid(self.Entity) then return end
		        local dirX = self._T.pendingFinalDirX or 1
		        local swing = self._T.pendingFinalSwing or { ruid = "", name = "?" }
		        local curWorldPos = self.Entity.TransformComponent.WorldPosition
		        local attackOffset = Vector2(
		            curWorldPos.x + 1.0 * dirX,
		            curWorldPos.y
		        )
		        local shape = BoxShape(attackOffset, Vector2(2, 2), 0)
		        local hitComps = self:Attack(shape, "skill.powerstrike.final", CollisionGroups.HitBox)
		        local targets = {}
		        for _, hc in ipairs(hitComps) do
		            if isvalid(hc) and isvalid(hc.Entity) then
		                table.insert(targets, hc.Entity)
		            end
		        end
		        self:PlayPowerStrikeEffects(self.Entity, dirX, targets, swing.ruid, swing.name, true)
		        for _, t in ipairs(targets) do
		            self:PlayFinalAttackHitEffect(t)
		        end
		        log("PlayerAttack: AttackPowerStrikeFinal dir=" .. tostring(dirX) .. " targets=" .. tostring(#targets))
	end

	@ExecSpace("ServerOnly")
	method void AttackSlashBlastFinal(number combatPower, number atkMultiplier, boolean isSpear, boolean wasStab)
		        -- (기능 추가) "다른 스킬을 쓰면 숨고르기 모션은 중지" 요청 - 이 스킬을 새로 시전하는 시점에 이전 숨고르기가 재생 중이었다면 즉시 정리한다.
		        self:StopBreather()
		        -- 파이널어택으로 발동되는 슬래쉬블래스트 추가타. 원본과 동일한 다중 대상(최대 6명) 순차 타격 구조.
		        -- 재시전 게이트(isSlashBlasting)는 파워스트라이크와 동일한 이유로 원본과 공유한다 - 클라이언트
		        -- 공용 쿨다운 재설정(LockSkillUse)이 네트워크 지연으로 늦게 도착해 홀드-반복이 새 요청을 보내도
		        -- 서버가 이 공유 게이트로 항상 거부하게 하기 위함(안 그러면 별도로 스윙만 재생되고 대상은 이미
		        -- 죽었거나 빗나가 "헛빵"이 나는 문제가 있었다).
		        local currentState = self.Entity.StateComponent.CurrentStateName
		        if currentState == "DEAD" or currentState == "CLIMB" or currentState == "LADDER" then
		            return
		        end
		        self._T.isSlashBlasting = true

		        self._T.pendingFinalSlashCombatPower = combatPower
		        local playerCtrl = self.Entity.PlayerControllerComponent
		        local worldPos = self.Entity.TransformComponent.WorldPosition
		        local dirX = playerCtrl.LookDirectionX
		        self._T.pendingFinalSlashDirX = dirX

		        local targets = self:FindSlashBlastTargets(Vector2(worldPos.x, worldPos.y), dirX, 6)

		        self._T.pendingFinalSlashWasControllerEnabled = isvalid(playerCtrl) and playerCtrl.Enable
		        if isvalid(playerCtrl) then
		            playerCtrl.Enable = false
		        end
		        if isvalid(self.Entity.MovementComponent) then
		            self.Entity.MovementComponent:Stop()
		        end

		        self:PlaySlashBlastStartEffect(self.Entity, dirX)

		        local swing = self:GetFinalAttackMotion(isSpear, wasStab)
		        self:PlaySlashBlastMotion(self.Entity, swing.name, dirX, atkMultiplier)

		        _TimerService:SetTimerOnce(function()
		            self:DealNextSlashBlastFinalHit(targets, 1, atkMultiplier)
		        end, 0.45 * atkMultiplier)

		        _TimerService:SetTimerOnce(function()
		            self:RestoreSlashBlastFinalControl()
		        end, 0.65 * atkMultiplier)
	end

	@ExecSpace("Server")
	method void RestoreSlashBlastFinalControl()
		        self._T.isSlashBlasting = false
		        local playerCtrl = self.Entity.PlayerControllerComponent
		        if isvalid(playerCtrl) and self._T.pendingFinalSlashWasControllerEnabled then
		            playerCtrl.Enable = true
		        end
		        -- (기능 추가) "파이널 어택 모션까지 끝나면 숨고르기를 하게 해달라"는 요청 - 파워스트라이크와
		        -- 동일한 이유로, 파이널 어택 자신의 모션이 끝나는 이 시점에는 정상적으로 숨고르기를 시작한다.
		        self:PlayBreather(self.Entity, self._T.pendingFinalSlashDirX or 1)
	end

	@ExecSpace("Server")
	method void DealNextSlashBlastFinalHit(table targets, integer idx, number atkMultiplier)
		        if idx > #targets then return end
		        if not isvalid(self.Entity) then return end

		        local target = targets[idx]
		        if isvalid(target) then
		            self._T.slashBlastFinalCurrentTarget = target
		            local dirX = self._T.pendingFinalSlashDirX or 1
		            local curWorldPos = self.Entity.TransformComponent.WorldPosition
		            local attackOffset = Vector2(
		                curWorldPos.x + 1.0 * dirX,
		                curWorldPos.y
		            )
		            local shape = BoxShape(attackOffset, Vector2(2, 2), 0)
		            local hitComps = self:Attack(shape, "skill.slashblast.final", CollisionGroups.HitBox)
		            local actuallyHit = false
		            for _, hc in ipairs(hitComps) do
		                if isvalid(hc) and isvalid(hc.Entity) and hc.Entity == target then
		                    actuallyHit = true
		                    break
		                end
		            end
		            if actuallyHit then
		                self:PlaySlashBlastHitEffect(target, true)
		                self:PlayFinalAttackHitEffect(target)
		            end
		            log("PlayerAttack: AttackSlashBlastFinal hit " .. tostring(idx) .. "/" .. tostring(#targets) .. " actuallyHit=" .. tostring(actuallyHit))
		        end

		        if idx < #targets then
		            _TimerService:SetTimerOnce(function()
		                self:DealNextSlashBlastFinalHit(targets, idx + 1, atkMultiplier)
		            end, 0.1)
		        end
	end

	@ExecSpace("Multicast")
	method void PlayFinalAttackHitEffect(Entity target)
		        -- 파이널어택 추가타에 맞은 몬스터 머리 위에 재생되는 전용 이펙트.
		        if not self:IsClient() then return end
		        if not isvalid(target) then return end
		        local headY = 0.5
		        local hit = target.HitComponent
		        if isvalid(hit) then
		            headY = hit.ColliderOffset.y + hit.BoxSize.y / 2
		        end
		        local serial = _EffectService:PlayEffectAttached("c36e70d7b1d84845bf4067d069ba5e1a", target, Vector3(0, headY, 0), 0, Vector3(1, 1, 1), false, {})
		        _TimerService:SetTimerOnce(function()
		            _EffectService:RemoveEffect(serial)
		        end, 1.0)
	end

	@ExecSpace("Multicast")
	method void PlaySkillUseSound(Entity attacker)
		        -- 파워스트라이크 사용 시 사운드 재생. Multicast는 서버 자신도 함께 실행하므로 클라이언트에서만 실행되게 막는다.
		        if not self:IsClient() then return end
		        if not isvalid(attacker) then return end
		        local hitSoundRUID = "e0178f48602742c0bd8b295fdc27261c"
		        _SoundService:PlaySound(hitSoundRUID, 1.0)
	end

	@ExecSpace("Multicast")
	method void PlayAttackMotion(Entity attacker, string motionName, number dirX, number atkMultiplier)
		        -- 파워스트라이크 전용 세부 모션(swingT1~TF, stabO1~OF)을 아바타 몸체에 직접 재생한다.
		        -- StateComponent:ChangeState("ATTACK")을 거치면 StateToAvatarBodyActionSheet의 기본 "attack" 클립이
		        -- 함께 재생을 시도해 이 이벤트와 경합하면서(레이스) 모든 시전이 같은 기본 자세로 보이는 문제가 있었다.
		        -- (animation-state.md 7절 "State change races animation" 패턴) 그래서 ATTACK 상태 전환 없이
		        -- ActionStateChangedEvent만으로 모션을 직접 재생해 7종 모션이 항상 구분되도록 한다.
		        -- Multicast는 서버 자신도 함께 실행하므로 클라이언트에서만 실행되게 막는다 (GetBodyEntity는 ClientOnly라 서버에서는 항상 실패한다).
		        if not self:IsClient() then return end
		        if not isvalid(attacker) then return end
		        local avatarRenderer = attacker.AvatarRendererComponent
		        if not isvalid(avatarRenderer) then return end
		        local body = avatarRenderer:GetBodyEntity()
		        if not isvalid(body) then return end
		
		        -- 기본 무기 스윙 이펙트(ShowDefaultWeaponEffects)를 여기(클라이언트, 같은 Multicast 호출 안)에서 직접 끈다.
		        -- 서버에서 끄면 @Sync 전파 지연 때문에 모션 재생(아래 SendEvent)과 도착 순서가 보장되지 않아,
		        -- 파워스트라이크가 "attack" 계열 모션을 그대로 갖다 쓰면서 딸려오는 기본 스윙 이펙트가 한 프레임 섞여 보였다.
		        avatarRenderer.ShowDefaultWeaponEffects = false
		
		        -- 이동 중이던 잔여 이동을 클라이언트 화면에서도 즉시 멈추고(순서상 반드시 모션 전송보다 먼저),
		        -- 바라보는 방향을 지금 이 시점 값으로 고정한다. 모션 재생 중 반대 방향키를 눌러도 바라보는 방향이
		        -- 바뀌지 않도록 OnUpdate에서 매 프레임 이 방향으로 다시 고정한다(아래 OnUpdate 참고) -
		        -- PlayerControllerComponent.Enable = false만으로는 이동은 막히지만 방향 전환까지는 막히지 않는다.
		        local playerCtrl = attacker.PlayerControllerComponent
		        if isvalid(attacker.MovementComponent) then
		            attacker.MovementComponent:Stop()
		        end
		        if isvalid(playerCtrl) then
		            playerCtrl.LookDirectionX = dirX
		        end
		        self._T.isDirectionLocked = true
		        self._T.lockedDirX = dirX
		        self._T.lockedMotionName = motionName
		        self._T.isMotionPlaying = true
		        -- 홀드 지속발동 중 다음 시전이 쿨다운(0.75*mult)만큼 뒤에 시작될 수 있는데, 이 잠금 해제 타이머는
		        -- 그보다 늦은 0.80*mult 뒤에 실행된다. 즉 새 시전이 이미 방향을 다시 잠근 뒤에 이전 시전의 해제
		        -- 타이머가 뒤늦게 실행되며 새 시전의 잠금을 잘못 풀어버려, 그 틈에 이동키 입력으로 방향이 갑자기
		        -- 바뀌는 문제가 있었다. 시전마다 토큰을 발급해 "그 사이 더 최근 시전이 없었을 때만" 해제한다.
		        self._T.powerStrikeLockToken = (self._T.powerStrikeLockToken or 0) + 1
		        local myLockToken = self._T.powerStrikeLockToken
		
		        -- 공격속도 배율(atkMultiplier)이 짧을수록(=공격속도가 빠를수록) 모션 재생속도(PlayRate)를 그만큼 올려서
		        -- 실제 화면 재생 시간이 아래 타이머들(0.25/0.65초 * atkMultiplier)과 어긋나지 않게 맞춘다.
		        local mult = math.max(atkMultiplier or 1.0, 0.001)
		        local playRate = 1.0 / mult
		        self._T.lockedPlayRate = playRate
		
		        local motionEvent = ActionStateChangedEvent(motionName, motionName, playRate, SpriteAnimClipPlayType.Onetime)
		        body:SendEvent(motionEvent)
		        log("[PowerStrike] PlayAttackMotion sent: " .. tostring(motionName) .. " playRate=" .. tostring(playRate))
		
		        -- 기본 스윙 이펙트 복구 + 실제 모션 재생 구간 종료(_T.isMotionPlaying)는 서버 타격 판정과 같은 시간(기본 0.25초 * 배율)에 처리한다.
		        _TimerService:SetTimerOnce(function()
		            if isvalid(avatarRenderer) then
		                avatarRenderer.ShowDefaultWeaponEffects = true
		            end
		            self._T.isMotionPlaying = false
		        end, 0.25 * mult)
		
		        -- 방향 잠금은 서버의 컨트롤러 잠금과 같은 길이(기본 0.65초 * 배율) 뒤 해제한다.
		        _TimerService:SetTimerOnce(function()
		            if self._T.powerStrikeLockToken ~= myLockToken then return end
		            self._T.isDirectionLocked = false
		            -- 반대 방향키를 누르고 있는 상태로 이 시점을 맞으면, 아직 화면에 남아있는 스킬 모션(raw
		            -- ActionStateChangedEvent) 클립의 꼬리 프레임이 보이면서 캐릭터가 반대 방향으로 움직이기
		            -- 시작하는 문제가 있었다. 상태가 계속 IDLE으로만 유지되면(자연스러운 MOVE 전환이 한 번도
		            -- 없었던 경우) StateChangeEvent가 새로 발생하지 않아 위 스킬 모션 클립이 그대로 남아있기
		            -- 때문이다. 여기서 IDLE -> MOVE -> IDLE로 강제 토글해 StateChangeEvent를 한 번 더 일으켜,
		            -- AvatarStateAnimationComponent가 걷기/서기 클립을 다시 내보내 남은 스킬 모션을 확실히
		            -- 덮어쓰게 한다. 이동 봉인이 완전히 풀리기 직전에 실행되므로 실제 조작감에는 영향이 없다.
		            local sc = self.Entity.StateComponent
		            if isvalid(sc) and sc.CurrentStateName ~= "DEAD" then
		                sc:ChangeState("IDLE")
		                sc:ChangeState("MOVE")
		                sc:ChangeState("IDLE")
		                log("[PowerStrike] unlock refresh toggle done (was " .. tostring(sc.CurrentStateName) .. ")")
		            end
		        end, 0.80 * mult)
	end

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		        -- (버그 수정) "여러 스킬을 사용해봤는데 스킬 사용 후 숨고르기 모션을 하지 않는다"는 신고 -
		        -- 원인은 각 스킬 모션 정리용 IDLE→MOVE→IDLE 강제 토글(PlayAttackMotion 등, 같은 서버 호출
		        -- 안에서 즉시 IDLE로 되돌아감)이 숨고르기 시작 직후와 시간상 겹쳐, 진짜 이동이 아닌 이 내부
		        -- 토글의 MOVE StateChangeEvent에 의해 숨고르기가 매번 취소되던 것이었다. StateChangeEvent
		        -- 즉시-반응 대신, 여러 프레임에 걸쳐 "실제로 지속되는" MOVE 상태만 진짜 이동으로 보고 매
		        -- 프레임 폴링으로 감지한다.
		        -- (버그 수정) "스피어 버스터는 정상인데 파워스트라이크/매직클로/슬래쉬블래스트 등은 숨고르기가
		        -- 한 번 잠깐 잡히고 바로 끝난다"는 신고 - 위 폴링이 "MOVE 상태가 딱 1프레임만 감지되면"
		        -- 바로 취소해버려서, 내부 토글의 IDLE→MOVE→IDLE 전환이 (스피어 버스터에는 이 토글 자체가
		        -- 없지만) 파워스트라이크류에는 있어 그 찰나의 MOVE 프레임 하나에 걸려 즉시 잘못 취소되던
		        -- 것이었다. 연속된 프레임에서 "계속" MOVE일 때만 진짜 이동으로 보도록 3프레임 연속 조건을
		        -- 추가한다 - 내부 토글은 같은 프레임(또는 아무리 길어도 1프레임) 안에 IDLE로 되돌아가므로
		        -- 3프레임 연속 조건을 절대 만족하지 못하고, 실제 이동은 방향키를 누르고 있는 한 계속
		        -- MOVE이므로 몇 프레임 안에 정상적으로 감지된다.
		        if self._T.isBreatherPlaying or self._T.isBreatherArmed then
		            local sc = self.Entity.StateComponent
		            if isvalid(sc) and sc.CurrentStateName == "MOVE" then
		                self._T.breatherMoveFrames = (self._T.breatherMoveFrames or 0) + 1
		                if self._T.breatherMoveFrames >= 3 then
		                    -- (기능 추가) IDLE 전환을 기다리는 중(armed)이었어도, 그 사이 실제로 계속
		                    -- 이동 중이면(=IDLE로 정착하지 않고 계속 MOVE) 숨고르기를 아예 시작하지 않고 취소한다.
		                    self._T.isBreatherPlaying = false
		                    self._T.isBreatherArmed = false
		                    self._T.breatherToken = (self._T.breatherToken or 0) + 1
		                    self._T.breatherMoveFrames = 0
		                    log("[Breather] 숨고르기 중단(이동 감지, 폴링)")
		                end
		            else
		                self._T.breatherMoveFrames = 0
		            end
		        end

		        -- 텔레포트 등으로 캐릭터가 카메라의 SoftZone을 벗어나면 부드러운 추적 대신 즉시 이동(스냅)으로
		        -- 바뀌는 것으로 추정됨(사용자 관찰) - SoftZone만 3배로 넓혀 텔레포트 거리(3유닛)가 이 범위 안에
		        -- 들어오게 한다. DeadZone은 건드리지 않는다 - DeadZone은 "카메라가 캐릭터를 안 움직이고 잡아두는
		        -- 영역"이라 이것까지 키우면 평소 걷기 이동에서도 캐릭터가 화면 정중앙까지 오지 않고 넓어진
		        -- 데드존 안 어딘가에서 멈춰버리는 문제가 있었다(사용자 재확인, 2026-07-05). 로컬 플레이어에게만,
		        -- 한 번만 적용(다른 클라이언트가 보는 원격 플레이어의 카메라 컴포넌트는 건드리지 않음).
		        if not self._T.cameraZoneApplied then
		            self._T.cameraZoneApplied = true
		            if self.Entity == _UserService.LocalPlayer then
		                local cam = self.Entity.CameraComponent
		                if isvalid(cam) then
		                    local ZONE_MULTIPLIER = 3.0
		                    local sz = cam.SoftZone
		                    cam.SoftZone = Vector2(math.min(sz.x * ZONE_MULTIPLIER, 1.0), math.min(sz.y * ZONE_MULTIPLIER, 1.0))
		                    log("[PlayerAttack] Camera zone enlarged: DeadZone=(" .. tostring(cam.DeadZone.x) .. "," .. tostring(cam.DeadZone.y) .. ") SoftZone=(" .. tostring(cam.SoftZone.x) .. "," .. tostring(cam.SoftZone.y) .. ")")
		                end
		            end
		        end
		        -- 파워스트라이크 모션 재생 중(_T.isDirectionLocked)에는 매 프레임 바라보는 방향을 고정해서,
		        -- 반대 방향키 입력으로 캐릭터가 순간적으로 반대쪽을 보며 모션이 어색하게 끊기는 것을 막는다.
		        if self._T.isDirectionLocked then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedDirX
		            end
		        end
		        -- 럭키세븐 모션 재생 중에도 매 프레임 바라보는 방향을 고정한다 (파워스트라이크/슬래쉬블래스트와 별도 플래그)
		        if self._T.isLuckySevenDirectionLocked then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedLuckySevenDirX
		            end
		        end
		        -- 슬래쉬블래스트 모션 재생 중에도 동일하게 방향을 고정한다 (파워스트라이크와 별도 플래그)
		        if self._T.isSlashDirectionLocked then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedSlashDirX
		            end
		        end
		        -- 더블스탭 모션 재생 중에도 동일하게 방향을 고정한다 (다른 스킬과 별도 플래그)
		        if self._T.isDoubleStabDirectionLocked then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedDoubleStabDirX
		            end
		        end
		        -- 매직클로 모션 재생 중에도 동일하게 방향을 고정한다 (다른 스킬과 별도 플래그)
		        if self._T.isMagicClawDirectionLocked then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedMagicClawDirX
		            end
		        end
		        -- 썬더볼트 모션 재생 중에도 동일하게 방향을 고정한다 (다른 스킬과 별도 플래그)
		        if self._T.isThunderboltDirectionLocked then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedThunderboltDirX
		            end
		        end
		        -- 힐 모션 재생 중에도 동일하게 방향을 고정한다 (다른 스킬과 별도 플래그)
		        if self._T.isHealDirectionLocked then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedHealDirX
		            end
		        end
		        -- 파이어에로우 모션 재생 중에도 동일하게 방향을 고정한다 (다른 스킬과 별도 플래그)
		        if self._T.isFireArrowDirectionLocked then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedFireArrowDirX
		            end
		        end
		        -- 아이언에로우 모션 재생 중에도 동일하게 방향을 고정한다 (파이어에로우와 별도 플래그)
		        if self._T.isIronArrowDirectionLocked then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedIronArrowDirX
		            end
		        end
		        -- 포이즌 미스트 모션 재생 중에도 동일하게 방향을 고정한다 (다른 스킬과 별도 플래그)
		        if self._T.isPoisonMistDirectionLocked then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedPoisonMistDirX
		            end
		        end
		        -- 익스플로젼 모션 재생 중에도 동일하게 방향을 고정한다 (다른 스킬과 별도 플래그)
		        if self._T.isExplosionDirectionLocked then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedExplosionDirX
		            end
		        end
		        -- 드래곤 로어 모션 재생 중에도 동일하게 방향을 고정한다 (다른 스킬과 별도 플래그)
		        if self._T.isDragonRoarDirectionLocked then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedDragonRoarDirX
		            end
		        end
		        -- 스피어 버스터 모션 재생 중에도 동일하게 방향을 고정한다 (다른 스킬과 별도 플래그).
		        -- (버그 수정) playerCtrl.Enable=false만으로는 "반대 방향키를 누르고 있으면 뒤로 돈다"는
		        -- 현상이 남아있어, 매 프레임 MovementComponent:Stop()도 함께 호출해 이동 자체를 확실히 막는다.
		        if self._T.isSpearBurstDirectionLocked then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedSpearBurstDirX
		            end
		            if isvalid(self.Entity.MovementComponent) then
		                self.Entity.MovementComponent:Stop()
		            end
		        end
		        -- 헤이스트 모션 재생 중에도 동일하게 방향을 고정한다 (다른 스킬과 별도 플래그)
		        if self._T.isHasteDirectionLocked then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedHasteDirX
		            end
		        end
		        -- 부스터 모션 재생 중에도 동일하게 방향을 고정한다 (다른 스킬과 별도 플래그)
		        if self._T.isBoosterDirectionLocked then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedBoosterDirX
		            end
		        end
	end

	@ExecSpace("Multicast")
	method void PlaySkillStartEffect(Entity attacker, number dirX)
		        -- 스킬 시전 시작 이펙트 재생: 파워 스트라이크 리소스팩(skill/800033.img/skill/80003316)의 "effect" 노드.
		        -- Multicast는 서버 자신도 함께 실행하므로 클라이언트에서만 실행되게 막는다.
		        if not self:IsClient() then return end
		        if not isvalid(attacker) then return end
		        local startEffectRUID = "522793cef4ff4b79bdf73b9eda9386f8"
		        local startOptions = { ["FlipX"] = dirX > 0 }
		        _EffectService:PlayEffectAttached(startEffectRUID, attacker, Vector3(0, 0, 0), 0, Vector3(1, 1, 1), false, startOptions)
		        log("[PowerStrike] 시전 시작 이펙트 재생")
	end

	@ExecSpace("ServerOnly")
	method Entity FindNearestMonster(Vector2 fromPos, number maxRange)
		        -- 파워스트라이크 대상 선정: 사거리 내 script.Monster 컴포넌트가 있는 살아있는 엔티티 중 가장 가까운 하나
		        local map = self.Entity.CurrentMap
		        if not isvalid(map) then return nil end
		        local monsterComps = map:GetChildComponentsByTypeName("script.Monster", true)
		        local nearest = nil
		        local nearestDist = maxRange
		        for _, comp in ipairs(monsterComps) do
		            ---@type Monster
		            local mc = comp
		            if isvalid(mc) and isvalid(mc.Entity) and not mc.IsDead then
		                local pos = mc.Entity.TransformComponent.WorldPosition
		                local dx = pos.x - fromPos.x
		                local dy = pos.y - fromPos.y
		                local dist = math.sqrt(dx * dx + dy * dy)
		                if dist <= nearestDist then
		                    nearest = mc.Entity
		                    nearestDist = dist
		                end
		            end
		        end
		        return nearest
	end

	@ExecSpace("Multicast")
	method void PlayPowerStrikeEffects(Entity attacker, number dirX, table targets, string swingEffectRUID, string swingEffectName, boolean isFinal)
		        -- 스윙 궤적 이펙트 + 몬스터 뒤쪽 후방 이펙트 재생. 호출 시점 자체가 이미 NotifyMotionEnded(모션 종료) 시점이므로 즉시 재생한다.
		        -- swingEffectRUID/Name은 호출부(AttackPowerStrike)에서 GetPowerStrikeSwing()으로 한 번만 뽑아 전달한 값 -
		        -- 여기서 다시 뽑으면 캐릭터 모션(PlayAttackMotion)과 서로 다른 자세로 어긋날 수 있다.
		        -- Multicast는 서버 자신도 함께 실행하므로 클라이언트에서만 실행되게 막는다 - 안 그러면 서버 쪽 실행이 fallback RUID로 별도의 스윙 이펙트를 한 번 더 재생해 2개가 겹쳐 보인다.
		        if not self:IsClient() then return end
		        if not isvalid(attacker) then return end
		        local backEffectRUID  = "dad03b3a528348bf98295b01edd621a4"
		        local swingSoundRUID  = "d3205fdd08e34b68bc01292a997531ed"

		        log("[PowerStrike] 파워스트라이크 스윙 재생: " .. tostring(swingEffectName) .. " (RUID=" .. tostring(swingEffectRUID) .. ")")
		        -- 스킬 이펙트 투명도 80%
		        local swingOptions = { ["FlipX"] = dirX > 0, ["Alpha"] = 0.8 }
		        _EffectService:PlayEffectAttached(swingEffectRUID, attacker, Vector3(0.1 * dirX, 0, 0), 0, Vector3(1, 1, 1), false, swingOptions)

		        -- (기능 변경) "파이널어택이 뜰 때 원래 히트 이펙트를 대체해서 파이널어택 히트 이펙트만 떠야
		        -- 한다"는 요청 - isFinal이면 몬스터 뒤쪽 후방 히트 이펙트(backEffectRUID)를 재생하지 않는다.
		        -- 호출부(NotifyFinalMotionEnded)가 곧이어 PlayFinalAttackHitEffect로 전용 이펙트를 대신 띄운다.
		        -- 스윙 궤적 이펙트(위)는 캐릭터 시전 모션에 붙는 연출이라 파이널어택에서도 그대로 유지한다.
		        if isFinal then return end

		        -- 스윙 사운드는 실제로 몬스터에 적중했을 때만 후방 이펙트와 함께 재생 (빗나가면 들리지 않아야 함)
		        for _, target in ipairs(targets) do
		            if isvalid(target) then
		                local flipBack   = dirX > 0
		                local backOffset = dirX > 0 and 0.4 or -0.4
		                local backOptions = { ["FlipX"] = flipBack }
		                _EffectService:PlayEffectAttached(backEffectRUID, target, Vector3(backOffset, 0, 0), 0, Vector3(1, 1, 1), false, backOptions)
		                _SoundService:PlaySound(swingSoundRUID, 1.0)
		            end
		        end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleStateChangeEvent(StateChangeEvent event)
		        -- 파워스트라이크 실제 모션 재생 구간(_T.isMotionPlaying, 0~0.25초)에 착지(FALL/JUMP -> IDLE) 등 다른 상태
		        -- 전환이 끼어들면 StateToAvatarBodyActionSheet의 기본 모션(stand/walk/fall 등)이 재생되어 스킬 모션이
		        -- 끊기는 문제가 있었다 - 이 구간에서만 방향을 다시 고정하고 스킬 모션을 즉시 다시 덮어씌운다.
		        --
		        -- 모션 재생이 끝난 뒤(0.25~0.65초, 추가 이동 봉인 구간)에는 모션을 다시 덮어씌우지 않는다. 이 구간에서도
		        -- 매번 재적용하면, 방향키를 눌러 MOVE 상태로 전환될 때마다 이미 끝난 스윙 모션이 처음부터 다시 재생되어
		        -- "방향을 바꾸면 모션이 한 번 더 재생된다"는 문제가 있었다. 대신 IDLE이 아닌 상태로 전환되려는 시도만
		        -- 즉시 IDLE로 되돌려서, 이동 봉인이 완전히 풀릴 때까지(RestoreControl) 겉보기에도 계속 서 있게 만든다.
		        if event.CurrentStateName == "DEAD" then return end
		        -- (기능 추가) "가만히 있을 때 기본모션으로 돌아갔다가 다시 숨고르기로 가서 불안정해 보인다 -
		        -- 기본모션으로 바뀌는 바로 그 타이밍에 숨고르기를 넣어달라"는 요청 - 각 스킬 정리용
		        -- IDLE→MOVE→IDLE 토글이 실제로 "IDLE"(기본 모션)로 전환되는 이 이벤트를 감지해, 그 순간
		        -- 지연 없이 곧바로 숨고르기로 덮어써서 기본 모션이 화면에 보일 틈을 없앤다.
		        if self._T.isBreatherArmed and event.CurrentStateName == "IDLE" then
		            self._T.isBreatherArmed = false
		            self:StartBreatherNow(self._T.breatherArmedAttacker, self._T.breatherToken)
		        end
		        if self._T.isMotionPlaying then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedDirX
		            end
		            local motionName = self._T.lockedMotionName
		            if not motionName then return end
		            local avatarRenderer = self.Entity.AvatarRendererComponent
		            if not isvalid(avatarRenderer) then return end
		            local body = avatarRenderer:GetBodyEntity()
		            if not isvalid(body) then return end
		            local motionEvent = ActionStateChangedEvent(motionName, motionName, self._T.lockedPlayRate or 1.0, SpriteAnimClipPlayType.Onetime)
		            body:SendEvent(motionEvent)
		            log("[PowerStrike] HandleStateChangeEvent re-applied motion over " .. tostring(event.CurrentStateName) .. ": " .. tostring(motionName))
		            return
		        end
		        if self._T.isDirectionLocked and event.CurrentStateName ~= "IDLE" then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedDirX
		            end
		            local sc = self.Entity.StateComponent
		            if isvalid(sc) then
		                sc:ChangeState("IDLE")
		                log("[PowerStrike] HandleStateChangeEvent forced back to IDLE from " .. tostring(event.CurrentStateName))
		            end
		        end
		
		        -- 럭키세븐 전용 처리 (파워스트라이크/슬래쉬블래스트와 동일한 패턴이지만 별도의 플래그를 사용 - 서로 간섭하지 않는다)
		        if self._T.isLuckySevenMotionPlaying then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedLuckySevenDirX
		            end
		            local motionName = self._T.lockedLuckySevenMotionName
		            if not motionName then return end
		            local avatarRenderer = self.Entity.AvatarRendererComponent
		            if not isvalid(avatarRenderer) then return end
		            local body = avatarRenderer:GetBodyEntity()
		            if not isvalid(body) then return end
		            local motionEvent = ActionStateChangedEvent(motionName, motionName, self._T.lockedLuckySevenPlayRate or 1.0, SpriteAnimClipPlayType.Onetime)
		            body:SendEvent(motionEvent)
		            log("[LuckySeven] HandleStateChangeEvent re-applied motion over " .. tostring(event.CurrentStateName) .. ": " .. tostring(motionName))
		            return
		        end
