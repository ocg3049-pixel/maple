		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedLuckySevenDirX
		            end
		            local sc = self.Entity.StateComponent
		            if isvalid(sc) then
		                sc:ChangeState("IDLE")
		                log("[LuckySeven] HandleStateChangeEvent forced back to IDLE from " .. tostring(event.CurrentStateName))
		            end
		        end

		        -- 슬래쉬블래스트 전용 처리 (파워스트라이크와 동일한 패턴이지만 별도의 플래그를 사용 - 서로 간섭하지 않는다)
		        if self._T.isSlashMotionPlaying then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
