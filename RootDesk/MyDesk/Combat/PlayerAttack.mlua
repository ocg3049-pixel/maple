		            end
		            local sc = self.Entity.StateComponent
		            if isvalid(sc) then
		                sc:ChangeState("IDLE")
		                log("[Explosion] HandleStateChangeEvent forced back to IDLE from " .. tostring(event.CurrentStateName))
		            end
		        end

		        -- 드래곤 로어 전용 처리 (익스플로젼과 동일한 패턴이지만 별도의 플래그를 사용 - 서로 간섭하지 않는다)
		        if self._T.isDragonRoarMotionPlaying then
		            local playerCtrl = self.Entity.PlayerControllerComponent
		            if isvalid(playerCtrl) then
		                playerCtrl.LookDirectionX = self._T.lockedDragonRoarDirX
		            end
		            local motionName = self._T.lockedDragonRoarMotionName
		            if not motionName then return end
		            local avatarRenderer = self.Entity.AvatarRendererComponent
		            if not isvalid(avatarRenderer) then return end
		            local body = avatarRenderer:GetBodyEntity()
		            if not isvalid(body) then return end
		            local motionEvent = ActionStateChangedEvent(motionName, motionName, self._T.lockedDragonRoarPlayRate or 1.0, SpriteAnimClipPlayType.Onetime)
		            body:SendEvent(motionEvent)
		            log("[DragonRoar] HandleStateChangeEvent re-applied motion over " .. tostring(event.CurrentStateName) .. ": " .. tostring(motionName))
		            return
