		            local motionEvent = ActionStateChangedEvent(motionName, motionName, self._T.lockedDoubleStabPlayRate or 1.0, SpriteAnimClipPlayType.Onetime)
		            body:SendEvent(motionEvent)
		            log("[DoubleStab] HandleStateChangeEvent re-applied motion over " .. tostring(event.CurrentStateName) .. ": " .. tostring(motionName))
